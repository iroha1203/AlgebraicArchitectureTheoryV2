{
  "schemaVersion": "archsig-v1-output-replacement-golden-corpus/v1",
  "corpusId": "archmap-v1-output-replacement",
  "purpose": "Lock ArchSig v1 output replacement acceptance around typed evaluator evidence, architecture distance, spectrum, homotopy, structural reading, and FieldSig handoff refs. v0 packet equality is not current completion evidence.",
  "completeAcceptanceManifestPath": "tests/fixtures/complete_archmap_acceptance/output_replacement_manifest.json",
  "positiveCases": [
    {
      "caseId": "minimal-v1",
      "family": "minimal",
      "archmapPath": "tests/fixtures/archmap_v1/archmap.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_emit_raw_artifacts_writes_typed_packet_detail_and_handoff",
      "requiredOutputSurfaces": [
        "typed-evaluator-results/v1",
        "archsig-architecture-distance/v1",
        "archsig-analysis-packet/v1",
        "archsig-analysis-summary/v1",
        "archsig-run-manifest-v1"
      ]
    },
    {
      "caseId": "practical-rust-service",
      "family": "practical",
      "archmapPath": "examples/practical-rust-service/archmap/archmap.json",
      "lawPolicyPath": "examples/practical-rust-service/law_policy/law_policy.json",
      "executableTest": "practical_rust_service_example_runs_v1_analyze",
      "requiredOutputSurfaces": [
        "diagnostic-value",
        "strict-distance",
        "architecture-distance-profile"
      ]
    },
    {
      "caseId": "solid-v1",
      "family": "solid",
      "archmapPath": "tests/fixtures/archmap_v1/archmap.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_writes_typed_evaluator_results",
      "requiredOutputSurfaces": [
        "solid.single-responsibility",
        "solid.dependency-inversion",
        "supportAtomRefs",
        "basisRefs"
      ]
    },
    {
      "caseId": "spectrum-nonzero-v1",
      "family": "spectrum",
      "archmapPath": "tests/fixtures/archmap_v1/archmap_violation.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_spectrum_detects_nonzero_curvature_from_typed_violation",
      "requiredOutputSurfaces": [
        "architectureSpectrumReport",
        "curvatureSupportReadings",
        "spectralModeReadings"
      ]
    },
    {
      "caseId": "homotopy-v1",
      "family": "homotopy",
      "archmapPath": "tests/fixtures/archmap_v1/archmap_homotopy_nonzero.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_homotopy_surfaces_zero_nonzero_and_missing_filler",
      "requiredOutputSurfaces": [
        "architectureHomotopyReport",
        "pathHomotopyDiagramReadings",
        "homotopyHolonomyReadings",
        "stokesStyleReadings"
      ]
    },
    {
      "caseId": "structural-reading-v1",
      "family": "structural",
      "archmapPath": "tests/fixtures/archmap_v1/archmap.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_structural_reading_review_surface_uses_typed_refs",
      "requiredOutputSurfaces": [
        "structuralReadingReviewSurface",
        "representationMetricReadings",
        "observationProjectionReadings",
        "stateTransitionAlgebraReadings"
      ]
    },
    {
      "caseId": "fieldsig-handoff-v1",
      "family": "fieldsig-handoff",
      "archmapPath": "tests/fixtures/archmap_v1/archmap.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_emit_raw_artifacts_writes_typed_packet_detail_and_handoff",
      "requiredOutputSurfaces": [
        "generatedPacketRefs",
        "architectureSpectrumReport",
        "architectureHomotopyReport",
        "structuralReadingReviewSurface"
      ]
    }
  ],
  "negativeCases": [
    {
      "caseId": "removed-field-only-v1",
      "family": "removed-field-only",
      "fixturePaths": [
        "tests/fixtures/archmap_v1/replacement_negative/archmap_projection_only_v0_field.json",
        "tests/fixtures/archmap_v1/replacement_negative/archmap_operation_square_only_v0_field.json",
        "tests/fixtures/archmap_v1/replacement_negative/archmap_observation_gaps_only_v0_field.json",
        "tests/fixtures/archmap_v1/replacement_negative/archmap_concern_only_v0_field.json",
        "tests/fixtures/archmap_v1/replacement_negative/archmap_non_conclusion_only_v0_field.json"
      ],
      "executableTest": "cli_analyze_v1_removed_field_only_artifacts_do_not_become_measured_results",
      "expectedGuard": "removed v0 helper fields fail before typed evaluator measurement"
    },
    {
      "caseId": "label-only-semantic-v1",
      "family": "label-only",
      "archmapPath": "tests/fixtures/archmap_v1/replacement_negative/archmap_label_only_semantic.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_label_only_semantic_does_not_become_measured_replacement",
      "expectedGuard": "semantic prose without typed shape fails before replacement measurement"
    },
    {
      "caseId": "schema-only-v1",
      "family": "schema-only",
      "archmapPath": "tests/fixtures/archmap_v1/replacement_negative/archmap_schema_only.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_schema_only_input_does_not_become_measured_replacement",
      "expectedGuard": "schema name alone can run only as bounded incomplete measurement"
    },
    {
      "caseId": "missing-support-v1",
      "family": "missing-support",
      "archmapPath": "tests/fixtures/archmap_v1/archmap_bad_ref.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_rejects_archmap_v1_unresolved_source_ref",
      "expectedGuard": "unresolved refs fail validation"
    },
    {
      "caseId": "blocked-molecule-v1",
      "family": "blocked-molecule",
      "archmapPath": "tests/fixtures/archmap_v1/archmap_blocked_molecule.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_marks_incomplete_molecule_candidate_blocked",
      "expectedGuard": "missing molecule support remains blocked, not measured zero"
    },
    {
      "caseId": "strict-distance-missing-profile-v1",
      "family": "strict-distance",
      "archmapPath": "tests/fixtures/archmap_v1/archmap.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_strict_distance_rejects_missing_distance_profile_ref",
      "expectedGuard": "strict distance requires selected distanceProfileRef"
    },
    {
      "caseId": "strict-distance-blocked-v1",
      "family": "strict-distance",
      "archmapPath": "tests/fixtures/archmap_v1/archmap_blocked_molecule.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_strict_distance_rejects_blocked_typed_results",
      "expectedGuard": "strict distance rejects blocked typed support"
    },
    {
      "caseId": "stale-success-artifact-suppression-v1",
      "family": "stale-success-artifact-suppression",
      "archmapPath": "tests/fixtures/archmap_v1/replacement_negative/archmap_label_only_semantic.json",
      "lawPolicyPath": "tests/fixtures/archmap_v1/law_policy.json",
      "executableTest": "cli_analyze_v1_validation_failure_removes_stale_success_artifacts",
      "expectedGuard": "validation failure removes stale success artifacts before stopping"
    }
  ],
  "nonGoals": [
    "v0 packet equality is not current v1 completion evidence.",
    "schema-only, label-only, and removed-field-only fixtures must not be promoted into measured results.",
    "fixtures are public sanitized evidence contracts, not private repository truth."
  ]
}
