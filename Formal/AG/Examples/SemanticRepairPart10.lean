/-!
Part X R9 / AC16 finite lawful firing instance.

Example 9.1 is the lawful firing witness.  It is separate from the circle-nerve
nonzero witness used by example 9.2: in this lawful instance the generated
degree-zero class vanishes by theorem 8.1, and that zero reading is the intended
end-to-end firing surface rather than a missing obstruction.
-/

/-! ## Concrete quotient-sheaf instance -/

/-- X.例9.1: the selected quotient coefficient presheaf on the finite site. -/
def quotientPresheaf : Site.AATPresheaf FiniteModel.site where
  obj _ := PUnit
  map _ x := x
  map_id _ := rfl
  map_comp _ _ := rfl

/--
X.例9.1: `quotientIsSheaf` is discharged as a theorem for the concrete finite
singleton quotient instance.  General quotient sheaf comparison remains data.
-/
theorem quotientIsSheaf :
    Site.AATSheafCondition FiniteModel.site quotientPresheaf := by
  intro _base _cover _hcover family _compatible
  refine ⟨PUnit.unit, ?_, ?_⟩
  · intro _Y f hf
    cases family f hf
    rfl
  · intro y _hy
    cases y
    rfl

/-- X.例9.1: concrete obstruction coefficient sheaf generated by the quotient. -/
def quotientObstructionSheaf :
    Cohomology.ObstructionSheaf FiniteModel.site where
  carrier := {
    carrier := quotientPresheaf
    isSheaf := quotientIsSheaf
  }
  addCommGroup W := by
    change AddCommGroup PUnit
    infer_instance
  map_zero := by
    intro _source _target _f
    rfl
  map_add := by
    intro _source _target _f x y
    cases x
    cases y
    rfl

