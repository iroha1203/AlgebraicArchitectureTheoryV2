/-- The actual triple overlap `(0, 1, 2)` is inhabited. -/
def zmodTwoTorsor_triple012 :
    zmodTwoTorsorCover.TripleOverlap zmodTwoTorsor_chart0
      zmodTwoTorsor_chart1 zmodTwoTorsor_chart2 :=
