/-!
PRD-10 R9 / AC16 finite lawful firing instance.

Example 9.1 is the lawful firing witness.  It is separate from the circle-nerve
nonzero witness used by example 9.2: in this lawful instance the generated
degree-zero class vanishes by theorem 8.1, and that zero reading is the intended
end-to-end firing surface rather than a missing obstruction.
-/

/-! ## Concrete quotient-sheaf instance -/

/-- X.例9.1: the selected quotient coefficient presheaf on the finite site. -/
def quotientPresheaf : Site.AATPresheaf FiniteModel.site where
  obj _ := PUnit
  map _ x := x
  map_id _ := rfl
  map_comp _ _ := rfl

/--
X.例9.1: `quotientIsSheaf` is discharged as a theorem for the concrete finite
singleton quotient instance.  General quotient sheaf comparison remains data.
-/
theorem quotientIsSheaf :
    Site.AATSheafCondition FiniteModel.site quotientPresheaf := by
  intro _base _cover _hcover family _compatible
  refine ⟨PUnit.unit, ?_, ?_⟩
  · intro _Y f hf
    cases family f hf
    rfl
  · intro y _hy
    cases y
    rfl

/-- X.例9.1: concrete obstruction coefficient sheaf generated by the quotient. -/
def quotientObstructionSheaf :
    Cohomology.ObstructionSheaf FiniteModel.site where
  carrier := {
    carrier := quotientPresheaf
    isSheaf := quotientIsSheaf
  }
  addCommGroup W := by
    change AddCommGroup PUnit
    infer_instance
  map_zero := by
    intro _source _target _f
    rfl
  map_add := by
    intro _source _target _f x y
    cases x
    cases y
    rfl

/-! ## Concrete semantic additive and cover-relative zero data -/

/-- X.例9.1: singleton semantic atom projection for the lawful firing witness. -/
def semanticProjection : SemanticAtomProjection where
  SemanticAtom := PUnit
  Component := PUnit
  project _ := PUnit.unit

/-- X.例9.1: singleton finite semantic repair cover. -/
def semanticCover : SemanticRepairCover semanticProjection where
  baseCover := {
    Chart := PUnit
    Transition := PUnit
    chartFinite := inferInstance
    transitionFinite := inferInstance
    holonomySupport := fun _ => True
  }
  CoverChart := PUnit
  chart _ := PUnit.unit
  chartFinite := inferInstance
  Overlap := fun _ _ => PUnit
  overlapFinite := fun _ _ => inferInstance
  TripleOverlap := fun _ _ _ => PUnit
  tripleFinite := fun _ _ _ => inferInstance
  tripleEdge01 := fun _ => PUnit.unit
  tripleEdge12 := fun _ => PUnit.unit
  tripleEdge02 := fun _ => PUnit.unit

/-- X.例9.1: zero additive Cech data for the lawful firing witness. -/
def semanticCechData : SemanticRepairCoverCechData semanticCover where
  C0 := PUnit
  C1 := PUnit
  C2 := PUnit
  c0Finite := inferInstance
  c1Finite := inferInstance
  zero1 := PUnit.unit
  zero2 := PUnit.unit
  delta0 _ := PUnit.unit
  delta1 _ := PUnit.unit
  residual := PUnit.unit
  zero1_cocycle := rfl
  delta1_delta0_eq_zero := fun _ => rfl
  residual_cocycle := rfl

/-- X.例9.1: additive law package for the zero Cech surface. -/
def semanticAdditiveData :
    SemanticRepairAdditiveCechH1Data semanticCechData where
  c0AddCommGroup := by
    change AddCommGroup PUnit
    infer_instance
  c1AddCommGroup := by
    change AddCommGroup PUnit
    infer_instance
  zero1_eq_zero := rfl
  delta0_zero := rfl
  delta0_add := fun _ _ => rfl
  delta0_neg := fun _ => rfl

/-- X.例9.1: boundary-relation data for the lawful zero instance. -/
def boundaryRelationData :
    SemanticRepairCoverH1BoundaryRelationAbelianData semanticProjection where
  cover := semanticCover
  cech := semanticCechData
  supportOf _ := fun _ => True
  component_covered_of_boundary := by
    intro _primitive _hboundary residual hresidual
    exact ⟨residual, trivial, rfl⟩
  component_faithful_of_boundary := by
    intro _primitive _hboundary _residual _candidate _hresidual _hcandidate _hprojection
    trivial

/-- X.例9.1: additive boundary-relation data used by theorem 7.5. -/
def boundaryAdditiveData :
    SemanticRepairCoverH1BoundaryRelationAdditiveData semanticProjection where
  boundaryRelation := boundaryRelationData
  additive := semanticAdditiveData

/-- X.例9.1: cover-relative singleton cover for the concrete Cech complex. -/
def coverRelativeCover :
    Cohomology.CoverRelativeCechCover FiniteModel.site where
  base := FiniteModel.siteBase
  Index := PUnit
  chart _ := FiniteModel.siteBase
  inclusion _ := 𝟙 FiniteModel.siteBase
  simplex _ := PUnit
  overlap _ _ := FiniteModel.siteBase
  face _ _ _ := PUnit.unit
  faceRestriction _ _ _ := 𝟙 FiniteModel.siteBase

/-- X.例9.1: singleton cover-relative Cech complex with zero differential. -/
def coverRelativeComplex :
    Cohomology.CoverRelativeCechComplex coverRelativeCover quotientObstructionSheaf where
  cochainAddCommGroup n := by
    change AddCommGroup (PUnit -> PUnit)
    infer_instance
  alternatingFaceCombination _ _ _ := PUnit.unit
  differential _ := by
    change (PUnit -> PUnit) →+ (PUnit -> PUnit)
    exact {
      toFun := fun _ _ => PUnit.unit
      map_zero' := by
        funext σ
        rfl
      map_add' := by
        intro x y
        funext σ
        cases x σ
        cases y σ
        rfl
    }
  differential_eq_alternatingFaceCombination := by
    intro _n c
    funext σ
    cases c σ
    rfl
  differential_comp := by
    intro _n c
    funext σ
    cases c σ
    rfl

/-- X.例9.1: additive equivalence between `PUnit` and singleton cochains. -/
def punitCochainAddEquiv (_n : Nat) :
    PUnit ≃+ (PUnit -> PUnit) where
  toFun _ _ := PUnit.unit
  invFun _ := PUnit.unit
  left_inv := by
    intro x
    cases x
    rfl
  right_inv := by
    intro f
    funext σ
    cases f σ
    rfl
  map_add' := by
    intro x y
    cases x
    cases y
    rfl

/-- X.例9.1: equivalence between `PUnit` and degree-two singleton cochains. -/
def punitCochainEquiv (_n : Nat) :
    PUnit ≃ (PUnit -> PUnit) where
  toFun _ _ := PUnit.unit
  invFun _ := PUnit.unit
  left_inv := by
    intro x
    cases x
    rfl
  right_inv := by
    intro f
    funext σ
    cases f σ
    rfl

/--
X.例9.1: concrete cochain comparison data.  Since both sides are singleton
zero surfaces, all differential compatibility obligations are definitional.
-/
def h1Comparison :
    SemanticRepairCoverRelativeH1Comparison
      boundaryAdditiveData.toAdditiveH1Surface coverRelativeComplex where
  c0Equiv := punitCochainAddEquiv 0
  c1Equiv := punitCochainAddEquiv 1
  c2Equiv := punitCochainEquiv 2
  c2Equiv_zero := rfl
  c2Equiv_symm_zero := rfl
  d0_to := by
    intro primitive
    cases primitive
    funext σ
    cases σ
    rfl
  d0_from := by
    intro primitive
    cases primitive PUnit.unit
    rfl
  d1_to := by
    intro cochain
    cases cochain
    funext σ
    cases σ
    rfl
  d1_from := by
    intro cochain
    cases cochain PUnit.unit
    rfl

/-! ## Concrete law-equation firing data -/

/-- X.例9.1: lawful finite object with the selected NoCycle relation removed. -/
def lawfulConfiguration : AtomConfiguration FiniteModel.carrier where
  family := FiniteModel.allFamily
  relation _ _ := False
  identification _ _ := False

/-- X.例9.1: lawful local object used by the displayed law source. -/
def lawfulObject : ArchitectureObject FiniteModel.carrier :=
  FiniteModel.objectOfConfiguration lawfulConfiguration

/-- X.例9.1: the selected local object satisfies the required NoCycle law. -/
theorem lawfulObject_noCycleLaw :
    FiniteModel.noCycleLaw.holds lawfulObject := by
  intro hcycle
  exact hcycle.1

/-- X.例9.1: concrete law-equation witness-ideal core over `ℤ`. -/
def lawEquationCore :
    LawAlgebra.SemanticLawEquationWitnessIdealCore FiniteModel.site where
  Observable _ := Int
  observableCommRing _ := inferInstance
  restrict _ := RingHom.id Int
  restrict_id := by
    intro _W x
    rfl
  restrict_comp := by
    intro _W₀ _W₁ _W₂ _f _g x
    rfl
  violationWitness _ _ _ := (2 : Int)
  violationWitness_restrict := by
    intro _source _target _f _lawIndex _atom
    rfl
  supportAtom := FiniteModel.FiniteAtom.componentA
  supportLawIndex := PUnit.unit
  supportLawIndex_required := rfl

/-- X.例9.1: displayed defect source whose defect lies in the selected witness ideal. -/
def defectSource :
    LawAlgebra.LawEquationDefectSource lawEquationCore where
  Chart := PUnit
  chart _ := FiniteModel.siteBase
  LocalInput _ := PUnit
  input _ := PUnit.unit
  lawSupport _ _ := [PUnit.unit]
  lawSupport_nonempty := by
    intro i
    exact ⟨PUnit.unit, by simp⟩
  lawSupport_required := by
    intro i lawIndex hmem
    cases lawIndex
    rfl
  objectOfLocalInput _ _ := lawfulObject
  defect _ _ := (2 : Int)
  holds_defect_mem := by
    intro i lawIndex hmem hrequired _hholds
    exact Ideal.subset_span
      ⟨FiniteModel.FiniteAtom.componentA, rfl⟩

/-- X.例9.1: displayed required laws hold on the selected lawful local input. -/
theorem displayedRequiredLawsHoldOn :
    defectSource.DisplayedRequiredLawsHoldOn := by
  intro i lawIndex hmem hrequired
  cases lawIndex
  exact lawfulObject_noCycleLaw

/-! ## End-to-end firing -/

/-- X.例9.1: top-cover gluing data for the singleton quotient presheaf. -/
def gluingData :
    Site.AATGluingData FiniteModel.site quotientPresheaf
      (⊤ : Sieve FiniteModel.siteBase) where
  localSections := fun _Y _f _hf => PUnit.unit
  overlapAgreement := by
    intro _Y _Z _W _f _g _hf _hg _w h₁ _hcomp
    rfl

/-- X.例9.1: true-sheaf certificate with `quotientIsSheaf` discharged as a theorem. -/
def trueSheafCertificate :
    boundaryAdditiveData.TrueSheafConditionCertificate
      FiniteModel.site quotientPresheaf (⊤ : Sieve FiniteModel.siteBase) where
  cover_mem := FiniteModel.site.top_mem FiniteModel.siteBase
  sheafCondition := quotientIsSheaf

/--
X.例9.1: lawful firing of theorem 7.5 on the concrete finite instance.

The packet is generated from the concrete law-equation source, the theorem-level
quotient sheaf certificate above, and the singleton H1 comparison data.
-/
theorem lawfulFiring_endToEndPacket :
    Nonempty
      (SemanticRepairGeneratedEndToEndSAGAPacket
        boundaryAdditiveData defectSource FiniteModel.site quotientPresheaf
        (⊤ : Sieve FiniteModel.siteBase) gluingData h1Comparison) :=
  lawEquation_constructs_groundedComparisonPacket
    boundaryAdditiveData defectSource displayedRequiredLawsHoldOn
    FiniteModel.site quotientPresheaf (⊤ : Sieve FiniteModel.siteBase)
    trueSheafCertificate gluingData h1Comparison

/--
X.例9.1: theorem 8.1 fires on the same lawful source, producing pointwise zero
and the selected degree-zero Cech-zero reading.
-/
theorem lawfulFiring_generatedSourceC0Zero :
    Nonempty (GeneratedSourceC0ZeroPackage defectSource) :=
  displayedRequiredLawsHoldOn_constructs_generatedSourceC0_zeroPackage
    defectSource displayedRequiredLawsHoldOn

