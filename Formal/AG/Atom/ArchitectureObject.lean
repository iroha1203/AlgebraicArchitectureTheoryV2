import Formal.AG.Atom.Configuration

namespace AAT.AG

universe u

/--
I.定義5.1: an architecture object `A = (C, S, Q)`.

The concrete readings of structure maps `S` and selected quantities `Q` remain
abstract in Part I. Graph, category, algebra, diagram, and state-transition
instances are later specialization work.
-/
structure ArchitectureObject (U : AtomCarrier.{u}) where
  configuration : AtomConfiguration U
  StructureMaps : Type u
  SelectedQuantities : Type u
  structureMaps : StructureMaps
  selectedQuantities : SelectedQuantities

namespace ArchitectureObject

/-- I.定義5.2: an Atom family generates an architecture object. -/
def GeneratedObject {U : AtomCarrier.{u}} (F : AtomFamily U)
    (A : ArchitectureObject U) : Prop :=
  F = A.configuration.family

/--
I.定義5.4: object equivalence preserves the selected configuration,
structure-map, and quantity readings.
-/
structure ObjectEquivalence {U : AtomCarrier.{u}} (A B : ArchitectureObject U) where
  configurationEquivalent :
    A.configuration.Subconfiguration B.configuration ∧
      B.configuration.Subconfiguration A.configuration
  structureMapsPreserved : A.StructureMaps -> B.StructureMaps -> Prop
  structureMapsPreserved_holds : structureMapsPreserved A.structureMaps B.structureMaps
  selectedQuantitiesPreserved : A.SelectedQuantities -> B.SelectedQuantities -> Prop
  selectedQuantitiesPreserved_holds :
    selectedQuantitiesPreserved A.selectedQuantities B.selectedQuantities

/-- I.命題5.3: every architecture object is generated by its Atom family. -/
theorem atom_origin {U : AtomCarrier.{u}} (A : ArchitectureObject U) :
    ∃ F : AtomFamily U, GeneratedObject F A :=
  ⟨A.configuration.family, rfl⟩

/-- I.定義5.2: generated objects use the selected configuration family. -/
theorem generated_family_eq {U : AtomCarrier.{u}} {F : AtomFamily U}
    {A : ArchitectureObject U} (h : GeneratedObject F A) :
    F = A.configuration.family :=
  h

/-- I.定義5.2: a generating family is included in the object's family. -/
theorem generated_family_subset {U : AtomCarrier.{u}} {F : AtomFamily U}
    {A : ArchitectureObject U} (h : GeneratedObject F A) :
    F.Subset A.configuration.family := by
  intro atom hAtom
  rw [← h]
  exact hAtom

namespace ObjectEquivalence

/-- I.定義5.4: object equivalence gives configuration equivalence. -/
theorem configuration_equivalent {U : AtomCarrier.{u}} {A B : ArchitectureObject U}
    (h : ObjectEquivalence A B) :
    A.configuration.Subconfiguration B.configuration ∧
      B.configuration.Subconfiguration A.configuration :=
  h.configurationEquivalent

/-- I.定義5.4: object equivalence records structure-map preservation. -/
theorem structure_maps_preserved {U : AtomCarrier.{u}} {A B : ArchitectureObject U}
    (h : ObjectEquivalence A B) :
    h.structureMapsPreserved A.structureMaps B.structureMaps :=
  h.structureMapsPreserved_holds

/-- I.定義5.4: object equivalence records selected-quantity preservation. -/
theorem selected_quantities_preserved {U : AtomCarrier.{u}} {A B : ArchitectureObject U}
    (h : ObjectEquivalence A B) :
    h.selectedQuantitiesPreserved A.selectedQuantities B.selectedQuantities :=
  h.selectedQuantitiesPreserved_holds

end ObjectEquivalence

end ArchitectureObject

end AAT.AG
