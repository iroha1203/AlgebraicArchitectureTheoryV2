import Formal.AG.SingularityMonodromyStack.Monodromy

noncomputable section

/-!
Fixed statement contracts for the Part VI presented monodromy connection.
-/

namespace AAT.AG
namespace SingularityMonodromyStack

universe u v w x y z

variable {U : AtomCarrier.{u}} {A : ArchitectureObject U}
variable {S : Site.AATSite A} {P : StratumReadingParameter S}
variable {k : Type v} [CommRing k]
variable {X : ArchitectureStratum.{u, v, w, x, y} P k}
variable {G : OperationCategoryData.{u, v, w, x, y, z} X}
variable {R : RefactorEndpointReading.{u, v, w, x, y, z} G}
variable {H : HomotopyGeneratorFamily.{u, v, w, x, y, z} R}
variable {base : G.State}

/-- Fixed contract: the one-skeleton edges are exactly the selected operations. -/
example (K : PresentationTwoComplex.{u, v, w, x, y, z} H) :
    K.Edge ≃ Σ a : G.State, Σ b : G.State, SelectedOperation G a b :=
  K.edgeBoundary

/-- Fixed contract: both path cells and loop relators are concrete two-cells of the presentation. -/
example (K : PresentationTwoComplex.{u, v, w, x, y, z} H) :
    K.TwoCell ≃ (H.PathCell ⊕ H.LoopRelator) :=
  K.twoCellEquivGenerator

/-- Fixed contract: selected free words are endpoint-typed loops at the base. -/
example (K : PresentationTwoComplex.{u, v, w, x, y, z} H)
    (word : FreeEdgeWord K base) : FormalEdgePath K base base :=
  word

/-- Fixed contract: backward orientation is interpreted by FreeGroup inversion. -/
example (K : PresentationTwoComplex.{u, v, w, x, y, z} H)
    (edge : K.Edge) :
    (FormalEdgeStep.backward edge).toFreeGroup = (FreeGroup.of edge)⁻¹ :=
  rfl

/-- Fixed contract: `pi1AAT` is the subgroup generated by typed based-loop images. -/
example (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base) :
    Pi.basedLoopSubgroup = Subgroup.closure (Set.range Pi.rawPresentedQuotientMap) :=
  rfl

/-- Fixed contract: path-cell words have actual attaching-path provenance. -/
example (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base)
    (h : BasedPathCell H Pi.presentation base) :
    Pi.freeWordEquivSelected (Pi.pathCellRelatorWord h) =
      pathCellRelatorPath Pi.presentation h.1 h.2 :=
  Pi.pathCellRelator_path_holds h

/-- Fixed contract: loop-relator words have actual operation-loop provenance. -/
example (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base)
    (r : BasedLoopRelator H Pi.presentation base) :
    Pi.freeWordEquivSelected (Pi.loopRelatorWord r) =
      loopRelatorPath Pi.presentation r.1 r.2 :=
  Pi.loopRelator_path_holds r

/-- Fixed contract: no relators occur outside the two actual attaching-loop families. -/
example (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base)
    {word : Pi.FreeWord} :
    Pi.Relator word ↔
      (∃ h : BasedPathCell H Pi.presentation base, Pi.pathCellRelatorWord h = word) ∨
      (∃ r : BasedLoopRelator H Pi.presentation base, Pi.loopRelatorWord r = word) :=
  Pi.relator_iff_actual_attaching_loop

/-- Fixed contract: coefficient automorphisms form the target automorphism group. -/
example (C : MonodromyCoefficientObject.{z}) :
    Group (CoefficientAutomorphism C) :=
  inferInstance

/-- Fixed contract: the custom carrier is the standard product of Mathlib permutation groups. -/
example (C : MonodromyCoefficientObject.{z}) :
    CoefficientAutomorphism C ≃*
      Equiv.Perm C.Ob × Equiv.Perm C.Sem × Equiv.Perm C.Eff :=
  CoefficientAutomorphism.standardProductMulEquiv C

/-- Fixed contract: multiplication follows the standard automorphism composition order. -/
example (C : MonodromyCoefficientObject.{z})
    (f g : CoefficientAutomorphism C)
    (xOb : C.Ob) (xSem : C.Sem) (xEff : C.Eff) :
    (f * g).obAut xOb = f.obAut (g.obAut xOb) ∧
      (f * g).semAut xSem = f.semAut (g.semAut xSem) ∧
      (f * g).effAut xEff = f.effAut (g.effAut xEff) :=
  ⟨rfl, rfl, rfl⟩

/-- Fixed contract: monodromy acts directly on the typed based-loop group. -/
example
    (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base)
    (M : MonodromyAction.{u, v, w, x, y, z} Pi) :
    Pi.pi1AAT →* CoefficientAutomorphism M.coefficient :=
  M.rho

/-- Fixed contract: edge actions killing actual attaching relators construct monodromy. -/
example
    (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base)
    (coefficient : MonodromyCoefficientObject.{z})
    (generatorAction : Pi.presentation.Edge -> CoefficientAutomorphism coefficient)
    (relators_map_to_one :
      ∀ r ∈ Pi.presentedRelators, FreeGroup.lift generatorAction r = 1) :
    MonodromyAction.{u, v, w, x, y, z} Pi :=
  MonodromyAction.ofPresentedGenerators
    Pi coefficient generatorAction relators_map_to_one

/-- Fixed contract: presented monodromy evaluates a typed based-loop word. -/
example
    (Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base)
    (coefficient : MonodromyCoefficientObject.{z})
    (generatorAction : Pi.presentation.Edge -> CoefficientAutomorphism coefficient)
    (relators_map_to_one :
      ∀ r ∈ Pi.presentedRelators, FreeGroup.lift generatorAction r = 1)
    (word : Pi.FreeWord) :
    (MonodromyAction.ofPresentedGenerators
      Pi coefficient generatorAction relators_map_to_one).Mon_gamma
        (Pi.presentedQuotientMap word) =
      FreeGroup.lift generatorAction (Pi.selectedFreeGroupWord word) :=
  MonodromyAction.mon_gamma_presented_loop
    Pi coefficient generatorAction relators_map_to_one word

/-- Fixed contract: every selected relator has identity monodromy. -/
example
    {Pi : PresentedArchitectureFundamentalGroup.{u, v, w, x, y, z} H base}
    (M : MonodromyAction.{u, v, w, x, y, z} Pi)
    {word : Pi.FreeWord} (hword : Pi.Relator word) :
    M.Mon_gamma (Pi.presentedQuotientMap word) = 1 :=
  M.mon_gamma_presented_relator hword

end SingularityMonodromyStack
end AAT.AG
