import Formal.AG.SemanticRepair.Conormal.LawGeneratedBooleanCircleSite
import Formal.Util.AssertStandardAxioms
import Mathlib.CategoryTheory.Sites.PrecoverageToGrothendieck

/-!
# Generated-topology classification for the Boolean-circle site

This file classifies the precoverage generators of the Cycle 17 site.  Every
admissible family is based at the selected empty-index context.  Its generated
sieve is either the sieve generated by the three singleton patches or the top
sieve, and every pullback of such a generator has the same dichotomy.

No presheaf, sheaf condition, coefficient, cocycle, or cohomology conclusion
is accepted as data.
-/

noncomputable section

namespace AAT.AG.SemanticRepair.Conormal
namespace LawGeneratedBooleanCircleTopology

open CategoryTheory
open AAT.AG
open LawGeneratedBooleanCircleSite

/-- The sieve generated by the selected three singleton patches. -/
abbrev selectedSieve : Sieve base := Sieve.generate cover.presieve

theorem exists_componentA_patch
    {X : site.category}
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap X) :
    ∃ i : F.Index, F.patch i = context (chartContextIndex 0) := by
  obtain ⟨i, hi⟩ := F.admissible.atomSupportCoverage
    FiniteModel.FiniteAtom.componentA (Or.inl rfl)
  refine ⟨i, ?_⟩
  have hi' : F.patch i = context (chartContextIndex 0) ∧
      ∃ support, (F.patch i).minimal.supportReads support
        FiniteModel.FiniteAtom.componentA := by
    simpa [coverageRequirements] using hi
  exact hi'.1

theorem exists_componentB_patch
    {X : site.category}
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap X) :
    ∃ i : F.Index, F.patch i = context (chartContextIndex 1) := by
  obtain ⟨i, hi⟩ := F.admissible.atomSupportCoverage
    FiniteModel.FiniteAtom.componentB (Or.inr (Or.inl rfl))
  refine ⟨i, ?_⟩
  have hi' : F.patch i = context (chartContextIndex 1) ∧
      ∃ support, (F.patch i).minimal.supportReads support
        FiniteModel.FiniteAtom.componentB := by
    simpa [coverageRequirements] using hi
  exact hi'.1

theorem exists_componentC_patch
    {X : site.category}
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap X) :
    ∃ i : F.Index, F.patch i = context (chartContextIndex 2) := by
  obtain ⟨i, hi⟩ := F.admissible.atomSupportCoverage
    FiniteModel.FiniteAtom.dependsAB (Or.inr (Or.inr rfl))
  refine ⟨i, ?_⟩
  have hi' : F.patch i = context (chartContextIndex 2) ∧
      ∃ support, (F.patch i).minimal.supportReads support
        FiniteModel.FiniteAtom.dependsAB := by
    simpa [coverageRequirements] using hi
  exact hi'.1

theorem family_base_eq
    {X : site.category}
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap X) :
    X = base := by
  obtain ⟨i0, hi0⟩ := exists_componentA_patch F
  obtain ⟨i1, hi1⟩ := exists_componentB_patch F
  have h0 : contextPreorder.le (context (chartContextIndex 0)) X.ctx := by
    simpa only [hi0] using F.inclusion i0
  have h1 : contextPreorder.le (context (chartContextIndex 1)) X.ctx := by
    simpa only [hi1] using F.inclusion i1
  have hX : Recognized X.ctx := by
    by_cases hEq : context (chartContextIndex 0) = X.ctx
    · exact hEq ▸ recognized_context (chartContextIndex 0)
    · exact (le_recognized_of_ne h0 hEq).2
  have hs0 : indexOf X.ctx ⊆ chartContextIndex 0 :=
    by simpa using (le_iff_indexOf_subset (recognized_context _) hX).mp h0
  have hs1 : indexOf X.ctx ⊆ chartContextIndex 1 :=
    by simpa using (le_iff_indexOf_subset (recognized_context _) hX).mp h1
  have hempty : indexOf X.ctx = ∅ := by
    apply Finset.eq_empty_iff_forall_notMem.mpr
    intro x hx
    have hx0 : x = 0 := by
      simpa [chartContextIndex] using hs0 hx
    have hx1 : x = 1 := by
      simpa [chartContextIndex] using hs1 hx
    omega
  have hctx : X.ctx = context ∅ := by
    rw [context_indexOf hX, hempty]
  cases X
  cases hctx
  rfl

/-- Every selected singleton generator belongs to an arbitrary admissible family's sieve. -/
theorem selectedSieve_le_familySieve
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base) :
    selectedSieve ≤ Sieve.generate F.presieve := by
  classical
  rw [Sieve.generate_le_iff]
  intro Y f hf
  rcases hf with ⟨i⟩
  change Fin 3 at i
  fin_cases i
  · obtain ⟨j, hj⟩ := exists_componentA_patch F
    change Sieve.ofArrows
      (fun j : F.Index => Site.ContextCategoryObject.of contextPreorder (F.patch j))
      (fun j => homOfLE (F.inclusion j)) _
    rw [Sieve.mem_ofArrows_iff]
    refine ⟨j, eqToHom ?_, Subsingleton.elim _ _⟩
    exact congrArg (Site.ContextCategoryObject.of contextPreorder) hj.symm
  · obtain ⟨j, hj⟩ := exists_componentB_patch F
    change Sieve.ofArrows
      (fun j : F.Index => Site.ContextCategoryObject.of contextPreorder (F.patch j))
      (fun j => homOfLE (F.inclusion j)) _
    rw [Sieve.mem_ofArrows_iff]
    refine ⟨j, eqToHom ?_, Subsingleton.elim _ _⟩
    exact congrArg (Site.ContextCategoryObject.of contextPreorder) hj.symm
  · obtain ⟨j, hj⟩ := exists_componentC_patch F
    change Sieve.ofArrows
      (fun j : F.Index => Site.ContextCategoryObject.of contextPreorder (F.patch j))
      (fun j => homOfLE (F.inclusion j)) _
    rw [Sieve.mem_ofArrows_iff]
    refine ⟨j, eqToHom ?_, Subsingleton.elim _ _⟩
    exact congrArg (Site.ContextCategoryObject.of contextPreorder) hj.symm

/-- A non-base selected context maps to the base through one singleton patch. -/
theorem nonbase_arrow_mem_selectedSieve
    {Y : site.category} (f : Y ⟶ base) (hne : Y ≠ base) :
    selectedSieve f := by
  have hctxne : Y.ctx ≠ (context ∅) := by
    intro h
    apply hne
    cases Y
    cases h
    rfl
  have hY : Recognized Y.ctx :=
    (le_recognized_of_ne (leOfHom f) hctxne).1
  have hnonempty : (indexOf Y.ctx).Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h
    apply hctxne
    rw [context_indexOf hY, h]
  obtain ⟨i, hi⟩ := hnonempty
  change Sieve.ofArrows
    (fun i : cover.Index => Site.ContextCategoryObject.of contextPreorder (cover.patch i))
    (fun i => homOfLE (cover.inclusion i)) f
  rw [Sieve.mem_ofArrows_iff]
  refine ⟨i, homOfLE ?_, ?_⟩
  · apply (le_iff_indexOf_subset hY (recognized_context _)).mpr
    simpa [chartContextIndex] using hi
  · apply Subsingleton.elim

/-- If an admissible family contains no base patch, its generated sieve is selected. -/
theorem familySieve_eq_selected_of_no_base_patch
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base)
    (hno : ∀ i : F.Index, F.patch i ≠ context ∅) :
    Sieve.generate F.presieve = selectedSieve := by
  apply le_antisymm
  · rw [Sieve.generate_le_iff]
    intro Y f hf
    rcases hf with ⟨i⟩
    apply nonbase_arrow_mem_selectedSieve (homOfLE (F.inclusion i))
    intro hobj
    apply hno i
    exact congrArg Site.ContextCategoryObject.ctx hobj
  · exact selectedSieve_le_familySieve F

/-- If an admissible family contains the base patch, its generated sieve is top. -/
theorem familySieve_eq_top_of_base_patch
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base)
    (i : F.Index) (hi : F.patch i = context ∅) :
    Sieve.generate F.presieve = ⊤ := by
  classical
  rw [← Sieve.id_mem_iff_eq_top]
  change Sieve.ofArrows
    (fun j : F.Index => Site.ContextCategoryObject.of contextPreorder (F.patch j))
    (fun j => homOfLE (F.inclusion j)) (𝟙 base)
  rw [Sieve.mem_ofArrows_iff]
  refine ⟨i, eqToHom ?_, Subsingleton.elim _ _⟩
  exact congrArg (Site.ContextCategoryObject.of contextPreorder) hi.symm

/-- Every admissible generator sieve is either the selected sieve or top. -/
theorem familySieve_eq_selected_or_top
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base) :
    Sieve.generate F.presieve = selectedSieve ∨
      Sieve.generate F.presieve = ⊤ := by
  by_cases h : ∃ i : F.Index, F.patch i = context ∅
  · obtain ⟨i, hi⟩ := h
    exact Or.inr (familySieve_eq_top_of_base_patch F i hi)
  · exact Or.inl (familySieve_eq_selected_of_no_base_patch F (by simpa using h))

/-- A non-base pullback of the selected sieve is top. -/
theorem selectedSieve_pullback_eq_top_of_ne_base
    {Y : site.category} (f : Y ⟶ base) (hY : Y ≠ base) :
    selectedSieve.pullback f = ⊤ := by
  rw [← Sieve.id_mem_iff_eq_top]
  simpa using nonbase_arrow_mem_selectedSieve f hY

/-- A base pullback of the selected sieve is the selected sieve itself. -/
theorem selectedSieve_pullback_id :
    selectedSieve.pullback (𝟙 base) = selectedSieve := by
  exact Sieve.pullback_id

/-- Every non-base pullback of every admissible generator is top. -/
theorem familySieve_pullback_eq_top_of_ne_base
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base)
    {Y : site.category} (f : Y ⟶ base) (hY : Y ≠ base) :
    (Sieve.generate F.presieve).pullback f = ⊤ := by
  rw [← Sieve.id_mem_iff_eq_top]
  exact selectedSieve_le_familySieve F f
    (nonbase_arrow_mem_selectedSieve f hY)

/-- Any pullback target is the base, or the pulled-back generator is top. -/
theorem familySieve_pullback_base_or_top
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base)
    {Y : site.category} (f : Y ⟶ base) :
    Y = base ∨ (Sieve.generate F.presieve).pullback f = ⊤ := by
  by_cases hY : Y = base
  · exact Or.inl hY
  · exact Or.inr (familySieve_pullback_eq_top_of_ne_base F f hY)

/-- At the base identity, an admissible generator remains selected or top. -/
theorem familySieve_pullback_id_eq_selected_or_top
    (F : Site.AATCoverageFamily coverageRequirements contextOverlap base) :
    (Sieve.generate F.presieve).pullback (𝟙 base) = selectedSieve ∨
      (Sieve.generate F.presieve).pullback (𝟙 base) = ⊤ := by
  simpa only [Sieve.pullback_id] using familySieve_eq_selected_or_top F

/-- A precoverage generator can occur only over the selected base. -/
theorem precoverage_generator_base_eq
    {X : site.category} (R : Presieve X)
    (hR : R ∈ Site.admissiblePrecoverage coverageRequirements contextOverlap X) :
    X = base := by
  rcases hR with ⟨F, _⟩
  exact family_base_eq F

/-- Full generator-pullback classification used by the precoverage sheaf criterion. -/
theorem precoverage_generator_pullback_base_or_top
    {X Y : site.category} (f : Y ⟶ X) (R : Presieve X)
    (hR : R ∈ Site.admissiblePrecoverage coverageRequirements contextOverlap X) :
    X = base ∧ (Y = base ∨ (Sieve.generate R).pullback f = ⊤) := by
  rcases hR with ⟨F, hF⟩
  subst R
  have e : X = base := family_base_eq F
  subst X
  exact ⟨rfl, familySieve_pullback_base_or_top F f⟩

end LawGeneratedBooleanCircleTopology
end AAT.AG.SemanticRepair.Conormal

#assert_standard_axioms_only AAT.AG.SemanticRepair.Conormal.LawGeneratedBooleanCircleTopology
