import Formal.AG.Measurement.FiniteRegime
import Formal.AG.Derived.TaylorResolution
import Formal.AG.LawAlgebra.StanleyReisner
import Mathlib.Algebra.Homology.ShortComplex.Exact
import Mathlib.LinearAlgebra.TensorProduct.Pi
import Mathlib.RingTheory.Ideal.Quotient.Operations
import Mathlib.RingTheory.MvPolynomial.Ideal

noncomputable section

namespace AAT.AG
namespace Measurement

universe u v

open CategoryTheory
open CategoryTheory.Limits

/-!
Part VIII theorem 4.2: finite AAT computations generated from a finite
measurement regime.

The Čech complex, route-selected kernel/image/quotient reductions, and
five-state verdicts are generated by `FiniteMeasurementGeometry`.  Square-free,
Stanley--Reisner, Tor, minimal-support, and selected-conflict computations are
generated from their selected finite data below.
-/

/-- VIII.Theorem 4.2 input: an enumerated square-free forbidden family. -/
structure FiniteSquareFreeComputationData {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M) where
  /-- Selected finite forbidden-support family. -/
  forbiddenSupports : Finset (Finset M.WitnessVariables)

namespace FiniteSquareFreeComputationData

variable {M : MeasurementProfile.{u, v}} {R : FiniteMeasurementRegime M}

/-- Square-free witness regime generated by the finite forbidden family. -/
def witnessRegime (D : FiniteSquareFreeComputationData R) :
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime M.WitnessVariables := by
  letI := R.witnessDecidableEq
  exact { Forb := fun support => support ∈ D.forbiddenSupports }

/-- Square-free obstruction ideal generated by the selected family. -/
def obstructionIdeal (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] : Ideal (MvPolynomial M.WitnessVariables k) := by
  letI := R.witnessDecidableEq
  exact LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.obstructionIdeal
    M.WitnessVariables k D.witnessRegime

/-- An empty forbidden support contributes the unit monomial, hence generates
the top obstruction ideal. -/
theorem obstructionIdeal_eq_top_of_empty_mem
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (hempty : (∅ : Finset M.WitnessVariables) ∈ D.forbiddenSupports) :
    D.obstructionIdeal k = ⊤ := by
  letI := R.witnessDecidableEq
  apply (Ideal.eq_top_iff_one _).mpr
  change (1 : MvPolynomial M.WitnessVariables k) ∈
    Ideal.span {f | ∃ support,
      support ∈ D.forbiddenSupports ∧
      f = LawAlgebra.StanleyReisner.squareFreeMonomial
        M.WitnessVariables k support}
  apply Ideal.subset_span
  exact ⟨∅, hempty, by
    simp [LawAlgebra.StanleyReisner.squareFreeMonomial]⟩

/-- Stanley--Reisner complex generated by the same forbidden family. -/
def stanleyReisnerComplex (D : FiniteSquareFreeComputationData R) :
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.AbstractSimplicialComplex
      M.WitnessVariables := by
  letI := R.witnessDecidableEq
  exact LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.delta
    M.WitnessVariables D.witnessRegime

/-- Stanley--Reisner ideal of the generated complex. -/
def stanleyReisnerIdeal (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] : Ideal (MvPolynomial M.WitnessVariables k) := by
  letI := R.witnessDecidableEq
  exact LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.stanleyReisnerIdeal
    M.WitnessVariables k D.stanleyReisnerComplex

/-- Inclusion-minimal supports computed by filtering the finite family. -/
def minimalForbiddenSupports (D : FiniteSquareFreeComputationData R) :
    Finset (Finset M.WitnessVariables) := by
  classical
  exact D.forbiddenSupports.filter fun support =>
    ∀ candidate ∈ D.forbiddenSupports,
      candidate ⊆ support -> support ⊆ candidate

/-- Membership in the computed list is exactly membership in the selected
family together with inclusion-minimality inside that family. -/
theorem mem_minimalForbiddenSupports_iff
    (D : FiniteSquareFreeComputationData R)
    (support : Finset M.WitnessVariables) :
    support ∈ D.minimalForbiddenSupports ↔
      support ∈ D.forbiddenSupports ∧
        ∀ candidate ∈ D.forbiddenSupports,
          candidate ⊆ support -> support ⊆ candidate := by
  classical
  simp [minimalForbiddenSupports]

/-- The finite family consisting of every singleton witness support. -/
def allSingletons (R : FiniteMeasurementRegime M) :
    FiniteSquareFreeComputationData R where
  forbiddenSupports := by
    letI := R.witnessFintype
    letI := R.witnessDecidableEq
    exact Finset.univ.image singleton

/-- Finite list of the selected monomial generators. -/
def generatorMonomials (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] : Finset (MvPolynomial M.WitnessVariables k) := by
  classical
  letI := R.witnessDecidableEq
  exact D.forbiddenSupports.image
    (LawAlgebra.StanleyReisner.squareFreeMonomial M.WitnessVariables k)

/-- Every computed generator passes ideal-membership checking. -/
theorem generatorMonomial_mem_obstructionIdeal
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    {f : MvPolynomial M.WitnessVariables k}
    (hf : f ∈ D.generatorMonomials k) : f ∈ D.obstructionIdeal k := by
  classical
  letI := R.witnessDecidableEq
  rcases Finset.mem_image.mp hf with ⟨support, hsupport, rfl⟩
  exact Ideal.subset_span ⟨support, hsupport, rfl⟩

/-- The finite monomial list generates exactly the selected obstruction ideal. -/
theorem obstructionIdeal_eq_span_generatorMonomials
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] :
    D.obstructionIdeal k = Ideal.span (D.generatorMonomials k : Set _) := by
  classical
  letI := R.witnessDecidableEq
  change
    Ideal.span
        {f | ∃ support, support ∈ D.forbiddenSupports ∧
          f = LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k support} =
      Ideal.span
        ((D.forbiddenSupports.image
          (LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k) :
          Finset (MvPolynomial M.WitnessVariables k)) : Set _)
  congr 1
  ext f
  simp [eq_comm]

/-- The singleton family generates the ideal spanned by all witness variables. -/
theorem allSingletons_obstructionIdeal
    (R : FiniteMeasurementRegime M)
    (k : Type v) [CommRing k] :
    (allSingletons R).obstructionIdeal k =
      MvPolynomial.idealOfVars M.WitnessVariables k := by
  letI := R.witnessFintype
  letI := R.witnessDecidableEq
  rw [obstructionIdeal_eq_span_generatorMonomials]
  unfold MvPolynomial.idealOfVars
  congr 1
  ext f
  simp [allSingletons, generatorMonomials,
    LawAlgebra.StanleyReisner.squareFreeMonomial]

/-- Exponent vector of a square-free witness support. -/
def supportExponent
    (support : Finset M.WitnessVariables) : M.WitnessVariables →₀ ℕ :=
  support.sum fun e => Finsupp.single e 1

/-- The constant unit polynomial is reduced modulo the singleton-generated
square-free ideal. -/
theorem allSingletons_one_isReduced
    (R : FiniteMeasurementRegime M)
    (k : Type v) [CommRing k] [Nontrivial k] :
    ∀ exponent,
      exponent ∈ (1 : MvPolynomial M.WitnessVariables k).support ->
        ∀ support ∈ (allSingletons R).forbiddenSupports,
          ¬ supportExponent support ≤ exponent := by
  letI := R.witnessFintype
  letI := R.witnessDecidableEq
  intro exponent hexponent support hsupport hle
  have hexponent_zero : exponent = 0 := by
    rw [MvPolynomial.mem_support_iff, MvPolynomial.coeff_one] at hexponent
    by_contra h
    simp at hexponent
    exact h hexponent.symm
  subst exponent
  rcases Finset.mem_image.mp hsupport with ⟨e, -, rfl⟩
  have he := hle e
  simp [supportExponent] at he

/-- The support product is the monic monomial of its exponent vector. -/
theorem squareFreeMonomial_eq_monomial
    (k : Type v) [CommRing k] (support : Finset M.WitnessVariables) :
    letI := R.witnessDecidableEq
    LawAlgebra.StanleyReisner.squareFreeMonomial
        M.WitnessVariables k support =
      MvPolynomial.monomial (supportExponent support) 1 := by
  letI := R.witnessDecidableEq
  classical
  induction support using Finset.induction_on with
  | empty =>
      simp [LawAlgebra.StanleyReisner.squareFreeMonomial, supportExponent]
  | insert e support he ih =>
      rw [LawAlgebra.StanleyReisner.squareFreeMonomial,
        Finset.prod_insert he]
      change MvPolynomial.X e *
          LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k support = _
      rw [ih]
      simp [MvPolynomial.X, supportExponent, he, MvPolynomial.monomial_mul]

/-- Finite exponent list generated by the selected forbidden supports. -/
def generatorExponents (D : FiniteSquareFreeComputationData R) :
    Finset (M.WitnessVariables →₀ ℕ) := by
  letI := R.witnessDecidableEq
  exact D.forbiddenSupports.image supportExponent

/-- The generated obstruction ideal is the monomial ideal of the exponent list. -/
theorem obstructionIdeal_eq_span_generatorExponents
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] :
    D.obstructionIdeal k =
      Ideal.span
        ((fun s : M.WitnessVariables →₀ ℕ => MvPolynomial.monomial s (1 : k)) ''
          (D.generatorExponents : Set (M.WitnessVariables →₀ ℕ))) := by
  classical
  rw [D.obstructionIdeal_eq_span_generatorMonomials]
  congr 1
  ext f
  simp only [generatorMonomials, generatorExponents, Finset.coe_image,
    Set.mem_image]
  constructor
  · rintro ⟨support, hsupport, rfl⟩
    refine ⟨supportExponent support, ⟨support, hsupport, rfl⟩, ?_⟩
    exact (squareFreeMonomial_eq_monomial (R := R) k support).symm
  · rintro ⟨exponent, ⟨support, hsupport, rfl⟩, rfl⟩
    refine ⟨support, hsupport, ?_⟩
    exact squareFreeMonomial_eq_monomial (R := R) k support

/--
Executable membership test for the monomial ideal generated by the finite
forbidden-support family.
-/
def decideObstructionIdealMembership
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) : Bool := by
  letI := R.witnessDecidableEq
  exact decide (∀ exponent ∈ f.support,
    ∃ generator ∈ D.generatorExponents, generator ≤ exponent)

/-- The finite exponent test decides membership in the generated ideal. -/
theorem decideObstructionIdealMembership_correct
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) :
    D.decideObstructionIdealMembership k f = true ↔ f ∈ D.obstructionIdeal k := by
  letI := R.witnessDecidableEq
  rw [D.obstructionIdeal_eq_span_generatorExponents]
  rw [MvPolynomial.mem_ideal_span_monomial_image]
  simp [decideObstructionIdealMembership, generatorExponents]

/-- An exponent is standard for the selected square-free monomial ideal when
it is not divisible by any selected generator exponent. -/
def IsStandardExponent (D : FiniteSquareFreeComputationData R)
    (exponent : M.WitnessVariables →₀ ℕ) : Prop :=
  ∀ generator ∈ D.generatorExponents, ¬ generator ≤ exponent

/-- Canonical monomial normal form obtained by retaining exactly the standard
exponents.  This is a coefficientwise construction and does not choose a lift
from the quotient. -/
def normalForm
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) :
    MvPolynomial M.WitnessVariables k := by
  letI := R.witnessDecidableEq
  letI : DecidablePred D.IsStandardExponent := Classical.decPred _
  exact Finsupp.filter D.IsStandardExponent f

/-- A standard exponent retains its coefficient in the canonical normal form. -/
theorem coeff_normalForm_of_standard
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k)
    (exponent : M.WitnessVariables →₀ ℕ)
    (hstandard : D.IsStandardExponent exponent) :
    MvPolynomial.coeff exponent (D.normalForm k f) =
      MvPolynomial.coeff exponent f := by
  letI := R.witnessDecidableEq
  letI : DecidablePred D.IsStandardExponent := Classical.decPred _
  change (Finsupp.filter D.IsStandardExponent f) exponent =
    MvPolynomial.coeff exponent f
  rw [Finsupp.filter_apply]
  simp [hstandard]
  rfl

/-- A nonstandard exponent has zero coefficient in the canonical normal form. -/
theorem coeff_normalForm_of_not_standard
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k)
    (exponent : M.WitnessVariables →₀ ℕ)
    (hstandard : ¬ D.IsStandardExponent exponent) :
    MvPolynomial.coeff exponent (D.normalForm k f) = 0 := by
  letI := R.witnessDecidableEq
  letI : DecidablePred D.IsStandardExponent := Classical.decPred _
  change (Finsupp.filter D.IsStandardExponent f) exponent = 0
  rw [Finsupp.filter_apply]
  simp [hstandard]

/-- Support membership in the normal form is support membership in the input
together with standardness of the exponent. -/
theorem mem_normalForm_support_iff
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k)
    (exponent : M.WitnessVariables →₀ ℕ) :
    exponent ∈ (D.normalForm k f).support ↔
      exponent ∈ f.support ∧ D.IsStandardExponent exponent := by
  letI := R.witnessDecidableEq
  by_cases hstandard : D.IsStandardExponent exponent
  · rw [MvPolynomial.mem_support_iff,
      D.coeff_normalForm_of_standard k f exponent hstandard,
      MvPolynomial.mem_support_iff]
    simp [hstandard]
  · rw [MvPolynomial.mem_support_iff,
      D.coeff_normalForm_of_not_standard k f exponent hstandard]
    simp [hstandard]

/-- The part discarded by the canonical monomial normal form. -/
def discardedPart
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) :
    MvPolynomial M.WitnessVariables k :=
  f - D.normalForm k f

/-- Every monomial retained by the normal form is reduced with respect to the
selected square-free generators. -/
theorem normalForm_reduced
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k)
    {exponent : M.WitnessVariables →₀ ℕ}
    (hexponent : exponent ∈ (D.normalForm k f).support) :
    ∀ support ∈ D.forbiddenSupports,
      ¬ supportExponent support ≤ exponent := by
  letI := R.witnessDecidableEq
  have hstandard : D.IsStandardExponent exponent := by
    exact (D.mem_normalForm_support_iff k f exponent).mp hexponent |>.2
  intro support hsupport hle
  apply hstandard (supportExponent support)
  · exact Finset.mem_image.mpr ⟨support, hsupport, rfl⟩
  · exact hle

/-- The terms removed by the canonical normal form belong to the generated
square-free monomial ideal. -/
theorem discardedPart_mem_obstructionIdeal
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) :
    D.discardedPart k f ∈ D.obstructionIdeal k := by
  letI := R.witnessDecidableEq
  rw [D.obstructionIdeal_eq_span_generatorExponents,
    MvPolynomial.mem_ideal_span_monomial_image]
  intro exponent hexponent
  by_contra hgenerator
  push_neg at hgenerator
  have hstandard : D.IsStandardExponent exponent := by
    intro generator hmem
    exact hgenerator generator hmem
  have hcoeff : MvPolynomial.coeff exponent (D.discardedPart k f) = 0 := by
    rw [discardedPart, MvPolynomial.coeff_sub,
      D.coeff_normalForm_of_standard k f exponent hstandard]
    exact sub_self _
  exact (MvPolynomial.mem_support_iff.mp hexponent) hcoeff

/-- Two polynomial lifts of the same quotient class have the same canonical
monomial normal form. -/
theorem normalForm_eq_of_sub_mem
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    {f g : MvPolynomial M.WitnessVariables k}
    (hsub : f - g ∈ D.obstructionIdeal k) :
    D.normalForm k f = D.normalForm k g := by
  letI := R.witnessDecidableEq
  rw [D.obstructionIdeal_eq_span_generatorExponents,
    MvPolynomial.mem_ideal_span_monomial_image] at hsub
  apply MvPolynomial.ext
  intro exponent
  by_cases hstandard : D.IsStandardExponent exponent
  · have hcoeff : MvPolynomial.coeff exponent (f - g) = 0 := by
      by_contra hne
      have hsupp : exponent ∈ (f - g).support :=
        MvPolynomial.mem_support_iff.mpr hne
      rcases hsub exponent hsupp with ⟨generator, hgenerator, hle⟩
      exact hstandard generator hgenerator hle
    have hfg : MvPolynomial.coeff exponent f = MvPolynomial.coeff exponent g := by
      simpa using sub_eq_zero.mp hcoeff
    rw [D.coeff_normalForm_of_standard k f exponent hstandard,
      D.coeff_normalForm_of_standard k g exponent hstandard]
    exact hfg
  · rw [D.coeff_normalForm_of_not_standard k f exponent hstandard,
      D.coeff_normalForm_of_not_standard k g exponent hstandard]

/-- A reduced polynomial is already in canonical monomial normal form. -/
theorem normalForm_eq_self_of_reduced
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k)
    (hreduced : ∀ exponent ∈ f.support,
      ∀ support ∈ D.forbiddenSupports,
        ¬ supportExponent support ≤ exponent) :
    D.normalForm k f = f := by
  letI := R.witnessDecidableEq
  apply MvPolynomial.ext
  intro exponent
  by_cases hexponent : exponent ∈ f.support
  · have hstandard : D.IsStandardExponent exponent := by
      intro generator hgenerator hle
      rcases Finset.mem_image.mp hgenerator with ⟨support, hsupport, rfl⟩
      exact hreduced exponent hexponent support hsupport hle
    exact D.coeff_normalForm_of_standard k f exponent hstandard
  · have hcoeff : MvPolynomial.coeff exponent f = 0 := by
      simpa [MvPolynomial.mem_support_iff] using hexponent
    by_cases hstandard : D.IsStandardExponent exponent
    · rw [D.coeff_normalForm_of_standard k f exponent hstandard, hcoeff]
    · rw [D.coeff_normalForm_of_not_standard k f exponent hstandard, hcoeff]

/-- The normal form represents the same quotient class as the input
polynomial. -/
theorem normalForm_mod
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) :
    Ideal.Quotient.mk (D.obstructionIdeal k) (D.normalForm k f) =
      Ideal.Quotient.mk (D.obstructionIdeal k) f := by
  rw [Ideal.Quotient.eq]
  have hmem := D.discardedPart_mem_obstructionIdeal k f
  have hneg := (D.obstructionIdeal k).neg_mem hmem
  simpa [discardedPart, sub_eq_add_neg, add_comm] using hneg

/-- Canonical representative of a quotient coefficient, defined by quotient
recursion from the monomial normal form. -/
def quotientNormalForm
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (q : MvPolynomial M.WitnessVariables k ⧸ D.obstructionIdeal k) :
    MvPolynomial M.WitnessVariables k := by
  classical
  refine Quotient.liftOn q (D.normalForm k) ?_
  intro f g hfg
  apply D.normalForm_eq_of_sub_mem k
  rw [← Ideal.Quotient.eq]
  exact Quotient.sound hfg

/-- Evaluating the quotient normal form on a polynomial class is the ordinary
normal form of that polynomial. -/
@[simp] theorem quotientNormalForm_mk
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (f : MvPolynomial M.WitnessVariables k) :
    D.quotientNormalForm k
        (Ideal.Quotient.mk (D.obstructionIdeal k) f) =
      D.normalForm k f := by
  classical
  rfl

/-- The quotient normal form maps back to the requested quotient class. -/
theorem quotientNormalForm_correct
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (q : MvPolynomial M.WitnessVariables k ⧸ D.obstructionIdeal k) :
    Ideal.Quotient.mk (D.obstructionIdeal k) (D.quotientNormalForm k q) = q := by
  classical
  induction q using Quotient.inductionOn with
  | _ f =>
      change Ideal.Quotient.mk (D.obstructionIdeal k) (D.normalForm k f) =
        Ideal.Quotient.mk (D.obstructionIdeal k) f
      exact D.normalForm_mod k f

/-- Every quotient normal form is reduced with respect to the selected
square-free generators. -/
theorem quotientNormalForm_reduced
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (q : MvPolynomial M.WitnessVariables k ⧸ D.obstructionIdeal k) :
    ∀ exponent ∈ (D.quotientNormalForm k q).support,
      ∀ support ∈ D.forbiddenSupports,
        ¬ supportExponent support ≤ exponent := by
  classical
  induction q using Quotient.inductionOn with
  | _ f =>
      change ∀ exponent ∈ (D.normalForm k f).support,
        ∀ support ∈ D.forbiddenSupports,
          ¬ supportExponent support ≤ exponent
      intro exponent hexponent
      exact D.normalForm_reduced k f hexponent

/-- Reduced representatives of a quotient class coincide with its canonical
normal form. -/
theorem quotientNormalForm_unique
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (q : MvPolynomial M.WitnessVariables k ⧸ D.obstructionIdeal k)
    (f : MvPolynomial M.WitnessVariables k)
    (hclass : Ideal.Quotient.mk (D.obstructionIdeal k) f = q)
    (hreduced : ∀ exponent ∈ f.support,
      ∀ support ∈ D.forbiddenSupports,
        ¬ supportExponent support ≤ exponent) :
    D.quotientNormalForm k q = f := by
  subst q
  change D.normalForm k f = f
  exact D.normalForm_eq_self_of_reduced k f hreduced

/-- Canonical quotient normal form transported along an equality identifying a
concrete ideal with the generated square-free ideal. -/
def quotientNormalFormOfIdealEq
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (I : Ideal (MvPolynomial M.WitnessVariables k))
    (hI : I = D.obstructionIdeal k)
    (q : MvPolynomial M.WitnessVariables k ⧸ I) :
    MvPolynomial M.WitnessVariables k := by
  subst I
  exact D.quotientNormalForm k q

/-- The transported normal form maps back to the original concrete quotient
class. -/
theorem quotientNormalFormOfIdealEq_correct
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (I : Ideal (MvPolynomial M.WitnessVariables k))
    (hI : I = D.obstructionIdeal k)
    (q : MvPolynomial M.WitnessVariables k ⧸ I) :
    Ideal.Quotient.mk I (D.quotientNormalFormOfIdealEq k I hI q) = q := by
  subst I
  exact D.quotientNormalForm_correct k q

/-- The transported normal form remains reduced by every selected generator. -/
theorem quotientNormalFormOfIdealEq_reduced
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (I : Ideal (MvPolynomial M.WitnessVariables k))
    (hI : I = D.obstructionIdeal k)
    (q : MvPolynomial M.WitnessVariables k ⧸ I) :
    ∀ exponent ∈ (D.quotientNormalFormOfIdealEq k I hI q).support,
      ∀ support ∈ D.forbiddenSupports,
        ¬ supportExponent support ≤ exponent := by
  subst I
  exact D.quotientNormalForm_reduced k q

/-- A reduced representative of the concrete quotient class is the
transported canonical normal form. -/
theorem quotientNormalFormOfIdealEq_unique
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    (I : Ideal (MvPolynomial M.WitnessVariables k))
    (hI : I = D.obstructionIdeal k)
    (q : MvPolynomial M.WitnessVariables k ⧸ I)
    (f : MvPolynomial M.WitnessVariables k)
    (hclass : Ideal.Quotient.mk I f = q)
    (hreduced : ∀ exponent ∈ f.support,
      ∀ support ∈ D.forbiddenSupports,
        ¬ supportExponent support ≤ exponent) :
    D.quotientNormalFormOfIdealEq k I hI q = f := by
  subst I
  exact D.quotientNormalForm_unique k q f hclass hreduced

/-- The generated obstruction ideal is the generated Stanley--Reisner ideal. -/
theorem obstructionIdeal_eq_stanleyReisnerIdeal
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] :
    D.obstructionIdeal k = D.stanleyReisnerIdeal k := by
  letI := R.witnessDecidableEq
  exact
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.obstructionIdeal_eq_stanleyReisnerIdeal
      M.WitnessVariables k D.witnessRegime

/--
Existing Taylor-resolution presentation generated from the finite forbidden
family.  Generators are the actual members of the finite family and therefore
carry their forbidden supports without a separate support procedure.
-/
noncomputable def monomialIdealPresentation
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] :
    Derived.TaylorResolution.SquareFreeMonomialIdealPresentation
      (MvPolynomial M.WitnessVariables k) M.WitnessVariables
      (D.obstructionIdeal k) := by
  letI := R.witnessFintype
  letI := R.witnessDecidableEq
  exact {
    Generator := { support : Finset M.WitnessVariables //
      support ∈ D.forbiddenSupports }
    generatorFintype := Fintype.ofFinite _
    generatorDecidableEq := inferInstance
    monomial := fun support =>
      LawAlgebra.StanleyReisner.squareFreeMonomial
        M.WitnessVariables k support.1
    forbiddenSupport := fun support => support.1
    monomial_mem := by
      intro support
      exact Ideal.subset_span ⟨support.1, support.2, rfl⟩
    spans := by
      change Ideal.span (Set.range fun support :
          { support : Finset M.WitnessVariables // support ∈ D.forbiddenSupports } =>
        LawAlgebra.StanleyReisner.squareFreeMonomial
          M.WitnessVariables k support.1) =
        Ideal.span {f | ∃ support, support ∈ D.forbiddenSupports ∧
          f = LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k support}
      congr 1
      ext f
      constructor
      · rintro ⟨support, rfl⟩
        exact ⟨support.1, support.2, rfl⟩
      · rintro ⟨support, hsupport, rfl⟩
        exact ⟨⟨support, hsupport⟩, rfl⟩
    squareFree := ∀ generator :
        { support : Finset M.WitnessVariables // support ∈ D.forbiddenSupports },
      ∃ support,
        LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k generator.1 =
          LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k support
    squareFree_holds := by
      intro generator
      exact ⟨generator.1, rfl⟩
  }

end FiniteSquareFreeComputationData

namespace PolynomialQuotient

/-- The kernel of constant-coefficient evaluation is the ideal generated by
all polynomial variables. -/
theorem ker_constantCoeff_eq_idealOfVars
    (E : Type u) (k : Type v) [CommRing k] :
    RingHom.ker (_root_.MvPolynomial.constantCoeff :
      _root_.MvPolynomial E k →+* k) =
      _root_.MvPolynomial.idealOfVars E k := by
  ext p
  rw [RingHom.mem_ker]
  unfold _root_.MvPolynomial.idealOfVars
  rw [show Set.range (_root_.MvPolynomial.X :
      E → _root_.MvPolynomial E k) =
      _root_.MvPolynomial.X '' (Set.univ : Set E) by
    ext f
    simp]
  rw [_root_.MvPolynomial.mem_ideal_span_X_image]
  constructor
  · intro hp m hm
    have hm0 : m ≠ 0 := by
      intro hzero
      subst m
      have hcoeff : p.coeff 0 ≠ 0 :=
        _root_.MvPolynomial.mem_support_iff.mp hm
      exact hcoeff (by simpa using hp)
    obtain ⟨i, hi⟩ := Finsupp.ne_iff.mp hm0
    exact ⟨i, Set.mem_univ i, hi⟩
  · intro hp
    by_contra hconstant
    have hmem : (0 : E →₀ ℕ) ∈ p.support := by
      rw [_root_.MvPolynomial.mem_support_iff]
      simpa using hconstant
    obtain ⟨i, -, hi⟩ := hp 0 hmem
    simp at hi

/-- The all-variable quotient is finite whenever the coefficient ring is
finite. -/
noncomputable def quotientIdealOfVarsFintype
    (E : Type u) (k : Type v) [CommRing k] [Fintype k] :
    Fintype (_root_.MvPolynomial E k ⧸
      _root_.MvPolynomial.idealOfVars E k) := by
  letI : DecidableEq
      (_root_.MvPolynomial E k ⧸
        _root_.MvPolynomial.idealOfVars E k) := Classical.decEq _
  apply Fintype.ofSurjective
    (fun a : k => Ideal.Quotient.mk
      (_root_.MvPolynomial.idealOfVars E k) (_root_.MvPolynomial.C a))
  intro q
  obtain ⟨p, rfl⟩ := Ideal.Quotient.mk_surjective q
  refine ⟨_root_.MvPolynomial.constantCoeff p, ?_⟩
  rw [Ideal.Quotient.eq, ← ker_constantCoeff_eq_idealOfVars]
  simp

end PolynomialQuotient

/-! ### Finite tensor-matrix homology -/

/--
Uniform matrix algorithm for the resolution after scalar reduction to
`A / I_U`. Every differential matrix is obtained by mapping the actual finite
free resolution matrix through the quotient map.
-/
structure FiniteTensorMatrixAlgorithm
    (A : Type v) [CommRing A] (I_U I_V : Ideal A)
    (F : Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution A I_V) where
  /-- Executable equality in the tensor coefficient ring. -/
  quotientDecidableEq : DecidableEq (A ⧸ I_U)
  /-- Uniform equation solver used for kernel, image, and quotient decisions. -/
  equationSolver : FiniteLinearSystemSolver (A ⧸ I_U)

namespace FiniteTensorMatrixAlgorithm

variable {A : Type v} [CommRing A] {I_U I_V : Ideal A}
variable {F : Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution A I_V}

/-- Build the uniform matrix algorithm when the selected quotient coefficient
ring has an explicit finite carrier. -/
noncomputable def ofFiniteQuotient
    [Fintype (A ⧸ I_U)] [DecidableEq (A ⧸ I_U)] :
    FiniteTensorMatrixAlgorithm A I_U I_V F where
  quotientDecidableEq := inferInstance
  equationSolver := FiniteLinearSystemSolver.ofFiniteSemiring (A ⧸ I_U)

/-- Build an exhaustive tensor-matrix algorithm when the selected left ideal
is top, so the quotient coefficient ring has one element. -/
noncomputable def ofIdealEqTop
    (hI : I_U = ⊤) : FiniteTensorMatrixAlgorithm A I_U I_V F := by
  letI : Subsingleton (A ⧸ I_U) := Ideal.Quotient.subsingleton_iff.mpr hI
  letI : Fintype (A ⧸ I_U) := Fintype.ofSubsingleton 0
  exact {
    quotientDecidableEq := Classical.decEq _
    equationSolver := FiniteLinearSystemSolver.ofFiniteSemiring (A ⧸ I_U)
  }

/-- Coordinate term of the tensor complex in homological degree `n`. -/
@[nolint unusedArguments]
abbrev CoordinateTerm (_C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :=
  F.BasisIndex n -> A ⧸ I_U

/-- Actual resolution matrix reduced coefficientwise modulo `I_U`. -/
@[nolint unusedArguments]
noncomputable def differentialMatrix
    (_C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    Matrix (F.BasisIndex n) (F.BasisIndex (n + 1)) (A ⧸ I_U) :=
  (F.differentialMatrix n).map (Ideal.Quotient.mk I_U)

/-- Linear map represented by the reduced tensor differential matrix. -/
noncomputable def differential
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    C.CoordinateTerm (n + 1) →ₗ[A ⧸ I_U] C.CoordinateTerm n :=
  Matrix.mulVecLin (C.differentialMatrix n)

/-- Consecutive reduced tensor matrices multiply to zero. -/
theorem differentialMatrix_mul_eq_zero
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    C.differentialMatrix n * C.differentialMatrix (n + 1) = 0 := by
  unfold differentialMatrix
  rw [← Matrix.map_mul]
  rw [F.differentialMatrix_mul_eq_zero]
  simp

/-- Consecutive tensor coordinate differentials compose to zero. -/
theorem differential_comp
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.CoordinateTerm (n + 2)) :
    C.differential n (C.differential (n + 1) x) = 0 := by
  rw [show C.differential n (C.differential (n + 1) x) =
      Matrix.mulVec (C.differentialMatrix n)
        (Matrix.mulVec (C.differentialMatrix (n + 1)) x) by rfl]
  rw [Matrix.mulVec_mulVec]
  rw [C.differentialMatrix_mul_eq_zero]
  simp

/-- Chain complex whose differentials are exactly the reduced finite matrices. -/
noncomputable def coordinateComplex
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) :
    ChainComplex (ModuleCat.{v} A) ℕ :=
  ChainComplex.of
    (fun n => ModuleCat.of A (C.CoordinateTerm n))
    (fun n => ModuleCat.ofHom ((C.differential n).restrictScalars A))
    (fun n => by
      apply ModuleCat.hom_ext
      apply LinearMap.ext
      intro x
      exact C.differential_comp n x)

/-- The actual tensor term is the finite coordinate module obtained from the
selected free basis and scalar reduction. -/
noncomputable def tensorTermIso
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    (F.tensorComplex I_U).X n ≅ (C.coordinateComplex).X n := by
  letI : DecidableEq (F.BasisIndex n) := Classical.decEq _
  exact
    (((CategoryTheory.MonoidalCategory.tensoringLeft (ModuleCat.{v} A)).obj
        (Derived.FreeResolution.MathlibResolution.quotientModule A I_U)).mapIso
          (F.termIsoFree n)) ≪≫
      ((TensorProduct.piScalarRight A (A ⧸ I_U) (A ⧸ I_U)
        (F.BasisIndex n)).restrictScalars A).toModuleIso

/-- The term isomorphisms commute with the actual tensor differential and the
reduced finite matrix differential. -/
theorem tensorTermIso_comm
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    (C.tensorTermIso (n + 1)).hom ≫ (C.coordinateComplex).d (n + 1) n =
      (F.tensorComplex I_U).d (n + 1) n ≫ (C.tensorTermIso n).hom := by
  letI : DecidableEq (F.BasisIndex n) := Classical.decEq _
  letI : DecidableEq (F.BasisIndex (n + 1)) := Classical.decEq _
  apply ModuleCat.hom_ext
  apply LinearMap.ext
  intro z
  induction z using TensorProduct.induction_on with
  | zero => simp
  | tmul q x =>
      simp only [ModuleCat.comp_apply]
      simp [tensorTermIso, coordinateComplex, ChainComplex.of_d]
      change C.differential n
          (fun j => ((F.termIsoFree (n + 1)).hom x j) • q) =
        fun i => ((F.termIsoFree n).hom
          (F.projectiveResolution.complex.d (n + 1) n x) i) • q
      unfold differential differentialMatrix
      unfold Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution.differentialMatrix
      funext i
      simp only [Algebra.smul_def, Matrix.mulVecLin_apply]
      rw [show (fun j => (algebraMap A (A ⧸ I_U))
            ((F.termIsoFree (n + 1)).hom x j) * q) =
          q • ((Ideal.Quotient.mk I_U) ∘
            (F.termIsoFree (n + 1)).hom x) by
        funext j
        simp [mul_comm]]
      rw [Matrix.mulVec_smul]
      simp only [Pi.smul_apply]
      rw [← RingHom.map_mulVec]
      rw [show (F.termIsoFree (n + 1)).hom x =
          ⇑((Pi.basisFun A (F.BasisIndex (n + 1))).repr
            ((F.termIsoFree (n + 1)).hom x)) by
        funext j
        simp]
      rw [LinearMap.toMatrix_mulVec_repr]
      simp only [Pi.basisFun_repr]
      change q * (Ideal.Quotient.mk I_U)
          (F.coordinateDifferential n ((F.termIsoFree (n + 1)).hom x) i) =
        (Ideal.Quotient.mk I_U)
          ((F.termIsoFree n).hom
            (F.projectiveResolution.complex.d (n + 1) n x) i) * q
      rw [mul_comm]
      simp [Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution.coordinateDifferential]
  | add x y hx hy =>
      simpa only [map_add] using congrArg₂ (· + ·) hx hy

/-- Chain-level comparison constructed from the selected finite bases. -/
noncomputable def tensorCoordinateComplexIso
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) :
    F.tensorComplex I_U ≅ C.coordinateComplex :=
  HomologicalComplex.Hom.isoOfComponents (fun n => C.tensorTermIso n) (by
    intro i j hij
    have h : j + 1 = i := hij
    subst i
    exact C.tensorTermIso_comm j)

/-- Coordinate homology is transported to actual tensor-complex homology by
the constructed chain isomorphism; no homology comparison is an input. -/
noncomputable def coordinateHomologyIsoTensor
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    (C.coordinateComplex).homology n ≅ (F.tensorComplex I_U).homology n :=
  (HomologicalComplex.homologyMapIso C.tensorCoordinateComplexIso n).symm

/-- Coordinate cycles are the concrete kernel used by Mathlib's homology
construction for the reduced finite matrix complex. -/
abbrev Cycle (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :=
  LinearMap.ker ((C.coordinateComplex).sc n).g.hom

/-- Underlying finite coordinate vector of a cycle. -/
def cycleValue (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :
    C.Cycle n → C.CoordinateTerm n :=
  Subtype.val

/-- Construct a positive-degree coordinate cycle from a kernel calculation. -/
noncomputable def cycleOfKernel
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.CoordinateTerm (n + 1)) (hx : C.differential n x = 0) :
    C.Cycle (n + 1) := by
  refine ⟨x, ?_⟩
  change ModuleCat.Hom.hom
      ((C.coordinateComplex).d (n + 1)
        ((ComplexShape.down ℕ).next (n + 1))) x = 0
  rw [ChainComplex.next_nat_succ]
  simpa [coordinateComplex, ChainComplex.of_d] using hx

/-- Coordinate homology is the actual homology object of the reduced finite
matrix complex. -/
abbrev Homology (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat) :=
  (C.coordinateComplex).homology n

/-- Homology class represented by an actual reduced-matrix cycle. -/
noncomputable def classOfCycle
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.Cycle n) : C.Homology n :=
  (C.coordinateComplex).homologyπ n
    (((C.coordinateComplex).sc n).moduleCatCyclesIso.inv x)

/-- A represented coordinate class is zero exactly when its cycle lies in
the actual incoming image of the coordinate complex. -/
theorem classOfCycle_eq_zero_iff_range
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.Cycle n) :
    C.classOfCycle n x = 0 ↔
      x ∈ LinearMap.range ((C.coordinateComplex).sc n).moduleCatToCycles := by
  let S := (C.coordinateComplex).sc n
  change S.homologyπ (S.moduleCatCyclesIso.inv x) = 0 ↔
    x ∈ LinearMap.range S.moduleCatToCycles
  constructor
  · intro h
    have h' := congrArg (fun y => S.moduleCatHomologyIso.hom y) h
    simp only [map_zero] at h'
    rw [← ModuleCat.comp_apply] at h'
    rw [S.π_moduleCatCyclesIso_hom] at h'
    rw [ModuleCat.comp_apply] at h'
    simp only [Iso.inv_hom_id_apply] at h'
    change (LinearMap.range S.moduleCatToCycles).mkQ x = 0 at h'
    rw [Submodule.mkQ_apply, Submodule.Quotient.mk_eq_zero] at h'
    exact h'
  · intro h
    apply (ModuleCat.mono_iff_injective S.moduleCatHomologyIso.hom).mp
      (inferInstance : Mono S.moduleCatHomologyIso.hom)
    rw [map_zero, ← ModuleCat.comp_apply]
    rw [S.π_moduleCatCyclesIso_hom]
    rw [ModuleCat.comp_apply]
    simp only [Iso.inv_hom_id_apply]
    change (LinearMap.range S.moduleCatToCycles).mkQ x = 0
    rw [Submodule.mkQ_apply, Submodule.Quotient.mk_eq_zero]
    exact h

/-- A represented coordinate class vanishes exactly when the uniform solver's
incoming matrix equation has a solution. -/
theorem classOfCycle_eq_zero_iff_incoming
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.Cycle n) :
    C.classOfCycle n x = 0 ↔
      ∃ b : C.CoordinateTerm (n + 1),
        C.differential n b = C.cycleValue n x := by
  rw [C.classOfCycle_eq_zero_iff_range]
  let hprev : (ComplexShape.down ℕ).prev n = n + 1 :=
    ChainComplex.prev ℕ n
  let e := (C.coordinateComplex).XIsoOfEq hprev
  constructor
  · rintro ⟨b0, hb⟩
    let b : C.CoordinateTerm (n + 1) := e.hom.hom b0
    refine ⟨b, ?_⟩
    have hbval := congrArg Subtype.val hb
    change ModuleCat.Hom.hom
      ((C.coordinateComplex).d
        ((ComplexShape.down ℕ).prev n) n) b0 = x.val at hbval
    have hd := congrArg
      (fun f : (C.coordinateComplex).X
          ((ComplexShape.down ℕ).prev n) ⟶
          (C.coordinateComplex).X n => f.hom b0)
      ((C.coordinateComplex).XIsoOfEq_hom_comp_d hprev n)
    change ModuleCat.Hom.hom
        ((C.coordinateComplex).d (n + 1) n) (e.hom.hom b0) =
      ModuleCat.Hom.hom
        ((C.coordinateComplex).d
          ((ComplexShape.down ℕ).prev n) n) b0 at hd
    have hcoordinate : ModuleCat.Hom.hom
        ((C.coordinateComplex).d (n + 1) n) b = x.val := by
      rw [hd]
      exact hbval
    simpa [coordinateComplex, ChainComplex.of_d] using hcoordinate
  · rintro ⟨b, hb⟩
    let b' : ((C.coordinateComplex).sc n).X₁ := e.inv.hom b
    refine ⟨b', ?_⟩
    apply Subtype.ext
    have hd := congrArg
      (fun f : (C.coordinateComplex).X (n + 1) ⟶
          (C.coordinateComplex).X n => f.hom b)
      ((C.coordinateComplex).XIsoOfEq_inv_comp_d hprev n)
    change ModuleCat.Hom.hom
      ((C.coordinateComplex).d
          ((ComplexShape.down ℕ).prev n) n) (e.inv.hom b) =
      ModuleCat.Hom.hom
        ((C.coordinateComplex).d (n + 1) n) b at hd
    change ModuleCat.Hom.hom
      ((C.coordinateComplex).d
        ((ComplexShape.down ℕ).prev n) n) (e.inv.hom b) = x.val
    rw [hd]
    simpa [coordinateComplex, ChainComplex.of_d] using hb

/-- Decide whether a coordinate vector belongs to the kernel. -/
def kernelDecision
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.CoordinateTerm (n + 1)) : Bool := by
  letI := C.quotientDecidableEq
  exact decide (Matrix.mulVec (C.differentialMatrix n) x = 0)

/-- The tensor kernel decision reads the reduced differential matrix. -/
theorem kernelDecision_correct
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.CoordinateTerm (n + 1)) :
    C.kernelDecision n x = true ↔ C.differential n x = 0 := by
  letI := C.quotientDecidableEq
  simp [kernelDecision, differential]

/-- Decide whether a coordinate vector belongs to the incoming image. -/
def imageDecision
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.CoordinateTerm n) : Bool := by
  letI : DecidableEq (F.BasisIndex n) := Classical.decEq _
  letI : DecidableEq (F.BasisIndex (n + 1)) := Classical.decEq _
  exact (C.equationSolver.solve (C.differentialMatrix n) x).isSome

/-- The tensor image decision is exactly solvability of the reduced matrix equation. -/
theorem imageDecision_correct
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.CoordinateTerm n) :
    C.imageDecision n x = true ↔
      ∃ b : C.CoordinateTerm (n + 1), C.differential n b = x := by
  letI : DecidableEq (F.BasisIndex n) := Classical.decEq _
  letI : DecidableEq (F.BasisIndex (n + 1)) := Classical.decEq _
  rw [imageDecision, C.equationSolver.solve_isSome_iff]
  rfl

/-- Decide whether a represented class vanishes in the actual coordinate
homology quotient. -/
def classZeroDecision
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.Cycle n) : Bool :=
  C.imageDecision n (C.cycleValue n x)

/-- The quotient-class decision is exactly the uniform incoming-image matrix
decision. -/
theorem classZeroDecision_correct
    (C : FiniteTensorMatrixAlgorithm A I_U I_V F) (n : Nat)
    (x : C.Cycle n) :
    C.classZeroDecision n x = true ↔ C.classOfCycle n x = 0 := by
  rw [classZeroDecision, C.imageDecision_correct,
    C.classOfCycle_eq_zero_iff_incoming]

end FiniteTensorMatrixAlgorithm

/--
VIII.Theorem 4.2 local realization of the profile-selected obstruction object,
obstruction ideal, and equation-generated ideals.  `MeasurementProfile` stores
opaque handle types, so this contract interprets only the selected handles and
records their equality with the concrete finite data used below.  It does not
identify either whole handle type with a concrete ideal type.
-/
structure FiniteAATProfileRealization
    (M : MeasurementProfile.{u, v})
    (R : FiniteMeasurementRegime M)
    (obstructionSquareFree leftSquareFree rightSquareFree :
      FiniteSquareFreeComputationData R) where
  /-- Selected profile handle for the obstruction coefficient object. -/
  selectedObstructionObject : M.ObstructionObject
  /-- Selected profile handle for the square-free obstruction ideal. -/
  selectedObstructionIdeal : M.ObstructionIdeal
  /-- Selected profile handle for the left equation ideal. -/
  selectedLeftEquation : M.EquationHandle
  /-- Selected profile handle for the right equation ideal. -/
  selectedRightEquation : M.EquationHandle
  /-- Interpret obstruction-object handles on the selected finite site. -/
  realizeObstructionObject :
    M.ObstructionObject -> Cohomology.ObstructionSheaf R.geometry.site
  /-- Interpret obstruction-ideal handles in the selected polynomial ring. -/
  realizeObstructionIdeal :
    letI := R.geometry.coeffCommRing
    M.ObstructionIdeal -> Ideal (MvPolynomial M.WitnessVariables M.Coeff)
  /-- Interpret equation handles in the selected polynomial ring. -/
  realizeEquationIdeal :
    letI := R.geometry.coeffCommRing
    M.EquationHandle -> Ideal (MvPolynomial M.WitnessVariables M.Coeff)
  /-- The selected obstruction object is the actual Čech coefficient sheaf. -/
  obstructionObject_realizes :
    realizeObstructionObject selectedObstructionObject =
      R.geometry.obstructionSheaf
  /-- The selected obstruction ideal is generated by the finite forbidden
  family used for the Stanley--Reisner computation. -/
  obstructionIdeal_realizes :
    letI := R.geometry.coeffCommRing
    realizeObstructionIdeal selectedObstructionIdeal =
      obstructionSquareFree.obstructionIdeal M.Coeff
  /-- The selected left equation handle realizes the generated left ideal. -/
  leftEquationIdeal_realizes :
    letI := R.geometry.coeffCommRing
    realizeEquationIdeal selectedLeftEquation =
      leftSquareFree.obstructionIdeal M.Coeff
  /-- The selected right equation handle realizes the generated right ideal. -/
  rightEquationIdeal_realizes :
    letI := R.geometry.coeffCommRing
    realizeEquationIdeal selectedRightEquation =
      rightSquareFree.obstructionIdeal M.Coeff

/-- VIII.Theorem 4.2 selected square-free, resolution, and conflict data. -/
structure FiniteAATComputationData (M : MeasurementProfile.{u, v})
    (R : FiniteMeasurementRegime M) where
  /-- Selected square-free obstruction family. -/
  obstructionSquareFree : FiniteSquareFreeComputationData R
  /-- Left selected square-free law family. -/
  leftSquareFree : FiniteSquareFreeComputationData R
  /-- Right selected square-free law family. -/
  rightSquareFree : FiniteSquareFreeComputationData R
  /-- Local provenance for the selected profile handles and support carrier. -/
  profileRealization :
    FiniteAATProfileRealization M R obstructionSquareFree
      leftSquareFree rightSquareFree
  /-- Concrete left ideal used by the selected tensor computation. -/
  leftIdeal :
    letI := R.geometry.coeffCommRing
    Ideal (MvPolynomial M.WitnessVariables M.Coeff)
  /-- The concrete left ideal is generated by the selected left family. -/
  leftIdeal_eq_squareFree :
    letI := R.geometry.coeffCommRing
    leftIdeal = leftSquareFree.obstructionIdeal M.Coeff
  /-- Concrete right ideal resolved by the selected finite-free resolution. -/
  rightIdeal :
    letI := R.geometry.coeffCommRing
    Ideal (MvPolynomial M.WitnessVariables M.Coeff)
  /-- The concrete right ideal is generated by the selected right family. -/
  rightIdeal_eq_squareFree :
    letI := R.geometry.coeffCommRing
    rightIdeal = rightSquareFree.obstructionIdeal M.Coeff
  /-- Selected finite-free resolution of the generated right ideal. -/
  rightResolution :
    letI := R.geometry.coeffCommRing
    Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution
      (MvPolynomial M.WitnessVariables M.Coeff)
      rightIdeal
  /-- Matrix algorithm for the actual resolution after tensor reduction. -/
  tensorMatrixAlgorithm :
    letI := R.geometry.coeffCommRing
    FiniteTensorMatrixAlgorithm.{max u v, max u v}
      (MvPolynomial M.WitnessVariables M.Coeff)
      leftIdeal
      rightIdeal
      rightResolution
  /-- Selected Tor degree. -/
  torDegree : Nat
  /-- Selected cycle in the actual reduced finite-matrix complex. -/
  selectedCoordinateCycle :
    letI := R.geometry.coeffCommRing
    tensorMatrixAlgorithm.Cycle torDegree

namespace FiniteAATComputationData

variable {M : MeasurementProfile.{u, v}} {R : FiniteMeasurementRegime M}

/-- Generated square-free obstruction ideal selected by the profile. -/
def obstructionIdeal (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    Ideal (MvPolynomial M.WitnessVariables M.Coeff) := by
  letI := R.geometry.coeffCommRing
  exact D.obstructionSquareFree.obstructionIdeal M.Coeff

/-- Existing monomial-law-conflict regime generated from the two finite families. -/
noncomputable def monomialConflictRegime (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    Derived.TaylorResolution.MonomialLawConflictRegime
      (MvPolynomial M.WitnessVariables M.Coeff) M.WitnessVariables
      D.leftIdeal D.rightIdeal := by
  letI := R.geometry.coeffCommRing
  rw [D.leftIdeal_eq_squareFree, D.rightIdeal_eq_squareFree]
  exact {
    left := D.leftSquareFree.monomialIdealPresentation M.Coeff
    right := D.rightSquareFree.monomialIdealPresentation M.Coeff
  }

/-- Variables occurring in the finite monomial support of a polynomial. -/
def polynomialVariableSupport
    (E : Type u) (k : Type v) [CommSemiring k] [DecidableEq E]
    (f : MvPolynomial E k) : Finset E := by
  exact f.support.biUnion Finsupp.support

/-- A constant unit coefficient contributes no witness variables. -/
@[simp] theorem polynomialVariableSupport_one
    (E : Type u) (k : Type v) [CommSemiring k] [DecidableEq E] :
    polynomialVariableSupport E k (1 : MvPolynomial E k) = ∅ := by
  apply Finset.eq_empty_iff_forall_notMem.mpr
  intro e he
  rcases Finset.mem_biUnion.mp he with ⟨m, hm, he⟩
  have hmcoeff : MvPolynomial.coeff m (1 : MvPolynomial E k) ≠ 0 :=
    MvPolynomial.mem_support_iff.mp hm
  rw [MvPolynomial.coeff_one] at hmcoeff
  by_cases hzero : 0 = m
  · subst m
    simp at he
  · simp [hzero] at hmcoeff

/-- A polynomial variable contributes exactly its singleton witness support. -/
@[simp] theorem polynomialVariableSupport_X
    (E : Type u) (k : Type v) [CommSemiring k] [Nontrivial k]
    [DecidableEq E] (e : E) :
    polynomialVariableSupport E k (MvPolynomial.X e) = {e} := by
  unfold polynomialVariableSupport
  rw [MvPolynomial.support_X]
  simp [Finsupp.support_single_ne_zero]

/-- Support of a finite-resolution basis vector, constructed recursively from
the actual differential matrices. Degree zero contributes no variables; each
higher degree collects the coefficient support and all lower basis supports
reached by its differential column. -/
noncomputable def resolutionBasisSupport (D : FiniteAATComputationData M R) :
    (n : Nat) -> D.rightResolution.BasisIndex n ->
      Finset M.WitnessVariables
  | 0, _ => ∅
  | n + 1, j => by
      letI := R.witnessDecidableEq
      letI := R.geometry.coeffCommRing
      letI := R.coeffDecidableEq
      letI : DecidableEq (D.rightResolution.BasisIndex n) :=
        Classical.decEq _
      exact Finset.univ.biUnion fun i =>
        if D.rightResolution.differentialMatrix n i j = 0 then
          ∅
        else
          polynomialVariableSupport M.WitnessVariables M.Coeff
              (D.rightResolution.differentialMatrix n i j) ∪
            D.resolutionBasisSupport n i

/-- Exact support recursion: only nonzero differential entries connect a
higher basis vector to coefficient variables and lower basis support. -/
theorem mem_resolutionBasisSupport_succ_iff
    (D : FiniteAATComputationData M R) (n : Nat)
    (j : D.rightResolution.BasisIndex (n + 1))
    (e : M.WitnessVariables) :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    e ∈ D.resolutionBasisSupport (n + 1) j ↔
      ∃ i : D.rightResolution.BasisIndex n,
        D.rightResolution.differentialMatrix n i j ≠ 0 ∧
          (e ∈ polynomialVariableSupport M.WitnessVariables M.Coeff
              (D.rightResolution.differentialMatrix n i j) ∨
            e ∈ D.resolutionBasisSupport n i) := by
  letI := R.witnessDecidableEq
  letI := R.coeffDecidableEq
  letI : DecidableEq (D.rightResolution.BasisIndex n) :=
    Classical.decEq _
  rw [resolutionBasisSupport]
  constructor
  · intro he
    rw [Finset.mem_biUnion] at he
    rcases he with ⟨i, -, hi⟩
    by_cases hzero : D.rightResolution.differentialMatrix n i j = 0
    · simp [hzero] at hi
    · refine ⟨i, hzero, ?_⟩
      simpa [hzero] using hi
  · rintro ⟨i, hnonzero, hi⟩
    rw [Finset.mem_biUnion]
    refine ⟨i, Finset.mem_univ i, ?_⟩
    simpa [hnonzero] using hi

/-- Canonical reduced polynomial representative of one coordinate of an
arbitrary cycle.  It is derived uniformly from the square-free quotient normal
form rather than supplied by the caller. -/
def coordinateRepresentative (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree)
    (i : D.rightResolution.BasisIndex D.torDegree) :
    letI := R.geometry.coeffCommRing
    MvPolynomial M.WitnessVariables M.Coeff := by
  letI := R.geometry.coeffCommRing
  exact D.leftSquareFree.quotientNormalFormOfIdealEq M.Coeff
    D.leftIdeal D.leftIdeal_eq_squareFree
    (D.tensorMatrixAlgorithm.cycleValue D.torDegree cycle i)

/-- The canonical coordinate representative maps to the original quotient
coefficient. -/
theorem coordinateRepresentative_mod
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree)
    (i : D.rightResolution.BasisIndex D.torDegree) :
    letI := R.geometry.coeffCommRing
    Ideal.Quotient.mk D.leftIdeal (D.coordinateRepresentative cycle i) =
      D.tensorMatrixAlgorithm.cycleValue D.torDegree cycle i := by
  letI := R.geometry.coeffCommRing
  exact D.leftSquareFree.quotientNormalFormOfIdealEq_correct M.Coeff
    D.leftIdeal D.leftIdeal_eq_squareFree _

/-- The canonical coordinate representative is reduced by every selected
left-law generator. -/
theorem coordinateRepresentative_reduced
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree)
    (i : D.rightResolution.BasisIndex D.torDegree) :
    letI := R.geometry.coeffCommRing
    ∀ exponent ∈ (D.coordinateRepresentative cycle i).support,
      ∀ support ∈ D.leftSquareFree.forbiddenSupports,
        ¬ FiniteSquareFreeComputationData.supportExponent support ≤ exponent := by
  letI := R.geometry.coeffCommRing
  exact D.leftSquareFree.quotientNormalFormOfIdealEq_reduced M.Coeff
    D.leftIdeal D.leftIdeal_eq_squareFree _

/-- Support computed from an arbitrary cycle's nonzero coefficients, their
canonical reduced polynomial representatives, and the recursively computed
supports of active resolution basis vectors. -/
def cycleSupportOf (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    Finset M.WitnessVariables := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  letI := D.tensorMatrixAlgorithm.quotientDecidableEq
  letI : DecidableEq (D.rightResolution.BasisIndex D.torDegree) :=
    Classical.decEq _
  exact Finset.univ.biUnion fun i =>
    if D.tensorMatrixAlgorithm.cycleValue D.torDegree
        cycle i = 0 then
      ∅
    else
      D.resolutionBasisSupport D.torDegree i ∪
        polynomialVariableSupport M.WitnessVariables M.Coeff
          (D.coordinateRepresentative cycle i)

/-- Existing selected-cycle name, now an alias of the uniform construction. -/
def selectedCycleSupport (D : FiniteAATComputationData M R) :
    Finset M.WitnessVariables :=
  D.cycleSupportOf D.selectedCoordinateCycle

/-- A zero cycle has empty computed support. -/
theorem cycleSupportOf_eq_empty_of_cycle_eq_zero
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree)
    (hzero : cycle = 0) :
    D.cycleSupportOf cycle = ∅ := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  letI := D.tensorMatrixAlgorithm.quotientDecidableEq
  letI : DecidableEq (D.rightResolution.BasisIndex D.torDegree) :=
    Classical.decEq _
  apply Finset.eq_empty_iff_forall_notMem.mpr
  intro e he
  simp only [cycleSupportOf, Finset.mem_biUnion] at he
  rcases he with ⟨i, -, hi⟩
  have hval := congrArg Subtype.val hzero
  have hcoord := congrFun hval i
  have hcoord' : D.tensorMatrixAlgorithm.cycleValue D.torDegree
      cycle i = 0 := by
    simpa [FiniteTensorMatrixAlgorithm.cycleValue] using hcoord
  simp [hcoord'] at hi

/-- The selected zero-cycle specialization of `cycleSupportOf`. -/
theorem selectedCycleSupport_eq_empty_of_cycle_eq_zero
    (D : FiniteAATComputationData M R)
    (hzero : D.selectedCoordinateCycle = 0) :
    D.selectedCycleSupport = ∅ :=
  D.cycleSupportOf_eq_empty_of_cycle_eq_zero D.selectedCoordinateCycle hzero

/-- Coordinate homology class represented by an arbitrary reduced-matrix cycle. -/
noncomputable def coordinateHomologyClassOf
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    letI := R.geometry.coeffCommRing
    D.tensorMatrixAlgorithm.Homology D.torDegree := by
  letI := R.geometry.coeffCommRing
  exact D.tensorMatrixAlgorithm.classOfCycle D.torDegree cycle

/-- Coordinate homology class represented by the selected reduced-matrix cycle. -/
noncomputable def selectedCoordinateHomologyClass
    (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    D.tensorMatrixAlgorithm.Homology D.torDegree :=
  D.coordinateHomologyClassOf D.selectedCoordinateCycle

/-- Support relation value attached to an arbitrary represented coordinate
homology class.  A zero class receives empty support; a nonzero represented
class receives the support of that representative. -/
def classSupportOf (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    Finset M.WitnessVariables := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  exact if D.tensorMatrixAlgorithm.classZeroDecision D.torDegree
      cycle = true then
    ∅
  else
    D.cycleSupportOf cycle

/-- Existing selected-class name, now an alias of the uniform relation value. -/
def selectedClassSupport (D : FiniteAATComputationData M R) :
    Finset M.WitnessVariables :=
  D.classSupportOf D.selectedCoordinateCycle

/-- A zero represented coordinate homology class has empty computed support. -/
theorem classSupportOf_eq_empty_of_class_eq_zero
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree)
    (hzero : D.coordinateHomologyClassOf cycle = 0) :
    D.classSupportOf cycle = ∅ := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  have hdecision : D.tensorMatrixAlgorithm.classZeroDecision D.torDegree
      cycle = true :=
    (D.tensorMatrixAlgorithm.classZeroDecision_correct D.torDegree
      cycle).mpr (by
        simpa [coordinateHomologyClassOf] using hzero)
  simp [classSupportOf, hdecision]

/-- For a nonzero represented class, support is exactly the support computed
from that cycle representative. -/
theorem classSupportOf_eq_cycleSupportOf_of_class_ne_zero
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree)
    (hnonzero : D.coordinateHomologyClassOf cycle ≠ 0) :
    D.classSupportOf cycle = D.cycleSupportOf cycle := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  have hdecision : D.tensorMatrixAlgorithm.classZeroDecision D.torDegree
      cycle ≠ true := by
    intro h
    exact hnonzero
      ((D.tensorMatrixAlgorithm.classZeroDecision_correct D.torDegree
        cycle).mp h)
  simp [classSupportOf, hdecision]

/-- A zero selected coordinate homology class has empty computed support. -/
theorem selectedClassSupport_eq_empty_of_class_eq_zero
    (D : FiniteAATComputationData M R)
    (hzero : D.selectedCoordinateHomologyClass = 0) :
    D.selectedClassSupport = ∅ :=
  D.classSupportOf_eq_empty_of_class_eq_zero D.selectedCoordinateCycle hzero

/-- For a nonzero selected coordinate homology class, the class support is
exactly the support computed from its selected cycle representative. -/
theorem selectedClassSupport_eq_selectedCycleSupport_of_class_ne_zero
    (D : FiniteAATComputationData M R)
    (hnonzero : D.selectedCoordinateHomologyClass ≠ 0) :
    D.selectedClassSupport = D.selectedCycleSupport :=
  D.classSupportOf_eq_cycleSupportOf_of_class_ne_zero
    D.selectedCoordinateCycle hnonzero

/-- Transport an arbitrary represented coordinate class through the constructed
chain-level comparison. -/
noncomputable def tensorHomologyClassOf
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    letI := R.geometry.coeffCommRing
    (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree := by
  letI := R.geometry.coeffCommRing
  exact (D.tensorMatrixAlgorithm.coordinateHomologyIsoTensor D.torDegree).hom
    (D.coordinateHomologyClassOf cycle)

/-- Transport an arbitrary represented coordinate class to actual Mathlib Tor. -/
noncomputable def torClassOf
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal D.torDegree := by
  letI := R.geometry.coeffCommRing
  exact (D.rightResolution.torIsoTensorHomology D.leftIdeal D.torDegree).inv
    (D.tensorHomologyClassOf cycle)

/-- Actual selected `LawConflict` carrier for the chosen degree. -/
abbrev ActualConflictClass (D : FiniteAATComputationData M R) :=
  letI := R.geometry.coeffCommRing
  (Derived.Intersection.canonicalSelectedTorBridge
    (MvPolynomial M.WitnessVariables M.Coeff)
    D.leftIdeal D.rightIdeal).LawConflict D.torDegree

/-- Transport an arbitrary represented coordinate cycle to the actual
`LawConflict` carrier. -/
noncomputable def conflictClassOfCycle
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    letI := R.geometry.coeffCommRing
    D.ActualConflictClass := by
  letI := R.geometry.coeffCommRing
  exact (Derived.Intersection.canonicalSelectedTorBridge
    (MvPolynomial M.WitnessVariables M.Coeff)
    D.leftIdeal D.rightIdeal).lawConflictLinearEquivMathlibTor D.torDegree |>.symm
      (D.torClassOf cycle)

/-- Selected class transported by the chain-level coordinate comparison. -/
noncomputable def selectedTensorHomologyClass (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree :=
  D.tensorHomologyClassOf D.selectedCoordinateCycle

/-- Selected actual Mathlib Tor class computed from the reduced-matrix cycle. -/
noncomputable def selectedTorClass (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal D.torDegree :=
  D.torClassOf D.selectedCoordinateCycle

/-- Selected law-conflict class computed from the same reduced-matrix cycle. -/
noncomputable def selectedConflictClass (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    D.ActualConflictClass :=
  D.conflictClassOfCycle D.selectedCoordinateCycle

/-- The chain comparison reflects vanishing for every represented cycle. -/
theorem tensorHomologyClassOf_eq_zero_iff
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    D.tensorHomologyClassOf cycle = 0 ↔
      D.coordinateHomologyClassOf cycle = 0 := by
  letI := R.geometry.coeffCommRing
  let e := D.tensorMatrixAlgorithm.coordinateHomologyIsoTensor D.torDegree
  constructor
  · intro h
    apply (ModuleCat.mono_iff_injective e.hom).mp
      (inferInstance : Mono e.hom)
    change e.hom (D.coordinateHomologyClassOf cycle) = e.hom 0
    simpa [e, tensorHomologyClassOf] using h
  · intro h
    simp [tensorHomologyClassOf, h]

/-- The resolution comparison reflects vanishing for every represented cycle. -/
theorem torClassOf_eq_zero_iff
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    D.torClassOf cycle = 0 ↔ D.tensorHomologyClassOf cycle = 0 := by
  letI := R.geometry.coeffCommRing
  let e := D.rightResolution.torIsoTensorHomology D.leftIdeal D.torDegree
  constructor
  · intro h
    apply (ModuleCat.mono_iff_injective e.inv).mp
      (inferInstance : Mono e.inv)
    change e.inv (D.tensorHomologyClassOf cycle) = e.inv 0
    simpa [e, torClassOf] using h
  · intro h
    simp [torClassOf, h]

/-- The canonical Tor/`LawConflict` equivalence reflects vanishing for every
represented cycle. -/
theorem conflictClassOfCycle_eq_zero_iff
    (D : FiniteAATComputationData M R)
    (cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree) :
    D.conflictClassOfCycle cycle = 0 ↔ D.torClassOf cycle = 0 := by
  letI := R.geometry.coeffCommRing
  let e := (Derived.Intersection.canonicalSelectedTorBridge
    (MvPolynomial M.WitnessVariables M.Coeff)
    D.leftIdeal D.rightIdeal).lawConflictLinearEquivMathlibTor D.torDegree
  constructor
  · intro h
    apply e.symm.injective
    change e.symm (D.torClassOf cycle) = e.symm 0
    simpa [e, conflictClassOfCycle] using h
  · intro h
    simp [conflictClassOfCycle, h]

/-- An actual conflict class is related to every finite support computed from
one of its represented coordinate cycles.  The relation deliberately retains
representative provenance instead of asserting uniqueness of representative
support. -/
def ComputedConflictSupport (D : FiniteAATComputationData M R)
    (conflictClass : D.ActualConflictClass)
    (support : Finset M.WitnessVariables) : Prop :=
  ∃ cycle : D.tensorMatrixAlgorithm.Cycle D.torDegree,
    D.conflictClassOfCycle cycle = conflictClass ∧
      D.classSupportOf cycle = support

/-- The selected cycle supplies the selected computed conflict-support
reading. -/
theorem computedConflictSupport_selected
    (D : FiniteAATComputationData M R) :
    D.ComputedConflictSupport D.selectedConflictClass D.selectedClassSupport :=
  ⟨D.selectedCoordinateCycle, rfl, rfl⟩

/-- The computed support relation respects equality of both the actual
conflict class and the transported finite support. -/
theorem computedConflictSupport_congr
    (D : FiniteAATComputationData M R)
    {conflictClass conflictClass' : D.ActualConflictClass}
    {support support' : Finset M.WitnessVariables}
    (hclass : conflictClass = conflictClass')
    (hsupport : support = support') :
    D.ComputedConflictSupport conflictClass support ↔
      D.ComputedConflictSupport conflictClass' support' := by
  subst conflictClass'
  subst support'
  rfl

/-- Every support related to the zero actual conflict class is empty. -/
theorem computedConflictSupport_zero
    (D : FiniteAATComputationData M R)
    {support : Finset M.WitnessVariables}
    (h : D.ComputedConflictSupport 0 support) :
    support = ∅ := by
  letI := R.geometry.coeffCommRing
  rcases h with ⟨cycle, hclass, hsupport⟩
  have hcoordinate : D.coordinateHomologyClassOf cycle = 0 := by
    apply D.tensorHomologyClassOf_eq_zero_iff cycle |>.mp
    apply D.torClassOf_eq_zero_iff cycle |>.mp
    apply D.conflictClassOfCycle_eq_zero_iff cycle |>.mp
    exact hclass
  rw [← hsupport]
  exact D.classSupportOf_eq_empty_of_class_eq_zero cycle hcoordinate

/-- A nonempty support is not related to the zero actual conflict class. -/
theorem not_computedConflictSupport_zero_of_ne_empty
    (D : FiniteAATComputationData M R)
    {support : Finset M.WitnessVariables}
    (hne : support ≠ ∅) :
    ¬ D.ComputedConflictSupport 0 support := by
  intro h
  exact hne (D.computedConflictSupport_zero h)

/-- The constructed chain isomorphism reflects vanishing of the selected
coordinate homology class. -/
theorem selectedTensorHomologyClass_eq_zero_iff
    (D : FiniteAATComputationData M R) :
    D.selectedTensorHomologyClass = 0 ↔
      D.selectedCoordinateHomologyClass = 0 := by
  change D.tensorHomologyClassOf D.selectedCoordinateCycle = 0 ↔
    D.coordinateHomologyClassOf D.selectedCoordinateCycle = 0
  exact D.tensorHomologyClassOf_eq_zero_iff D.selectedCoordinateCycle

/-- The actual resolution comparison reflects vanishing when transporting
between tensor homology and Mathlib Tor. -/
theorem selectedTorClass_eq_zero_iff
    (D : FiniteAATComputationData M R) :
    D.selectedTorClass = 0 ↔ D.selectedTensorHomologyClass = 0 := by
  change D.torClassOf D.selectedCoordinateCycle = 0 ↔
    D.tensorHomologyClassOf D.selectedCoordinateCycle = 0
  exact D.torClassOf_eq_zero_iff D.selectedCoordinateCycle

/-- The canonical Tor/LawConflict equivalence reflects vanishing of the
selected Mathlib Tor class. -/
theorem selectedConflictClass_eq_zero_iff
    (D : FiniteAATComputationData M R) :
    D.selectedConflictClass = 0 ↔ D.selectedTorClass = 0 := by
  change D.conflictClassOfCycle D.selectedCoordinateCycle = 0 ↔
    D.torClassOf D.selectedCoordinateCycle = 0
  exact D.conflictClassOfCycle_eq_zero_iff D.selectedCoordinateCycle

/-- The final selected LawConflict class vanishes exactly when its coordinate
homology class vanishes. -/
theorem selectedConflictClass_eq_zero_iff_coordinate
    (D : FiniteAATComputationData M R) :
    D.selectedConflictClass = 0 ↔
      D.selectedCoordinateHomologyClass = 0 := by
  rw [D.selectedConflictClass_eq_zero_iff,
    D.selectedTorClass_eq_zero_iff,
    D.selectedTensorHomologyClass_eq_zero_iff]

/-- A zero selected LawConflict class has empty computed class support. -/
theorem selectedClassSupport_eq_empty_of_conflictClass_eq_zero
    (D : FiniteAATComputationData M R)
    (hzero : D.selectedConflictClass = 0) :
    D.selectedClassSupport = ∅ :=
  D.selectedClassSupport_eq_empty_of_class_eq_zero
    (D.selectedConflictClass_eq_zero_iff_coordinate.mp hzero)

/-- The constructed coordinate chain isomorphism preserves nonvanishing of
the selected class. -/
theorem selectedTensorHomologyClass_ne_zero
    (D : FiniteAATComputationData M R)
    (h : D.selectedCoordinateHomologyClass ≠ 0) :
    D.selectedTensorHomologyClass ≠ 0 := by
  intro hz
  exact h (D.selectedTensorHomologyClass_eq_zero_iff.mp hz)

/-- The actual resolution comparison preserves nonvanishing when transporting
the selected tensor-homology class to Mathlib Tor. -/
theorem selectedTorClass_ne_zero
    (D : FiniteAATComputationData M R)
    (h : D.selectedTensorHomologyClass ≠ 0) :
    D.selectedTorClass ≠ 0 := by
  intro hz
  exact h (D.selectedTorClass_eq_zero_iff.mp hz)

/-- The canonical Tor/LawConflict linear equivalence preserves nonvanishing
of the selected Mathlib Tor class. -/
theorem selectedConflictClass_ne_zero
    (D : FiniteAATComputationData M R)
    (h : D.selectedTorClass ≠ 0) :
    D.selectedConflictClass ≠ 0 := by
  intro hz
  exact h (D.selectedConflictClass_eq_zero_iff.mp hz)

/--
Coordinate differential of the selected finite-free resolution.  It is
obtained from the actual Mathlib projective-resolution differential through the
finite bases carried by the selected resolution.
-/
noncomputable def resolutionCoordinateDifferential
    (D : FiniteAATComputationData M R) (n : Nat) :
    letI := R.geometry.coeffCommRing
    (D.rightResolution.BasisIndex (n + 1) ->
        MvPolynomial M.WitnessVariables M.Coeff) →ₗ[
          MvPolynomial M.WitnessVariables M.Coeff]
      (D.rightResolution.BasisIndex n ->
        MvPolynomial M.WitnessVariables M.Coeff) := by
  letI := R.geometry.coeffCommRing
  exact D.rightResolution.coordinateDifferential n

/--
Finite matrix of each differential in the selected resolution.  This is the
finite chain-computation input whose homology is identified with Mathlib Tor.
-/
noncomputable def resolutionDifferentialMatrix
    (D : FiniteAATComputationData M R) (n : Nat) :
    letI := R.geometry.coeffCommRing
    Matrix (D.rightResolution.BasisIndex n)
      (D.rightResolution.BasisIndex (n + 1))
      (MvPolynomial M.WitnessVariables M.Coeff) := by
  letI := R.geometry.coeffCommRing
  exact D.rightResolution.differentialMatrix n

/-- The exposed resolution matrix is the matrix of the actual differential. -/
theorem resolutionDifferentialMatrix_correct
    (D : FiniteAATComputationData M R) (n : Nat) :
    letI := R.geometry.coeffCommRing
    letI : DecidableEq (D.rightResolution.BasisIndex n) := Classical.decEq _
    letI : DecidableEq (D.rightResolution.BasisIndex (n + 1)) := Classical.decEq _
    LinearMap.toMatrix
        (Pi.basisFun (MvPolynomial M.WitnessVariables M.Coeff)
          (D.rightResolution.BasisIndex (n + 1)))
        (Pi.basisFun (MvPolynomial M.WitnessVariables M.Coeff)
          (D.rightResolution.BasisIndex n))
        (D.resolutionCoordinateDifferential n) =
      D.resolutionDifferentialMatrix n := by
  rfl

end FiniteAATComputationData

/--
VIII.Theorem 4.2 conclusion: explicit finite computation objects and their
correctness properties.
-/
structure FiniteAATComputability {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R) : Type (max (u + 1) (v + 1)) where
  /-- Actual finite profile site-object carrier. -/
  siteObjFintype : Fintype M.SiteObj
  /-- Actual finite profile cover carrier. -/
  coverFintype : Fintype M.Cover
  /-- Every generated Čech cochain degree is a coefficient module. -/
  cochainModule :
    ∀ n,
      letI := R.geometry.coeffCommRing
      letI := R.geometry.cochainAddCommGroup n
      Module M.Coeff (R.geometry.CechCochain n)
  /-- Selected finite-dimensional or effective finitely-presented Čech reduction. -/
  coefficientComputation : CechComputationProcedure M R.geometry
  /-- Canonical cocycle representative exposed uniformly by the selected Čech
  computation route. -/
  cocycleRepresentative :
    ∀ n, R.geometry.CechHn n -> R.geometry.CechCocycle n
  /-- Every exposed cocycle represents exactly its requested canonical class. -/
  cocycleRepresentative_correct :
    ∀ n h,
      R.geometry.classOfCocycle n (cocycleRepresentative n h) = h
  /-- Certified five-state verdict computed from actual Čech classes. -/
  verdict : ∀ alpha : M.Domain, MeasurementVerdict M alpha
  /-- Procedure result together with the selected method/certificate channels. -/
  verdictData : ∀ alpha : M.Domain, VerdictData M alpha
  /-- The exposed verdict is exactly the verdict produced by `verdictData`. -/
  verdict_eq : ∀ alpha, verdict alpha = (verdictData alpha).verdict
  /-- The profile-selected obstruction object is the actual coefficient
  sheaf used by the canonical Čech computation. -/
  profileObstructionObject_realizes :
    D.profileRealization.realizeObstructionObject
        D.profileRealization.selectedObstructionObject =
      R.geometry.obstructionSheaf
  /-- The profile-selected obstruction-ideal handle realizes the generated
  square-free obstruction ideal used by this computation. -/
  profileObstructionIdeal_realizes :
    letI := R.geometry.coeffCommRing
    D.profileRealization.realizeObstructionIdeal
        D.profileRealization.selectedObstructionIdeal =
      D.obstructionIdeal
  /-- The profile-selected left-equation handle realizes the concrete left ideal
  used in the tensor computation. -/
  profileLeftEquationIdeal_realizes :
    letI := R.geometry.coeffCommRing
    D.profileRealization.realizeEquationIdeal
        D.profileRealization.selectedLeftEquation = D.leftIdeal
  /-- The profile-selected right-equation handle realizes the concrete ideal
  resolved by the selected finite-free resolution. -/
  profileRightEquationIdeal_realizes :
    letI := R.geometry.coeffCommRing
    D.profileRealization.realizeEquationIdeal
        D.profileRealization.selectedRightEquation = D.rightIdeal
  /-- Finite monomial presentation of the selected obstruction ideal. -/
  obstructionGenerators :
    letI := R.geometry.coeffCommRing
    Finset (MvPolynomial M.WitnessVariables M.Coeff)
  /-- Every obstruction generator belongs to the selected obstruction ideal. -/
  obstructionGenerator_mem :
    letI := R.geometry.coeffCommRing
    ∀ {f}, f ∈ obstructionGenerators -> f ∈ D.obstructionIdeal
  /-- The finite obstruction generator list presents the selected ideal. -/
  obstructionIdeal_eq_span_generators :
    letI := R.geometry.coeffCommRing
    D.obstructionIdeal = Ideal.span (obstructionGenerators : Set _)
  /-- Obstruction ideal-membership decision derived from the finite monomial
  family. -/
  obstructionIdealMembership :
    letI := R.geometry.coeffCommRing
    MvPolynomial M.WitnessVariables M.Coeff -> Bool
  /-- Obstruction ideal-membership is decided correctly for every polynomial. -/
  obstructionIdealMembership_correct :
    letI := R.geometry.coeffCommRing
    ∀ f, obstructionIdealMembership f = true ↔ f ∈ D.obstructionIdeal
  /-- Computed inclusion-minimal obstruction supports. -/
  obstructionMinimalForbiddenSupports : Finset (Finset M.WitnessVariables)
  /-- The exposed obstruction list is the actual finite minimal-support
  computation. -/
  obstructionMinimalForbiddenSupports_eq :
    obstructionMinimalForbiddenSupports =
      D.obstructionSquareFree.minimalForbiddenSupports
  /-- Exact membership characterization for minimal obstruction supports. -/
  obstructionMinimalForbiddenSupports_spec :
    ∀ support, support ∈ obstructionMinimalForbiddenSupports ↔
      support ∈ D.obstructionSquareFree.forbiddenSupports ∧
        ∀ candidate ∈ D.obstructionSquareFree.forbiddenSupports,
          candidate ⊆ support -> support ⊆ candidate
  /-- The profile-selected obstruction ideal equals the Stanley--Reisner
  ideal generated by the same finite family. -/
  obstructionStanleyReisner :
    letI := R.geometry.coeffCommRing
    D.obstructionIdeal =
      D.obstructionSquareFree.stanleyReisnerIdeal M.Coeff
  /-- Finite left monomial presentation. -/
  leftGenerators :
    letI := R.geometry.coeffCommRing
    Finset (MvPolynomial M.WitnessVariables M.Coeff)
  /-- Every left generator belongs to the generated left ideal. -/
  leftGenerator_mem :
    letI := R.geometry.coeffCommRing
    ∀ {f}, f ∈ leftGenerators -> f ∈ D.leftIdeal
  /-- The finite left generator list presents the selected left ideal. -/
  leftIdeal_eq_span_generators :
    letI := R.geometry.coeffCommRing
    D.leftIdeal = Ideal.span (leftGenerators : Set _)
  /-- Left ideal-membership decision derived from the finite monomial family. -/
  leftIdealMembership :
    letI := R.geometry.coeffCommRing
    MvPolynomial M.WitnessVariables M.Coeff -> Bool
  /-- Left ideal-membership procedure is correct for every polynomial. -/
  leftIdealMembership_correct :
    letI := R.geometry.coeffCommRing
    ∀ f, leftIdealMembership f = true ↔ f ∈ D.leftIdeal
  /-- Finite right monomial presentation. -/
  rightGenerators :
    letI := R.geometry.coeffCommRing
    Finset (MvPolynomial M.WitnessVariables M.Coeff)
  /-- Every right generator belongs to the generated right ideal. -/
  rightGenerator_mem :
    letI := R.geometry.coeffCommRing
    ∀ {f}, f ∈ rightGenerators -> f ∈ D.rightIdeal
  /-- The finite right generator list presents the selected right ideal. -/
  rightIdeal_eq_span_generators :
    letI := R.geometry.coeffCommRing
    D.rightIdeal = Ideal.span (rightGenerators : Set _)
  /-- Right ideal-membership decision derived from the finite monomial family. -/
  rightIdealMembership :
    letI := R.geometry.coeffCommRing
    MvPolynomial M.WitnessVariables M.Coeff -> Bool
  /-- Right ideal-membership procedure is correct for every polynomial. -/
  rightIdealMembership_correct :
    letI := R.geometry.coeffCommRing
    ∀ f, rightIdealMembership f = true ↔ f ∈ D.rightIdeal
  /-- Computed left minimal forbidden supports. -/
  leftMinimalForbiddenSupports : Finset (Finset M.WitnessVariables)
  /-- Computed right minimal forbidden supports. -/
  rightMinimalForbiddenSupports : Finset (Finset M.WitnessVariables)
  /-- The exposed left list is the actual finite minimal-support computation. -/
  leftMinimalForbiddenSupports_eq :
    leftMinimalForbiddenSupports =
      D.leftSquareFree.minimalForbiddenSupports
  /-- The exposed right list is the actual finite minimal-support computation. -/
  rightMinimalForbiddenSupports_eq :
    rightMinimalForbiddenSupports =
      D.rightSquareFree.minimalForbiddenSupports
  /-- Exact membership characterization for the left minimal supports. -/
  leftMinimalForbiddenSupports_spec :
    ∀ support, support ∈ leftMinimalForbiddenSupports ↔
      support ∈ D.leftSquareFree.forbiddenSupports ∧
        ∀ candidate ∈ D.leftSquareFree.forbiddenSupports,
          candidate ⊆ support -> support ⊆ candidate
  /-- Exact membership characterization for the right minimal supports. -/
  rightMinimalForbiddenSupports_spec :
    ∀ support, support ∈ rightMinimalForbiddenSupports ↔
      support ∈ D.rightSquareFree.forbiddenSupports ∧
        ∀ candidate ∈ D.rightSquareFree.forbiddenSupports,
          candidate ⊆ support -> support ⊆ candidate
  /-- Generated left obstruction ideal equals its Stanley--Reisner ideal. -/
  leftStanleyReisner :
    letI := R.geometry.coeffCommRing
    D.leftIdeal = D.leftSquareFree.stanleyReisnerIdeal M.Coeff
  /-- Generated right obstruction ideal equals its Stanley--Reisner ideal. -/
  rightStanleyReisner :
    letI := R.geometry.coeffCommRing
    D.rightIdeal = D.rightSquareFree.stanleyReisnerIdeal M.Coeff
  /-- Selected finite-free resolution computes the Mathlib Tor object. -/
  torComparison :
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
        (MvPolynomial M.WitnessVariables M.Coeff)
        D.leftIdeal D.rightIdeal D.torDegree ≅
      (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree
  /-- Finite length of the selected resolution. -/
  torResolutionLength : Nat
  /-- Finite basis indices of every selected resolution term. -/
  torBasisIndex : Nat -> Type (max u v)
  /-- Each selected basis-index carrier is finite. -/
  torBasisIndexFintype : ∀ n, Fintype (torBasisIndex n)
  /-- Coordinate realization of every selected resolution term. -/
  torTermIsoFree :
    letI := R.geometry.coeffCommRing
    ∀ n,
      D.rightResolution.projectiveResolution.complex.X n ≅
        ModuleCat.of (MvPolynomial M.WitnessVariables M.Coeff)
          (torBasisIndex n -> MvPolynomial M.WitnessVariables M.Coeff)
  /-- Terms above the selected finite length vanish extensionally. -/
  torSupported_le_length :
    ∀ n, torResolutionLength < n ->
      Subsingleton (D.rightResolution.projectiveResolution.complex.X n)
  /-- Finite coordinate matrix of every selected resolution differential. -/
  torDifferentialMatrix :
    letI := R.geometry.coeffCommRing
    ∀ n,
      Matrix (D.rightResolution.BasisIndex n)
        (D.rightResolution.BasisIndex (n + 1))
        (MvPolynomial M.WitnessVariables M.Coeff)
  /-- The matrices are obtained from the actual selected resolution. -/
  torDifferentialMatrix_correct :
    letI := R.geometry.coeffCommRing
    ∀ n,
      letI : DecidableEq (D.rightResolution.BasisIndex n) := Classical.decEq _
      letI : DecidableEq (D.rightResolution.BasisIndex (n + 1)) := Classical.decEq _
      LinearMap.toMatrix
          (Pi.basisFun (MvPolynomial M.WitnessVariables M.Coeff)
            (D.rightResolution.BasisIndex (n + 1)))
          (Pi.basisFun (MvPolynomial M.WitnessVariables M.Coeff)
            (D.rightResolution.BasisIndex n))
          (D.resolutionCoordinateDifferential n) =
        torDifferentialMatrix n
  /-- Differential matrices after coefficient reduction modulo the left ideal. -/
  torTensorDifferentialMatrix :
    letI := R.geometry.coeffCommRing
    ∀ n,
      Matrix (D.rightResolution.BasisIndex n)
        (D.rightResolution.BasisIndex (n + 1))
        (MvPolynomial M.WitnessVariables M.Coeff ⧸ D.leftIdeal)
  /-- Tensor matrices are coefficientwise images of the actual resolution matrices. -/
  torTensorDifferentialMatrix_eq_map :
    letI := R.geometry.coeffCommRing
    ∀ n, torTensorDifferentialMatrix n =
      (D.resolutionDifferentialMatrix n).map (Ideal.Quotient.mk D.leftIdeal)
  /-- Kernel decision on every reduced tensor differential matrix. -/
  torTensorKernelDecision :
    letI := R.geometry.coeffCommRing
    ∀ n, D.tensorMatrixAlgorithm.CoordinateTerm (n + 1) -> Bool
  /-- Kernel procedure correctness for the actual reduced matrix. -/
  torTensorKernelDecision_correct :
    letI := R.geometry.coeffCommRing
    ∀ n x, torTensorKernelDecision n x = true ↔
      D.tensorMatrixAlgorithm.differential n x = 0
  /-- Image decision on every reduced tensor differential matrix. -/
  torTensorImageDecision :
    letI := R.geometry.coeffCommRing
    ∀ n, D.tensorMatrixAlgorithm.CoordinateTerm n -> Bool
  /-- Image procedure correctness for the actual reduced matrix. -/
  torTensorImageDecision_correct :
    letI := R.geometry.coeffCommRing
    ∀ n x, torTensorImageDecision n x = true ↔
      ∃ b : D.tensorMatrixAlgorithm.CoordinateTerm (n + 1),
        D.tensorMatrixAlgorithm.differential n b = x
  /-- Vanishing decision for every represented coordinate homology class. -/
  torCoordinateClassZeroDecision :
    letI := R.geometry.coeffCommRing
    ∀ n, D.tensorMatrixAlgorithm.Cycle n -> Bool
  /-- Quotient-class vanishing is exactly the incoming-image matrix decision. -/
  torCoordinateClassZeroDecision_correct :
    letI := R.geometry.coeffCommRing
    ∀ n x, torCoordinateClassZeroDecision n x = true ↔
      D.tensorMatrixAlgorithm.classOfCycle n x = 0
  /-- Actual finite-resolution tensor chain complex. -/
  torTensorComplex :
    letI := R.geometry.coeffCommRing
    ChainComplex
      (ModuleCat.{max u v} (MvPolynomial M.WitnessVariables M.Coeff)) ℕ
  /-- The exposed chain complex is the selected resolution after tensoring. -/
  torTensorComplex_eq :
    letI := R.geometry.coeffCommRing
    torTensorComplex = D.rightResolution.tensorComplex D.leftIdeal
  /-- Reduced finite-matrix chain complex. -/
  torCoordinateComplex :
    letI := R.geometry.coeffCommRing
    ChainComplex
      (ModuleCat.{max u v} (MvPolynomial M.WitnessVariables M.Coeff)) ℕ
  /-- The exposed coordinate complex is generated by the reduced matrices. -/
  torCoordinateComplex_eq :
    letI := R.geometry.coeffCommRing
    torCoordinateComplex = D.tensorMatrixAlgorithm.coordinateComplex
  /-- Chain-level comparison constructed from the selected finite bases. -/
  torTensorCoordinateComplexIso :
    letI := R.geometry.coeffCommRing
    torTensorComplex ≅ torCoordinateComplex
  /-- Actual selected law-conflict class. -/
  selectedConflictClass :
    letI := R.geometry.coeffCommRing
    (Derived.Intersection.canonicalSelectedTorBridge
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal).LawConflict D.torDegree
  /-- Selected conflict class after transport to Mathlib Tor. -/
  selectedTorClass :
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal D.torDegree
  /-- Selected conflict class after finite-resolution chain transport. -/
  selectedTensorHomologyClass :
    letI := R.geometry.coeffCommRing
    (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree
  /-- Selected cycle before homology quotienting. -/
  selectedCoordinateCycle :
    letI := R.geometry.coeffCommRing
    D.tensorMatrixAlgorithm.Cycle D.torDegree
  /-- The exposed cycle is the selected input to the finite chain computation. -/
  selectedCoordinateCycle_eq :
    letI := R.geometry.coeffCommRing
    selectedCoordinateCycle = D.selectedCoordinateCycle
  /-- Selected coordinate homology class. -/
  selectedCoordinateHomologyClass :
    letI := R.geometry.coeffCommRing
    D.tensorMatrixAlgorithm.Homology D.torDegree
  /-- The coordinate class is the quotient class of the selected cycle. -/
  selectedCoordinateHomologyClass_eq :
    letI := R.geometry.coeffCommRing
    selectedCoordinateHomologyClass =
      D.tensorMatrixAlgorithm.classOfCycle D.torDegree selectedCoordinateCycle
  /-- Tensor homology is obtained through the constructed chain comparison. -/
  selectedTensorHomologyClass_eq :
    letI := R.geometry.coeffCommRing
    selectedTensorHomologyClass =
      (D.tensorMatrixAlgorithm.coordinateHomologyIsoTensor D.torDegree).hom
        selectedCoordinateHomologyClass
  /-- Mathlib Tor is obtained by the selected resolution comparison. -/
  selectedTorClass_eq :
    letI := R.geometry.coeffCommRing
    selectedTorClass =
      (D.rightResolution.torIsoTensorHomology D.leftIdeal D.torDegree).inv
        selectedTensorHomologyClass
  /-- The law-conflict class is the canonical Tor transport. -/
  selectedConflictClass_eq :
    letI := R.geometry.coeffCommRing
    selectedConflictClass =
      ((Derived.Intersection.canonicalSelectedTorBridge
        (MvPolynomial M.WitnessVariables M.Coeff)
        D.leftIdeal D.rightIdeal).lawConflictLinearEquivMathlibTor
          D.torDegree).symm selectedTorClass
  /-- Finite support computed for the selected homology class. -/
  conflictSupport : Finset M.WitnessVariables
  /-- The exposed support is the support constructed for the same selected
  homology class. -/
  conflictSupport_eq_selectedClassSupport :
    letI := R.witnessDecidableEq
    conflictSupport = D.selectedClassSupport
  /-- A zero selected coordinate homology class cannot carry nonempty support. -/
  conflictSupport_eq_empty_of_selectedCoordinateHomologyClass_eq_zero :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    selectedCoordinateHomologyClass = 0 -> conflictSupport = ∅
  /-- A zero selected final LawConflict class cannot carry nonempty support. -/
  conflictSupport_eq_empty_of_selectedConflictClass_eq_zero :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    selectedConflictClass = 0 -> conflictSupport = ∅
  /-- For a nonzero selected class, support is computed from its selected
  reduced cycle representative and the actual resolution matrices. -/
  conflictSupport_eq_selectedCycleSupport_of_selectedCoordinateHomologyClass_ne_zero :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    selectedCoordinateHomologyClass ≠ 0 ->
      conflictSupport = D.selectedCycleSupport

/-- Construct all theorem 4.2 outputs from the selected primitive inputs. -/
def finiteAATComputabilityPackage {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R) :
    FiniteAATComputability.{u, v} R D where
  siteObjFintype := R.geometry.siteObjFintype
  coverFintype := R.geometry.coverFintype
  cochainModule := R.geometry.cochainModule
  coefficientComputation := R.effCoeff.cechProcedure
  cocycleRepresentative := R.effCoeff.cechProcedure.quotientRepresentative
  cocycleRepresentative_correct :=
    R.effCoeff.cechProcedure.quotientRepresentative_correct
  verdict := R.verdict
  verdictData := R.verdictData
  verdict_eq := fun _ => rfl
  profileObstructionObject_realizes :=
    D.profileRealization.obstructionObject_realizes
  profileObstructionIdeal_realizes := by
    letI := R.geometry.coeffCommRing
    exact D.profileRealization.obstructionIdeal_realizes
  profileLeftEquationIdeal_realizes := by
    letI := R.geometry.coeffCommRing
    rw [D.leftIdeal_eq_squareFree]
    exact D.profileRealization.leftEquationIdeal_realizes
  profileRightEquationIdeal_realizes := by
    letI := R.geometry.coeffCommRing
    rw [D.rightIdeal_eq_squareFree]
    exact D.profileRealization.rightEquationIdeal_realizes
  obstructionGenerators := by
    letI := R.geometry.coeffCommRing
    exact D.obstructionSquareFree.generatorMonomials M.Coeff
  obstructionGenerator_mem := by
    letI := R.geometry.coeffCommRing
    intro f hf
    exact D.obstructionSquareFree.generatorMonomial_mem_obstructionIdeal M.Coeff hf
  obstructionIdeal_eq_span_generators := by
    letI := R.geometry.coeffCommRing
    exact D.obstructionSquareFree.obstructionIdeal_eq_span_generatorMonomials M.Coeff
  obstructionIdealMembership := by
    letI := R.geometry.coeffCommRing
    letI := R.coeffDecidableEq
    exact D.obstructionSquareFree.decideObstructionIdealMembership M.Coeff
  obstructionIdealMembership_correct := by
    letI := R.geometry.coeffCommRing
    letI := R.coeffDecidableEq
    intro f
    exact D.obstructionSquareFree.decideObstructionIdealMembership_correct
      M.Coeff f
  obstructionMinimalForbiddenSupports :=
    D.obstructionSquareFree.minimalForbiddenSupports
  obstructionMinimalForbiddenSupports_eq := rfl
  obstructionMinimalForbiddenSupports_spec := by
    intro support
    exact D.obstructionSquareFree.mem_minimalForbiddenSupports_iff support
  obstructionStanleyReisner := by
    letI := R.geometry.coeffCommRing
    exact D.obstructionSquareFree.obstructionIdeal_eq_stanleyReisnerIdeal M.Coeff
  leftGenerators := by
    letI := R.geometry.coeffCommRing
    exact D.leftSquareFree.generatorMonomials M.Coeff
  leftGenerator_mem := by
    letI := R.geometry.coeffCommRing
    intro f hf
    rw [D.leftIdeal_eq_squareFree]
    exact D.leftSquareFree.generatorMonomial_mem_obstructionIdeal M.Coeff hf
  leftIdeal_eq_span_generators := by
    letI := R.geometry.coeffCommRing
    rw [D.leftIdeal_eq_squareFree]
    exact D.leftSquareFree.obstructionIdeal_eq_span_generatorMonomials M.Coeff
  leftIdealMembership := by
    letI := R.geometry.coeffCommRing
    letI := R.coeffDecidableEq
    exact D.leftSquareFree.decideObstructionIdealMembership M.Coeff
  leftIdealMembership_correct := by
    letI := R.geometry.coeffCommRing
    letI := R.coeffDecidableEq
    intro f
    rw [D.leftIdeal_eq_squareFree]
    exact D.leftSquareFree.decideObstructionIdealMembership_correct M.Coeff f
  rightGenerators := by
    letI := R.geometry.coeffCommRing
    exact D.rightSquareFree.generatorMonomials M.Coeff
  rightGenerator_mem := by
    letI := R.geometry.coeffCommRing
    intro f hf
    rw [D.rightIdeal_eq_squareFree]
    exact D.rightSquareFree.generatorMonomial_mem_obstructionIdeal M.Coeff hf
  rightIdeal_eq_span_generators := by
    letI := R.geometry.coeffCommRing
    rw [D.rightIdeal_eq_squareFree]
    exact D.rightSquareFree.obstructionIdeal_eq_span_generatorMonomials M.Coeff
  rightIdealMembership := by
    letI := R.geometry.coeffCommRing
    letI := R.coeffDecidableEq
    exact D.rightSquareFree.decideObstructionIdealMembership M.Coeff
  rightIdealMembership_correct := by
    letI := R.geometry.coeffCommRing
    letI := R.coeffDecidableEq
    intro f
    rw [D.rightIdeal_eq_squareFree]
    exact D.rightSquareFree.decideObstructionIdealMembership_correct M.Coeff f
  leftMinimalForbiddenSupports := D.leftSquareFree.minimalForbiddenSupports
  rightMinimalForbiddenSupports := D.rightSquareFree.minimalForbiddenSupports
  leftMinimalForbiddenSupports_eq := rfl
  rightMinimalForbiddenSupports_eq := rfl
  leftMinimalForbiddenSupports_spec := by
    intro support
    exact D.leftSquareFree.mem_minimalForbiddenSupports_iff support
  rightMinimalForbiddenSupports_spec := by
    intro support
    exact D.rightSquareFree.mem_minimalForbiddenSupports_iff support
  leftStanleyReisner := by
    letI := R.geometry.coeffCommRing
    rw [D.leftIdeal_eq_squareFree]
    exact D.leftSquareFree.obstructionIdeal_eq_stanleyReisnerIdeal M.Coeff
  rightStanleyReisner := by
    letI := R.geometry.coeffCommRing
    rw [D.rightIdeal_eq_squareFree]
    exact D.rightSquareFree.obstructionIdeal_eq_stanleyReisnerIdeal M.Coeff
  torComparison := by
    letI := R.geometry.coeffCommRing
    exact D.rightResolution.torIsoTensorHomology D.leftIdeal D.torDegree
  torResolutionLength := D.rightResolution.length
  torBasisIndex := D.rightResolution.BasisIndex
  torBasisIndexFintype := D.rightResolution.basisIndexFintype
  torTermIsoFree := D.rightResolution.termIsoFree
  torSupported_le_length := D.rightResolution.supported_le_length
  torDifferentialMatrix := D.resolutionDifferentialMatrix
  torDifferentialMatrix_correct := D.resolutionDifferentialMatrix_correct
