import Formal.AG.Measurement.FiniteRegime
import Formal.AG.Derived.FreeResolution
import Formal.AG.LawAlgebra.StanleyReisner

noncomputable section

namespace AAT.AG
namespace Measurement

universe u v

open CategoryTheory

/-!
Part VIII theorem 4.2: finite AAT computations generated from a finite
measurement regime.

The Čech complex, route-selected kernel/image/quotient reductions, and
five-state verdicts are generated by `FiniteMeasurementGeometry`.  Square-free,
Stanley--Reisner, Tor, minimal-support, and selected-conflict computations are
generated from their selected finite data below.
-/

/-- Selected ideal-membership algorithm with correctness on every input. -/
structure IdealMembershipProcedure (A : Type v) [CommRing A] (I : Ideal A) where
  /-- Run the selected ideal-membership decision procedure. -/
  decide : A -> Bool
  correct : ∀ f, decide f = true ↔ f ∈ I

namespace IdealMembershipProcedure

/-- Build the selected Boolean procedure from an explicit decidable predicate. -/
def ofDecidable (A : Type v) [CommRing A] (I : Ideal A)
    [membershipDecidable : ∀ f : A, Decidable (f ∈ I)] :
    IdealMembershipProcedure A I where
  decide := fun f =>
    match membershipDecidable f with
    | isTrue _ => true
    | isFalse _ => false
  correct := by
    intro f
    cases membershipDecidable f with
    | isTrue h => simp [h]
    | isFalse h => simp [h]

end IdealMembershipProcedure

/-- VIII.Theorem 4.2 input: an enumerated square-free forbidden family. -/
structure FiniteSquareFreeComputationData {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M) where
  /-- Selected finite forbidden-support family. -/
  forbiddenSupports : Finset (Finset M.WitnessVariables)
  /-- Profile-owned name of the selected obstruction ideal. -/
  selectedObstructionIdeal : M.ObstructionIdeal
  /-- Realization of profile obstruction ideals in the selected polynomial ring. -/
  realizeObstructionIdeal :
    letI := R.geometry.coeffCommRing
    M.ObstructionIdeal -> Ideal (MvPolynomial M.WitnessVariables M.Coeff)
  /-- The finite support family generates the profile-selected ideal. -/
  generatedIdeal_eq_selected :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.obstructionIdeal
        M.WitnessVariables M.Coeff
        { Forb := fun support => support ∈ forbiddenSupports } =
      realizeObstructionIdeal selectedObstructionIdeal
  /-- Selected ideal-membership procedure on the generated ideal. -/
  idealMembership :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    IdealMembershipProcedure
      (MvPolynomial M.WitnessVariables M.Coeff)
      (LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.obstructionIdeal
        M.WitnessVariables M.Coeff
        { Forb := fun support => support ∈ forbiddenSupports })

namespace FiniteSquareFreeComputationData

variable {M : MeasurementProfile.{u, v}} {R : FiniteMeasurementRegime M}

/-- Square-free witness regime generated by the finite forbidden family. -/
def witnessRegime (D : FiniteSquareFreeComputationData R) :
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime M.WitnessVariables := by
  letI := R.witnessDecidableEq
  exact { Forb := fun support => support ∈ D.forbiddenSupports }

/-- Square-free obstruction ideal generated by the selected family. -/
def obstructionIdeal (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] : Ideal (MvPolynomial M.WitnessVariables k) := by
  letI := R.witnessDecidableEq
  exact LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.obstructionIdeal
    M.WitnessVariables k D.witnessRegime

/-- Stanley--Reisner complex generated by the same forbidden family. -/
def stanleyReisnerComplex (D : FiniteSquareFreeComputationData R) :
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.AbstractSimplicialComplex
      M.WitnessVariables := by
  letI := R.witnessDecidableEq
  exact LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.delta
    M.WitnessVariables D.witnessRegime

/-- Stanley--Reisner ideal of the generated complex. -/
def stanleyReisnerIdeal (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] : Ideal (MvPolynomial M.WitnessVariables k) := by
  letI := R.witnessDecidableEq
  exact LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.stanleyReisnerIdeal
    M.WitnessVariables k D.stanleyReisnerComplex

/-- Inclusion-minimal supports computed by filtering the finite family. -/
def minimalForbiddenSupports (D : FiniteSquareFreeComputationData R) :
    Finset (Finset M.WitnessVariables) := by
  classical
  exact D.forbiddenSupports.filter fun support =>
    ∀ candidate ∈ D.forbiddenSupports,
      candidate ⊆ support -> support ⊆ candidate

/-- Finite list of the selected monomial generators. -/
def generatorMonomials (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] : Finset (MvPolynomial M.WitnessVariables k) := by
  classical
  letI := R.witnessDecidableEq
  exact D.forbiddenSupports.image
    (LawAlgebra.StanleyReisner.squareFreeMonomial M.WitnessVariables k)

/-- Every computed generator passes ideal-membership checking. -/
theorem generatorMonomial_mem_obstructionIdeal
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k]
    {f : MvPolynomial M.WitnessVariables k}
    (hf : f ∈ D.generatorMonomials k) : f ∈ D.obstructionIdeal k := by
  classical
  letI := R.witnessDecidableEq
  rcases Finset.mem_image.mp hf with ⟨support, hsupport, rfl⟩
  exact Ideal.subset_span ⟨support, hsupport, rfl⟩

/-- The finite monomial list generates exactly the selected obstruction ideal. -/
theorem obstructionIdeal_eq_span_generatorMonomials
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] :
    D.obstructionIdeal k = Ideal.span (D.generatorMonomials k : Set _) := by
  classical
  letI := R.witnessDecidableEq
  change
    Ideal.span
        {f | ∃ support, support ∈ D.forbiddenSupports ∧
          f = LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k support} =
      Ideal.span
        ((D.forbiddenSupports.image
          (LawAlgebra.StanleyReisner.squareFreeMonomial
            M.WitnessVariables k) :
          Finset (MvPolynomial M.WitnessVariables k)) : Set _)
  congr 1
  ext f
  simp [eq_comm]

/-- The generated obstruction ideal is the generated Stanley--Reisner ideal. -/
theorem obstructionIdeal_eq_stanleyReisnerIdeal
    (D : FiniteSquareFreeComputationData R)
    (k : Type v) [CommRing k] :
    D.obstructionIdeal k = D.stanleyReisnerIdeal k := by
  letI := R.witnessDecidableEq
  exact
    LawAlgebra.StanleyReisner.SquareFreeWitnessRegime.obstructionIdeal_eq_stanleyReisnerIdeal
      M.WitnessVariables k D.witnessRegime

/-- The generated ideal is the realization of the profile-selected ideal. -/
theorem obstructionIdeal_eq_profileSelected
    (D : FiniteSquareFreeComputationData R) :
    letI := R.geometry.coeffCommRing
    D.obstructionIdeal M.Coeff =
      D.realizeObstructionIdeal D.selectedObstructionIdeal := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  exact D.generatedIdeal_eq_selected

/-- The selected ideal-membership algorithm is correct on every polynomial. -/
theorem idealMembership_correct
    (D : FiniteSquareFreeComputationData R) :
    letI := R.geometry.coeffCommRing
    ∀ f : MvPolynomial M.WitnessVariables M.Coeff,
      D.idealMembership.decide f = true ↔ f ∈ D.obstructionIdeal M.Coeff := by
  letI := R.geometry.coeffCommRing
  intro f
  exact D.idealMembership.correct f

end FiniteSquareFreeComputationData

/-- VIII.Theorem 4.2 selected square-free, resolution, and conflict data. -/
structure FiniteAATComputationData (M : MeasurementProfile.{u, v})
    (R : FiniteMeasurementRegime M) where
  /-- Left selected square-free law family. -/
  leftSquareFree : FiniteSquareFreeComputationData R
  /-- Right selected square-free law family. -/
  rightSquareFree : FiniteSquareFreeComputationData R
  /-- Selected finite-free resolution of the generated right ideal. -/
  rightResolution :
    letI := R.geometry.coeffCommRing
    Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution
      (MvPolynomial M.WitnessVariables M.Coeff)
      (rightSquareFree.obstructionIdeal M.Coeff)
  /-- Selected Tor degree. -/
  torDegree : Nat
  /-- Selected actual law-conflict class in the canonical Tor bridge. -/
  selectedConflictClass :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    (Derived.Intersection.canonicalSelectedTorBridge
      (MvPolynomial M.WitnessVariables M.Coeff)
      (leftSquareFree.obstructionIdeal M.Coeff)
      (rightSquareFree.obstructionIdeal M.Coeff)).LawConflict torDegree
  /-- Selected support computation on actual law-conflict classes. -/
  conflictSupportProcedure :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    (Derived.Intersection.canonicalSelectedTorBridge
      (MvPolynomial M.WitnessVariables M.Coeff)
      (leftSquareFree.obstructionIdeal M.Coeff)
      (rightSquareFree.obstructionIdeal M.Coeff)).LawConflict torDegree ->
        Finset M.WitnessVariables
  /-- Profile-relative support relation for actual conflict classes. -/
  conflictSupportRelation :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    (Derived.Intersection.canonicalSelectedTorBridge
      (MvPolynomial M.WitnessVariables M.Coeff)
      (leftSquareFree.obstructionIdeal M.Coeff)
      (rightSquareFree.obstructionIdeal M.Coeff)).LawConflict torDegree ->
        Finset M.WitnessVariables -> Prop
  /-- The selected support procedure is correct on the selected class. -/
  conflictSupport_correct :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    conflictSupportRelation selectedConflictClass
      (conflictSupportProcedure selectedConflictClass)

namespace FiniteAATComputationData

variable {M : MeasurementProfile.{u, v}} {R : FiniteMeasurementRegime M}

/-- Generated left square-free ideal in the common polynomial ring. -/
def leftIdeal (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    Ideal (MvPolynomial M.WitnessVariables M.Coeff) := by
  letI := R.geometry.coeffCommRing
  exact D.leftSquareFree.obstructionIdeal M.Coeff

/-- Generated right square-free ideal in the common polynomial ring. -/
def rightIdeal (D : FiniteAATComputationData M R) :
    letI := R.geometry.coeffCommRing
    Ideal (MvPolynomial M.WitnessVariables M.Coeff) := by
  letI := R.geometry.coeffCommRing
  exact D.rightSquareFree.obstructionIdeal M.Coeff

/-- Support of the selected conflict class. -/
def conflictSupport (D : FiniteAATComputationData M R) :
    Finset M.WitnessVariables :=
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  D.conflictSupportProcedure D.selectedConflictClass

/-- The selected procedure output satisfies the selected support relation. -/
theorem computedConflictSupport_correct (D : FiniteAATComputationData M R) :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    D.conflictSupportRelation D.selectedConflictClass D.conflictSupport := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  exact D.conflictSupport_correct

/-- Selected actual law-conflict class transported to Mathlib Tor. -/
noncomputable def selectedTorClass (D : FiniteAATComputationData M R) :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal D.torDegree := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  exact (Derived.Intersection.canonicalSelectedTorBridge
    (MvPolynomial M.WitnessVariables M.Coeff)
    D.leftIdeal D.rightIdeal).lawConflictLinearEquivMathlibTor D.torDegree
      D.selectedConflictClass

/-- Selected conflict class transported through the finite-resolution comparison. -/
noncomputable def selectedTensorHomologyClass (D : FiniteAATComputationData M R) :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree := by
  letI := R.witnessDecidableEq
  letI := R.geometry.coeffCommRing
  exact (D.rightResolution.torIsoTensorHomology D.leftIdeal D.torDegree).hom
    D.selectedTorClass

end FiniteAATComputationData

/--
VIII.Theorem 4.2 conclusion: explicit finite computation objects and their
correctness properties.
-/
structure FiniteAATComputability {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R) where
  /-- Actual finite profile site-object carrier. -/
  siteObjFintype : Fintype M.SiteObj
  /-- Actual finite profile cover carrier. -/
  coverFintype : Fintype M.Cover
  /-- Every generated Čech cochain degree is a coefficient module. -/
  cochainModule :
    ∀ n,
      letI := R.geometry.coeffCommRing
      letI := R.geometry.cochainAddCommGroup n
      Module M.Coeff (R.geometry.CechCochain n)
  /-- Selected finite-dimensional or effective finitely-presented Čech reduction. -/
  coefficientComputation : CechComputationProcedure M R.geometry
  /-- Certified five-state verdict computed from actual Čech classes. -/
  verdict : ∀ alpha : M.Domain, MeasurementVerdict M alpha
  /-- Procedure result together with the selected method/certificate channels. -/
  verdictData : ∀ alpha : M.Domain, VerdictData M alpha
  /-- The exposed verdict is exactly the verdict produced by `verdictData`. -/
  verdict_eq : ∀ alpha, verdict alpha = (verdictData alpha).verdict
  /-- Finite left monomial presentation. -/
  leftGenerators :
    letI := R.geometry.coeffCommRing
    Finset (MvPolynomial M.WitnessVariables M.Coeff)
  /-- Every left generator belongs to the generated left ideal. -/
  leftGenerator_mem :
    letI := R.geometry.coeffCommRing
    ∀ {f}, f ∈ leftGenerators -> f ∈ D.leftIdeal
  /-- The finite left generator list presents the selected left ideal. -/
  leftIdeal_eq_span_generators :
    letI := R.geometry.coeffCommRing
    D.leftIdeal = Ideal.span (leftGenerators : Set _)
  /-- Left ideal is the realization of the profile-selected obstruction ideal. -/
  leftIdeal_eq_profileSelected :
    letI := R.geometry.coeffCommRing
    D.leftIdeal =
      D.leftSquareFree.realizeObstructionIdeal
        D.leftSquareFree.selectedObstructionIdeal
  /-- Selected left ideal-membership decision procedure. -/
  leftIdealMembership :
    letI := R.geometry.coeffCommRing
    MvPolynomial M.WitnessVariables M.Coeff -> Bool
  /-- Left ideal-membership procedure is correct for every polynomial. -/
  leftIdealMembership_correct :
    letI := R.geometry.coeffCommRing
    ∀ f, leftIdealMembership f = true ↔ f ∈ D.leftIdeal
  /-- Finite right monomial presentation. -/
  rightGenerators :
    letI := R.geometry.coeffCommRing
    Finset (MvPolynomial M.WitnessVariables M.Coeff)
  /-- Every right generator belongs to the generated right ideal. -/
  rightGenerator_mem :
    letI := R.geometry.coeffCommRing
    ∀ {f}, f ∈ rightGenerators -> f ∈ D.rightIdeal
  /-- The finite right generator list presents the selected right ideal. -/
  rightIdeal_eq_span_generators :
    letI := R.geometry.coeffCommRing
    D.rightIdeal = Ideal.span (rightGenerators : Set _)
  /-- Right ideal is the realization of the profile-selected obstruction ideal. -/
  rightIdeal_eq_profileSelected :
    letI := R.geometry.coeffCommRing
    D.rightIdeal =
      D.rightSquareFree.realizeObstructionIdeal
        D.rightSquareFree.selectedObstructionIdeal
  /-- Selected right ideal-membership decision procedure. -/
  rightIdealMembership :
    letI := R.geometry.coeffCommRing
    MvPolynomial M.WitnessVariables M.Coeff -> Bool
  /-- Right ideal-membership procedure is correct for every polynomial. -/
  rightIdealMembership_correct :
    letI := R.geometry.coeffCommRing
    ∀ f, rightIdealMembership f = true ↔ f ∈ D.rightIdeal
  /-- Computed left minimal forbidden supports. -/
  leftMinimalForbiddenSupports : Finset (Finset M.WitnessVariables)
  /-- Computed right minimal forbidden supports. -/
  rightMinimalForbiddenSupports : Finset (Finset M.WitnessVariables)
  /-- Generated left obstruction ideal equals its Stanley--Reisner ideal. -/
  leftStanleyReisner :
    letI := R.geometry.coeffCommRing
    D.leftIdeal = D.leftSquareFree.stanleyReisnerIdeal M.Coeff
  /-- Generated right obstruction ideal equals its Stanley--Reisner ideal. -/
  rightStanleyReisner :
    letI := R.geometry.coeffCommRing
    D.rightIdeal = D.rightSquareFree.stanleyReisnerIdeal M.Coeff
  /-- Selected finite-free resolution computes the Mathlib Tor object. -/
  torComparison :
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
        (MvPolynomial M.WitnessVariables M.Coeff)
        D.leftIdeal D.rightIdeal D.torDegree ≅
      (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree
  /-- Finite length of the selected resolution. -/
  torResolutionLength : Nat
  /-- Finite basis indices of every selected resolution term. -/
  torBasisIndex : Nat -> Type (max u v)
  /-- Each selected basis-index carrier is finite. -/
  torBasisIndexFintype : ∀ n, Fintype (torBasisIndex n)
  /-- Coordinate realization of every selected resolution term. -/
  torTermIsoFree :
    letI := R.geometry.coeffCommRing
    ∀ n,
      D.rightResolution.projectiveResolution.complex.X n ≅
        ModuleCat.of (MvPolynomial M.WitnessVariables M.Coeff)
          (torBasisIndex n -> MvPolynomial M.WitnessVariables M.Coeff)
  /-- Terms above the selected finite length vanish extensionally. -/
  torSupported_le_length :
    ∀ n, torResolutionLength < n ->
      Subsingleton (D.rightResolution.projectiveResolution.complex.X n)
  /-- Actual finite-resolution tensor chain complex. -/
  torTensorComplex :
    letI := R.geometry.coeffCommRing
    ChainComplex
      (ModuleCat.{max u v} (MvPolynomial M.WitnessVariables M.Coeff)) ℕ
  /-- The exposed chain complex is the selected resolution after tensoring. -/
  torTensorComplex_eq :
    letI := R.geometry.coeffCommRing
    torTensorComplex = D.rightResolution.tensorComplex D.leftIdeal
  /-- Actual selected law-conflict class. -/
  selectedConflictClass :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    (Derived.Intersection.canonicalSelectedTorBridge
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal).LawConflict D.torDegree
  /-- Selected conflict class after transport to Mathlib Tor. -/
  selectedTorClass :
    letI := R.geometry.coeffCommRing
    Derived.Intersection.mathlibTor
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal D.torDegree
  /-- Selected conflict class after finite-resolution chain transport. -/
  selectedTensorHomologyClass :
    letI := R.geometry.coeffCommRing
    (D.rightResolution.tensorComplex D.leftIdeal).homology D.torDegree
  /-- Finite support of the selected conflict class. -/
  conflictSupport : Finset M.WitnessVariables
  /-- The computed support satisfies the profile-selected support relation. -/
  conflictSupport_correct :
    letI := R.witnessDecidableEq
    letI := R.geometry.coeffCommRing
    D.conflictSupportRelation selectedConflictClass conflictSupport

/-- Construct all theorem 4.2 outputs from the selected primitive inputs. -/
def finiteAATComputabilityPackage {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R) :
    FiniteAATComputability R D where
  siteObjFintype := R.geometry.siteObjFintype
  coverFintype := R.geometry.coverFintype
  cochainModule := R.geometry.cochainModule
  coefficientComputation := R.effCoeff.cechProcedure
  verdict := R.verdict
  verdictData := R.verdictData
  verdict_eq := fun _ => rfl
  leftGenerators := by
    letI := R.geometry.coeffCommRing
    exact D.leftSquareFree.generatorMonomials M.Coeff
  leftGenerator_mem := by
    letI := R.geometry.coeffCommRing
    intro f hf
    exact D.leftSquareFree.generatorMonomial_mem_obstructionIdeal M.Coeff hf
  leftIdeal_eq_span_generators := by
    letI := R.geometry.coeffCommRing
    exact D.leftSquareFree.obstructionIdeal_eq_span_generatorMonomials M.Coeff
  leftIdeal_eq_profileSelected := by
    letI := R.geometry.coeffCommRing
    exact D.leftSquareFree.obstructionIdeal_eq_profileSelected
  leftIdealMembership := by
    letI := R.geometry.coeffCommRing
    exact D.leftSquareFree.idealMembership.decide
  leftIdealMembership_correct := by
    letI := R.geometry.coeffCommRing
    intro f
    exact D.leftSquareFree.idealMembership_correct f
  rightGenerators := by
    letI := R.geometry.coeffCommRing
    exact D.rightSquareFree.generatorMonomials M.Coeff
  rightGenerator_mem := by
    letI := R.geometry.coeffCommRing
    intro f hf
    exact D.rightSquareFree.generatorMonomial_mem_obstructionIdeal M.Coeff hf
  rightIdeal_eq_span_generators := by
    letI := R.geometry.coeffCommRing
    exact D.rightSquareFree.obstructionIdeal_eq_span_generatorMonomials M.Coeff
  rightIdeal_eq_profileSelected := by
    letI := R.geometry.coeffCommRing
    exact D.rightSquareFree.obstructionIdeal_eq_profileSelected
  rightIdealMembership := by
    letI := R.geometry.coeffCommRing
    exact D.rightSquareFree.idealMembership.decide
  rightIdealMembership_correct := by
    letI := R.geometry.coeffCommRing
    intro f
    exact D.rightSquareFree.idealMembership_correct f
  leftMinimalForbiddenSupports := D.leftSquareFree.minimalForbiddenSupports
  rightMinimalForbiddenSupports := D.rightSquareFree.minimalForbiddenSupports
  leftStanleyReisner := by
    letI := R.geometry.coeffCommRing
    exact D.leftSquareFree.obstructionIdeal_eq_stanleyReisnerIdeal M.Coeff
  rightStanleyReisner := by
    letI := R.geometry.coeffCommRing
    exact D.rightSquareFree.obstructionIdeal_eq_stanleyReisnerIdeal M.Coeff
  torComparison := by
    letI := R.geometry.coeffCommRing
    exact D.rightResolution.torIsoTensorHomology D.leftIdeal D.torDegree
  torResolutionLength := D.rightResolution.length
  torBasisIndex := D.rightResolution.BasisIndex
  torBasisIndexFintype := D.rightResolution.basisIndexFintype
  torTermIsoFree := D.rightResolution.termIsoFree
  torSupported_le_length := D.rightResolution.supported_le_length
  torTensorComplex := D.rightResolution.tensorComplex D.leftIdeal
  torTensorComplex_eq := rfl
  selectedConflictClass := D.selectedConflictClass
  selectedTorClass := D.selectedTorClass
  selectedTensorHomologyClass := D.selectedTensorHomologyClass
  conflictSupport := D.conflictSupport
  conflictSupport_correct := D.computedConflictSupport_correct

/--
VIII.Theorem 4.2 fixed statement: a finite measurement regime plus selected
square-free and finite-resolution data determines all finite computation
objects above.
-/
theorem finiteAATComputability {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R) :
    Nonempty (FiniteAATComputability R D) :=
  ⟨finiteAATComputabilityPackage R D⟩

/-! ### A canonical finite-free resolution for the zero ideal -/

/-- The degree-zero self resolution of `A / 0`. -/
noncomputable def bottomProjectiveResolution (A : Type v) [CommRing A] :
    ProjectiveResolution
      (Derived.FreeResolution.MathlibResolution.quotientModule A (⊥ : Ideal A)) := by
  let e : Derived.FreeResolution.MathlibResolution.quotientModule A (⊥ : Ideal A) ≅
      ModuleCat.of A A :=
    (AlgEquiv.quotientBot A A).toLinearEquiv.toModuleIso
  letI : Projective
      (Derived.FreeResolution.MathlibResolution.quotientModule A (⊥ : Ideal A)) :=
    Projective.of_iso e.symm inferInstance
  exact ProjectiveResolution.self _

/-- A one-term finite-free Mathlib resolution of `A / 0`. -/
noncomputable def bottomFiniteFreeResolution (A : Type v) [CommRing A] :
    Derived.FreeResolution.MathlibResolution.FiniteFreeMathlibResolution
      A (⊥ : Ideal A) where
  projectiveResolution := bottomProjectiveResolution A
  length := 0
  BasisIndex n := if n = 0 then ULift.{v} Unit else ULift.{v} Empty
  basisIndexFintype n := by
    by_cases h : n = 0
    · subst n
      simp
      infer_instance
    · simp [h]
      infer_instance
  termIsoFree n := by
    cases n with
    | zero =>
        simpa using
          ((AlgEquiv.quotientBot A A).toLinearEquiv.trans
            (LinearEquiv.funUnique (ULift.{v} Unit) A A).symm).toModuleIso
    | succ n =>
        let hsource := HomologicalComplex.isZero_single_obj_X
          (ComplexShape.down Nat) 0
          (Derived.FreeResolution.MathlibResolution.quotientModule
            A (⊥ : Ideal A)) (n + 1) (by omega)
        let htarget : CategoryTheory.Limits.IsZero
            (ModuleCat.of A
              ((if n + 1 = 0 then ULift.{v} Unit else ULift.{v} Empty) -> A)) := by
          simp
          letI : Subsingleton (ULift.{v} Empty -> A) :=
            ⟨fun f g => funext fun x => nomatch x.down⟩
          exact inferInstance
        exact hsource.isoZero ≪≫ htarget.isoZero.symm
  supported_le_length n hn := by
    have hn0 : n ≠ 0 := by omega
    let hzero := HomologicalComplex.isZero_single_obj_X
      (ComplexShape.down Nat) 0
      (Derived.FreeResolution.MathlibResolution.quotientModule
        A (⊥ : Ideal A)) n hn0
    exact ModuleCat.subsingleton_of_isZero hzero

end Measurement
end AAT.AG
