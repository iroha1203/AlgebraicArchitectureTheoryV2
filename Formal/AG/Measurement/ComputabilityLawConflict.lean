import Formal.AG.Measurement.Computability
import Formal.AG.Measurement.LawConflict

noncomputable section

namespace AAT.AG
namespace Measurement

universe u v

open AlgebraicGeometry

/-!
Part VIII theorem 4.2 connection from the computed finite support relation to
the canonical `LawConflictMeasurement` API.

The common ambient in this module is generated from the finite regime itself.
Its affine scheme is the Mathlib spectrum of the witness polynomial ring, and
its two ideals are the actual selected equation-coordinate ideals.  The
module-valued obstruction sheaf is the coefficient object of the Čech
complex, while the affine scheme carries Mathlib's ring-valued structure
sheaf.
-/

/-- Domain selections for the two equation-generated lawful loci.

The affine scheme, coordinate ring, law ideals, witness families, comparison
profile, and affine point carrier are derived from `R` and `D` by
`commonAmbient`; the structure records only the two domain selections.
-/
structure FiniteAATConflictRealization
    {M : MeasurementProfile.{u, v}}
    {R : FiniteMeasurementRegime M}
    (_D : FiniteAATComputationData M R) where
  /-- Measurement-domain element read by the selected left equation. -/
  leftDomain : M.Domain
  /-- Measurement-domain element read by the selected right equation. -/
  rightDomain : M.Domain

namespace FiniteAATConflictRealization

variable {M : MeasurementProfile.{u, v}}
variable {R : FiniteMeasurementRegime M}
variable {D : FiniteAATComputationData M R}

/-- Canonical affine common ambient generated by the finite regime.

Implementation notes: Mathlib `Scheme.Spec` supplies the locally ringed
space, while the shared witness polynomial ring supplies both selected ideals.
The equation context and module-valued obstruction sheaf remain in the finite
Čech source, and the affine spectrum carries the ring-valued structure sheaf.
-/
def commonAmbient (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    CommonAmbientPair M
      (MvPolynomial M.WitnessVariables M.Coeff)
      D.leftIdeal D.rightIdeal :=
  letI := R.geometry.coeffCommRing
  CommonAmbientPair.ofAffineSpec
    D.leftIdeal D.rightIdeal C.leftDomain C.rightDomain (1 : M.Coeff)
    (Finset (Finset M.WitnessVariables) ×
      Finset (Finset M.WitnessVariables))
    (M.equationGeometry.site.equationSystem.RequiredIndex ×
      M.equationGeometry.site.equationSystem.RequiredIndex)
    (D.leftSquareFree.forbiddenSupports,
      D.rightSquareFree.forbiddenSupports)
    (D.profileRealization.selectedLeftEquation,
      D.profileRealization.selectedRightEquation)

/-- The selected structure datum is a pair of actual ideal sheaves on the
shared affine spectrum. -/
theorem commonAmbient_structureSheaf
    (C : FiniteAATConflictRealization D) :
    C.commonAmbient.StructureSheaf =
      AffineIdealSheafPair.{max u v} :=
  rfl

/-- The selected structure datum is induced canonically from the two actual
equation-coordinate ideals. -/
theorem commonAmbient_selectedStructureSheaf
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.selectedStructureSheaf =
      AffineIdealSheafPair.ofSpec D.leftIdeal D.rightIdeal :=
  rfl

/-- The scheme carrying both selected ideal sheaves is Mathlib `Spec` of the
shared witness polynomial ring. -/
theorem commonAmbient_selectedScheme
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.selectedStructureSheaf.scheme =
      AlgebraicGeometry.Scheme.Spec.obj
        (Opposite.op
          (CommRingCat.of
            (MvPolynomial M.WitnessVariables M.Coeff))) :=
  rfl

/-- The selected scheme carries Mathlib's ring-valued affine structure
sheaf. -/
theorem commonAmbient_schemeSheaf
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.selectedStructureSheaf.scheme.sheaf =
      AlgebraicGeometry.Spec.structureSheaf
        (CommRingCat.of
          (MvPolynomial M.WitnessVariables M.Coeff)) :=
  rfl

/-- The left ideal sheaf is induced from the actual left equation ideal. -/
theorem commonAmbient_leftIdealSheaf
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.selectedStructureSheaf.leftIdealSheaf =
      AlgebraicGeometry.Scheme.IdealSheafData.ofIdealTop
        (Ideal.map
          ((AlgebraicGeometry.Scheme.ΓSpecIso
            (CommRingCat.of
              (MvPolynomial M.WitnessVariables
                M.Coeff))).commRingCatIsoToRingEquiv).symm.toRingHom
          D.leftIdeal) :=
  rfl

/-- The right ideal sheaf is induced from the actual right equation ideal. -/
theorem commonAmbient_rightIdealSheaf
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.selectedStructureSheaf.rightIdealSheaf =
      AlgebraicGeometry.Scheme.IdealSheafData.ofIdealTop
        (Ideal.map
          ((AlgebraicGeometry.Scheme.ΓSpecIso
            (CommRingCat.of
              (MvPolynomial M.WitnessVariables
                M.Coeff))).commRingCatIsoToRingEquiv).symm.toRingHom
          D.rightIdeal) :=
  rfl

/-- The law-ideal carrier is the ideal lattice of the witness polynomial
chart generated over the structure sheaf's coefficient ring. -/
theorem commonAmbient_lawIdeal
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.LawIdeal =
      Ideal (MvPolynomial M.WitnessVariables M.Coeff) :=
  rfl

/-- The common-ringed-site obligation is the defining locally-ringed-space
identity of Mathlib `Scheme.Spec`. -/
theorem commonAmbient_commonRingedSite
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.commonRingedSite =
      (C.commonAmbient.selectedStructureSheaf.scheme.toLocallyRingedSpace =
        AlgebraicGeometry.Spec.locallyRingedSpaceObj
          (CommRingCat.of
            (MvPolynomial M.WitnessVariables M.Coeff))) :=
  rfl

/-- The selected ambient left ideal is fixed by construction to the actual
left equation ideal. -/
theorem commonAmbient_leftLawIdeal
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.leftLawIdeal = D.leftIdeal :=
  rfl

/-- The selected ambient right ideal is fixed by construction to the actual
right equation ideal. -/
theorem commonAmbient_rightLawIdeal
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.commonAmbient.rightLawIdeal = D.rightIdeal :=
  rfl

/-- The top components of the two actual ideal sheaves recover exactly the
two coordinate-ring ideals used by the selected Tor bridge. -/
theorem commonAmbient_globalSectionsIdeals
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    let e :=
      (AlgebraicGeometry.Scheme.ΓSpecIso
        (CommRingCat.of
          (MvPolynomial M.WitnessVariables
            M.Coeff))).commRingCatIsoToRingEquiv
    let pair := C.commonAmbient.selectedStructureSheaf
    let _ : IsAffine pair.scheme :=
      pair.schemeIsAffine
    Ideal.map e.toRingHom
        (pair.leftIdealSheaf.ideal
          ⟨⊤, isAffineOpen_top pair.scheme⟩) =
          D.leftIdeal ∧
      Ideal.map e.toRingHom
        (pair.rightIdealSheaf.ideal
          ⟨⊤, isAffineOpen_top pair.scheme⟩) =
          D.rightIdeal :=
  C.commonAmbient.lawIdealsInCommonAmbient_cert

/-- Both actual Tor ideals are generated by their selected equation
coordinates in the shared witness polynomial ring. -/
theorem commonAmbient_ideals_eq_span_range
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    (show Ideal (MvPolynomial M.WitnessVariables M.Coeff) from
      C.commonAmbient.leftLawIdeal) =
          Ideal.span
            (Set.range
              (D.profileRealization.equationCoordinate
                D.profileRealization.selectedLeftEquation.1)) ∧
      (show Ideal (MvPolynomial M.WitnessVariables M.Coeff) from
        C.commonAmbient.rightLawIdeal) =
          Ideal.span
            (Set.range
              (D.profileRealization.equationCoordinate
                D.profileRealization.selectedRightEquation.1)) :=
  ⟨D.profileRealization.leftIdeal_eq_span_range,
    D.profileRealization.rightIdeal_eq_span_range⟩

/-- Existing `LawConflictMeasurement` constructed from the same selected Tor
bridge and actual class. The computed support remains a theorem of the finite
regime rather than a freely supplied field of the generic measurement. -/
def lawConflictMeasurement (C : FiniteAATConflictRealization D) :
    LawConflictMeasurement C.commonAmbient := by
  letI := R.geometry.coeffCommRing
  exact
    LawConflictMeasurement.ofAffineSpecCanonicalTor
      D.leftIdeal D.rightIdeal C.leftDomain C.rightDomain
      (1 : M.Coeff)
      (Finset (Finset M.WitnessVariables) ×
        Finset (Finset M.WitnessVariables))
      (M.equationGeometry.site.equationSystem.RequiredIndex ×
        M.equationGeometry.site.equationSystem.RequiredIndex)
      (D.leftSquareFree.forbiddenSupports,
        D.rightSquareFree.forbiddenSupports)
      (D.profileRealization.selectedLeftEquation,
        D.profileRealization.selectedRightEquation)
      D.torDegree D.selectedConflictClass

/-- The support used by transfer is the Mathlib affine support of the cyclic
submodule generated by the same selected class produced by the finite
computation. -/
theorem selectedConflictSupport_nonempty
    (C : FiniteAATConflictRealization D)
    (hclass : D.selectedConflictClass ≠ 0) :
    letI := R.geometry.coeffCommRing
    C.lawConflictMeasurement.selectedConflictSupport.Nonempty := by
  letI := R.geometry.coeffCommRing
  apply
    (C.lawConflictMeasurement.conflictClassSupport_nonempty_iff
      C.lawConflictMeasurement.selectedConflictClass).mpr
  simpa [lawConflictMeasurement] using hclass

/-- The final measurement's common-ambient obligation contains the actual
equation-generated ideals used by its selected Tor bridge. -/
theorem lawConflictMeasurement_commonAmbientRequired_shape
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.lawConflictMeasurement.commonAmbientRequired =
      (C.commonAmbient.commonRingedSite ∧
        C.commonAmbient.lawIdealsInCommonAmbient) :=
  rfl

/-- The final measurement's Tor reading is indexed by the same two actual
equation ideals used to construct its affine ideal sheaves. -/
theorem lawConflictMeasurement_torReading_shape
    (C : FiniteAATConflictRealization D) :
    letI := R.geometry.coeffCommRing
    C.lawConflictMeasurement.lawConflictTorReading =
      Nonempty
        ((Derived.Intersection.canonicalSelectedTorBridge
            (MvPolynomial M.WitnessVariables M.Coeff)
            D.leftIdeal D.rightIdeal).LawConflict D.torDegree ≃ₗ[
              MvPolynomial M.WitnessVariables M.Coeff]
          Derived.Intersection.mathlibTor
            (MvPolynomial M.WitnessVariables M.Coeff)
            D.leftIdeal D.rightIdeal D.torDegree) :=
  rfl

end FiniteAATConflictRealization

/-- Final theorem 4.2 package after a selected common ambient has been
realized.  The base computation and canonical `LawConflictMeasurement`
are both conclusions. The finite support summary remains a computed theorem,
while transfer support is the actual affine support of the selected Tor
class.
-/
structure FiniteAATConflictComputability
    {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R)
    (C : FiniteAATConflictRealization D) :
    Type (max (u + 1) (v + 1)) where
  /-- The complete finite Čech, square-free, and Tor computation package. -/
  computation : FiniteAATComputability R D
  /-- Existing measurement semantics instantiated by the computed support
  relation and the actual transported conflict class. -/
  lawConflictMeasurement :
    LawConflictMeasurement C.commonAmbient
  /-- The exposed measurement is exactly the one constructed from the
  canonical selected Tor bridge and `ComputedConflictSupport`. -/
  lawConflictMeasurement_eq_computed :
    lawConflictMeasurement = C.lawConflictMeasurement

/-- Construct the final common-ambient theorem 4.2 package. -/
def finiteAATConflictComputabilityPackage
    {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R)
    (C : FiniteAATConflictRealization D) :
    FiniteAATConflictComputability R D C where
  computation := finiteAATComputabilityPackage R D
  lawConflictMeasurement := C.lawConflictMeasurement
  lawConflictMeasurement_eq_computed := rfl

/-- A finite regime, selected computation data, and local common-ambient
realization determine the final conflict computation. -/
theorem finiteAATConflictComputability
    {M : MeasurementProfile.{u, v}}
    (R : FiniteMeasurementRegime M)
    (D : FiniteAATComputationData M R)
    (C : FiniteAATConflictRealization D) :
    Nonempty (FiniteAATConflictComputability R D C) :=
  ⟨finiteAATConflictComputabilityPackage R D C⟩

end Measurement
end AAT.AG
