import Formal.AG.LawAlgebra.AmbientAlgebra
import Mathlib.Algebra.MvPolynomial.CommRing
import Mathlib.Algebra.MvPolynomial.Eval
import Mathlib.RingTheory.Ideal.Quotient.Operations

namespace AAT.AG
namespace LawAlgebra

universe u v w x

noncomputable section

local instance freeTypedCommAlgCommRing {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} (F : CoordinateFamily W)
    (k : Type v) [CommRing k] : CommRing (FreeTypedCommAlg F k) :=
  inferInstance

/--
III.定義4.2: structural relations selected on a context.

`Relation` indexes the presented structural equations, while `polynomial`
gives the actual element of the free typed commutative algebra. This keeps
`Rel_struct(W)` distinct from the generated ideal `J_struct(W)`.
-/
structure StructuralRelationFamily {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {W : Site.ArchitectureContext A}
    (F : CoordinateFamily W) (k : Type v) [CommRing k] where
  Relation : Type u
  polynomial : Relation -> FreeTypedCommAlg F k

namespace StructuralRelationFamily

/-- III.定義4.2: the structural relation polynomial set `Rel_struct(W)`. -/
def RelStruct {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {F : CoordinateFamily W}
    {k : Type v} [CommRing k] (R : StructuralRelationFamily F k) :
    Set (FreeTypedCommAlg F k) :=
  Set.range R.polynomial

/-- III.定義4.2: the structural ideal `J_struct(W)` generated by `Rel_struct(W)`. -/
def JStruct {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {F : CoordinateFamily W}
    {k : Type v} [CommRing k] (R : StructuralRelationFamily F k) :
    Ideal (FreeTypedCommAlg F k) :=
  Ideal.span R.RelStruct

/-- III.定義4.2: each selected structural relation lies in `J_struct(W)`. -/
theorem polynomial_mem_JStruct {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {F : CoordinateFamily W}
    {k : Type v} [CommRing k] (R : StructuralRelationFamily F k)
    (r : R.Relation) :
    R.polynomial r ∈ R.JStruct :=
  Ideal.subset_span (Set.mem_range_self r)

/--
III.定義4.3: raw ambient law algebra.

Only structural relations are quotiented at this ambient stage. Law witness
equations are kept outside this quotient and enter later through witness ideals.
-/
abbrev RawAmbientLawAlgebra {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {F : CoordinateFamily W}
    {k : Type v} [CommRing k] (R : StructuralRelationFamily F k) :
    Type (max u v) :=
  FreeTypedCommAlg F k ⧸ R.JStruct

/-- III.定義4.3: the quotient map from the free algebra to `O_raw^U(W)`. -/
def quotientMap {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {F : CoordinateFamily W}
    {k : Type v} [CommRing k] (R : StructuralRelationFamily F k) :
    FreeTypedCommAlg F k →+* R.RawAmbientLawAlgebra :=
  Ideal.Quotient.mk R.JStruct

/-- III.定義4.3: structural relation polynomials vanish in the raw quotient. -/
theorem quotientMap_polynomial_eq_zero {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {W : Site.ArchitectureContext A}
    {F : CoordinateFamily W} {k : Type v} [CommRing k]
    (R : StructuralRelationFamily F k) (r : R.Relation) :
    R.quotientMap (R.polynomial r) = 0 := by
  change Ideal.Quotient.mk R.JStruct (R.polynomial r) = 0
  rw [Ideal.Quotient.eq_zero_iff_mem]
  exact R.polynomial_mem_JStruct r

/-! ### SD7 generic configuration representability -/

/--
SD7 / Definition 8.2: configurations valued in a target `k`-algebra.

This generic core depends only on the selected coordinate family and structural relation family;
site and sheafification data enter only through later adapters.
-/
def Configuration {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    (R : Type w) [CommRing R] [Algebra k R] :=
  { a : F.CoordX → R //
    ∀ r : relations.Relation,
      MvPolynomial.aeval a (relations.polynomial r) = 0 }

namespace Configuration

/-- SD7 functorial action of a target algebra morphism on configurations. -/
def map {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} {relations : StructuralRelationFamily F k}
    {R : Type w} {T : Type x} [CommRing R] [Algebra k R]
    [CommRing T] [Algebra k T]
    (a : relations.Configuration R) (g : R →ₐ[k] T) :
    relations.Configuration T where
  val c := g (a.1 c)
  property r := by
    rw [← MvPolynomial.comp_aeval_apply (f := a.1) g (relations.polynomial r),
      a.2 r, map_zero]

/-- SD7 target functoriality: mapping a configuration by the identity is identity. -/
@[simp] theorem map_id {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} {relations : StructuralRelationFamily F k}
    {R : Type w} [CommRing R] [Algebra k R]
    (a : relations.Configuration R) :
    a.map (AlgHom.id k R) = a := by
  apply Subtype.ext
  rfl

/-- SD7 target functoriality: configuration maps compose covariantly. -/
@[simp] theorem map_comp {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} {relations : StructuralRelationFamily F k}
    {R : Type w} {T : Type x} {Q : Type*}
    [CommRing R] [Algebra k R] [CommRing T] [Algebra k T]
    [CommRing Q] [Algebra k Q]
    (a : relations.Configuration R)
    (g : R →ₐ[k] T) (h : T →ₐ[k] Q) :
    (a.map g).map h = a.map (h.comp g) := by
  apply Subtype.ext
  rfl

end Configuration

/-- Evaluation hom associated to a structural configuration. -/
def configurationAlgHom {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    {R : Type w} [CommRing R] [Algebra k R]
    (a : relations.Configuration R) : FreeTypedCommAlg F k →ₐ[k] R :=
  MvPolynomial.aeval a.1

/-- A configuration kills every element of the generated structural ideal. -/
theorem configurationAlgHom_eq_zero_of_mem_JStruct
    {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    {R : Type w} [CommRing R] [Algebra k R]
    (a : relations.Configuration R) {p : FreeTypedCommAlg F k}
    (hp : p ∈ relations.JStruct) :
    relations.configurationAlgHom a p = 0 := by
  refine Submodule.span_induction ?hset ?hzero ?hadd ?hsmul hp
  · rintro p ⟨r, rfl⟩
    exact a.2 r
  · simp
  · intro p q _ _ hp hq
    simp [map_add, hp, hq]
  · intro c p _ hp
    simp [hp]

/-- The quotient hom represented by a structural configuration. -/
def quotientAlgHomOfConfiguration
    {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    {R : Type w} [CommRing R] [Algebra k R]
    (a : relations.Configuration R) :
    relations.RawAmbientLawAlgebra →ₐ[k] R :=
  Ideal.Quotient.liftₐ relations.JStruct (relations.configurationAlgHom a)
    (fun _p hp => relations.configurationAlgHom_eq_zero_of_mem_JStruct a hp)

/-- The represented quotient hom agrees with evaluation before quotienting. -/
theorem quotientAlgHomOfConfiguration_mk
    {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    {R : Type w} [CommRing R] [Algebra k R]
    (a : relations.Configuration R) (p : FreeTypedCommAlg F k) :
    relations.quotientAlgHomOfConfiguration a (relations.quotientMap p) =
      relations.configurationAlgHom a p :=
  rfl

/-- Recover a structural configuration from a hom out of the raw quotient. -/
def configurationOfQuotientAlgHom
    {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    {R : Type w} [CommRing R] [Algebra k R]
    (f : relations.RawAmbientLawAlgebra →ₐ[k] R) :
    relations.Configuration R where
  val c := f (relations.quotientMap (MvPolynomial.X c))
  property r := by
    have h :
        MvPolynomial.aeval
            (fun c => f (relations.quotientMap (MvPolynomial.X c))) =
          f.comp (Ideal.Quotient.mkₐ k relations.JStruct) := by
      apply MvPolynomial.algHom_ext
      intro c
      simp [StructuralRelationFamily.quotientMap]
    rw [AlgHom.congr_fun h (relations.polynomial r)]
    change f (relations.quotientMap (relations.polynomial r)) = 0
    rw [relations.quotientMap_polynomial_eq_zero]
    simp

/--
SD7 / Theorem 8.3: the unique generic universal-property proof for raw structural quotients.
All site-specific and legacy presentation APIs below this layer are direct applications of this
equivalence rather than independent quotient proofs.
-/
def configurationRepresentability
    {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    (R : Type w) [CommRing R] [Algebra k R] :
    relations.Configuration R ≃ (relations.RawAmbientLawAlgebra →ₐ[k] R) where
  toFun := relations.quotientAlgHomOfConfiguration
  invFun := relations.configurationOfQuotientAlgHom
  left_inv a := by
    apply Subtype.ext
    funext c
    change relations.quotientAlgHomOfConfiguration a
        (relations.quotientMap (MvPolynomial.X c)) = a.1 c
    rw [relations.quotientAlgHomOfConfiguration_mk a (MvPolynomial.X c)]
    simp [configurationAlgHom]
  right_inv f := by
    apply AlgHom.ext
    intro q
    refine Quotient.inductionOn' q ?_
    intro p
    have h :
        relations.configurationAlgHom
            (relations.configurationOfQuotientAlgHom f) =
          f.comp (Ideal.Quotient.mkₐ k relations.JStruct) := by
      apply MvPolynomial.algHom_ext
      intro c
      simp [configurationOfQuotientAlgHom, configurationAlgHom,
        StructuralRelationFamily.quotientMap]
    change relations.quotientAlgHomOfConfiguration
        (relations.configurationOfQuotientAlgHom f)
        (relations.quotientMap p) = f (relations.quotientMap p)
    rw [relations.quotientAlgHomOfConfiguration_mk
      (relations.configurationOfQuotientAlgHom f) p]
    exact AlgHom.congr_fun h p

/-- SD7 naturality of generic representability in the target algebra. -/
theorem configurationRepresentability_natural
    {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {W : Site.ArchitectureContext A} {k : Type v} [CommRing k]
    {F : CoordinateFamily W} (relations : StructuralRelationFamily F k)
    {R : Type w} {T : Type x} [CommRing R] [Algebra k R]
    [CommRing T] [Algebra k T]
    (g : R →ₐ[k] T) (a : relations.Configuration R) :
    relations.configurationRepresentability T (a.map g) =
      g.comp (relations.configurationRepresentability R a) := by
  apply AlgHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro p
  change relations.quotientAlgHomOfConfiguration (a.map g)
      (relations.quotientMap p) =
    g (relations.quotientAlgHomOfConfiguration a (relations.quotientMap p))
  rw [quotientAlgHomOfConfiguration_mk]
  rw [quotientAlgHomOfConfiguration_mk]
  exact (MvPolynomial.comp_aeval_apply (f := a.1) g p).symm

end StructuralRelationFamily

/--
III.条件4.4: a typed coordinate restriction before quotienting.

For a context morphism `source -> target`, a presheaf restriction reads
functions on the target through polynomials on the source.
-/
structure TypedCoordinateRestriction {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {source target : Site.ArchitectureContext A}
    (sourceFamily : CoordinateFamily source) (targetFamily : CoordinateFamily target)
    (k : Type v) [CommRing k] (f : Site.ContextMorphism source target) where
  variableImage : targetFamily.CoordX -> FreeTypedCommAlg sourceFamily k

namespace TypedCoordinateRestriction

/-- III.条件4.4: the polynomial map induced by a typed coordinate restriction. -/
def polynomialMap {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {source target : Site.ArchitectureContext A}
    {sourceFamily : CoordinateFamily source} {targetFamily : CoordinateFamily target}
    {k : Type v} [CommRing k] {f : Site.ContextMorphism source target}
    (rho : TypedCoordinateRestriction sourceFamily targetFamily k f) :
    FreeTypedCommAlg targetFamily k →+* FreeTypedCommAlg sourceFamily k :=
  MvPolynomial.eval₂Hom MvPolynomial.C rho.variableImage

/-- III.条件4.4: variables restrict to their selected image polynomials. -/
theorem polynomialMap_X {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {source target : Site.ArchitectureContext A}
    {sourceFamily : CoordinateFamily source} {targetFamily : CoordinateFamily target}
    {k : Type v} [CommRing k] {f : Site.ContextMorphism source target}
    (rho : TypedCoordinateRestriction sourceFamily targetFamily k f)
    (c : targetFamily.CoordX) :
    rho.polynomialMap (MvPolynomial.X c) = rho.variableImage c := by
  simp [polynomialMap]

end TypedCoordinateRestriction

/--
III.条件4.4: restriction-stability of structural relations.

The induced polynomial map must send the target structural ideal into the source
structural ideal. Under this assumption, restriction descends to the raw
ambient quotient.
-/
structure RestrictionStableStructuralRelations {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {source target : Site.ArchitectureContext A}
    {sourceFamily : CoordinateFamily source} {targetFamily : CoordinateFamily target}
    {k : Type v} [CommRing k]
    (sourceRelations : StructuralRelationFamily sourceFamily k)
    (targetRelations : StructuralRelationFamily targetFamily k)
    (f : Site.ContextMorphism source target) where
  restriction : TypedCoordinateRestriction sourceFamily targetFamily k f
  maps_JStruct :
    ∀ p : FreeTypedCommAlg targetFamily k,
      p ∈ targetRelations.JStruct ->
        restriction.polynomialMap p ∈ sourceRelations.JStruct

namespace RestrictionStableStructuralRelations

/--
III.定義10.1 / 条件4.4: restriction descends to the raw ambient quotient.

This is the quotient descent lemma for `O_raw^U`; it is the algebraic content
needed before packaging the raw algebras as a presheaf.
-/
def quotientDesc {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {source target : Site.ArchitectureContext A}
    {sourceFamily : CoordinateFamily source} {targetFamily : CoordinateFamily target}
    {k : Type v} [CommRing k]
    {sourceRelations : StructuralRelationFamily sourceFamily k}
    {targetRelations : StructuralRelationFamily targetFamily k}
    {f : Site.ContextMorphism source target}
    (h : RestrictionStableStructuralRelations sourceRelations targetRelations f) :
    targetRelations.RawAmbientLawAlgebra →+* sourceRelations.RawAmbientLawAlgebra :=
  Ideal.Quotient.lift targetRelations.JStruct
    ((sourceRelations.quotientMap).comp h.restriction.polynomialMap)
    (by
      intro p hp
      rw [RingHom.comp_apply]
      change Ideal.Quotient.mk sourceRelations.JStruct
          (h.restriction.polynomialMap p) = 0
      rw [Ideal.Quotient.eq_zero_iff_mem]
      exact h.maps_JStruct p hp)

/-- III.条件4.4: the descended map agrees with polynomial restriction. -/
theorem quotientDesc_mk {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {source target : Site.ArchitectureContext A}
    {sourceFamily : CoordinateFamily source} {targetFamily : CoordinateFamily target}
    {k : Type v} [CommRing k]
    {sourceRelations : StructuralRelationFamily sourceFamily k}
    {targetRelations : StructuralRelationFamily targetFamily k}
    {f : Site.ContextMorphism source target}
    (h : RestrictionStableStructuralRelations sourceRelations targetRelations f)
    (p : FreeTypedCommAlg targetFamily k) :
    h.quotientDesc (targetRelations.quotientMap p) =
      sourceRelations.quotientMap (h.restriction.polynomialMap p) :=
  rfl

end RestrictionStableStructuralRelations

/--
III.R2: minimal presheaf-reading package for raw ambient algebras.

This records the context-indexed coordinate family, structural relation family,
and a quotient-descended restriction map for every selected context morphism.
The identity and composition laws are explicit fields, rather than inferred.
-/
structure RawAmbientPresheafBridge {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    (k : Type v) [CommRing k] where
  coordFamilySpec :
    (W : Site.ArchitectureContext A) -> CoordinateFamily W
  relationFamily :
    (W : Site.ArchitectureContext A) ->
      StructuralRelationFamily (coordFamilySpec W) k
  restrictionStable :
    {source target : Site.ArchitectureContext A} ->
      (f : Site.ContextMorphism source target) ->
        RestrictionStableStructuralRelations
          (relationFamily source) (relationFamily target) f
  identity_law :
    ∀ {W : Site.ArchitectureContext A} (id : Site.ContextMorphism W W),
      (restrictionStable id).quotientDesc =
        RingHom.id ((relationFamily W).RawAmbientLawAlgebra)
  composition_law :
    ∀ {source middle target : Site.ArchitectureContext A}
      (f : Site.ContextMorphism source middle)
      (g : Site.ContextMorphism middle target)
      (comp : Site.ContextMorphism source target),
        (restrictionStable comp).quotientDesc =
          ((restrictionStable f).quotientDesc).comp
            ((restrictionStable g).quotientDesc)

namespace RawAmbientPresheafBridge

/-- III.R2: the raw ambient algebra assigned to a context. -/
abbrev rawAlgebra {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {k : Type v} [CommRing k] (B : RawAmbientPresheafBridge (A := A) k)
    (W : Site.ArchitectureContext A) : Type (max u v) :=
  (B.relationFamily W).RawAmbientLawAlgebra

/-- III.R2: the quotient-descended restriction map assigned to a context morphism. -/
def res {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {k : Type v} [CommRing k] (B : RawAmbientPresheafBridge (A := A) k)
    {source target : Site.ArchitectureContext A}
    (f : Site.ContextMorphism source target) :
    B.rawAlgebra target →+* B.rawAlgebra source :=
  (B.restrictionStable f).quotientDesc

/-- III.R2: the restriction assigned to an identity context morphism is identity. -/
theorem identityLaw {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {k : Type v} [CommRing k] (B : RawAmbientPresheafBridge (A := A) k) :
    ∀ {W : Site.ArchitectureContext A} (id : Site.ContextMorphism W W),
      B.res id = RingHom.id (B.rawAlgebra W) :=
  B.identity_law

/-- III.R2: quotient-descended restrictions compose contravariantly. -/
theorem compositionLaw {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {k : Type v} [CommRing k] (B : RawAmbientPresheafBridge (A := A) k)
    {source middle target : Site.ArchitectureContext A}
    (f : Site.ContextMorphism source middle)
    (g : Site.ContextMorphism middle target)
    (comp : Site.ContextMorphism source target) :
    B.res comp = (B.res f).comp (B.res g) :=
  B.composition_law f g comp

end RawAmbientPresheafBridge

end

