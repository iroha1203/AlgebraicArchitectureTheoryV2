/--
III.補題5.6A: Boolean points for a finite witness coordinate set.

A point chooses the idempotent value `0` or `1` for each witness coordinate.
-/
abbrev BoolPoint (E : Type u) : Type u :=
  E -> Bool

namespace IdempotentCollapse

variable (E : Type u) (k : Type v) [Field k]

/-- III.補題5.6A: interpret a Boolean truth value as an element of the field. -/
def boolValue (b : Bool) : k :=
  if b then (1 : k) else 0

/-- III.補題5.6A: the Boolean evaluation value of each coordinate. -/
def boolEvalVars : E -> (BoolPoint E -> k) :=
  fun e p => boolValue k (p e)

/-- III.補題5.6A: simultaneous evaluation at all Boolean points. -/
def booleanEval : MvPolynomial E k →ₐ[k] (BoolPoint E -> k) :=
  MvPolynomial.aeval (boolEvalVars E k)

/-- III.補題5.6A: the idempotence relation `x_e^2 - x_e`. -/
def booleanRelation (e : E) : MvPolynomial E k :=
  X e ^ 2 - X e

/-- III.補題5.6A: the ideal generated by all idempotence relations. -/
def booleanIdeal : Ideal (MvPolynomial E k) :=
  Ideal.span (Set.range (booleanRelation E k))

/--
III.補題5.6A: `A = k[x_e | e in E] / <x_e^2 - x_e>`.

This is the Booleanized coordinate algebra. The following equivalence shows
that, in this regime, the algebra is a finite product of copies of `k`; derived
and infinitesimal information disappears after Boolean collapse.
-/
abbrev IdempotentAlgebra : Type (max u v) :=
  MvPolynomial E k ⧸ booleanIdeal E k

lemma booleanRelation_mem_ker (e : E) :
    booleanRelation E k e ∈ RingHom.ker (booleanEval E k) := by
  rw [RingHom.mem_ker]
  ext p
  simp [booleanEval, boolEvalVars, boolValue, booleanRelation]

lemma booleanIdeal_le_ker :
    booleanIdeal E k ≤ RingHom.ker (booleanEval E k) := by
  rw [booleanIdeal]
  exact Ideal.span_le.mpr fun x hx => by
    rcases hx with ⟨e, rfl⟩
    exact booleanRelation_mem_ker E k e

variable [Fintype E] [DecidableEq E]

def boolFinset : E -> Finset k := by
  classical
  exact fun _ => ({0, 1} : Finset k)

lemma boolFinset_nonempty (e : E) : (boolFinset E k e).Nonempty := by
  classical
  simp [boolFinset]

lemma bool_of_mem_boolFinset {x : E -> k} (hx : ∀ e, x e ∈ boolFinset E k e) :
    ∃ p : BoolPoint E, ∀ e, x e = boolValue k (p e) := by
  classical
  refine ⟨fun e => if x e = 1 then true else false, ?_⟩
  intro e
  have hx' : x e = 0 ∨ x e = 1 := by
    simpa [boolFinset] using hx e
  rcases hx' with h0 | h1
  · simp [h0, boolValue]
  · simp [h1, boolValue]

lemma booleanEval_apply (f : MvPolynomial E k) (p : BoolPoint E) :
    booleanEval E k f p = MvPolynomial.eval (fun e => boolValue k (p e)) f := by
  have hcomp :
      (Pi.evalAlgHom k (fun _ : BoolPoint E => k) p).comp (booleanEval E k) =
        MvPolynomial.aeval (fun e => boolValue k (p e)) := by
    ext e
    simp [booleanEval, boolEvalVars]
  change (((Pi.evalAlgHom k (fun _ : BoolPoint E => k) p).comp (booleanEval E k)) f) =
    MvPolynomial.eval (fun e => boolValue k (p e)) f
  rw [hcomp]
  rfl

lemma ker_le_booleanIdeal :
    RingHom.ker (booleanEval E k) ≤ booleanIdeal E k := by
  intro f hf
  rw [RingHom.mem_ker] at hf
  have heval : ∀ (x : E -> k), (∀ i, x i ∈ boolFinset E k i) -> MvPolynomial.eval x f = 0 := by
    intro x hx
    rcases bool_of_mem_boolFinset E k hx with ⟨p, hp⟩
    have hf' : MvPolynomial.eval (fun e => boolValue k (p e)) f = 0 := by
      simpa [booleanEval_apply] using congrFun hf p
    rw [show x = fun e => boolValue k (p e) from funext hp]
    exact hf'
  obtain ⟨h, _hdeg, hlin⟩ :=
    MvPolynomial.combinatorial_nullstellensatz_exists_linearCombination
      (R := k) (σ := E) (boolFinset E k) (boolFinset_nonempty E k) f heval
  rw [hlin]
  rw [booleanIdeal]
  rw [Ideal.mem_span_range_iff_exists_fun]
  refine ⟨fun e => h e, ?_⟩
  rw [Finsupp.linearCombination_apply, Finsupp.sum_fintype]
  · simp [booleanRelation, boolFinset]
    apply Finset.sum_congr rfl
    intro e _
    ring_nf
  · intro i
    simp

/-- III.補題5.6A(a): the Boolean ideal is exactly the kernel of Boolean evaluation. -/
theorem booleanIdeal_eq_ker :
    booleanIdeal E k = RingHom.ker (booleanEval E k) :=
  le_antisymm (booleanIdeal_le_ker E k) (ker_le_booleanIdeal E k)

def boolIndicator (p : BoolPoint E) : MvPolynomial E k :=
  ∏ e, if p e then X e else 1 - X e

lemma eval_boolIndicator (p q : BoolPoint E) :
    MvPolynomial.eval (fun e => boolValue k (q e)) (boolIndicator E k p) =
      if q = p then 1 else 0 := by
  classical
  by_cases hpq : q = p
  · subst q
    rw [if_pos rfl]
    rw [boolIndicator, map_prod]
    apply Finset.prod_eq_one
    intro e _
    by_cases hp : p e <;> simp [hp, boolValue]
  · have hne : ∃ e, q e ≠ p e := by
      by_contra h
      apply hpq
      funext e
      exact of_not_not fun hne => h ⟨e, hne⟩
    rcases hne with ⟨e, he⟩
    rw [if_neg hpq]
    rw [boolIndicator, map_prod]
    exact Finset.prod_eq_zero (Finset.mem_univ e) (by
      by_cases hp : p e <;> by_cases hq : q e <;> simp [hp, hq, boolValue] at he ⊢)

lemma booleanEval_surjective : Function.Surjective (booleanEval E k) := by
  classical
  intro y
  refine ⟨∑ p : BoolPoint E, C (y p) * boolIndicator E k p, ?_⟩
  ext q
  rw [booleanEval_apply]
  simp only [map_sum, map_mul, eval_C]
  rw [Finset.sum_eq_single q]
  · simp [eval_boolIndicator]
  · intro p _ hp
    simp [eval_boolIndicator, hp.symm]
  · intro hq
    exact (hq (Finset.mem_univ q)).elim

/-- III.補題5.6A(a): `k[x_e]/(x_e^2-x_e)` is a finite product of copies of `k`. -/
def quotientAlgEquivPi : IdempotentAlgebra E k ≃ₐ[k] (BoolPoint E -> k) :=
  (Ideal.quotientEquivAlgOfEq k (booleanIdeal_eq_ker E k)).trans
    (Ideal.quotientKerAlgEquivOfSurjective (booleanEval_surjective E k))

/-- III.補題5.6A(a): ring-equivalence form of the finite-product collapse. -/
def quotientRingEquivPi : IdempotentAlgebra E k ≃+* (BoolPoint E -> k) :=
  (quotientAlgEquivPi E k).toRingEquiv

instance product_isSemisimpleRing : IsSemisimpleRing (BoolPoint E -> k) :=
  inferInstance

instance algebra_isSemisimpleRing : IsSemisimpleRing (IdempotentAlgebra E k) :=
  (quotientRingEquivPi E k).symm.isSemisimpleRing

/-- III.補題5.6A(b): every module over the collapsed algebra is projective. -/
theorem module_projective (M : Type*) [AddCommGroup M] [Module (IdempotentAlgebra E k) M] :
    Module.Projective (IdempotentAlgebra E k) M :=
  Module.projective_of_isSemisimpleRing (IdempotentAlgebra E k) M

/-- III.補題5.6A(b): every module over the collapsed algebra is flat. -/
instance module_flat (M : Type*) [AddCommGroup M] [Module (IdempotentAlgebra E k) M] :
    Module.Flat (IdempotentAlgebra E k) M :=
  haveI : Module.Projective (IdempotentAlgebra E k) M := module_projective E k M
  Module.Flat.of_projective (M := M)

/-- III.補題5.6A(b): higher Tor vanishes for modules over the collapsed algebra. -/
theorem isZero_Tor_succ
    (M N : ModuleCat.{max u v} (IdempotentAlgebra E k)) (n : ℕ) :
    CategoryTheory.Limits.IsZero
      (((CategoryTheory.Tor (ModuleCat.{max u v} (IdempotentAlgebra E k)) (n + 1)).obj M).obj N) := by
  haveI : CategoryTheory.Projective N := by
    haveI : Module.Projective (IdempotentAlgebra E k) N := module_projective E k N
    infer_instance
  exact CategoryTheory.isZero_Tor_succ_of_projective
    (ModuleCat.{max u v} (IdempotentAlgebra E k)) M N n

/-- III.補題5.6A(c): every ideal in the finite product of fields is idempotent. -/
theorem product_ideal_mul_self (I : Ideal (BoolPoint E -> k)) :
    I * I = I := by
  classical
  apply le_antisymm
  · exact Ideal.mul_le_right
  · intro f hf
    let invSupport : BoolPoint E -> k := fun p => if f p = 0 then 0 else (f p)⁻¹
    let idem : BoolPoint E -> k := f * invSupport
    have hidem_mem : idem ∈ I := I.mul_mem_right invSupport hf
    have hf_eq : f = idem * f := by
      ext p
      by_cases hp : f p = 0
      · simp [idem, invSupport, hp]
      · simp [idem, invSupport, hp]
    rw [hf_eq]
    exact Ideal.mul_mem_mul hidem_mem hf

/-- III.補題5.6A(c): every ideal in the collapsed algebra is idempotent. -/
theorem ideal_mul_self (I : Ideal (IdempotentAlgebra E k)) :
    I * I = I :=
  IsSemisimpleRing.ideal_eq_span_idempotent I |>.elim fun e he =>
    he.elim fun he_idem hI => by
      rw [hI, Ideal.span_singleton_mul_span_singleton, he_idem]

/--
III.補題5.6A(c): the conormal quotient `I/I²` is zero.

In Lean we expose the quotient-zero condition as the equivalent submodule
statement: the preimage of `I²` in `I` is top.
-/
theorem ideal_square_comap_eq_top (I : Ideal (IdempotentAlgebra E k)) :
    Submodule.comap (Submodule.subtype I)
      (I * I : Submodule (IdempotentAlgebra E k) (IdempotentAlgebra E k)) = ⊤ := by
  rw [ideal_mul_self E k I]
  ext x
  simp

instance product_formallyUnramified : Algebra.FormallyUnramified k (BoolPoint E -> k) :=
  inferInstance

instance algebra_formallyUnramified : Algebra.FormallyUnramified k (IdempotentAlgebra E k) :=
  Algebra.FormallyUnramified.of_equiv (quotientAlgEquivPi E k).symm

/-- III.補題5.6A(d): `Ω_{A/k}=0` for the collapsed algebra. -/
theorem kaehler_subsingleton :
    Subsingleton Ω[IdempotentAlgebra E k⁄k] :=
  inferInstance

