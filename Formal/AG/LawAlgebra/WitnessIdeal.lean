import Formal.AG.LawAlgebra.StructureSheaf

namespace AAT.AG
namespace LawAlgebra

universe u v

open CategoryTheory
open Opposite

/--
III.定義5.1: violation witness family on a selected context.

The selected law label is retained in the API so later obstruction ideals can
sum law-indexed witness ideals. Each violation witness carries the coordinate
element `x_v` in the raw input of the law algebra sheafification at `W`. This
is the primary input for the law witness ideal.
-/
structure ViolationWitnessFamily {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    (P : LawAlgebraSheafPackage S k) (W : S.category) where
  LawIndex : Type u
  law : LawIndex
  Witness : Type u
  coordinate : Witness -> (P.sheafification.raw.obj (op W)).right

namespace ViolationWitnessFamily

/-- III.定義5.1: the selected violation coordinate set `{x_v}`. -/
def coordinateSet {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    (V : ViolationWitnessFamily P W) :
    Set (P.sheafification.raw.obj (op W)).right :=
  Set.range V.coordinate

end ViolationWitnessFamily

/--
III.定義5.2: law witness ideal `I_L(W)`.

The ideal is generated by the selected violation coordinates. This is the
primary equational encoding of law failure at the witness layer.
-/
def LawWitnessIdeal {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    (V : ViolationWitnessFamily P W) :
    Ideal (P.sheafification.raw.obj (op W)).right :=
  Ideal.span V.coordinateSet

namespace LawWitnessIdeal

/-- III.定義5.2: each violation coordinate lies in `I_L(W)`. -/
theorem coordinate_mem {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    (V : ViolationWitnessFamily P W) (w : V.Witness) :
    V.coordinate w ∈ LawWitnessIdeal V :=
  Ideal.subset_span (Set.mem_range_self w)

end LawWitnessIdeal

/--
III.定義5.3: an ideal used as the support of a point-like reading.

The `isPoint` field keeps the point condition explicit without committing this
early layer to a particular prime/maximal/local-point API.
-/
structure LawWitnessPoint {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    (P : LawAlgebraSheafPackage S k) (W : S.category) where
  support : Ideal (P.sheafification.raw.obj (op W)).right
  isPoint : Prop

/-- III.定義5.3: primary ideal vanishing along an arbitrary ideal support. -/
def LawWitnessIdealVanishesAtIdeal {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    (V : ViolationWitnessFamily P W)
    (p : Ideal (P.sheafification.raw.obj (op W)).right) : Prop :=
  LawWitnessIdeal V ≤ p

/-- III.定義5.3: lawfulness at a point is primary ideal vanishing `I_L(W) ⊆ p`. -/
def LawWitnessIdealVanishesAtPoint {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    (V : ViolationWitnessFamily P W)
    (p : LawWitnessPoint P W) : Prop :=
  LawWitnessIdealVanishesAtIdeal V p.support

/--
III.定義5.3: a section-valued pullback surface for the law witness ideal.

The section map is defined on the sheafified law algebra. The raw witness ideal
is pulled back only through the canonical `O_raw^U(W) -> O_X^U(W)` bridge, so
the primary section condition cannot bypass the R3 sheafification boundary.
-/
structure LawWitnessSectionPullback {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : Site.AATSite A}
    {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    (V : ViolationWitnessFamily P W) where
  SectionRing : Type (max u v)
  commRing : CommRing SectionRing
  sheafifiedPullback :
    (P.sheafification.OXPresheaf.obj (op W)).right →+* SectionRing

attribute [instance] LawWitnessSectionPullback.commRing

namespace LawWitnessSectionPullback

/-- III.定義5.3: raw witness coordinates pull back through the canonical bridge. -/
def pullback {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    {V : ViolationWitnessFamily P W}
    (s : LawWitnessSectionPullback V) :
    (P.sheafification.raw.obj (op W)).right →+* s.SectionRing :=
  s.sheafifiedPullback.comp (P.sheafification.canonicalAt W).right.hom

/-- III.定義5.3: the pulled-back law witness ideal along a section. -/
def pulledIdeal {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    {V : ViolationWitnessFamily P W}
    (s : LawWitnessSectionPullback V) : Ideal s.SectionRing :=
  Ideal.map s.pullback (LawWitnessIdeal V)

/-- III.定義5.3: section lawfulness is primary ideal vanishing `s^* I_L = 0`. -/
def Vanishes {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    {V : ViolationWitnessFamily P W}
    (s : LawWitnessSectionPullback V) : Prop :=
  s.pulledIdeal = ⊥

end LawWitnessSectionPullback

/--
III.定義5.3: defect section with an explicit no-cancellation boundary.

This is the secondary representative reading `s^*(δ_L) = 0`. It is deliberately
separate from the primary ideal-vanishing definitions above.
-/
structure DefectRepresentativeReading {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : Site.AATSite A}
    {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    {V : ViolationWitnessFamily P W}
    (s : LawWitnessSectionPullback V) where
  defect :
    (P.sheafification.raw.obj (op W)).right
  defect_mem_I_L : defect ∈ LawWitnessIdeal V
  noCancellation : Prop

namespace DefectRepresentativeReading

/-- III.定義5.3: the representative defect vanishes along the selected section. -/
def Vanishes {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    {V : ViolationWitnessFamily P W}
    {s : LawWitnessSectionPullback V}
    (D : DefectRepresentativeReading s) : Prop :=
  D.noCancellation ∧ s.pullback D.defect = 0

/--
III.定義5.3: the representative reading carries an explicit no-cancellation
hypothesis, so it cannot silently replace ideal vanishing.
-/
theorem noCancellation_of_vanishes {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : Site.AATSite A} {k : Type v} [CommRing k]
    {P : LawAlgebraSheafPackage S k} {W : S.category}
    {V : ViolationWitnessFamily P W}
    {s : LawWitnessSectionPullback V}
    {D : DefectRepresentativeReading s} (h : D.Vanishes) :
    D.noCancellation :=
  h.1

end DefectRepresentativeReading

end LawAlgebra
end AAT.AG
