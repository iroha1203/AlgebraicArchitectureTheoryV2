import Formal.AG.LawAlgebra.LawfulLocus

noncomputable section

namespace AAT.AG
namespace LawAlgebra

universe u v

open MvPolynomial

namespace Nullstellensatz

variable (E : Type u) (k : Type v) [Field k]

/-- III.定理候補7.2A: Boolean law ideal `I_U(W) + B_W`. -/
def booleanLawIdeal (I : Ideal (MvPolynomial E k)) : Ideal (MvPolynomial E k) :=
  I ⊔ IdempotentCollapse.booleanIdeal E k

/-- III.定理候補7.2A: a point vanishes on an ideal. -/
def VanishesAtIdeal (p : E -> k) (I : Ideal (MvPolynomial E k)) : Prop :=
  ∀ f, f ∈ I -> MvPolynomial.eval p f = 0

/-- III.定理候補7.2A: the Boolean law variety is empty over `k`. -/
def BooleanLawZeroSetEmpty (I : Ideal (MvPolynomial E k)) : Prop :=
  ¬ ∃ p : E -> k, VanishesAtIdeal E k p (booleanLawIdeal E k I)

/--
III.定理候補7.2A: Architecture Nullstellensatz statement.

This is intentionally a statement-only `Prop`, not a proved theorem in PRD-3.
It records the future theorem target: emptiness of the Boolean law zero set is
equivalent to the radical unit certificate.
-/
def ArchitectureNullstellensatzCandidate (I : Ideal (MvPolynomial E k)) : Prop :=
  BooleanLawZeroSetEmpty E k I ↔ (1 : MvPolynomial E k) ∈ (booleanLawIdeal E k I).radical

/-- III.定理候補7.2A: radical unit membership certificate surface. -/
def RadicalUnitCertificate (I : Ideal (MvPolynomial E k)) : Prop :=
  (1 : MvPolynomial E k) ∈ (booleanLawIdeal E k I).radical

/--
III.定義7.2B: an abstract unlawfulness certificate with an explicit display
degree. Later finite examples can instantiate this with concrete polynomial
linear combinations.
-/
structure UnlawfulnessCertificate where
  degree : ℕ
  certifies : Prop

/-- III.定義7.2B: certificate availability by display degree. -/
def HasCertificateAt (certs : Type u) (degreeOf : certs -> ℕ) (d : ℕ) : Prop :=
  ∃ c : certs, degreeOf c ≤ d

/--
III.定義7.2B: NSdepth profile for a chosen generator system.

`depth` is packaged with its minimality proof, so monotonicity can be proved
without choosing a global computable minimization procedure.
-/
structure NSdepthProfile where
  HasCertificateAt : ℕ -> Prop
  depth : ℕ
  depth_hasCertificate : HasCertificateAt depth
  depth_minimal : ∀ d, HasCertificateAt d -> depth ≤ d

namespace NSdepthProfile

/-- III.定義7.2B: the selected Nullstellensatz depth. -/
def NSdepth (P : NSdepthProfile) : ℕ :=
  P.depth

/--
III.命題7.2C: generator extension data preserving every old certificate
display at the same degree.
-/
structure GeneratorExtension (old new : NSdepthProfile) where
  preservesCertificates : ∀ d, old.HasCertificateAt d -> new.HasCertificateAt d

/--
III.命題7.2C: adding generators cannot increase NSdepth, provided old
certificates remain valid in the extended generator system.
-/
theorem NSdepth_mono_of_generatorExtension {old new : NSdepthProfile}
    (h : GeneratorExtension old new) :
    new.NSdepth ≤ old.NSdepth :=
  new.depth_minimal old.depth (h.preservesCertificates old.depth old.depth_hasCertificate)

end NSdepthProfile

section GeneratorCertificates

variable {E : Type u} {R : Type v} [CommRing R]

/--
III.R4 / III-5: concrete certificate that `1` is displayed as a finite linear
combination of a selected generator family.

The `displayDegree` field is part of the certificate payload and is bounded
against every nonzero summand in the displayed combination. This keeps NSdepth
tied to an actual generator expression rather than an arbitrary `Nat -> Prop`.
-/
structure GeneratorUnitCertificate (ι : Type u) (G : ι -> MvPolynomial E R) where
  coeff : ι →₀ MvPolynomial E R
  unit_eq_linearCombination : coeff.sum (fun i a => a * G i) = 1
  displayDegree : ℕ
  displayDegree_bounds : ∀ i, (coeff i * G i).totalDegree ≤ displayDegree

namespace GeneratorUnitCertificate

/--
III.R4 / III-5: a displayed unit combination proves membership in the ideal
spanned by the selected generators.
-/
theorem one_mem_span {ι : Type u} {G : ι -> MvPolynomial E R}
    (C : GeneratorUnitCertificate ι G) :
    (1 : MvPolynomial E R) ∈ Ideal.span (Set.range G) := by
  rw [← C.unit_eq_linearCombination]
  exact Ideal.sum_mem (Ideal.span (Set.range G)) (by
    intro i _hi
    exact Ideal.mul_mem_left _ _ (Ideal.subset_span ⟨i, rfl⟩))

end GeneratorUnitCertificate

/--
III.R4 / III-5: certificate availability generated by a selected family of
actual unit-combination certificates and their display degrees.
-/
def HasSelectedGeneratorUnitCertificateAt {ι : Type u}
    (G : ι -> MvPolynomial E R) (certs : Type u)
    (certificate : certs -> GeneratorUnitCertificate ι G) (d : ℕ) : Prop :=
  ∃ c : certs, (certificate c).displayDegree ≤ d

/--
III.R4 / III-5: NSdepth profile tied to a selected generator family and
concrete unit-combination certificates.
-/
structure GeneratorNSdepthProfile (ι : Type u) (G : ι -> MvPolynomial E R) where
  Certificate : Type u
  certificate : Certificate -> GeneratorUnitCertificate ι G
  depth : ℕ
  depth_hasCertificate :
    HasSelectedGeneratorUnitCertificateAt G Certificate certificate depth
  depth_minimal :
    ∀ d, HasSelectedGeneratorUnitCertificateAt G Certificate certificate d -> depth ≤ d

namespace GeneratorNSdepthProfile

/--
III.R4 / III-5: forget the concrete generator source to the legacy
`NSdepthProfile` surface.
-/
def toNSdepthProfile {ι : Type u} {G : ι -> MvPolynomial E R}
    (P : GeneratorNSdepthProfile ι G) : NSdepthProfile where
  HasCertificateAt := HasSelectedGeneratorUnitCertificateAt G P.Certificate P.certificate
  depth := P.depth
  depth_hasCertificate := P.depth_hasCertificate
  depth_minimal := P.depth_minimal

/-- III.R4 / III-5: concrete generator NSdepth reads as the selected depth. -/
theorem NSdepth_eq_depth {ι : Type u} {G : ι -> MvPolynomial E R}
    (P : GeneratorNSdepthProfile ι G) :
    P.toNSdepthProfile.NSdepth = P.depth :=
  rfl

/--
III.R4 / III-5: generator extensions cannot increase the concrete NSdepth when
they preserve every displayed unit certificate at the same degree.
-/
structure GeneratorCertificateExtension {ι κ : Type u}
    {G : ι -> MvPolynomial E R} {H : κ -> MvPolynomial E R}
    (old : GeneratorNSdepthProfile ι G) (new : GeneratorNSdepthProfile κ H) where
  preservesCertificates :
    ∀ d,
      HasSelectedGeneratorUnitCertificateAt G old.Certificate old.certificate d ->
        HasSelectedGeneratorUnitCertificateAt H new.Certificate new.certificate d

/--
III.R4 / III-5: concrete generator version of the legacy NSdepth monotonicity
theorem.
-/
theorem NSdepth_mono_of_generatorCertificateExtension {ι κ : Type u}
    {G : ι -> MvPolynomial E R} {H : κ -> MvPolynomial E R}
    (old : GeneratorNSdepthProfile ι G) (new : GeneratorNSdepthProfile κ H)
    (h : GeneratorCertificateExtension old new) :
    new.depth ≤ old.depth :=
  new.depth_minimal old.depth
    (h.preservesCertificates old.depth old.depth_hasCertificate)

end GeneratorNSdepthProfile

end GeneratorCertificates

end Nullstellensatz

end LawAlgebra
end AAT.AG
