import Formal.AG.Site.FinitePoset
import Mathlib.AlgebraicTopology.SimplexCategory.Basic

namespace AAT.AG
namespace Site

universe u

open CategoryTheory

/--
X.R1(b): coefficient-free finite-poset atom/law cover geometry.

This is the finite-poset cover and overlap surface before choosing a
coefficient presheaf.  It mirrors `FinitePosetAATSiteRegime` except for the
`coefficient` field, so later layers can generate the coefficient from an
obstruction sheaf rather than supplying it as comparison data.
-/
structure FinitePosetCoverGeometry {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} (S : AATSite A) where
  ContextIndex : Type u
  finiteContextIndex : Finite ContextIndex
  context : ContextIndex -> ArchCtx A
  contextLe : ContextIndex -> ContextIndex -> Prop
  contextLe_refl : ∀ i : ContextIndex, contextLe i i
  contextLe_trans :
    ∀ {i j k : ContextIndex}, contextLe i j -> contextLe j k -> contextLe i k
  contextLe_antisymm :
    ∀ {i j : ContextIndex}, contextLe i j -> contextLe j i -> i = j
  contextLe_sound :
    ∀ {i j : ContextIndex}, contextLe i j -> S.contextPreorder.le (context i) (context j)
  contextMeet : ContextIndex -> ContextIndex -> ContextIndex
  contextMeet_le_left : ∀ i j : ContextIndex, contextLe (contextMeet i j) i
  contextMeet_le_right : ∀ i j : ContextIndex, contextLe (contextMeet i j) j
  context_le_meet :
    ∀ {i j k : ContextIndex}, contextLe k i -> contextLe k j ->
      contextLe k (contextMeet i j)
  base : S.category
  cover : AATCoverageFamily S.requirements S.overlap base
  finiteCoverIndex : Finite cover.Index
  nerveSimplex : Nat -> Type u
  finiteNerveSimplex : ∀ n : Nat, Finite (nerveSimplex n)
  simplexIndices : ∀ n : Nat, nerveSimplex n -> Fin (n + 1) -> cover.Index
  simplexOverlap : ∀ n : Nat, nerveSimplex n -> ArchCtx A
  simplexOverlap_le_patch :
    ∀ (n : Nat) (simplex : nerveSimplex n) (k : Fin (n + 1)),
      S.contextPreorder.le (simplexOverlap n simplex)
        (cover.patch (simplexIndices n simplex k))
  adequacyRequirements : UAdequacyRequirements S.contextPreorder S.requirements
  coverAdequate : UAdequateCover adequacyRequirements cover

namespace FinitePosetCoverGeometry

variable {U : AtomCarrier.{u}} {A : ArchitectureObject U}
variable {S : AATSite A}

/--
X.R1(b): choose a coefficient presheaf after the coefficient-free geometry has
been fixed.
-/
def toRegime (geometry : FinitePosetCoverGeometry S)
    (coefficient : AATPresheaf S) :
    FinitePosetAATSiteRegime S where
  ContextIndex := geometry.ContextIndex
  finiteContextIndex := geometry.finiteContextIndex
  context := geometry.context
  contextLe := geometry.contextLe
  contextLe_refl := geometry.contextLe_refl
  contextLe_trans := geometry.contextLe_trans
  contextLe_antisymm := geometry.contextLe_antisymm
  contextLe_sound := geometry.contextLe_sound
  contextMeet := geometry.contextMeet
  contextMeet_le_left := geometry.contextMeet_le_left
  contextMeet_le_right := geometry.contextMeet_le_right
  context_le_meet := geometry.context_le_meet
  base := geometry.base
  cover := geometry.cover
  finiteCoverIndex := geometry.finiteCoverIndex
  nerveSimplex := geometry.nerveSimplex
  finiteNerveSimplex := geometry.finiteNerveSimplex
  simplexIndices := geometry.simplexIndices
  simplexOverlap := geometry.simplexOverlap
  simplexOverlap_le_patch := geometry.simplexOverlap_le_patch
  adequacyRequirements := geometry.adequacyRequirements
  coverAdequate := geometry.coverAdequate
  coefficient := coefficient

/-- X.R1(b): the generated regime keeps the selected cover. -/
theorem toRegime_cover (geometry : FinitePosetCoverGeometry S)
    (coefficient : AATPresheaf S) :
    (geometry.toRegime coefficient).cover = geometry.cover :=
  rfl

/-- X.R1(b): the generated regime keeps the selected simplex family. -/
theorem toRegime_nerveSimplex (geometry : FinitePosetCoverGeometry S)
    (coefficient : AATPresheaf S) (n : Nat) :
    (geometry.toRegime coefficient).nerveSimplex n = geometry.nerveSimplex n :=
  rfl

/-- X.R1(b): the generated regime uses exactly the supplied coefficient. -/
theorem toRegime_coefficient (geometry : FinitePosetCoverGeometry S)
    (coefficient : AATPresheaf S) :
    (geometry.toRegime coefficient).coefficient = coefficient :=
  rfl

end FinitePosetCoverGeometry

/-! ## Canonical tuple nerve geometry -/

/--
X.R1(a): canonical ordered tuple simplex for a selected finite cover.

An `n`-simplex is the generated ordered `(n+1)`-tuple of selected cover indices.
Face maps are generated by precomposition in `SimplexCategory`.
-/
abbrev FinitePosetCechCanonicalTupleSimplex (Index : Type u) (n : Nat) :=
  Fin (n + 1) -> Index

namespace FinitePosetCechCanonicalTupleSimplex

/-- X.R1(a): contravariant map on canonical cover-index tuples. -/
def simplexMap {Index : Type u} {n m : Nat}
    (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
    (simplex : FinitePosetCechCanonicalTupleSimplex Index m) :
    FinitePosetCechCanonicalTupleSimplex Index n :=
  fun i => simplex (f.toOrderHom i)

@[simp]
theorem simplexMap_apply {Index : Type u} {n m : Nat}
    (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
    (simplex : FinitePosetCechCanonicalTupleSimplex Index m)
    (i : Fin (n + 1)) :
    simplexMap f simplex i = simplex (f.toOrderHom i) :=
  rfl

/-- X.R1(a): canonical tuple maps are functorial by definition. -/
theorem simplexMap_comp {Index : Type u} {n m l : Nat}
    (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
    (g : SimplexCategory.mk m ⟶ SimplexCategory.mk l)
    (simplex : FinitePosetCechCanonicalTupleSimplex Index l) :
    simplexMap (f ≫ g) simplex = simplexMap f (simplexMap g simplex) :=
  rfl

/--
X.R1(a): the triangular two-face identity is the standard coface identity in
`SimplexCategory`.
-/
theorem twoFace_simplex_eq {Index : Type u}
    (n : Nat)
    (simplex : FinitePosetCechCanonicalTupleSimplex Index (n + 2))
    (i j : Fin (n + 2)) (hle : i ≤ j) :
    simplexMap (SimplexCategory.δ i)
        (simplexMap (SimplexCategory.δ j.succ) simplex) =
      simplexMap (SimplexCategory.δ j)
        (simplexMap (SimplexCategory.δ i.castSucc) simplex) := by
  rw [← simplexMap_comp, ← simplexMap_comp, SimplexCategory.δ_comp_δ hle]

end FinitePosetCechCanonicalTupleSimplex

/--
X.R1(a): canonical tuple nerve source for a finite-poset regime.

This source says selected simplices are controlled by ordered cover-index
tuples. It stores no cancellation or exactness conclusion.
-/
structure FinitePosetCechCanonicalTupleNerveSource {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    (K : FinitePosetAATSiteRegime S) where
  simplex_ext :
    ∀ (n : Nat) (left right : FinitePosetCechSimplex K n),
      (∀ i : Fin (n + 1), K.simplexIndices n left i = K.simplexIndices n right i) ->
        left = right
  simplexMap :
    ∀ {n m : Nat}, (SimplexCategory.mk n ⟶ SimplexCategory.mk m) ->
      FinitePosetCechSimplex K m -> FinitePosetCechSimplex K n
  simplexMap_indices :
    ∀ {n m : Nat} (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
      (simplex : FinitePosetCechSimplex K m) (i : Fin (n + 1)),
      K.simplexIndices n (simplexMap f simplex) i =
        K.simplexIndices m simplex (f.toOrderHom i)
  faceOverlap_le :
    ∀ (n : Nat) (simplex : FinitePosetCechSimplex K (n + 1))
      (i : Fin (n + 2)),
      S.contextPreorder.le (K.simplexOverlap (n + 1) simplex)
        (K.simplexOverlap n (simplexMap (SimplexCategory.δ i) simplex))

namespace FinitePosetCechCanonicalTupleNerveSource

/-- X.R1(a): tuple extensionality generates functoriality of simplex maps. -/
theorem simplexMap_comp {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : AATSite A} {K : FinitePosetAATSiteRegime S}
    (source : FinitePosetCechCanonicalTupleNerveSource K)
    {n m l : Nat}
    (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
    (g : SimplexCategory.mk m ⟶ SimplexCategory.mk l)
    (simplex : FinitePosetCechSimplex K l) :
    source.simplexMap (f ≫ g) simplex =
      source.simplexMap f (source.simplexMap g simplex) := by
  apply source.simplex_ext n
  intro i
  calc
    K.simplexIndices n (source.simplexMap (f ≫ g) simplex) i =
        K.simplexIndices l simplex ((f ≫ g).toOrderHom i) := by
      exact source.simplexMap_indices (f ≫ g) simplex i
    _ = K.simplexIndices l simplex (g.toOrderHom (f.toOrderHom i)) := by
      rfl
    _ = K.simplexIndices m (source.simplexMap g simplex) (f.toOrderHom i) := by
      exact (source.simplexMap_indices g simplex (f.toOrderHom i)).symm
    _ = K.simplexIndices n
          (source.simplexMap f (source.simplexMap g simplex)) i := by
      exact (source.simplexMap_indices f (source.simplexMap g simplex) i).symm

end FinitePosetCechCanonicalTupleNerveSource

/--
X.R1(a): generated simplicial face action on selected finite-poset simplices.

The action supplies face maps by the standard coface maps. It stores no
restriction-map equality, signed cancellation, `d ∘ d = 0`, or H1 conclusion.
-/
structure FinitePosetCechSimplicialFaceAction {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    (K : FinitePosetAATSiteRegime S) where
  simplexMap :
    ∀ {n m : Nat}, (SimplexCategory.mk n ⟶ SimplexCategory.mk m) ->
      FinitePosetCechSimplex K m -> FinitePosetCechSimplex K n
  simplexMap_comp :
    ∀ {n m l : Nat} (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
      (g : SimplexCategory.mk m ⟶ SimplexCategory.mk l)
      (simplex : FinitePosetCechSimplex K l),
      simplexMap (f ≫ g) simplex = simplexMap f (simplexMap g simplex)
  faceOverlap_le :
    ∀ (n : Nat) (simplex : FinitePosetCechSimplex K (n + 1))
      (i : Fin (n + 2)),
      S.contextPreorder.le (K.simplexOverlap (n + 1) simplex)
        (K.simplexOverlap n (simplexMap (SimplexCategory.δ i) simplex))

namespace FinitePosetCechSimplicialFaceAction

/-- X.R1(a): read a simplicial action as the existing face-data API. -/
def toFaceData {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : AATSite A} {K : FinitePosetAATSiteRegime S}
    (action : FinitePosetCechSimplicialFaceAction K) :
    FinitePosetCechFaceData K where
  face := by
    intro n simplex i
    exact action.simplexMap (SimplexCategory.δ i) simplex
  faceOverlap_le := action.faceOverlap_le

/-- X.R1(a): simplicial functoriality generates the triangular two-face law. -/
theorem twoFace_simplex_eq {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : AATSite A} {K : FinitePosetAATSiteRegime S}
    (action : FinitePosetCechSimplicialFaceAction K)
    (n : Nat) (simplex : FinitePosetCechSimplex K (n + 2))
    (i j : Fin (n + 2)) (hle : i ≤ j) :
    (action.toFaceData).face n
        ((action.toFaceData).face (n + 1) simplex j.succ) i =
      (action.toFaceData).face n
        ((action.toFaceData).face (n + 1) simplex i.castSucc) j := by
  dsimp [toFaceData]
  rw [← action.simplexMap_comp
    (SimplexCategory.δ i) (SimplexCategory.δ j.succ) simplex]
  rw [← action.simplexMap_comp
    (SimplexCategory.δ j) (SimplexCategory.δ i.castSucc) simplex]
  rw [SimplexCategory.δ_comp_δ hle]

end FinitePosetCechSimplicialFaceAction

namespace FinitePosetCechCanonicalTupleNerveSource

/-- X.R1(a): canonical tuple provenance generates the simplicial face action. -/
def toSimplicialFaceAction {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : AATSite A} {K : FinitePosetAATSiteRegime S}
    (source : FinitePosetCechCanonicalTupleNerveSource K) :
    FinitePosetCechSimplicialFaceAction K where
  simplexMap := source.simplexMap
  simplexMap_comp := by
    intro n m l f g simplex
    exact source.simplexMap_comp f g simplex
  faceOverlap_le := source.faceOverlap_le

/-- X.R1(a): generated action uses exactly the coface maps. -/
theorem toSimplicialFaceAction_face_eq {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    {K : FinitePosetAATSiteRegime S}
    (source : FinitePosetCechCanonicalTupleNerveSource K)
    (n : Nat) (simplex : FinitePosetCechSimplex K (n + 1))
    (i : Fin (n + 2)) :
    (source.toSimplicialFaceAction.toFaceData).face n simplex i =
      source.simplexMap (SimplexCategory.δ i) simplex :=
  rfl

end FinitePosetCechCanonicalTupleNerveSource

/--
X.R1(a): coefficient-free cover geometry with generated canonical tuple nerve.

It keeps the original selected cover and replaces the abstract nerve by the
free ordered tuple nerve. The final field is the geometric monotonicity needed
for tuple pullback along simplex-category maps.
-/
structure FinitePosetCanonicalTupleCoverGeometry {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    (geometry : FinitePosetCoverGeometry S) where
  tupleOverlap :
    ∀ n : Nat, FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n ->
      ArchCtx A
  tupleOverlap_le_patch :
    ∀ (n : Nat)
      (simplex : FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n)
      (k : Fin (n + 1)),
      S.contextPreorder.le (tupleOverlap n simplex)
        (geometry.cover.patch (simplex k))
  tupleOverlap_le_tupleMap :
    ∀ {n m : Nat} (f : SimplexCategory.mk n ⟶ SimplexCategory.mk m)
      (simplex : FinitePosetCechCanonicalTupleSimplex geometry.cover.Index m),
      S.contextPreorder.le (tupleOverlap m simplex)
        (tupleOverlap n (FinitePosetCechCanonicalTupleSimplex.simplexMap f simplex))

namespace FinitePosetCoverGeometry

variable {U : AtomCarrier.{u}} {A : ArchitectureObject U}
variable {S : AATSite A}

/--
X.R1(a): generate the canonical n-ary tuple overlap from the selected AAT site
overlap.  Singleton tuples use their patch, and longer tuples iteratively meet
the generated initial tuple overlap with the last patch over the cover base.
-/
def canonicalTupleOverlapFromOverlap
    (geometry : FinitePosetCoverGeometry S) :
    ∀ n : Nat,
      FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n ->
        ArchCtx A
  | 0, simplex => geometry.cover.patch (simplex 0)
  | n + 1, simplex =>
      S.overlap.overlap geometry.base.ctx
        (canonicalTupleOverlapFromOverlap geometry n
          (fun k => simplex k.castSucc))
        (geometry.cover.patch (simplex (Fin.last (n + 1))))

/-- The generated tuple overlap lies over the selected cover base. -/
theorem canonicalTupleOverlapFromOverlap_le_base
    (geometry : FinitePosetCoverGeometry S) :
    ∀ (n : Nat)
      (simplex : FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n),
      S.contextPreorder.le
        (geometry.canonicalTupleOverlapFromOverlap n simplex)
        geometry.base.ctx
  | 0, simplex => geometry.cover.inclusion (simplex 0)
  | n + 1, simplex =>
      S.overlap.overlap_le_base
        (canonicalTupleOverlapFromOverlap_le_base geometry n
          (fun k => simplex k.castSucc))
        (geometry.cover.inclusion (simplex (Fin.last (n + 1))))

/-- The generated tuple overlap maps to every patch in the tuple. -/
theorem canonicalTupleOverlapFromOverlap_le_patch
    (geometry : FinitePosetCoverGeometry S) :
    ∀ (n : Nat)
      (simplex : FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n)
      (k : Fin (n + 1)),
      S.contextPreorder.le
        (geometry.canonicalTupleOverlapFromOverlap n simplex)
        (geometry.cover.patch (simplex k))
  | 0, simplex, k => by
      have hk : k = 0 := by
        apply Fin.ext
        exact Nat.eq_zero_of_le_zero (Nat.le_of_lt_succ k.isLt)
      subst k
      exact S.contextPreorder.refl (geometry.cover.patch (simplex 0))
  | n + 1, simplex, k => by
      refine Fin.lastCases ?_ (fun initIndex => ?_) k
      · exact
          S.overlap.overlap_le_right
            (geometry.canonicalTupleOverlapFromOverlap_le_base n
              (fun q => simplex q.castSucc))
            (geometry.cover.inclusion (simplex (Fin.last (n + 1))))
      · exact
          S.contextPreorder.trans
            (S.overlap.overlap_le_left
              (geometry.canonicalTupleOverlapFromOverlap_le_base n
                (fun q => simplex q.castSucc))
              (geometry.cover.inclusion (simplex (Fin.last (n + 1)))))
            (geometry.canonicalTupleOverlapFromOverlap_le_patch n
              (fun q => simplex q.castSucc) initIndex)

/--
The generated tuple overlap has the expected universal lifting property with
respect to the tuple's patches.
-/
theorem canonicalTupleOverlapFromOverlap_lift
    (geometry : FinitePosetCoverGeometry S) :
    ∀ {n : Nat} {X : ArchCtx A}
      (simplex : FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n),
      (∀ k : Fin (n + 1),
        S.contextPreorder.le X (geometry.cover.patch (simplex k))) ->
        S.contextPreorder.le X
          (geometry.canonicalTupleOverlapFromOverlap n simplex)
  | 0, _, _, hX => hX 0
  | n + 1, _, simplex, hX =>
      S.overlap.overlap_lift
        (geometry.canonicalTupleOverlapFromOverlap_le_base n
          (fun q => simplex q.castSucc))
        (geometry.cover.inclusion (simplex (Fin.last (n + 1))))
        (geometry.canonicalTupleOverlapFromOverlap_lift
          (fun q => simplex q.castSucc) (fun q => hX q.castSucc))
        (hX (Fin.last (n + 1)))

/--
X.R1(a): the selected site overlap constructs the canonical tuple cover
geometry consumed by the finite-poset Cech route.
-/
def canonicalTupleCoverGeometryFromOverlap
    (geometry : FinitePosetCoverGeometry S) :
    FinitePosetCanonicalTupleCoverGeometry geometry where
  tupleOverlap := geometry.canonicalTupleOverlapFromOverlap
  tupleOverlap_le_patch := geometry.canonicalTupleOverlapFromOverlap_le_patch
  tupleOverlap_le_tupleMap := by
    intro n m f simplex
    exact
      geometry.canonicalTupleOverlapFromOverlap_lift
        (FinitePosetCechCanonicalTupleSimplex.simplexMap f simplex)
        (fun k =>
          geometry.canonicalTupleOverlapFromOverlap_le_patch m simplex
            (f.toOrderHom k))

/--
X.R1(a): positive construction theorem for the overlap-generated canonical
tuple cover geometry.
-/
theorem constructs_canonicalTupleCoverGeometry_from_overlap
    (geometry : FinitePosetCoverGeometry S) :
    Nonempty (FinitePosetCanonicalTupleCoverGeometry geometry) :=
  ⟨geometry.canonicalTupleCoverGeometryFromOverlap⟩

end FinitePosetCoverGeometry

namespace FinitePosetCanonicalTupleCoverGeometry

/-- X.R1(a): read canonical tuple geometry as coefficient-free cover geometry. -/
def toCoverGeometry {U : AtomCarrier.{u}} {A : ArchitectureObject U}
    {S : AATSite A} {geometry : FinitePosetCoverGeometry S}
    (tupleGeometry : FinitePosetCanonicalTupleCoverGeometry geometry) :
    FinitePosetCoverGeometry S where
  ContextIndex := geometry.ContextIndex
  finiteContextIndex := geometry.finiteContextIndex
  context := geometry.context
  contextLe := geometry.contextLe
  contextLe_refl := geometry.contextLe_refl
  contextLe_trans := geometry.contextLe_trans
  contextLe_antisymm := geometry.contextLe_antisymm
  contextLe_sound := geometry.contextLe_sound
  contextMeet := geometry.contextMeet
  contextMeet_le_left := geometry.contextMeet_le_left
  contextMeet_le_right := geometry.contextMeet_le_right
  context_le_meet := geometry.context_le_meet
  base := geometry.base
  cover := geometry.cover
  finiteCoverIndex := geometry.finiteCoverIndex
  nerveSimplex := fun n => FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n
  finiteNerveSimplex := by
    intro n
    letI := geometry.finiteCoverIndex
    infer_instance
  simplexIndices := by
    intro n simplex k
    exact simplex k
  simplexOverlap := tupleGeometry.tupleOverlap
  simplexOverlap_le_patch := tupleGeometry.tupleOverlap_le_patch
  adequacyRequirements := geometry.adequacyRequirements
  coverAdequate := geometry.coverAdequate

/-- X.R1(a): generated canonical tuple simplices are definitional. -/
theorem toCoverGeometry_nerveSimplex_eq {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    {geometry : FinitePosetCoverGeometry S}
    (tupleGeometry : FinitePosetCanonicalTupleCoverGeometry geometry)
    (n : Nat) :
    tupleGeometry.toCoverGeometry.nerveSimplex n =
      FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n :=
  rfl

/-- X.R1(a): generated canonical tuple indices are tuple evaluation. -/
theorem toCoverGeometry_simplexIndices_eq {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    {geometry : FinitePosetCoverGeometry S}
    (tupleGeometry : FinitePosetCanonicalTupleCoverGeometry geometry)
    (n : Nat)
    (simplex : FinitePosetCechCanonicalTupleSimplex geometry.cover.Index n)
    (k : Fin (n + 1)) :
    tupleGeometry.toCoverGeometry.simplexIndices n simplex k = simplex k :=
  rfl

/--
X.R1(a): canonical tuple-overlap geometry generates the canonical tuple nerve
source for any selected coefficient.
-/
def toCanonicalTupleNerveSource {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    {geometry : FinitePosetCoverGeometry S}
    (tupleGeometry : FinitePosetCanonicalTupleCoverGeometry geometry)
    (coefficient : AATPresheaf S) :
    FinitePosetCechCanonicalTupleNerveSource
      (tupleGeometry.toCoverGeometry.toRegime coefficient) where
  simplex_ext := by
    intro n left right h
    funext i
    exact h i
  simplexMap := by
    intro n m f simplex
    exact FinitePosetCechCanonicalTupleSimplex.simplexMap f simplex
  simplexMap_indices := by
    intro n m f simplex i
    rfl
  faceOverlap_le := by
    intro n simplex i
    exact tupleGeometry.tupleOverlap_le_tupleMap (SimplexCategory.δ i) simplex

/-- X.R1(a): tuple geometry generates the face action consumed by Cech. -/
def toSimplicialFaceAction {U : AtomCarrier.{u}}
    {A : ArchitectureObject U} {S : AATSite A}
    {geometry : FinitePosetCoverGeometry S}
    (tupleGeometry : FinitePosetCanonicalTupleCoverGeometry geometry)
    (coefficient : AATPresheaf S) :
    FinitePosetCechSimplicialFaceAction
      (tupleGeometry.toCoverGeometry.toRegime coefficient) :=
  (tupleGeometry.toCanonicalTupleNerveSource coefficient).toSimplicialFaceAction

end FinitePosetCanonicalTupleCoverGeometry

end Site
end AAT.AG
