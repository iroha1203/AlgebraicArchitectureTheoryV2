import Formal.AG.Research.SFT.ConwayBoundaryQuotient

/-!
Cycle 4 evidence for `G-sft-conway-01`.

Cycle 3 used a predicate-driven boundary subgroup for each support fork.  This
file adds explicit provenance for that boundary: a boundary generator is a
chosen owner together with a proof that it supports the fork's communication
block.  The selected generator subgroup is generated by the defect contributed
by such boundary generators.

This is still selected finite receiver vocabulary.  It is not a full boundary
map, quotient object, sheaf cohomology class, or functorial comparison theorem.
-/

namespace Formal.AG.Research
namespace SFT
namespace ConwayTwoTopology

/-! ## Explicit boundary generator provenance -/

/--
An explicit boundary generator for a support fork: one selected owner supports
the fork's communication block.
-/
structure SupportForkBoundaryGenerator {atlas : TwoCoverAtlas}
    (fork : SupportForkOneCochain atlas) where
  owner : atlas.OwnerIdx
  supports : forall context,
    atlas.communication fork.left.comm context -> atlas.ownership owner context

namespace SupportForkBoundaryGenerator

/-- A boundary generator gives the Cycle 2 single-owner support condition. -/
theorem toSingleOwnerSupport {atlas : TwoCoverAtlas}
    {fork : SupportForkOneCochain atlas}
    (generator : SupportForkBoundaryGenerator fork) :
    ForkHasSingleOwnerSupport fork :=
  ⟨generator.owner, generator.supports⟩

/-- A Cycle 2 single-owner support witness can be recorded as a boundary generator. -/
noncomputable def ofSingleOwnerSupport {atlas : TwoCoverAtlas}
    {fork : SupportForkOneCochain atlas}
    (support : ForkHasSingleOwnerSupport fork) :
    SupportForkBoundaryGenerator fork where
  owner := support.choose
  supports := support.choose_spec

end SupportForkBoundaryGenerator

/-- Boundary generators exist exactly when the fork has single-owner support. -/
theorem boundaryGenerator_nonempty_iff_singleOwnerSupport
    {atlas : TwoCoverAtlas} (fork : SupportForkOneCochain atlas) :
    Nonempty (SupportForkBoundaryGenerator fork) ↔
      ForkHasSingleOwnerSupport fork := by
  constructor
  · intro h
    rcases h with ⟨generator⟩
    exact generator.toSingleOwnerSupport
  · intro h
    exact ⟨SupportForkBoundaryGenerator.ofSingleOwnerSupport h⟩

/--
The generator-provenance boundary subgroup: it is generated by the selected
defect of explicit boundary generators.
-/
noncomputable def SupportForkGeneratorBoundarySubgroup {atlas : TwoCoverAtlas}
    (fork : SupportForkOneCochain atlas) : AddSubgroup ConwayZ2 :=
  AddSubgroup.closure
    { value | exists _generator : SupportForkBoundaryGenerator fork,
      value = SupportForkDefect fork }

/-- The selected defect vanishes modulo the explicit generator boundary subgroup. -/
def SupportForkDefectVanishesModuloGeneratorBoundary {atlas : TwoCoverAtlas}
    (fork : SupportForkOneCochain atlas) : Prop :=
  SupportForkDefect fork ∈ SupportForkGeneratorBoundarySubgroup fork

/-- A boundary generator absorbs the selected fork defect. -/
theorem generatorBoundary_absorbs_defect {atlas : TwoCoverAtlas}
    {fork : SupportForkOneCochain atlas}
    (generator : SupportForkBoundaryGenerator fork) :
    SupportForkDefect fork ∈ SupportForkGeneratorBoundarySubgroup fork := by
  exact AddSubgroup.subset_closure ⟨generator, rfl⟩

/--
The explicit generator boundary is contained in the Cycle 3 predicate-driven
boundary subgroup.
-/
theorem generatorBoundarySubgroup_le_predicateBoundary
    {atlas : TwoCoverAtlas} (fork : SupportForkOneCochain atlas) :
    SupportForkGeneratorBoundarySubgroup fork ≤
      SupportForkBoundarySubgroup fork := by
  classical
  by_cases hsupport : ForkHasSingleOwnerSupport fork
  · intro value _hvalue
    simp [SupportForkBoundarySubgroup, hsupport]
  · apply (AddSubgroup.closure_le (SupportForkBoundarySubgroup fork)).2
    intro value hvalue
    rcases hvalue with ⟨generator, rfl⟩
    exact False.elim (hsupport generator.toSingleOwnerSupport)

/--
Functional ownership rules out explicit boundary generators for any support
fork with distinct owner endpoints.
-/
theorem functionalFork_noBoundaryGenerator {atlas : TwoCoverAtlas}
    (functional : OwnershipFunctional atlas)
    (fork : SupportForkOneCochain atlas) :
    Not (Nonempty (SupportForkBoundaryGenerator fork)) := by
  rw [boundaryGenerator_nonempty_iff_singleOwnerSupport]
  exact (supportForkNonzeroClass_iff_noSingleOwnerSupport fork).mp
    (functionalFork_nonzeroClass functional fork)

/--
Under functional ownership, the selected fork defect does not vanish modulo the
explicit generator boundary subgroup.
-/
theorem functionalFork_not_generatorBoundaryVanishes {atlas : TwoCoverAtlas}
    (functional : OwnershipFunctional atlas)
    (fork : SupportForkOneCochain atlas) :
    Not (SupportForkDefectVanishesModuloGeneratorBoundary fork) := by
  intro hvanish
  have hNoGenerator : Not (Nonempty (SupportForkBoundaryGenerator fork)) :=
    functionalFork_noBoundaryGenerator functional fork
  have hleBot :
      SupportForkGeneratorBoundarySubgroup fork ≤ ⊥ := by
    apply (AddSubgroup.closure_le (⊥ : AddSubgroup ConwayZ2)).2
    intro value hvalue
    rcases hvalue with ⟨generator, rfl⟩
    exact False.elim (hNoGenerator ⟨generator⟩)
  have hzero : SupportForkDefect fork = 0 :=
    AddSubgroup.mem_bot.mp (hleBot hvanish)
  exact supportForkDefect_nonzero fork hzero

/-! ## Receiver and finite examples -/

/-- A receiver whose selected defect survives all explicit boundary generators. -/
def GeneratorBoundaryReceiver (atlas : TwoCoverAtlas) : Prop :=
  exists fork : SupportForkOneCochain atlas,
    Not (SupportForkDefectVanishesModuloGeneratorBoundary fork)

/-- A functional ownership fork induces a generator-boundary receiver. -/
theorem generatorBoundaryReceiver_of_functionalFork {atlas : TwoCoverAtlas}
    (functional : OwnershipFunctional atlas)
    (fork : SupportForkOneCochain atlas) :
    GeneratorBoundaryReceiver atlas :=
  ⟨fork, functionalFork_not_generatorBoundaryVanishes functional fork⟩

/-- The canonical mismatched fork has nonzero generator-boundary class. -/
theorem mismatchedSupportFork_notGeneratorBoundaryVanishes :
    Not (SupportForkDefectVanishesModuloGeneratorBoundary mismatchedSupportFork) :=
  functionalFork_not_generatorBoundaryVanishes
    mismatchedAtlas_ownershipFunctional
    mismatchedSupportFork

/-- The mismatched atlas has a generator-boundary receiver. -/
theorem mismatchedAtlas_generatorBoundaryReceiver :
    GeneratorBoundaryReceiver mismatchedAtlas :=
  ⟨mismatchedSupportFork, mismatchedSupportFork_notGeneratorBoundaryVanishes⟩

/-- Compatibility supplies a boundary generator for every support fork. -/
theorem compatible_no_generatorBoundaryReceiver (atlas : TwoCoverAtlas)
    (compatible : CommunicationCoverCompatible atlas) :
    Not (GeneratorBoundaryReceiver atlas) := by
  intro hreceiver
  rcases hreceiver with ⟨fork, hnonzero⟩
  exact hnonzero
    (generatorBoundary_absorbs_defect
      (SupportForkBoundaryGenerator.ofSingleOwnerSupport (compatible fork.left.comm)))

/-- The compatible Cycle 1 atlas has zero generator-boundary receiver. -/
theorem compatibleAtlas_zeroGeneratorBoundaryReceiver :
    Not (GeneratorBoundaryReceiver compatibleAtlas) := by
  apply compatible_no_generatorBoundaryReceiver
  intro comm
  cases comm with
  | platform =>
      refine ⟨Owner.apiOwner, ?_⟩
      intro context hcomm
      cases context <;>
        simp [compatibleAtlas, splitCommunication, splitOwnership] at hcomm ⊢
  | data =>
      refine ⟨Owner.dbOwner, ?_⟩
      intro context hcomm
      cases context <;>
        simp [compatibleAtlas, splitCommunication, splitOwnership] at hcomm ⊢

/-- The reorg-side repaired atlas has zero generator-boundary receiver. -/
theorem reorgedAtlas_zeroGeneratorBoundaryReceiver :
    Not (GeneratorBoundaryReceiver reorgedAtlas) :=
  compatibleAtlas_zeroGeneratorBoundaryReceiver

/-- The refactor-side repaired atlas has zero generator-boundary receiver. -/
theorem refactoredAtlas_zeroGeneratorBoundaryReceiver :
    Not (GeneratorBoundaryReceiver refactoredAtlas) := by
  apply compatible_no_generatorBoundaryReceiver
  intro comm
  cases comm
  refine ⟨(), ?_⟩
  intro context _hcomm
  cases context <;> simp [refactoredAtlas, mergedOwnership]

/--
The selected Cycle 4 package: explicit boundary-generator provenance absorbs
the selected defect in compatible/repaired examples, while functional ownership
prevents such a generator for the mismatched fork.
-/
theorem selectedGeneratorBoundaryReceiverPackage :
    Not (GeneratorBoundaryReceiver compatibleAtlas) /\
      GeneratorBoundaryReceiver mismatchedAtlas /\
      Not (SupportForkDefectVanishesModuloGeneratorBoundary mismatchedSupportFork) /\
      Not (Nonempty (SupportForkBoundaryGenerator mismatchedSupportFork)) /\
      Not (GeneratorBoundaryReceiver reorgedAtlas) /\
      Not (GeneratorBoundaryReceiver refactoredAtlas) := by
  exact
    ⟨compatibleAtlas_zeroGeneratorBoundaryReceiver,
      mismatchedAtlas_generatorBoundaryReceiver,
      mismatchedSupportFork_notGeneratorBoundaryVanishes,
      functionalFork_noBoundaryGenerator
        mismatchedAtlas_ownershipFunctional
        mismatchedSupportFork,
      reorgedAtlas_zeroGeneratorBoundaryReceiver,
      refactoredAtlas_zeroGeneratorBoundaryReceiver⟩

end ConwayTwoTopology
end SFT
end Formal.AG.Research
