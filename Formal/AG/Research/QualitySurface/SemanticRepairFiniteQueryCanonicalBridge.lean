import Formal.AG.Research.QualitySurface.SemanticRepairFiniteQueryRepresentation

/-!
Cycle 24 evidence for `G-aat-quality-surface-04`.

This file records the visible bridge needed to lift finite support-trace
extensionality to canonical all-layer shadow extensionality.  The bridge is a
premise: the current four-bit shadow must determine the chosen finite support
trace shadow.  The file also records a Bool obstruction showing that this
determination is not automatic for trace-sensitive support readings.
-/

namespace Formal.AG.Research
namespace QualitySurface
namespace SemanticRepairFiniteQueryCanonicalBridge

open SemanticRepairObstructionTower
open SemanticRepairUniversalShadow
open SemanticRepairTargetCompletion
open SemanticRepairTraceProbeShadow
open SemanticRepairFiniteTraceSupport
open SemanticRepairFiniteSupportSeparation
open SemanticRepairFiniteSupportCompleteness
open SemanticRepairFiniteQueryObservation
open SemanticRepairFiniteQueryExtensionality
open SemanticRepairFiniteQueryRepresentation

universe u v w x y z

/-! ## Exact support-shadow boundary -/

/-- Equality of finite-support trace shadows implies equality of current shadows. -/
theorem same_supportTraceShadow_implies_same_currentShadow
    {Atom : Type u}
    {support : List Atom}
    {left right :
      FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom}
    (hshadow :
      canonicalSupportTraceProbeTowerLayerShadow support left =
        canonicalSupportTraceProbeTowerLayerShadow support right) :
    canonicalTowerLayerShadow left = canonicalTowerLayerShadow right := by
  exact congrArg TraceProbeFiniteTowerLayerShadow.layer hshadow

/--
Equality of finite-support trace shadows is exactly equality of the current
canonical shadow plus equality of the finite support trace readings.
-/
theorem supportTraceShadow_eq_iff_currentShadow_eq_and_sourceTraceReadings_eq
    {Atom : Type u}
    {support : List Atom}
    {left right :
      FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom} :
    canonicalSupportTraceProbeTowerLayerShadow support left =
        canonicalSupportTraceProbeTowerLayerShadow support right ↔
      canonicalTowerLayerShadow left = canonicalTowerLayerShadow right ∧
        supportTraceVector support left.sourceTraceToken =
          supportTraceVector support right.sourceTraceToken := by
  constructor
  · intro hshadow
    exact
      ⟨congrArg TraceProbeFiniteTowerLayerShadow.layer hshadow,
        congrArg TraceProbeFiniteTowerLayerShadow.sourceTraceReadings hshadow⟩
  · intro hpair
    rcases hpair with ⟨hlayer, hreadings⟩
    change
      ({ layer := canonicalTowerLayerShadow left
         sourceTraceReadings :=
          supportTraceVector support left.sourceTraceToken } :
          TraceProbeFiniteTowerLayerShadow) =
        { layer := canonicalTowerLayerShadow right
          sourceTraceReadings :=
            supportTraceVector support right.sourceTraceToken }
    rw [hlayer, hreadings]

/-! ## Visible bridge from support trace shadow to canonical shadow -/

/--
The current canonical all-layer shadow determines a finite support-trace shadow.

This is a visible material premise.  It is not implied by the support list,
the query package, or semantic soundness in this file.
-/
def CurrentShadowDeterminesSupportTraceShadow
    {Atom : Type u}
    (support : List Atom) : Prop :=
  ∀ left right : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom,
    canonicalTowerLayerShadow left = canonicalTowerLayerShadow right ->
      canonicalSupportTraceProbeTowerLayerShadow support left =
        canonicalSupportTraceProbeTowerLayerShadow support right

/--
The current canonical all-layer shadow determines the trace shadow generated by
a concrete finite query.

This is weaker than determining a larger ambient support trace shadow.  It is
still a visible material premise, not a semantic-soundness theorem.
-/
abbrev CurrentShadowDeterminesTraceQuery
    {Atom : Type u}
    (query : List Atom) : Prop :=
  CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} query

/-- Support-trace extensionality becomes canonical-shadow extensionality. -/
theorem shadowExtensional_of_supportTraceShadowExtensional_of_currentShadowDeterminesSupportTraceShadow
    {Atom : Type u}
    {support : List Atom}
    {Out : Type z}
    {observe :
      FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom -> Out}
    (hcurrent :
      CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} support)
    (extensional : SupportTraceShadowExtensional support observe) :
    ShadowExtensionalTowerObservation observe := by
  intro left right hshadow
  exact extensional left right (hcurrent left right hshadow)

/--
A finite query-generated observation is canonical-shadow extensional when its
support trace shadow is determined by the canonical current shadow.
-/
theorem finiteTraceQueryObservation_shadowExtensional_of_currentShadowDeterminesSupportTraceShadow
    {Atom : Type u}
    {support : List Atom}
    {Out : Type z}
    (obs : FiniteTraceQueryObservation support Out)
    (hcurrent :
      CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} support) :
    ShadowExtensionalTowerObservation
      (fun T : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom =>
        obs.observe T) := by
  exact
    shadowExtensional_of_supportTraceShadowExtensional_of_currentShadowDeterminesSupportTraceShadow hcurrent
      (finiteTraceQueryObservation_supportTraceShadowExtensional obs)

/-- A finite query-generated observation factors through the canonical shadow. -/
theorem finiteTraceQueryObservation_eq_canonicalShadowFactor_of_currentShadowDeterminesSupportTraceShadow
    {Atom : Type u}
    {support : List Atom}
    {Out : Type z}
    (obs : FiniteTraceQueryObservation support Out)
    (hcurrent :
      CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} support)
    (T : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom) :
    obs.observe T =
      canonicalShadowFactor
        (fun U : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom =>
          obs.observe U)
        (canonicalTowerLayerShadow T) := by
  exact
    shadowExtensionalObservation_factors
      (finiteTraceQueryObservation_shadowExtensional_of_currentShadowDeterminesSupportTraceShadow
        obs hcurrent)
      T

/-- A represented finite-query observation is canonical-shadow extensional. -/
theorem representedFiniteTraceQueryObservation_shadowExtensional_of_currentShadowDeterminesSupportTraceShadow
    {Atom : Type u}
    {support : List Atom}
    {Out : Type z}
    {observe :
      FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom -> Out}
    (repr :
      FiniteTraceQueryObservationRepresentation support observe)
    (hcurrent :
      CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} support) :
    ShadowExtensionalTowerObservation observe := by
  exact
    shadowExtensional_of_supportTraceShadowExtensional_of_currentShadowDeterminesSupportTraceShadow hcurrent
      (representedFiniteTraceQueryObservation_supportTraceShadowExtensional
        repr)

/-- A represented finite-query observation factors through the canonical shadow. -/
theorem representedFiniteTraceQueryObservation_eq_canonicalShadowFactor_of_currentShadowDeterminesSupportTraceShadow
    {Atom : Type u}
    {support : List Atom}
    {Out : Type z}
    {observe :
      FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom -> Out}
    (repr :
      FiniteTraceQueryObservationRepresentation support observe)
    (hcurrent :
      CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} support)
    (T : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom) :
    observe T =
      canonicalShadowFactor observe (canonicalTowerLayerShadow T) := by
  exact
    shadowExtensionalObservation_factors
      (representedFiniteTraceQueryObservation_shadowExtensional_of_currentShadowDeterminesSupportTraceShadow
        repr hcurrent)
      T

/--
Universal canonical factorization package for represented finite-query
observations whose support trace shadow is determined by the current shadow.
-/
theorem representedSupportControlledUniversalFactorization
    {Atom : Type u}
    {support : List Atom}
    {Out : Type z}
    {observe :
      FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom -> Out}
    (repr :
      FiniteTraceQueryObservationRepresentation support observe)
    (hcurrent :
      CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y} support) :
    (∀ T : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom,
      observe T =
        canonicalShadowFactor observe (canonicalTowerLayerShadow T)) /\
      (∀ factor : FiniteTowerLayerShadow -> Out,
        (∀ T : FiniteSemanticRepairObstructionTower.{u, v, w, x, y} Atom,
          observe T = factor (canonicalTowerLayerShadow T)) ->
          ∀ shadow,
            factor shadow = canonicalShadowFactor observe shadow) := by
  exact
    shadowExtensionalObservation_universalFactorization observe
      (representedFiniteTraceQueryObservation_shadowExtensional_of_currentShadowDeterminesSupportTraceShadow
        repr hcurrent)

/-! ## Boundary witnesses -/

/-- The empty support trace shadow is determined by the current shadow. -/
theorem nilCurrentShadowDeterminesSupportTraceShadow
    {Atom : Type u} :
    CurrentShadowDeterminesSupportTraceShadow.{u, v, w, x, y}
      (Atom := Atom) ([] : List Atom) := by
  intro left right hshadow
  change
    ({ layer := canonicalTowerLayerShadow left, sourceTraceReadings := [] } :
        TraceProbeFiniteTowerLayerShadow) =
      { layer := canonicalTowerLayerShadow right, sourceTraceReadings := [] }
  rw [hshadow]

/--
The complete Bool support trace shadow is not determined by the current
four-bit shadow.  The existing missed-coordinate pair has the same current
shadow but different complete support trace readings.
-/
theorem not_currentShadowDetermines_boolCompleteSupportTraceShadow :
    ¬ CurrentShadowDeterminesSupportTraceShadow.{0, 0, 0, 0, 0}
      (Atom := Bool)
      SemanticRepairFiniteSupportCompleteness.boolCompleteTraceSupport := by
  intro hcurrent
  have hsupport :=
    hcurrent
      SemanticRepairFiniteSupportSeparation.boolTraceBaseTower
      SemanticRepairFiniteSupportSeparation.boolTraceMissedTrueTower
      SemanticRepairFiniteSupportSeparation.bool_missedTrue_same_currentShadow
  exact
    bool_missedTrue_completeSupportShadow_readings_ne
      (congrArg TraceProbeFiniteTowerLayerShadow.sourceTraceReadings hsupport)

end SemanticRepairFiniteQueryCanonicalBridge
end QualitySurface
end Formal.AG.Research
