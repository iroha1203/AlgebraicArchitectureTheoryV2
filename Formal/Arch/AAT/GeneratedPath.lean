import Formal.Arch.AAT.GeneratedGraph
import Formal.Arch.Evolution.ArchitecturePath

namespace Formal.Arch
namespace AAT

universe u v

/-- Primitive generated architecture step backed by a generated relation atom. -/
structure GeneratedArchitectureStep {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (source target : GeneratedCarrier object) where
  witness : GeneratedRelationEdgeWitness object source target

/-- Finite path family generated by relation atoms in a generated object. -/
abbrev GeneratedArchitecturePath {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation) :=
  ArchitecturePath (GeneratedArchitectureStep object)

namespace GeneratedArchitecturePath

/-- Empty generated path at a generated carrier. -/
def nil {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    {object : GeneratedArchitectureObject presentation}
    (carrier : GeneratedCarrier object) :
    GeneratedArchitecturePath object carrier carrier :=
  ArchitecturePath.nil carrier

/-- Generated path length is the existing finite architecture-path length. -/
def length {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    {object : GeneratedArchitectureObject presentation}
    {source target : GeneratedCarrier object}
    (path : GeneratedArchitecturePath object source target) : Nat :=
  ArchitecturePath.length path

/-- Generated paths preserve invariants through the existing path theorem package. -/
theorem preservesInvariant
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    {object : GeneratedArchitectureObject presentation}
    {I : GeneratedCarrier object -> Prop}
    {source target : GeneratedCarrier object}
    (path : GeneratedArchitecturePath object source target)
    (hStart : ArchitecturePath.InvariantHolds I source)
    (hEvery :
      ArchitecturePath.EveryStepPreserves path I) :
    ArchitecturePath.InvariantHolds I
      (ArchitecturePath.ApplyPath source path) :=
  ArchitecturePath.pathPreservesInvariant path hStart hEvery

end GeneratedArchitecturePath

/-- Generated homotopy is the existing path homotopy restricted to generated steps. -/
abbrev GeneratedPathHomotopy {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    {object : GeneratedArchitectureObject presentation}
    (IndependentSquare :
      (W X Y Z : GeneratedCarrier object) ->
        GeneratedArchitectureStep object W X ->
        GeneratedArchitectureStep object X Z ->
        GeneratedArchitectureStep object W Y ->
        GeneratedArchitectureStep object Y Z -> Prop)
    (SameExternalContract :
      (X Y : GeneratedCarrier object) ->
        GeneratedArchitectureStep object X Y ->
        GeneratedArchitectureStep object X Y -> Prop)
    (RepairFill :
      (X Y : GeneratedCarrier object) ->
        GeneratedArchitecturePath object X Y ->
        GeneratedArchitecturePath object X Y -> Prop)
    {source target : GeneratedCarrier object}
    (left right : GeneratedArchitecturePath object source target) :=
  ArchitecturePath.PathHomotopy
    IndependentSquare SameExternalContract RepairFill left right

end AAT
end Formal.Arch
