import Formal.Arch.AAT.GeneratedMolecule
import Formal.Arch.Law.Observation

namespace Formal.Arch
namespace AAT

universe u v

/--
Architecture object generated by an Atom-compatible molecule.

The carrier list is finite evidence for the generated carrier. It does not
supply a hand-authored graph or law model.
-/
structure GeneratedArchitectureObject {system : AtomAxiomSystem.{u, v}}
    (presentation : AtomShapePresentation system) where
  molecule : GeneratedMolecule presentation
  carrierList : List { atom : system.Atom // molecule.atoms atom }
  carrierListNodup : carrierList.Nodup
  carrierListCovers :
    ∀ carrier : { atom : system.Atom // molecule.atoms atom },
      carrier ∈ carrierList
  objectBoundary : Prop

/-- Components of a generated architecture object are exactly selected atoms. -/
abbrev GeneratedCarrier {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation) :=
  { atom : system.Atom // object.molecule.atoms atom }

/-- Decidable observation coordinate extracted from a shape. -/
structure GeneratedObservationCoordinate where
  family : AtomKind
  axis : Axis
  deriving DecidableEq, Repr

namespace GeneratedObservationCoordinate

/-- Shape coordinates used by generated observations and Signature examples. -/
def ofShape (shape : AtomShape) : GeneratedObservationCoordinate where
  family := shape.family
  axis := shape.axis

end GeneratedObservationCoordinate

namespace GeneratedArchitectureObject

/-- Carrier atoms remain primitive atoms of the root system. -/
theorem carrier_atom_primitive {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (carrier : GeneratedCarrier object) :
    system.Primitive carrier.val :=
  object.molecule.atoms_primitive carrier.property

/-- Generated observations read the shape coordinate of each generated carrier. -/
def generatedObservation {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation) :
    Observation (GeneratedCarrier object) GeneratedObservationCoordinate where
  observe := fun carrier =>
    GeneratedObservationCoordinate.ofShape
      (AtomShapeOf presentation carrier.val)

/-- Semantic atoms contribute semantic generated observations. -/
theorem generated_observation_from_semantic_atoms
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (carrier : GeneratedCarrier object)
    (hSemantic :
      (AtomShapeOf presentation carrier.val).family =
        AtomKind.semanticInterpretation) :
    (object.generatedObservation).observe carrier =
      { family := AtomKind.semanticInterpretation
        axis := (AtomShapeOf presentation carrier.val).axis } := by
  simp [generatedObservation, GeneratedObservationCoordinate.ofShape, hSemantic]

/-- Authority surface generated from authority-shaped atoms. -/
def GeneratedAuthority {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (carrier : GeneratedCarrier object) : Prop :=
  (AtomShapeOf presentation carrier.val).family =
    AtomKind.boundaryAuthority

/-- Effect surface generated from effect-shaped atoms. -/
def GeneratedEffect {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (carrier : GeneratedCarrier object) : Prop :=
  (AtomShapeOf presentation carrier.val).family = AtomKind.effect

/-- Contract surface generated from contract-specification atoms. -/
def GeneratedContract {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (carrier : GeneratedCarrier object) : Prop :=
  (AtomShapeOf presentation carrier.val).family =
    AtomKind.contractSpecification

/-- Semantic interpretation surface generated from semantic-shaped atoms. -/
def GeneratedSemanticInterpretation {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (carrier : GeneratedCarrier object) : Prop :=
  (AtomShapeOf presentation carrier.val).family =
    AtomKind.semanticInterpretation

/--
Semantic-contract coverage is generated when a semantic interpretation atom has
a generated contract-specification atom in the same generated object.
-/
def GeneratedSemanticContractCoverage {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (semantic : GeneratedCarrier object) : Prop :=
  GeneratedSemanticInterpretation object semantic ∧
  ∃ contract : GeneratedCarrier object,
    GeneratedContract object contract

/-- Policy surface generated by an authority-shaped Atom. -/
def GeneratedAuthorityPolicy {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (authority : GeneratedCarrier object) : Prop :=
  GeneratedAuthority object authority

/-- Law input generated by an effect-shaped Atom. -/
def GeneratedEffectLawInput {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (effect : GeneratedCarrier object) : Prop :=
  GeneratedEffect object effect

/--
An effect law is locally satisfied only when an effect Atom has a generated
authority Atom available in the same generated object.
-/
def GeneratedAuthorityEffectLawSatisfied {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (effect : GeneratedCarrier object) : Prop :=
  GeneratedEffectLawInput object effect ∧
  ∃ authority : GeneratedCarrier object,
    GeneratedAuthorityPolicy object authority

/-- Authority policy is generated from authority-shaped Atoms. -/
theorem generated_authority_policy_from_authority_atoms
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (authority : GeneratedCarrier object)
    (hAuthority : GeneratedAuthority object authority) :
    GeneratedAuthorityPolicy object authority :=
  hAuthority

/-- Effect law inputs are generated from effect-shaped Atoms. -/
theorem generated_effect_law_input_from_effect_atoms
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (effect : GeneratedCarrier object)
    (hEffect : GeneratedEffect object effect) :
    GeneratedEffectLawInput object effect :=
  hEffect

/-- Contract surface is generated from contract-specification Atoms. -/
theorem generated_contract_from_contract_atoms
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (contract : GeneratedCarrier object)
    (hContract : GeneratedContract object contract) :
    GeneratedContract object contract :=
  hContract

/-- Semantic interpretation surface is generated from semantic Atoms. -/
theorem generated_semantic_interpretation_from_semantic_atoms
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (semantic : GeneratedCarrier object)
    (hSemantic : GeneratedSemanticInterpretation object semantic) :
    GeneratedSemanticInterpretation object semantic :=
  hSemantic

/--
Semantic-contract coverage is generated only from a semantic Atom and a
contract-specification Atom that are both carriers of the generated object.
-/
theorem generated_semantic_contract_coverage_from_contract_atoms
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (semantic : GeneratedCarrier object)
    (hSemantic : GeneratedSemanticInterpretation object semantic)
    (contract : GeneratedCarrier object)
    (hContract : GeneratedContract object contract) :
    GeneratedSemanticContractCoverage object semantic :=
  ⟨generated_semantic_interpretation_from_semantic_atoms
      object semantic hSemantic,
    contract,
    generated_contract_from_contract_atoms object contract hContract⟩

/--
Authority-effect law satisfaction is generated only from an effect Atom plus a
generated authority policy in the same generated object.
-/
theorem generated_authority_effect_law_satisfied_from_authority_policy
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (effect : GeneratedCarrier object)
    (hEffect : GeneratedEffect object effect)
    (authority : GeneratedCarrier object)
    (hAuthority : GeneratedAuthorityPolicy object authority) :
    GeneratedAuthorityEffectLawSatisfied object effect :=
  ⟨generated_effect_law_input_from_effect_atoms object effect hEffect,
    authority, hAuthority⟩

/-- Without a generated authority policy, an effect law is not locally satisfied. -/
theorem no_authority_policy_not_generated_authority_effect_law_satisfied
    {system : AtomAxiomSystem.{u, v}}
    {presentation : AtomShapePresentation system}
    (object : GeneratedArchitectureObject presentation)
    (effect : GeneratedCarrier object)
    (hNoAuthority :
      ∀ authority : GeneratedCarrier object,
        ¬ GeneratedAuthorityPolicy object authority) :
    ¬ GeneratedAuthorityEffectLawSatisfied object effect := by
  intro hSatisfied
  rcases hSatisfied with ⟨_hEffect, authority, hAuthority⟩
  exact hNoAuthority authority hAuthority

end GeneratedArchitectureObject

end AAT
end Formal.Arch
