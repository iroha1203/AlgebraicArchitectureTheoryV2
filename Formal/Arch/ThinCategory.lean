import Formal.Arch.Category
import Formal.Arch.Reachability

namespace Formal.Arch

universe u

open Formal.Arch.Category

/--
The thin category generated by dependency reachability.

It records only whether one component can reach another; it does not record the
number, length, or shape of dependency walks.
-/
def ComponentCategory {C : Type u} (G : ArchGraph C) : SmallCategory where
  Obj := C
  Hom := Reachable G
  id := Reachable.refl _
  comp := fun f g => Reachable.trans f g
  id_comp := by
    intro X Y f
    apply Subsingleton.elim
  comp_id := by
    intro X Y f
    apply Subsingleton.elim
  assoc := by
    intro W X Y Z f g h
    apply Subsingleton.elim

/-- `ComponentCategory` is thin because every Hom is a proposition. -/
theorem componentCategory_thin {C : Type u} (G : ArchGraph C) :
    ∀ (X Y : (ComponentCategory G).Obj)
      (f g : (ComponentCategory G).Hom X Y), f = g := by
  intro X Y f g
  apply Subsingleton.elim

end Formal.Arch
