namespace Formal.Arch

universe u v w

/--
The Chapter 3 operation catalog stabilized for the Architecture Calculus core.

These tags classify theorem packages; they do not by themselves assert that an
operation preserves, improves, or removes any obstruction.
-/
inductive ArchitectureOperationKind where
  | compose
  | refine
  | abstract
  | replace
  | split
  | merge
  | isolate
  | protect
  | migrate
  | reverse
  | contract
  | repair
  | synthesize
  deriving DecidableEq, Repr

namespace ArchitectureOperationKind

/-- Human-readable operation tag used by documentation-facing theorem packages. -/
def label : ArchitectureOperationKind -> String
  | compose => "compose"
  | refine => "refine"
  | abstract => "abstract"
  | replace => "replace"
  | split => "split"
  | merge => "merge"
  | isolate => "isolate"
  | protect => "protect"
  | migrate => "migrate"
  | reverse => "reverse"
  | contract => "contract"
  | repair => "repair"
  | synthesize => "synthesize"

end ArchitectureOperationKind

/--
Chapter 3 role tags for how an operation is meant to relate invariants,
obstruction witnesses, measures, or assumptions across an architecture change.

These tags are metadata for theorem packages.  A role tag alone does not prove
preservation, reflection, improvement, localization, translation, transfer, or
assumption discharge.
-/
inductive ArchitectureOperationRole where
  | preserve
  | reflect
  | improve
  | localize
  | translate
  | transfer
  | assume
  deriving DecidableEq, Repr

namespace ArchitectureOperationRole

/-- Human-readable operation-role label used by documentation-facing packages. -/
def label : ArchitectureOperationRole -> String
  | preserve => "preserve"
  | reflect => "reflect"
  | improve => "improve"
  | localize => "localize"
  | translate => "translate"
  | transfer => "transfer"
  | assume => "assume"

end ArchitectureOperationRole

/--
Minimal proof-obligation schema for an architecture operation theorem package.

`nonConclusions` is an explicit field: a theorem package must record what it
does not claim, such as runtime or semantic flatness outside the selected
universe.
-/
structure ProofObligation (State : Type u) (Witness : Type v) where
  formalUniverse : Prop
  requiredLaws : Prop
  invariantFamily : State -> Prop
  witnessUniverse : Witness -> Prop
  coverageAssumptions : Prop
  exactnessAssumptions : Prop
  operationPreconditions : Prop
  conclusion : Prop
  nonConclusions : Prop

namespace ProofObligation

variable {State : Type u} {Witness : Type v}

/-- The assumptions that must be visible before the obligation conclusion is used. -/
def AssumptionsHold (P : ProofObligation State Witness) : Prop :=
  P.formalUniverse ∧
  P.requiredLaws ∧
  P.coverageAssumptions ∧
  P.exactnessAssumptions ∧
  P.operationPreconditions

/-- An obligation is discharged when its visible assumptions imply its conclusion. -/
def Discharged (P : ProofObligation State Witness) : Prop :=
  AssumptionsHold P -> P.conclusion

/-- The theorem package explicitly records claims it does not make. -/
def RecordsNonConclusions (P : ProofObligation State Witness) : Prop :=
  P.nonConclusions

/-- A direct conclusion proof discharges the proof obligation. -/
theorem discharged_of_conclusion (P : ProofObligation State Witness)
    (h : P.conclusion) : P.Discharged := by
  intro _hAssumptions
  exact h

end ProofObligation

/--
Operation-specific proof-obligation package.

This records the operation family together with the precondition and
non-conclusion clauses that are generated for that operation.
-/
structure OperationProofObligation (State : Type u) (Witness : Type v) where
  kind : ArchitectureOperationKind
  obligation : ProofObligation State Witness
  precondition : Prop
  nonConclusion : Prop

namespace OperationProofObligation

variable {State : Type u} {Witness : Type v}

/-- Build an operation proof-obligation package for a selected operation kind. -/
def ofKind (kind : ArchitectureOperationKind)
    (obligation : ProofObligation State Witness)
    (precondition nonConclusion : Prop) :
    OperationProofObligation State Witness :=
  { kind
    obligation
    precondition
    nonConclusion }

/-- Proof-obligation package generated by a `compose` operation. -/
def compose (obligation : ProofObligation State Witness)
    (precondition nonConclusion : Prop) :
    OperationProofObligation State Witness :=
  ofKind ArchitectureOperationKind.compose obligation precondition nonConclusion

/-- Proof-obligation package generated by a `refine` operation. -/
def refine (obligation : ProofObligation State Witness)
    (precondition nonConclusion : Prop) :
    OperationProofObligation State Witness :=
  ofKind ArchitectureOperationKind.refine obligation precondition nonConclusion

/-- Proof-obligation package generated by an `abstract` operation. -/
