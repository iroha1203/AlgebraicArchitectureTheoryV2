import Formal.Arch.Finite
import Formal.Arch.Operation

namespace Formal.Arch

universe u

/--
Concrete graph-level transformation kernel for Architecture Calculus operations.

This kernel is deliberately finite: every source and target is a
`FiniteArchGraph`, so graph transformations stay inside the proof-carrying
measurement universe used by executable metrics.
-/
structure ConcreteGraphOperation (C : Type u) where
  kind : ArchitectureOperationKind
  source : FiniteArchGraph C
  target : FiniteArchGraph C
  precondition : Prop
  nonConclusion : Prop

namespace ConcreteGraphOperation

/-- The proof-obligation package generated by a concrete graph operation. -/
def generatedProofObligation {C : Type u}
    (op : ConcreteGraphOperation C) :
    OperationProofObligation (FiniteArchGraph C) PUnit :=
  OperationProofObligation.ofKind op.kind
    { formalUniverse := True
      requiredLaws := True
      invariantFamily := fun _ => True
      witnessUniverse := fun _ => True
      coverageAssumptions := True
      exactnessAssumptions := True
      operationPreconditions := op.precondition
      conclusion := True
      nonConclusions := op.nonConclusion }
    op.precondition
    op.nonConclusion

/--
Connect a concrete graph operation to the existing `ArchitectureOperation`
schema.

The witness family is intentionally trivial here: graph-level preservation
theorems are proved separately on the concrete source and target graphs.
-/
def toArchitectureOperation {C : Type u}
    (op : ConcreteGraphOperation C) :
    ArchitectureOperation (FiniteArchGraph C) PUnit PUnit where
  kind := op.kind
  source := op.source
  target := op.target
  precondition := op.precondition
  generatedProofObligation := op.generatedProofObligation
  generatedProofObligationKind := rfl
  sourceWitness := fun _ => True
  targetWitness := fun _ => True
  witnessMap := id
  witnessMappingSound := by
    intro _ _h
    trivial
  nonConclusion := op.nonConclusion

/-- Concrete operations preserve their operation tag when embedded in the schema. -/
theorem toArchitectureOperation_kind {C : Type u}
    (op : ConcreteGraphOperation C) :
    op.toArchitectureOperation.kind = op.kind :=
  rfl

/-- Concrete operations preserve their source when embedded in the schema. -/
theorem toArchitectureOperation_source {C : Type u}
    (op : ConcreteGraphOperation C) :
    op.toArchitectureOperation.source = op.source :=
  rfl

/-- Concrete operations preserve their target when embedded in the schema. -/
theorem toArchitectureOperation_target {C : Type u}
    (op : ConcreteGraphOperation C) :
    op.toArchitectureOperation.target = op.target :=
  rfl

end ConcreteGraphOperation

namespace ArchGraph

/-- Reverse every dependency edge in a graph. -/
def reverse {C : Type u} (G : ArchGraph C) : ArchGraph C where
  edge c d := G.edge d c

/-- Membership in a reversed graph is exactly the opposite edge of the source graph. -/
theorem reverse_edge_iff {C : Type u} (G : ArchGraph C) {c d : C} :
    (G.reverse).edge c d ↔ G.edge d c :=
  Iff.rfl

/-- Reversing twice restores the original edge relation. -/
theorem reverse_reverse_edge_iff {C : Type u} (G : ArchGraph C) {c d : C} :
    (G.reverse.reverse).edge c d ↔ G.edge c d :=
  Iff.rfl

end ArchGraph

namespace FiniteArchGraph

/-- Reverse every dependency edge while keeping the same finite component universe. -/
def reverse {C : Type u} (FG : FiniteArchGraph C) : FiniteArchGraph C where
  graph := FG.graph.reverse
  componentUniverse :=
    { components := FG.components
      nodup := FG.nodup_components
      covers := FG.covers_components
      edgeClosed := by
        intro c d hEdge
        have hClosed := FG.edgeClosed_components hEdge
        exact ⟨hClosed.2, hClosed.1⟩ }

/-- Edges of the reversed finite graph are exactly source edges in the opposite direction. -/
theorem reverse_edge_iff {C : Type u} (FG : FiniteArchGraph C) {c d : C} :
    FG.reverse.graph.edge c d ↔ FG.graph.edge d c :=
  Iff.rfl

/-- Reversing a finite graph twice restores the original edge relation. -/
theorem reverse_reverse_edge_iff {C : Type u} (FG : FiniteArchGraph C) {c d : C} :
    FG.reverse.reverse.graph.edge c d ↔ FG.graph.edge c d :=
  Iff.rfl

/--
Protect is the graph-level identity transform at this kernel layer.

Runtime protection parameters such as fallback, queue, or circuit breaker labels
belong to later runtime-semantic packages; the finite static graph is preserved.
-/
def protect {C : Type u} (FG : FiniteArchGraph C) : FiniteArchGraph C :=
  FG

/-- The graph-level protect kernel preserves exactly the source edge relation. -/
theorem protect_edge_iff {C : Type u} (FG : FiniteArchGraph C) {c d : C} :
    FG.protect.graph.edge c d ↔ FG.graph.edge c d :=
  Iff.rfl

end FiniteArchGraph

namespace ConcreteGraphOperation

/-- Concrete `reverse` graph operation on a finite architecture graph. -/
def reverse {C : Type u} (FG : FiniteArchGraph C) :
    ConcreteGraphOperation C where
  kind := ArchitectureOperationKind.reverse
  source := FG
  target := FG.reverse
  precondition := True
  nonConclusion := True

/-- Concrete `protect` graph operation on a finite architecture graph. -/
def protect {C : Type u} (FG : FiniteArchGraph C) :
    ConcreteGraphOperation C where
  kind := ArchitectureOperationKind.protect
  source := FG
  target := FG.protect
  precondition := True
  nonConclusion := True

/-- The concrete reverse operation is connected to the `reverse` operation kind. -/
theorem reverse_kind {C : Type u} (FG : FiniteArchGraph C) :
    (reverse FG).kind = ArchitectureOperationKind.reverse :=
  rfl

/-- The concrete protect operation is connected to the `protect` operation kind. -/
theorem protect_kind {C : Type u} (FG : FiniteArchGraph C) :
    (protect FG).kind = ArchitectureOperationKind.protect :=
  rfl

/-- The schema embedding of concrete reverse keeps the `reverse` operation kind. -/
theorem reverse_schema_kind {C : Type u} (FG : FiniteArchGraph C) :
    (reverse FG).toArchitectureOperation.kind =
      ArchitectureOperationKind.reverse :=
  rfl

/-- The schema embedding of concrete protect keeps the `protect` operation kind. -/
theorem protect_schema_kind {C : Type u} (FG : FiniteArchGraph C) :
    (protect FG).toArchitectureOperation.kind =
      ArchitectureOperationKind.protect :=
  rfl

end ConcreteGraphOperation

end Formal.Arch
