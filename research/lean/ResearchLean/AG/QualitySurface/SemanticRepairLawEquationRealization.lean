/-! ## Law-equation witness-ideal core -/

/--
G-06 law-equation input geometry (core data).

`Observable` is a ring-valued presheaf of readings on the AAT site, given as
raw restriction data so the lower restriction geometry stays visible.
`violationWitness` realizes each law index as an atom-indexed family of
violation coordinates inside the observable ring, mirroring the III.定義5.1
violation witness family.  `violationWitness_restrict` is the material lower
restriction geometry isolated by Cycle 346/347: the equations themselves are
restriction-compatible.

The structure stores no interpretation map, no overlap equality, no
compatibility law, no Cech data, and no vanishing conclusion.
-/
structure SemanticLawEquationWitnessIdealCore
    {U : AAT.AG.AtomCarrier.{r}} {A : AAT.AG.ArchitectureObject U}
    (semanticSite : SemanticRepairSite.{r, v} U.Atom)
    (S : AAT.AG.Site.AATSite A) where
  Observable : S.category -> Type r
  observableCommRing : forall W : S.category, CommRing (Observable W)
  restrict :
    forall {source target : S.category},
      (source ⟶ target) -> Observable target →+* Observable source
  restrict_id :
    forall (W : S.category) (x : Observable W), restrict (𝟙 W) x = x
  restrict_comp :
    forall {W₀ W₁ W₂ : S.category} (f : W₀ ⟶ W₁) (g : W₁ ⟶ W₂)
      (x : Observable W₂),
      restrict (f ≫ g) x = restrict f (restrict g x)
  violationWitness :
    forall (W : S.category), S.lawUniverse.Index -> U.Atom -> Observable W
  violationWitness_restrict :
    forall {source target : S.category} (f : source ⟶ target)
      (lawIndex : S.lawUniverse.Index) (atom : U.Atom),
      restrict f (violationWitness target lawIndex atom) =
        violationWitness source lawIndex atom
  supportAtom : U.Atom
  supportAtom_traceVisible : semanticSite.sourceTraceToken supportAtom = true
  supportLawIndex : S.lawUniverse.Index
  supportLawIndex_required : S.lawUniverse.Required supportLawIndex

attribute [instance] SemanticLawEquationWitnessIdealCore.observableCommRing

namespace SemanticLawEquationWitnessIdealCore

variable {U : AAT.AG.AtomCarrier.{r}} {A : AAT.AG.ArchitectureObject U}
variable {semanticSite : SemanticRepairSite.{r, v} U.Atom}
variable {S : AAT.AG.Site.AATSite A}

/--
III.定義5.2 realization: the witness ideal of one law is the span of its
atom-indexed violation coordinates.  The ideal is atom-generated by
construction; no ad hoc generator can be inserted.
-/
def lawWitnessIdeal
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    (W : S.category) (lawIndex : S.lawUniverse.Index) :
    Ideal (G.Observable W) :=
  Ideal.span (Set.range (G.violationWitness W lawIndex))

/--
III.定義6.1 reuse: the selected law witness ideal family at one context, with
selection given exactly by required-law membership in the site law universe.
-/
def selectedLawWitnessIdealFamily
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    (W : S.category) :
    AAT.AG.LawAlgebra.ObstructionIdeal.SelectedLawWitnessIdealFamily.{r, r}
      (G.Observable W) where
  LawIndex := S.lawUniverse.Index
  selected := S.lawUniverse.Required
  witnessIdeal := G.lawWitnessIdeal W

/-- III.定義6.1 reuse: the local obstruction ideal `I_Ob(W) = Σ_L I_L(W)`. -/
def obstructionIdeal
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    (W : S.category) : Ideal (G.Observable W) :=
  (G.selectedLawWitnessIdealFamily W).localObstructionIdeal

/--
A required law's witness ideal is contained in the local obstruction ideal.
This is the LawAlgebra containment theorem read through the realization.
-/
theorem lawWitnessIdeal_le_obstructionIdeal
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    (W : S.category) {lawIndex : S.lawUniverse.Index}
    (hrequired : S.lawUniverse.Required lawIndex) :
    G.lawWitnessIdeal W lawIndex ≤ G.obstructionIdeal W :=
  AAT.AG.LawAlgebra.ObstructionIdeal.SelectedLawWitnessIdealFamily.witnessIdeal_le_localObstructionIdeal
    (G.Observable W) (G.selectedLawWitnessIdealFamily W) hrequired

/--
Lower restriction geometry, ideal level: restriction maps each law's witness
ideal into the same law's witness ideal on the smaller context.  The proof
uses only `Ideal.map_span` and the coordinate-level restriction compatibility;
no overlap equality or interpretation data enters.
-/
theorem map_lawWitnessIdeal_le
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    {source target : S.category} (f : source ⟶ target)
    (lawIndex : S.lawUniverse.Index) :
    Ideal.map (G.restrict f) (G.lawWitnessIdeal target lawIndex) ≤
      G.lawWitnessIdeal source lawIndex := by
  rw [lawWitnessIdeal, Ideal.map_span]
  refine Ideal.span_mono ?_
  rintro x ⟨y, ⟨atom, rfl⟩, rfl⟩
  exact ⟨atom, (G.violationWitness_restrict f lawIndex atom).symm⟩

/--
III.定義6.2 reuse: the realization's restriction maps are
`RestrictionCompatible` for the selected law witness ideal families.
-/
def restrictionCompatible
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    {source target : S.category} (f : source ⟶ target) :
    AAT.AG.LawAlgebra.ObstructionIdeal.SelectedLawWitnessIdealFamily.RestrictionCompatible
      (G.selectedLawWitnessIdealFamily target)
      (G.selectedLawWitnessIdealFamily source)
      (G.restrict f) where
  maps_selected := fun lawIndex hselected =>
    ⟨lawIndex, hselected, G.map_lawWitnessIdeal_le f lawIndex⟩

/--
III.定義6.2 reuse: restriction maps the local obstruction ideal into the local
obstruction ideal.  This is `map_localObstructionIdeal_le` from
`Formal.AG.LawAlgebra.ObstructionIdeal`, consumed as a theorem rather than
re-proved or supplied as a field.
-/
theorem map_obstructionIdeal_le
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    {source target : S.category} (f : source ⟶ target) :
    Ideal.map (G.restrict f) (G.obstructionIdeal target) ≤
      G.obstructionIdeal source :=
  AAT.AG.LawAlgebra.ObstructionIdeal.SelectedLawWitnessIdealFamily.map_localObstructionIdeal_le
    (G.restrictionCompatible f)

/-! ## Generated obstruction-quotient coefficient -/

/--
The generated obstruction coefficient carrier: readings modulo the local
obstruction ideal.  This is the IV.定義2.4 lawful-locus quotient
`O / I_Ob` read as the semantic coefficient carrier.
-/
abbrev ObstructionQuotient
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    (W : S.category) : Type r :=
  G.Observable W ⧸ G.obstructionIdeal W

/--
The generated restriction map on obstruction quotients, induced by
`Ideal.quotientMap` along the LawAlgebra restriction-compatibility theorem.
-/
def obstructionQuotientRestrict
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    {source target : S.category} (f : source ⟶ target) :
    G.ObstructionQuotient target →+* G.ObstructionQuotient source :=
  Ideal.quotientMap (G.obstructionIdeal source) (G.restrict f)
    (Ideal.map_le_iff_le_comap.mp (G.map_obstructionIdeal_le f))

/--
The generated quotient restriction acts on classes by restricting a
representative.  This is the construction-unfolding lemma used by all
functoriality proofs below.
-/
theorem obstructionQuotientRestrict_mk
    (G : SemanticLawEquationWitnessIdealCore semanticSite S)
    {source target : S.category} (f : source ⟶ target)
    (x : G.Observable target) :
    G.obstructionQuotientRestrict f
        (Ideal.Quotient.mk (G.obstructionIdeal target) x) =
      Ideal.Quotient.mk (G.obstructionIdeal source) (G.restrict f x) := by
  simp [obstructionQuotientRestrict]

/--
The generated additive-group-valued obstruction coefficient presheaf.

Object part: the obstruction quotient.  Map part: the generated quotient
restriction.  Identity and composition laws are proved from the observable
presheaf laws by quotient induction; they are not supplied as fields.
-/
def obstructionQuotientCoefficient
    (G : SemanticLawEquationWitnessIdealCore semanticSite S) :
    S.categoryᵒᵖ ⥤ AddCommGrpCat.{r} where
  obj W := AddCommGrpCat.of (G.ObstructionQuotient W.unop)
  map {X Y} φ :=
    AddCommGrpCat.ofHom (G.obstructionQuotientRestrict φ.unop).toAddMonoidHom
  map_id X := by
    ext x
    refine Quotient.inductionOn' x ?_
    intro r
    show G.obstructionQuotientRestrict (𝟙 X.unop)
        (Ideal.Quotient.mk (G.obstructionIdeal X.unop) r) =
      Ideal.Quotient.mk (G.obstructionIdeal X.unop) r
    rw [G.obstructionQuotientRestrict_mk, G.restrict_id]
  map_comp {X Y Z} φ ψ := by
    ext x
    refine Quotient.inductionOn' x ?_
    intro r
    show G.obstructionQuotientRestrict (ψ.unop ≫ φ.unop)
        (Ideal.Quotient.mk (G.obstructionIdeal X.unop) r) =
      G.obstructionQuotientRestrict ψ.unop
        (G.obstructionQuotientRestrict φ.unop
          (Ideal.Quotient.mk (G.obstructionIdeal X.unop) r))
    rw [G.obstructionQuotientRestrict_mk, G.obstructionQuotientRestrict_mk,
      G.obstructionQuotientRestrict_mk, G.restrict_comp]

end SemanticLawEquationWitnessIdealCore

/-! ## Law-equation geometry and the generated coefficient realization -/

/--
G-06 law-equation input geometry.

This bundles the witness-ideal core with the sheaf condition of the generated
obstruction-quotient presheaf.  The sheaf condition is input geometry in the
same ambient position as the existing
`SemanticAtomLawAdditiveCoefficientGeometry.isSheaf` field; it asserts nothing
about interpretation maps, overlap equality of any source, `sourceC0CechZero`,
residual zero, `H1` zero, or global coherence.
-/
structure SemanticLawEquationWitnessIdealGeometry
    {U : AAT.AG.AtomCarrier.{r}} {A : AAT.AG.ArchitectureObject U}
    (semanticSite : SemanticRepairSite.{r, v} U.Atom)
    (S : AAT.AG.Site.AATSite A) extends
      SemanticLawEquationWitnessIdealCore semanticSite S where
  quotientIsSheaf :
    AAT.AG.Site.AATSheafCondition S
      (toSemanticLawEquationWitnessIdealCore.obstructionQuotientCoefficient ⋙
        forget AddCommGrpCat)

namespace SemanticLawEquationWitnessIdealGeometry

variable {U : AAT.AG.AtomCarrier.{r}} {A : AAT.AG.ArchitectureObject U}
variable {semanticSite : SemanticRepairSite.{r, v} U.Atom}
variable {S : AAT.AG.Site.AATSite A}

/--
The law-equation geometry generates the Cycle 247 semantic atom/law additive
coefficient geometry.  The coefficient functor is the generated
obstruction-quotient presheaf, so additive restriction laws are constructed by
`obstructionQuotientCoefficient` rather than supplied; the support fields are
the designated trace-visible atom and required law index.
-/
def toSemanticAtomLawAdditiveCoefficientGeometry
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S) :
    SemanticAtomLawAdditiveCoefficientGeometry semanticSite S where
  coefficient :=
    G.toSemanticLawEquationWitnessIdealCore.obstructionQuotientCoefficient
  isSheaf := G.quotientIsSheaf
  atomSupport := fun _ _ => [G.supportAtom]
  atomSupport_traceVisible := fun _ _ =>
    ⟨G.supportAtom, List.mem_singleton_self G.supportAtom,
      G.supportAtom_traceVisible⟩
  lawSupport := fun _ _ => [G.supportLawIndex]
  lawSupport_nonempty := fun _ _ =>
    ⟨G.supportLawIndex, List.mem_singleton_self G.supportLawIndex⟩
  lawSupport_required := fun _ _ lawIndex hmem => by
    have heq : lawIndex = G.supportLawIndex := List.eq_of_mem_singleton hmem
    exact heq ▸ G.supportLawIndex_required

/--
The generated obstruction sheaf of the law-equation realization: the
obstruction-quotient coefficient read through the Cycle 246/247 additive
restriction route.  Its carrier presheaf is the generated quotient; nothing is
supplied beyond the geometry itself.
-/
abbrev lawEquationObstructionSheaf
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S) :
    AAT.AG.Cohomology.ObstructionSheaf S :=
  G.toSemanticAtomLawAdditiveCoefficientGeometry.toAdditiveRestrictionLaw.toObstructionSheaf

/--
Sections of the generated obstruction sheaf at a context are the obstruction
quotient at that context.  This is a construction-unfolding bridge, proved by
definitional equality alone.
-/
def toObstructionSection
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S)
    (W : S.category)
    (x : G.toSemanticLawEquationWitnessIdealCore.ObstructionQuotient W) :
    G.lawEquationObstructionSheaf.carrier.toPresheaf.obj (op W) :=
  x

end SemanticLawEquationWitnessIdealGeometry

end CoverRelativeCechGeneratedSemanticCoefficient

/-! ## Law-equation defect source and the generated positive constructions -/

namespace CoverRelativeCechFinitePosetChartProjectionPointwiseAtomLawInputBoundaryBasis

open CoverRelativeCechGeneratedSemanticCoefficient

variable {U : AAT.AG.AtomCarrier.{r}} {A : AAT.AG.ArchitectureObject U}
variable {semanticSite : SemanticRepairSite.{r, v} U.Atom}
variable {S : AAT.AG.Site.AATSite A}

/-- The generated finite-poset regime of the law-equation realization. -/
abbrev lawEquationRegime
    (coverGeometry : FinitePosetAtomLawCoverGeometry S)
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S) :=
  (coverGeometry.canonicalTupleOverlapGeometryFromOverlap.toCanonicalTupleCoverGeometry).toObstructionCoefficientRegime
    G.lawEquationObstructionSheaf

/-- The generated standard finite-poset Cech complex of the realization. -/
abbrev lawEquationStandardComplex
    (coverGeometry : FinitePosetAtomLawCoverGeometry S)
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S) :=
  atomLawOverlapStandardFinitePosetCechComplex coverGeometry
    G.lawEquationObstructionSheaf

/-- The generated cover-relative Cech complex of the realization. -/
abbrev lawEquationCechComplex
    (coverGeometry : FinitePosetAtomLawCoverGeometry S)
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S) :=
  atomLawOverlapCoverRelativeCechComplex coverGeometry
    G.lawEquationObstructionSheaf

/-- The displayed atom/law chart of the generated realization cover. -/
abbrev lawEquationChart
    (coverGeometry : FinitePosetAtomLawCoverGeometry S)
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S)
    (i : (lawEquationRegime coverGeometry G).cover.Index) :
    S.category :=
  (AAT.AG.Cohomology.finitePosetCoverRelativeCover
    (lawEquationStandardComplex coverGeometry G)).chart i

/--
G-06 law-equation defect source.

This is the input-boundary source for the generated realization: local inputs,
atom/law support, a displayed architecture-object reading, and a defect
observable for each local input.  The single semantic tie `holds_defect_mem`
is the law-as-equation semantics: a displayed required law holding on the
displayed local reading places the displayed defect inside that law's own
atom-generated witness ideal on the same chart.

The tie is pointwise and chart-local.  The structure has no `interpret` field:
the interpretation is generated below as the obstruction-quotient class of the
defect.  No overlap equality, `arrowCompatibilityLaw`,
`commonRestrictionRealization`, evaluator, `sourceC0CechZero`, residual-zero,
or `H1` zero appears as a field.
-/
structure LawEquationDefectSemanticAtomLawInputBoundarySource
    (coverGeometry : FinitePosetAtomLawCoverGeometry S)
    (G : SemanticLawEquationWitnessIdealGeometry semanticSite S)
    (skeleton :
      SourceSectionFreeSkeleton
        (semanticSite := semanticSite) (S := S)
        (regime := lawEquationRegime coverGeometry G)
        (C := lawEquationStandardComplex coverGeometry G)
        (Ob := G.lawEquationObstructionSheaf)
        (K := lawEquationCechComplex coverGeometry G)) where
  LocalInput : (lawEquationRegime coverGeometry G).cover.Index -> Type r
  input : (i : (lawEquationRegime coverGeometry G).cover.Index) -> LocalInput i
  atomSupport :
    (i : (lawEquationRegime coverGeometry G).cover.Index) ->
      LocalInput i -> List U.Atom
  atomSupport_traceVisible :
    forall (i : (lawEquationRegime coverGeometry G).cover.Index)
      (localInput : LocalInput i),
      exists atom : U.Atom,
        atom ∈ atomSupport i localInput ∧
          semanticSite.sourceTraceToken atom = true
  lawSupport :
    (i : (lawEquationRegime coverGeometry G).cover.Index) ->
      LocalInput i -> List S.lawUniverse.Index
  lawSupport_nonempty :
    forall (i : (lawEquationRegime coverGeometry G).cover.Index)
      (localInput : LocalInput i),
      exists lawIndex : S.lawUniverse.Index,
        lawIndex ∈ lawSupport i localInput
  lawSupport_required :
    forall (i : (lawEquationRegime coverGeometry G).cover.Index)
      (localInput : LocalInput i) (lawIndex : S.lawUniverse.Index),
      lawIndex ∈ lawSupport i localInput -> S.lawUniverse.Required lawIndex
  objectOfLocalInput :
    (i : (lawEquationRegime coverGeometry G).cover.Index) ->
      LocalInput i -> AAT.AG.ArchitectureObject U
  defect :
    (i : (lawEquationRegime coverGeometry G).cover.Index) ->
      LocalInput i ->
        G.Observable (lawEquationChart coverGeometry G i)
  holds_defect_mem :
    forall (i : (lawEquationRegime coverGeometry G).cover.Index)
      (lawIndex : S.lawUniverse.Index),
      lawIndex ∈ lawSupport i (input i) ->
        S.lawUniverse.Required lawIndex ->
          (S.lawUniverse.law lawIndex).holds (objectOfLocalInput i (input i)) ->
            defect i (input i) ∈
              G.toSemanticLawEquationWitnessIdealCore.lawWitnessIdeal
                (lawEquationChart coverGeometry G i) lawIndex

namespace LawEquationDefectSemanticAtomLawInputBoundarySource

variable {coverGeometry : FinitePosetAtomLawCoverGeometry S}
variable {G : SemanticLawEquationWitnessIdealGeometry semanticSite S}
variable {skeleton :
  SourceSectionFreeSkeleton
    (semanticSite := semanticSite) (S := S)
    (regime := lawEquationRegime coverGeometry G)
    (C := lawEquationStandardComplex coverGeometry G)
    (Ob := G.lawEquationObstructionSheaf)
    (K := lawEquationCechComplex coverGeometry G)}

/--
Generate the Cycle 295 support-only source from the law-equation defect
source.  The `interpret` map is not a free field: it is the
obstruction-quotient class of the displayed defect observable.
-/
def toSupportOnlySemanticAtomLawInputBoundarySource
    (D :
      LawEquationDefectSemanticAtomLawInputBoundarySource coverGeometry G
        skeleton) :
    SourceSectionFreeSkeleton.GeneratedFinitePosetSelectedCoverPresieveSupportOnlySemanticAtomLawInputBoundarySource
      skeleton where
  LocalInput := D.LocalInput
  input := D.input
  atomSupport := D.atomSupport
  atomSupport_traceVisible := D.atomSupport_traceVisible
  lawSupport := D.lawSupport
  lawSupport_nonempty := D.lawSupport_nonempty
  lawSupport_required := D.lawSupport_required
  interpret := fun i localInput =>
    G.toObstructionSection (lawEquationChart coverGeometry G i)
      (Ideal.Quotient.mk
        (G.toSemanticLawEquationWitnessIdealCore.obstructionIdeal
          (lawEquationChart coverGeometry G i))
        (D.defect i localInput))

/--
Law-equation vanishing theorem: if the displayed required laws hold on the
displayed local readings, then every generated interpretation is the zero
class of the obstruction quotient.

The proof consumes `holds` through the law-as-equation tie and the LawAlgebra
containment `I_L ≤ I_Ob`; it does not consume any overlap equality,
compatibility law, or Cech-side premise.
-/
theorem displayedRequiredLawsHoldOn_constructs_interpret_eq_zero
    (D :
      LawEquationDefectSemanticAtomLawInputBoundarySource coverGeometry G
        skeleton)
    (hholds :
      D.toSupportOnlySemanticAtomLawInputBoundarySource.displayedRequiredLawsHoldOn
        D.objectOfLocalInput) :
    forall i : (lawEquationRegime coverGeometry G).cover.Index,
      D.toSupportOnlySemanticAtomLawInputBoundarySource.interpret i
          (D.toSupportOnlySemanticAtomLawInputBoundarySource.input i) = 0 := by
  intro i
  obtain ⟨lawIndex, hmem⟩ := D.lawSupport_nonempty i (D.input i)
  have hrequired : S.lawUniverse.Required lawIndex :=
    D.lawSupport_required i (D.input i) lawIndex hmem
  have hholdsLaw :
      (S.lawUniverse.law lawIndex).holds (D.objectOfLocalInput i (D.input i)) :=
    hholds i lawIndex hmem hrequired
  have hdefect :
      D.defect i (D.input i) ∈
        G.toSemanticLawEquationWitnessIdealCore.lawWitnessIdeal
          (lawEquationChart coverGeometry G i) lawIndex :=
    D.holds_defect_mem i lawIndex hmem hrequired hholdsLaw
  have hobstruction :
      D.defect i (D.input i) ∈
        G.toSemanticLawEquationWitnessIdealCore.obstructionIdeal
          (lawEquationChart coverGeometry G i) :=
    G.toSemanticLawEquationWitnessIdealCore.lawWitnessIdeal_le_obstructionIdeal
      (lawEquationChart coverGeometry G i) hrequired hdefect
  exact Ideal.Quotient.eq_zero_iff_mem.mpr hobstruction

/--
Construction-faithfulness reading: the generated interpretation vanishes
exactly when the displayed defect lies in the atom-generated local obstruction
ideal.  Vanishing is therefore ideal membership, not a definitional collapse.
-/
theorem interpret_eq_zero_iff_defect_mem_obstructionIdeal
    (D :
      LawEquationDefectSemanticAtomLawInputBoundarySource coverGeometry G
        skeleton)
    (i : (lawEquationRegime coverGeometry G).cover.Index) :
    D.toSupportOnlySemanticAtomLawInputBoundarySource.interpret i
        (D.toSupportOnlySemanticAtomLawInputBoundarySource.input i) = 0 <->
      D.defect i (D.input i) ∈
        G.toSemanticLawEquationWitnessIdealCore.obstructionIdeal
          (lawEquationChart coverGeometry G i) :=
  Ideal.Quotient.eq_zero_iff_mem

/--
Nondegeneracy reading: a displayed defect outside the local obstruction ideal
has a nonzero generated interpretation.  The quotient realization is faithful:
it does not collapse every reading to zero.
-/
theorem interpret_ne_zero_of_defect_notMem_obstructionIdeal
    (D :
      LawEquationDefectSemanticAtomLawInputBoundarySource coverGeometry G
        skeleton)
    (i : (lawEquationRegime coverGeometry G).cover.Index)
    (hnot :
      D.defect i (D.input i) ∉
        G.toSemanticLawEquationWitnessIdealCore.obstructionIdeal
          (lawEquationChart coverGeometry G i)) :
    D.toSupportOnlySemanticAtomLawInputBoundarySource.interpret i
        (D.toSupportOnlySemanticAtomLawInputBoundarySource.input i) ≠ 0 :=
  fun h => hnot ((D.interpret_eq_zero_iff_defect_mem_obstructionIdeal i).mp h)

/--
Detector soundness: a nonzero generated interpretation certifies that every
displayed required law fails on the displayed local reading.  This is the
AAT reading of the obstruction class: nonzero class means law failure, traced
through the displayed law support.
-/
theorem interpret_ne_zero_detects_displayed_required_law_failure
    (D :
      LawEquationDefectSemanticAtomLawInputBoundarySource coverGeometry G
        skeleton)
    (i : (lawEquationRegime coverGeometry G).cover.Index)
    (hne :
      D.toSupportOnlySemanticAtomLawInputBoundarySource.interpret i
          (D.toSupportOnlySemanticAtomLawInputBoundarySource.input i) ≠ 0) :
    forall lawIndex : S.lawUniverse.Index,
      lawIndex ∈ D.lawSupport i (D.input i) ->
        S.lawUniverse.Required lawIndex ->
