import ResearchLean.AG.QualitySurface.LawGeneratedLargeCoefficientCech
import ResearchLean.AG.QualitySurface.LawGeneratedIdealPowerLiftedSheafification
import Formal.Util.AssertStandardAxioms
import Mathlib.Tactic

/-!
# Degree-zero comparison for large additive sheaves

For the canonical tuple complex of a selected finite-poset cover, degree-zero
cohomology is the kernel of the first differential.  This file proves directly
from the bundled sheaf condition that sections on the selected base are
additively equivalent to this cover-relative `H⁰`.

The inverse map is generated by canonical-pair compatibility, extension to all
common refinements, and sheaf amalgamation.  No compatible family, gluing
witness, or comparison inverse is supplied as input.
-/

noncomputable section

namespace ResearchLean.AG.QualitySurface
namespace LawGeneratedLargeCoefficientH0

universe u

open CategoryTheory Limits Opposite
open AAT.AG

variable {U : AtomCarrier.{u}} {A : ArchitectureObject U}
variable {S : Site.AATSite A}
variable {geometry : Site.FinitePosetCoverGeometry S}

/-- The degree-zero restriction cochain of a section over the selected base. -/
def restrictionCochain (F : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u + 1})
    (x : F.obj (op geometry.base)) :
    LawGeneratedLargeCoefficientCech.Cochain geometry F 0 :=
  fun sigma => F.map (homOfLE (geometry.cover.inclusion (sigma 0))).op x

/-- Restrictions of one base section agree on every canonical pair overlap. -/
theorem restrictionCochain_cocycle
    (F : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u + 1})
    (x : F.obj (op geometry.base)) :
    LawGeneratedLargeCoefficientCech.d0 geometry F
      (restrictionCochain (geometry := geometry) F x) = 0 := by
  funext sigma
  dsimp [LawGeneratedLargeCoefficientCech.d0,
    LawGeneratedLargeCoefficientCech.differential]
  rw [Fin.sum_univ_two]
  simp only [Fin.val_zero, Fin.val_one,
    if_pos (by decide : Even 0), if_neg (by decide : ¬ Even 1)]
  dsimp [LawGeneratedLargeCoefficientCech.faceRestriction, restrictionCochain]
  change (F ⋙ forget AddCommGrpCat).map _ ((F ⋙ forget AddCommGrpCat).map _ x) +
      -((F ⋙ forget AddCommGrpCat).map _ ((F ⋙ forget AddCommGrpCat).map _ x)) = 0
  rw [← FunctorToTypes.map_comp_apply, ← FunctorToTypes.map_comp_apply]
  let m₀ :=
    (homOfLE (geometry.cover.inclusion
      ((LawGeneratedLargeCoefficientCech.face geometry 0 sigma 0) 0))).op ≫
      (LawGeneratedLargeCoefficientCech.faceHom geometry 0 sigma 0).op
  let m₁ :=
    (homOfLE (geometry.cover.inclusion
      ((LawGeneratedLargeCoefficientCech.face geometry 0 sigma 1) 0))).op ≫
      (LawGeneratedLargeCoefficientCech.faceHom geometry 0 sigma 1).op
  change (F ⋙ forget AddCommGrpCat).map m₀ x +
    -(F ⋙ forget AddCommGrpCat).map m₁ x = 0
  rw [show m₀ = m₁ from Subsingleton.elim _ _, add_neg_cancel]

/-- Degree-zero cover-relative cohomology is the kernel of the first differential. -/
abbrev H0 (geometry : Site.FinitePosetCoverGeometry S)
    (F : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u + 1}) :=
  AddMonoidHom.ker (LawGeneratedLargeCoefficientCech.d0 geometry F)

/-- Canonical degree-zero tuple displaying one cover generator. -/
def zeroSimplex (i : geometry.cover.Index) :
    LawGeneratedLargeCoefficientCech.Tuple geometry 0 := fun _ => i

/-- Canonical degree-one tuple displaying an ordered pair of generators. -/
def pairSimplex (i j : geometry.cover.Index) :
    LawGeneratedLargeCoefficientCech.Tuple geometry 1 := Fin.cases i (fun _ => j)

@[simp] theorem face_pairSimplex_zero (i j : geometry.cover.Index) :
    LawGeneratedLargeCoefficientCech.face geometry 0 (pairSimplex i j) 0 =
      zeroSimplex j := by
  funext k
  have hk : k = 0 := Fin.eq_zero k
  subst k
  rfl

@[simp] theorem face_pairSimplex_one (i j : geometry.cover.Index) :
    LawGeneratedLargeCoefficientCech.face geometry 0 (pairSimplex i j) 1 =
      zeroSimplex i := by
  funext k
  have hk : k = 0 := Fin.eq_zero k
  subst k
  rfl

/-- Restriction of a base section as a degree-zero cohomology class. -/
def baseSectionToH0 (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1}) :
    𝓕.val.obj (op geometry.base) →+ H0 geometry 𝓕.val where
  toFun x :=
    ⟨restrictionCochain (geometry := geometry) 𝓕.val x,
      restrictionCochain_cocycle (geometry := geometry) 𝓕.val x⟩
  map_zero' := by
    apply Subtype.ext
    funext sigma
    simp [restrictionCochain]
  map_add' x y := by
    apply Subtype.ext
    funext sigma
    simp [restrictionCochain]

/-- A zero-cocycle value displayed as a section on one cover generator. -/
def localSection (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) (i : geometry.cover.Index) :
    𝓕.val.obj (op
      (Site.ContextCategoryObject.of S.contextPreorder (geometry.cover.patch i))) := by
  simpa [zeroSimplex, LawGeneratedLargeCoefficientCech.overlapObject,
    Site.FinitePosetCoverGeometry.canonicalTupleCoverGeometryFromOverlap,
    Site.FinitePosetCoverGeometry.canonicalTupleOverlapFromOverlap] using
    c.1 (zeroSimplex i)

theorem localSection_eq_cochain (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) (i : geometry.cover.Index) :
    localSection 𝓕 c i = c.1 (zeroSimplex i) := by
  simp [localSection, LawGeneratedLargeCoefficientCech.overlapObject,
    Site.FinitePosetCoverGeometry.canonicalTupleCoverGeometryFromOverlap,
    Site.FinitePosetCoverGeometry.canonicalTupleOverlapFromOverlap]

/-- Evaluation at any degree-zero tuple is the displayed generator section. -/
theorem map_cochain_eq_localSection
    (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val)
    (tau : LawGeneratedLargeCoefficientCech.Tuple geometry 0)
    {X : S.category}
    (f : X ⟶ LawGeneratedLargeCoefficientCech.overlapObject geometry 0 tau)
    (g : X ⟶ Site.ContextCategoryObject.of S.contextPreorder
      (geometry.cover.patch (tau 0))) :
    (𝓕.val ⋙ forget AddCommGrpCat).map f.op (c.1 tau) =
      (𝓕.val ⋙ forget AddCommGrpCat).map g.op (localSection 𝓕 c (tau 0)) := by
  let i := tau 0
  have htau : tau = zeroSimplex i := by
    funext k
    have hk : k = 0 := Fin.eq_zero k
    subst k
    rfl
  revert f g
  rw [htau]
  intro f g
  rw [localSection_eq_cochain]
  rw [show f = g from Subsingleton.elim _ _]
  rfl

/-- A degree-zero cocycle agrees on every canonical ordered pair overlap. -/
theorem pairAgreement (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) (i j : geometry.cover.Index) :
    let sigma := pairSimplex i j
    let overlapObj := LawGeneratedLargeCoefficientCech.overlapObject geometry 1 sigma
    let toI : overlapObj ⟶ Site.ContextCategoryObject.of S.contextPreorder
        (geometry.cover.patch i) :=
      homOfLE (by simpa [sigma, pairSimplex] using
        geometry.canonicalTupleOverlapFromOverlap_le_patch 1 sigma 0)
    let toJ : overlapObj ⟶ Site.ContextCategoryObject.of S.contextPreorder
        (geometry.cover.patch j) :=
      homOfLE (by simpa [sigma, pairSimplex] using
        geometry.canonicalTupleOverlapFromOverlap_le_patch 1 sigma 1)
    𝓕.val.map toJ.op (localSection 𝓕 c j) =
      𝓕.val.map toI.op (localSection 𝓕 c i) := by
  intro sigma overlapObj toI toJ
  have hz := congrFun c.2 sigma
  dsimp [LawGeneratedLargeCoefficientCech.d0,
    LawGeneratedLargeCoefficientCech.differential] at hz
  rw [Fin.sum_univ_two] at hz
  simp only [Fin.val_zero, Fin.val_one, if_pos (by decide : Even 0),
    if_neg (by decide : ¬ Even 1)] at hz
  have heq : LawGeneratedLargeCoefficientCech.faceRestriction geometry 𝓕.val 0
      c.1 sigma 0 =
    LawGeneratedLargeCoefficientCech.faceRestriction geometry 𝓕.val 0
      c.1 sigma 1 := by
    exact sub_eq_zero.mp (by simpa [sub_eq_add_neg] using hz)
  rw [localSection_eq_cochain 𝓕 c i, localSection_eq_cochain 𝓕 c j]
  let tau0 := LawGeneratedLargeCoefficientCech.face geometry 0 sigma 0
  let tau1 := LawGeneratedLargeCoefficientCech.face geometry 0 sigma 1
  let f0 := LawGeneratedLargeCoefficientCech.faceHom geometry 0 sigma 0
  let f1 := LawGeneratedLargeCoefficientCech.faceHom geometry 0 sigma 1
  have h0 := map_cochain_eq_localSection 𝓕 c tau0 f0 toJ
  have h1 := map_cochain_eq_localSection 𝓕 c tau1 f1 toI
  change (𝓕.val ⋙ forget AddCommGrpCat).map f0.op (c.1 tau0) =
    (𝓕.val ⋙ forget AddCommGrpCat).map f1.op (c.1 tau1) at heq
  simpa [tau0, tau1, sigma] using h0.symm.trans (heq.trans h1)

/-- Canonical-pair agreement extends to every common refinement. -/
theorem arrowsCompatible (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) :
    Presieve.Arrows.Compatible (𝓕.val ⋙ forget AddCommGrpCat)
      (fun i : geometry.cover.Index => homOfLE (geometry.cover.inclusion i))
      (localSection 𝓕 c) := by
  intro i j Z gi gj hcomm
  let sigma := pairSimplex i j
  let overlapObj := LawGeneratedLargeCoefficientCech.overlapObject geometry 1 sigma
  have hZi : S.contextPreorder.le Z.ctx (geometry.cover.patch i) := leOfHom gi
  have hZj : S.contextPreorder.le Z.ctx (geometry.cover.patch j) := leOfHom gj
  have hkLe : S.contextPreorder.le Z.ctx
      (geometry.canonicalTupleOverlapFromOverlap 1 sigma) :=
    geometry.canonicalTupleOverlapFromOverlap_lift sigma (by
      intro k
      refine Fin.cases hZi (fun _ => hZj) k)
  let kHom : Z ⟶ overlapObj := homOfLE hkLe
  let toI : overlapObj ⟶ Site.ContextCategoryObject.of S.contextPreorder
      (geometry.cover.patch i) :=
    homOfLE (geometry.canonicalTupleOverlapFromOverlap_le_patch 1 sigma 0)
  let toJ : overlapObj ⟶ Site.ContextCategoryObject.of S.contextPreorder
      (geometry.cover.patch j) :=
    homOfLE (geometry.canonicalTupleOverlapFromOverlap_le_patch 1 sigma 1)
  have hpair := pairAgreement 𝓕 c i j
  dsimp only at hpair
  rw [show gi = kHom ≫ toI from Subsingleton.elim _ _,
    show gj = kHom ≫ toJ from Subsingleton.elim _ _]
  change (𝓕.val ⋙ forget AddCommGrpCat).map (kHom ≫ toI).op (localSection 𝓕 c i) =
    (𝓕.val ⋙ forget AddCommGrpCat).map (kHom ≫ toJ).op (localSection 𝓕 c j)
  rw [op_comp, op_comp, FunctorToTypes.map_comp_apply,
    FunctorToTypes.map_comp_apply]
  exact congrArg ((𝓕.val ⋙ forget AddCommGrpCat).map kHom.op) hpair.symm

/-- The selected cover carries the underlying type-valued sheaf condition. -/
theorem isSheafFor_selectedCover (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1}) :
    Presieve.IsSheafFor (𝓕.val ⋙ forget AddCommGrpCat) geometry.cover.presieve := by
  apply (Presieve.isSheafFor_iff_generate geometry.cover.presieve).2
  exact (isSheaf_iff_isSheaf_of_type S.topology _).1
    (Presheaf.isSheaf_comp_of_isSheaf S.topology 𝓕.val
      (forget AddCommGrpCat) 𝓕.cond)
    (Sieve.generate geometry.cover.presieve) geometry.coverAdequate.isCover

/-- Compatible zero-cocycle sections as a presieve family. -/
noncomputable def h0Family (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) :
    Presieve.FamilyOfElements (𝓕.val ⋙ forget AddCommGrpCat)
      geometry.cover.presieve := by
  simpa [Site.AATCoverageFamily.presieve] using
    (arrowsCompatible 𝓕 c).familyOfElements

theorem h0Family_compatible (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) : (h0Family 𝓕 c).Compatible := by
  simpa [h0Family, Site.AATCoverageFamily.presieve] using
    (arrowsCompatible 𝓕 c).familyOfElements_compatible

/-- Amalgamate a degree-zero cocycle into a base section. -/
noncomputable def h0ToBaseSection (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) : 𝓕.val.obj (op geometry.base) :=
  (isSheafFor_selectedCover 𝓕).amalgamate (h0Family 𝓕 c)
    (h0Family_compatible 𝓕 c)

theorem h0ToBaseSection_restrict (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) (i : geometry.cover.Index) :
    𝓕.val.map (homOfLE (geometry.cover.inclusion i)).op (h0ToBaseSection 𝓕 c) =
      localSection 𝓕 c i := by
  have hvalid := (isSheafFor_selectedCover 𝓕).valid_glue
    (h0Family_compatible 𝓕 c) (homOfLE (geometry.cover.inclusion i))
    (show geometry.cover.presieve (homOfLE (geometry.cover.inclusion i)) by
      exact Presieve.ofArrows.mk i)
  calc
    _ = h0Family 𝓕 c (homOfLE (geometry.cover.inclusion i))
        (show geometry.cover.presieve (homOfLE (geometry.cover.inclusion i)) by
          exact Presieve.ofArrows.mk i) := by
      simpa [h0ToBaseSection] using hvalid
    _ = localSection 𝓕 c i := by
      simp [h0Family, Site.AATCoverageFamily.presieve]

theorem localSection_baseSectionToH0
    (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (x : 𝓕.val.obj (op geometry.base)) (i : geometry.cover.Index) :
    localSection 𝓕 (baseSectionToH0 𝓕 x) i =
      𝓕.val.map (homOfLE (geometry.cover.inclusion i)).op x := by
  rw [localSection_eq_cochain]
  rfl

theorem h0ToBaseSection_baseSectionToH0
    (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (x : 𝓕.val.obj (op geometry.base)) :
    h0ToBaseSection 𝓕 (baseSectionToH0 𝓕 x) = x := by
  apply (isSheafFor_selectedCover 𝓕).isSeparatedFor.ext
  rintro Y _ ⟨i⟩
  calc
    𝓕.val.map (homOfLE (geometry.cover.inclusion i)).op
        (h0ToBaseSection 𝓕 (baseSectionToH0 𝓕 x)) =
      localSection 𝓕 (baseSectionToH0 𝓕 x) i :=
        h0ToBaseSection_restrict 𝓕 _ i
    _ = 𝓕.val.map (homOfLE (geometry.cover.inclusion i)).op x :=
      localSection_baseSectionToH0 𝓕 x i

theorem baseSectionToH0_h0ToBaseSection
    (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1})
    (c : H0 geometry 𝓕.val) :
    baseSectionToH0 𝓕 (h0ToBaseSection 𝓕 c) = c := by
  apply Subtype.ext
  funext tau
  let i := tau 0
  have htau : tau = zeroSimplex i := by
    funext k
    have hk : k = 0 := Fin.eq_zero k
    subst k
    rfl
  change 𝓕.val.map (homOfLE (geometry.cover.inclusion (tau 0))).op
      (h0ToBaseSection 𝓕 c) = c.1 tau
  calc
    _ = localSection 𝓕 c i := h0ToBaseSection_restrict 𝓕 c i
    _ = c.1 tau := by
      let overlapObj := LawGeneratedLargeCoefficientCech.overlapObject geometry 0 tau
      let g : overlapObj ⟶ Site.ContextCategoryObject.of S.contextPreorder
          (geometry.cover.patch (tau 0)) :=
        homOfLE (geometry.canonicalTupleOverlapFromOverlap_le_patch 0 tau 0)
      have h := map_cochain_eq_localSection 𝓕 c tau (𝟙 overlapObj) g
      have hg : g.op = 𝟙 (op overlapObj) := Subsingleton.elim _ _
      rw [hg] at h
      have hid := ConcreteCategory.congr_hom (𝓕.val.map_id (op overlapObj))
        (localSection 𝓕 c (tau 0))
      have hid' := ConcreteCategory.congr_hom (𝓕.val.map_id (op overlapObj)) (c.1 tau)
      exact hid.symm.trans (h.symm.trans hid')

/-- Base sections are additively equivalent to cover-relative degree-zero cohomology. -/
noncomputable def baseSectionsEquivH0
    (𝓕 : Sheaf S.topology AddCommGrpCat.{u + 1}) :
    𝓕.val.obj (op geometry.base) ≃+ H0 geometry 𝓕.val where
  toFun := baseSectionToH0 𝓕
  invFun := h0ToBaseSection 𝓕
  left_inv := h0ToBaseSection_baseSectionToH0 𝓕
  right_inv := baseSectionToH0_h0ToBaseSection 𝓕
  map_add' := map_add (baseSectionToH0 𝓕)

/-! ## Law-generated conormal specialization -/

/-- The law-generated kernel sheaf satisfies the required base-section/Čech-H⁰ comparison. -/
noncomputable def lawGeneratedConormalSectionsEquivH0
    (G : AAT.AG.ArchitecturalEquationSystem S.contextPreorder) :
    (LawGeneratedIdealPowerLiftedSheafification.sheafifiedShortComplex G).X₁.val.obj
        (op geometry.base) ≃+
      H0 geometry
        (LawGeneratedIdealPowerLiftedSheafification.sheafifiedShortComplex G).X₁.val :=
  baseSectionsEquivH0
    (LawGeneratedIdealPowerLiftedSheafification.sheafifiedShortComplex G).X₁

end LawGeneratedLargeCoefficientH0
end ResearchLean.AG.QualitySurface

#assert_standard_axioms_only ResearchLean.AG.QualitySurface.LawGeneratedLargeCoefficientH0
