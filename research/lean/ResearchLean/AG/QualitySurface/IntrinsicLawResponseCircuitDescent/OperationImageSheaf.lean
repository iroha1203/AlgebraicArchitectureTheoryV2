import Mathlib.Algebra.Category.ModuleCat.Sheaf.Free
import ResearchLean.AG.QualitySurface.IntrinsicLawResponseCircuitDescent.DerivationCoefficientSheaf

/-!
# Allowed-operation image sheaf

This file constructs the J3b allowed-operation sheaf.  The operation-indexed
global sections from J3a determine a morphism from the free module sheaf
`O_Y^Op` to the ambient-to-quotient derivation coefficient sheaf.  The allowed
operation sheaf is the image of this morphism in the abelian category of
`O_Y`-modules.

The construction uses the sheaf-category image, not an objectwise span.
Selected generators factor through the image, their inclusions recover the J3a
global sections, and their chart and overlap readouts recover the J2
quotient-valued derivations with both restriction laws.
-/

open CategoryTheory
open CategoryTheory.Limits
open TopologicalSpace
open scoped AlgebraicGeometry

namespace ResearchLean.AG.QualitySurface.IntrinsicLawResponseCircuitDescent

universe u uk uA uOp uChart uState uBefore uAfter

namespace TypedLocalizationGeometry

/-- A section over the top open, viewed as a compatible section family. -/
noncomputable def globalSectionFamily
    {X : AlgebraicGeometry.Scheme.{u}} (M : X.Modules)
    (s : Γ(M, ⊤)) : M.sections :=
  PresheafOfModules.sectionsMk
    (fun U ↦ M.val.map (homOfLE le_top).op s)
    (by
      intro U V f
      rw [← M.val.map_comp_apply]
      apply M.val.congr_map_apply
      apply Subsingleton.elim)

@[simp] theorem globalSectionFamily_top
    {X : AlgebraicGeometry.Scheme.{u}} (M : X.Modules)
    (s : Γ(M, ⊤)) :
    (globalSectionFamily M s).val (.op ⊤) = s := by
  change M.val.map (homOfLE le_rfl).op s = s
  rw [M.val.congr_map_apply (Subsingleton.elim _ (𝟙 _)) s]
  rw [M.val.map_id]
  rfl

end TypedLocalizationGeometry

namespace ArchitectureOperationPresentation

variable {k : Type uk} {A0 : Type uA} {Op : Type uOp} {Chart : Type uChart}
variable {State : Type uState} {BeforeWitness : Type uBefore}
variable {AfterWitness : Type uAfter}
variable [Field k] [CommRing A0] [Algebra k A0]
variable [Fintype Op] [Fintype Chart]

/-- A scheme-universe index type explicitly equivalent to the finite operation labels. -/
noncomputable abbrev operationIndex (_A0 : Type uA) (Op : Type uOp) [Fintype Op] : Type uA :=
  ULift.{uA} (Fin (Fintype.card Op))

/-- The explicit equivalence used to index the free sheaf by the original operations. -/
noncomputable def operationIndexEquiv (A0 : Type uA) (Op : Type uOp) [Fintype Op] :
    operationIndex A0 Op ≃ Op :=
  Equiv.ulift.trans (Fintype.equivFin Op).symm

/-- The free `O_Y`-module sheaf on the primitive operation labels. -/
noncomputable abbrev operationFreeSheaf
    (Op : Type uOp) [Fintype Op]
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    (G.lawfulSpace I0).Modules :=
  SheafOfModules.free (R := (G.lawfulSpace I0).ringCatSheaf)
    (operationIndex A0 Op)

/-- The morphism generated by the J3a operation sections. -/
noncomputable def operationToCoefficient
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    operationFreeSheaf Op G I0 ⟶ G.derivationCoefficientSheaf I0 :=
  (G.derivationCoefficientSheaf I0).freeHomEquiv.symm
    (fun i ↦ TypedLocalizationGeometry.globalSectionFamily _
      (P.operationDerivationSection G I0
        (operationIndexEquiv A0 Op i)))

theorem operationToCoefficient_generator
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) (op : Op) :
    (G.derivationCoefficientSheaf I0).freeHomEquiv
        (P.operationToCoefficient G I0)
        ((operationIndexEquiv A0 Op).symm op) =
      TypedLocalizationGeometry.globalSectionFamily _
        (P.operationDerivationSection G I0 op) := by
  simp [operationToCoefficient]

/-- The allowed-operation sheaf, defined as a sheaf-category image. -/
noncomputable abbrev allowedOperationSheaf
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    (G.lawfulSpace I0).Modules :=
  Abelian.image (P.operationToCoefficient G I0)

/-- The canonical monomorphism from allowed operations to the coefficient sheaf. -/
noncomputable abbrev allowedOperationToCoefficient
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    P.allowedOperationSheaf G I0 ⟶ G.derivationCoefficientSheaf I0 :=
  Abelian.image.ι (P.operationToCoefficient G I0)

/-- The canonical epimorphism from the free operation sheaf to its image. -/
noncomputable abbrev operationToAllowed
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    operationFreeSheaf Op G I0 ⟶ P.allowedOperationSheaf G I0 :=
  Abelian.factorThruImage (P.operationToCoefficient G I0)

theorem operation_image_factorization
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    P.operationToAllowed G I0 ≫ P.allowedOperationToCoefficient G I0 =
      P.operationToCoefficient G I0 :=
  Abelian.image.fac _

theorem operationToAllowed_epi
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    Epi (P.operationToAllowed G I0) :=
  inferInstance

theorem allowedOperationToCoefficient_mono
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    Mono (P.allowedOperationToCoefficient G I0) :=
  inferInstance

theorem allowedOperationSheaf_isSheaf
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) :
    (AlgebraicGeometry.Scheme.Modules.presheaf
      (P.allowedOperationSheaf G I0)).IsSheaf :=
  AlgebraicGeometry.Scheme.Modules.isSheaf _

/-- The image-sheaf section generated by one primitive operation. -/
noncomputable def allowedOperationSection
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) (op : Op) :
    (P.allowedOperationSheaf G I0).sections :=
  (P.allowedOperationSheaf G I0).freeHomEquiv
    (P.operationToAllowed G I0)
    ((operationIndexEquiv A0 Op).symm op)

theorem allowedOperationSection_maps_to
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) (op : Op) :
    SheafOfModules.sectionsMap (P.allowedOperationToCoefficient G I0)
        (P.allowedOperationSection G I0 op) =
      TypedLocalizationGeometry.globalSectionFamily _
        (P.operationDerivationSection G I0 op) := by
  unfold allowedOperationSection
  calc
    _ = (G.derivationCoefficientSheaf I0).freeHomEquiv
        (P.operationToAllowed G I0 ≫ P.allowedOperationToCoefficient G I0)
        ((operationIndexEquiv A0 Op).symm op) :=
      (SheafOfModules.freeHomEquiv_comp_apply
        (P.operationToAllowed G I0) (P.allowedOperationToCoefficient G I0)
        ((operationIndexEquiv A0 Op).symm op)).symm
    _ = _ := by
      rw [P.operation_image_factorization G I0]
      exact P.operationToCoefficient_generator G I0 op

theorem allowedOperationSection_top_maps_to
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0) (op : Op) :
    (P.allowedOperationToCoefficient G I0).app ⊤
        ((P.allowedOperationSection G I0 op).val (.op ⊤)) =
      P.operationDerivationSection G I0 op := by
  have h := congrArg (fun s ↦ s.val (.op ⊤))
    (P.allowedOperationSection_maps_to G I0 op)
  simpa using h

/-- The selected allowed-operation section on a lawful-space chart. -/
noncomputable def allowedOperationSectionOnChart
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i : Chart) :
    Γ(P.allowedOperationSheaf G I0, G.lawfulChartOpenOnSpace I0 i) :=
  (P.allowedOperationSection G I0 op).val
    (.op (G.lawfulChartOpenOnSpace I0 i))

/-- The selected allowed-operation section on a lawful-space overlap. -/
noncomputable def allowedOperationSectionOnOverlap
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i j : Chart) :
    Γ(P.allowedOperationSheaf G I0, G.lawfulOverlapOpenOnSpace I0 i j) :=
  (P.allowedOperationSection G I0 op).val
    (.op (G.lawfulOverlapOpenOnSpace I0 i j))

theorem allowedOperationSectionOnChart_maps_to
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i : Chart) :
    (P.allowedOperationToCoefficient G I0).app
        (G.lawfulChartOpenOnSpace I0 i)
        (P.allowedOperationSectionOnChart G I0 op i) =
      P.operationDerivationSectionOnChart G I0 op i := by
  have h := congrArg
    (fun s ↦ s.val (.op (G.lawfulChartOpenOnSpace I0 i)))
    (P.allowedOperationSection_maps_to G I0 op)
  exact h

theorem allowedOperationSectionOnOverlap_maps_to
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i j : Chart) :
    (P.allowedOperationToCoefficient G I0).app
        (G.lawfulOverlapOpenOnSpace I0 i j)
        (P.allowedOperationSectionOnOverlap G I0 op i j) =
      P.operationDerivationSectionOnOverlap G I0 op i j := by
  have h := congrArg
    (fun s ↦ s.val (.op (G.lawfulOverlapOpenOnSpace I0 i j)))
    (P.allowedOperationSection_maps_to G I0 op)
  exact h

theorem allowedOperationSectionOnChart_recovers
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i : Chart) :
    G.chartSectionToDerivationOnSpace I0 i
        ((P.allowedOperationToCoefficient G I0).app
          (G.lawfulChartOpenOnSpace I0 i)
          (P.allowedOperationSectionOnChart G I0 op i)) =
      P.chartQuotientDerivation G I0 op i := by
  rw [P.allowedOperationSectionOnChart_maps_to G I0 op i]
  exact P.operationDerivationSection_restrict_chart G I0 op i

theorem allowedOperationSectionOnOverlap_recovers
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i j : Chart) :
    G.overlapSectionToDerivationOnSpace I0 i j
        ((P.allowedOperationToCoefficient G I0).app
          (G.lawfulOverlapOpenOnSpace I0 i j)
          (P.allowedOperationSectionOnOverlap G I0 op i j)) =
      P.overlapQuotientDerivation G I0 op i j := by
  rw [P.allowedOperationSectionOnOverlap_maps_to G I0 op i j]
  exact P.operationDerivationSection_restrict_overlap G I0 op i j

theorem left_allowedOperationSection_natural
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i j : Chart) (x : G.chartRing i) :
    (G.overlapSectionToDerivationOnSpace I0 i j
        ((P.allowedOperationToCoefficient G I0).app
          (G.lawfulOverlapOpenOnSpace I0 i j)
          (P.allowedOperationSectionOnOverlap G I0 op i j)))
          (G.leftChartToOverlap i j x) =
      G.leftLawQuotientRestriction I0 i j
        ((G.chartSectionToDerivationOnSpace I0 i
          ((P.allowedOperationToCoefficient G I0).app
            (G.lawfulChartOpenOnSpace I0 i)
            (P.allowedOperationSectionOnChart G I0 op i))) x) := by
  rw [P.allowedOperationSectionOnOverlap_recovers G I0 op i j,
    P.allowedOperationSectionOnChart_recovers G I0 op i]
  exact P.leftQuotientDerivation_natural G I0 op i j x

theorem right_allowedOperationSection_natural
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (op : Op) (i j : Chart) (x : G.chartRing j) :
    (G.overlapSectionToDerivationOnSpace I0 i j
        ((P.allowedOperationToCoefficient G I0).app
          (G.lawfulOverlapOpenOnSpace I0 i j)
          (P.allowedOperationSectionOnOverlap G I0 op i j)))
          (G.rightChartToOverlap i j x) =
      G.rightLawQuotientRestriction I0 i j
        ((G.chartSectionToDerivationOnSpace I0 j
          ((P.allowedOperationToCoefficient G I0).app
            (G.lawfulChartOpenOnSpace I0 j)
            (P.allowedOperationSectionOnChart G I0 op j))) x) := by
  rw [P.allowedOperationSectionOnOverlap_recovers G I0 op i j,
    P.allowedOperationSectionOnChart_recovers G I0 op j]
  exact P.rightQuotientDerivation_natural G I0 op i j x

theorem allowedOperationToCoefficient_smul
    (P : ArchitectureOperationPresentation k A0 Op State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k A0 Chart) (I0 : Ideal A0)
    (U : (G.lawfulSpace I0).Opens) (r : Γ(G.lawfulSpace I0, U))
    (s : Γ(P.allowedOperationSheaf G I0, U)) :
    (P.allowedOperationToCoefficient G I0).app U (r • s) =
      r • (P.allowedOperationToCoefficient G I0).app U s :=
  AlgebraicGeometry.Scheme.Modules.Hom.app_smul _ _ _

end ArchitectureOperationPresentation

end ResearchLean.AG.QualitySurface.IntrinsicLawResponseCircuitDescent

#assert_standard_axioms_only
  ResearchLean.AG.QualitySurface.IntrinsicLawResponseCircuitDescent.TypedLocalizationGeometry

#assert_standard_axioms_only
  ResearchLean.AG.QualitySurface.IntrinsicLawResponseCircuitDescent.ArchitectureOperationPresentation
