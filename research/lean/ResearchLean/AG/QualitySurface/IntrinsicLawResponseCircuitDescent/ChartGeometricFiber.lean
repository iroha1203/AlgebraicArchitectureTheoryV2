/-- Denominators acting by units on the scalar field act invertibly on every
compatible scalar-extension module. -/
private theorem denominatorActsByUnit
    (S0 : Submonoid R)
    (hS : ∀ s : S0, IsUnit (algebraMap R K s.1))
    (P : Type*) [AddCommGroup P] [Module R P] [Module K P]
    [IsScalarTower R K P] (s : S0) :
    IsUnit (algebraMap R (Module.End R P) s.1) := by
  rw [Module.End.isUnit_iff]
  change Function.Bijective (fun x : P ↦ s.1 • x)
  have heq : (fun x : P ↦ s.1 • x) =
      fun x : P ↦ algebraMap R K s.1 • x := by
    funext x
    exact (IsScalarTower.algebraMap_smul K s.1 x).symm
  rw [heq]
  exact (hS s).smul_bijective (β := P)

/-- The inverse to localization base change, generated by the
`IsLocalizedModule` universal property. -/
private noncomputable def inverse
    (S0 : Submonoid R) (f : M →ₗ[R] N) [IsLocalizedModule S0 f]
    (hS : ∀ s : S0, IsUnit (algebraMap R K s.1)) :
    TensorProduct R K N →ₗ[K] TensorProduct R K M := by
  let toTensor : M →ₗ[R] TensorProduct R K M :=
    TensorProduct.mk R K M 1
  let liftToTensor : N →ₗ[R] TensorProduct R K M :=
    IsLocalizedModule.lift S0 f toTensor
      (denominatorActsByUnit S0 hS (TensorProduct R K M))
  exact TensorProduct.AlgebraTensorModule.lift
    { toFun := fun a ↦ a • liftToTensor
      map_add' := by
        intro a b
        ext n
        simp only [add_smul, LinearMap.add_apply]
      map_smul' := by
        intro a b
        ext n
        simp only [RingHom.id_apply, smul_eq_mul, mul_smul, LinearMap.smul_apply] }

/-- The universal-property inverse is a left inverse to base change. -/
private theorem inverse_comp_baseChange
    (S0 : Submonoid R) (f : M →ₗ[R] N) [IsLocalizedModule S0 f]
    (hS : ∀ s : S0, IsUnit (algebraMap R K s.1)) :
    inverse S0 f hS ∘ₗ f.baseChange K = LinearMap.id := by
  apply TensorProduct.AlgebraTensorModule.ext
  intro a m
  simp only [LinearMap.comp_apply, LinearMap.baseChange_tmul,
    inverse, TensorProduct.AlgebraTensorModule.lift_tmul]
  change a • (IsLocalizedModule.lift S0 f
    (TensorProduct.mk R K M 1)
    (denominatorActsByUnit S0 hS (TensorProduct R K M)) (f m)) = a ⊗ₜ[R] m
  rw [IsLocalizedModule.lift_apply]
  exact (TensorProduct.tmul_eq_smul_one_tmul a m).symm

/-- The universal-property inverse is a right inverse to base change. -/
private theorem baseChange_comp_inverse
    (S0 : Submonoid R) (f : M →ₗ[R] N) [IsLocalizedModule S0 f]
    (hS : ∀ s : S0, IsUnit (algebraMap R K s.1)) :
    f.baseChange K ∘ₗ inverse S0 f hS = LinearMap.id := by
  let toTensorN : N →ₗ[R] TensorProduct R K N :=
    TensorProduct.mk R K N 1
  let toTensorM : M →ₗ[R] TensorProduct R K M :=
    TensorProduct.mk R K M 1
  let liftToTensor : N →ₗ[R] TensorProduct R K M :=
    IsLocalizedModule.lift S0 f toTensorM
      (denominatorActsByUnit S0 hS (TensorProduct R K M))
  have hlift : ((f.baseChange K).restrictScalars R) ∘ₗ liftToTensor = toTensorN := by
    apply IsLocalizedModule.ext (S := S0) (f := f)
      (denominatorActsByUnit S0 hS (TensorProduct R K N))
    rw [LinearMap.comp_assoc]
    ext m
    simp only [LinearMap.comp_apply, liftToTensor]
    rw [IsLocalizedModule.lift_apply]
    rfl
  apply TensorProduct.AlgebraTensorModule.ext
  intro a n
  simp only [LinearMap.comp_apply, inverse,
    TensorProduct.AlgebraTensorModule.lift_tmul, LinearMap.id_apply]
  change (f.baseChange K) (a • (IsLocalizedModule.lift S0 f
    (TensorProduct.mk R K M 1)
    (denominatorActsByUnit S0 hS (TensorProduct R K M)) n)) = a ⊗ₜ[R] n
  rw [map_smul]
  change a • ((f.baseChange K).restrictScalars R (liftToTensor n)) = a ⊗ₜ[R] n
  rw [show (f.baseChange K).restrictScalars R (liftToTensor n) = toTensorN n by
    exact LinearMap.congr_fun hlift n]
  change a • (1 ⊗ₜ[R] n) = a ⊗ₜ[R] n
  exact (TensorProduct.tmul_eq_smul_one_tmul a n).symm

/-- Base change along a scalar algebra that inverts the localization
denominators is a canonical linear equivalence. -/
private noncomputable def baseChangeEquiv
    (S0 : Submonoid R) (f : M →ₗ[R] N) [IsLocalizedModule S0 f]
    (hS : ∀ s : S0, IsUnit (algebraMap R K s.1)) :
    TensorProduct R K M ≃ₗ[K] TensorProduct R K N :=
  LinearEquiv.ofLinear (f.baseChange K) (inverse S0 f hS)
    (baseChange_comp_inverse S0 f hS)
    (inverse_comp_baseChange S0 f hS)

end LocalizationFiber

local notation "Γₘ(" M ", " U ")" =>
  (Functor.obj (Sheaf.val (AlgebraicGeometry.structureSheafInType _ M)))
    (Opposite.op U)

/-- The germ map for the raw module-valued structure presheaf, with its global
ring linearity made explicit. -/
private noncomputable def moduleGermLinear
    (R : CommRingCat.{uA}) (M : ModuleCat.{uA} R)
    (U : Opens (PrimeSpectrum.Top R)) (x : PrimeSpectrum.Top R) (hxU : x ∈ U) :
    Γₘ(M, U) →ₗ[R]
      ↑(TopCat.Presheaf.stalk
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf x) where
  __ := (TopCat.Presheaf.germ
    (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf U x hxU).hom
  map_smul' r m := by
    change _ = AlgebraicGeometry.StructureSheaf.toStalk R x r •
      TopCat.Presheaf.germ
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf _ _ _ _
    rw [← AlgebraicGeometry.StructureSheaf.algebraMap_germ_apply U x hxU]
    refine .trans ?_ (PresheafOfModules.germ_smul ..)
    congr 1
    exact (IsScalarTower.algebraMap_smul Γₘ(R, U) r m).symm

/-- Compare the additive-presheaf stalk used by `tilde` with the fixed-ring
module-presheaf stalk used after `modulesSpecToSheaf`. -/
private noncomputable def modulePresheafStalkLinearEquiv
    (R : CommRingCat.{uA}) (M : ModuleCat.{uA} R)
    (x : PrimeSpectrum.Top R) :
    ↑(TopCat.Presheaf.stalk
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf x) ≃ₗ[R]
      (AlgebraicGeometry.structurePresheafInModuleCat R M).stalk x where
  __ := (Limits.colimit.isoColimitCocone ⟨_, Limits.isColimitOfPreserves
    (forget₂ (ModuleCat R) Ab)
    (Limits.colimit.isColimit ((OpenNhds.inclusion x).op ⋙
      AlgebraicGeometry.structurePresheafInModuleCat R M))⟩).addCommGroupIsoToAddEquiv
  map_smul' r m := by
    let α : TopCat.Presheaf.stalk
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf x ≅
      (forget₂ _ _).obj
        ((AlgebraicGeometry.structurePresheafInModuleCat R M).stalk x) :=
      Limits.colimit.isoColimitCocone ⟨_, Limits.isColimitOfPreserves
        (forget₂ (ModuleCat R) Ab)
        (Limits.colimit.isColimit ((OpenNhds.inclusion x).op ⋙
          AlgebraicGeometry.structurePresheafInModuleCat R M))⟩
    obtain ⟨U, hxU, s, rfl⟩ := TopCat.Presheaf.germ_exist _ _ m
    have hα : TopCat.Presheaf.germ
          (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf U x hxU ≫ α.hom =
        (forget₂ _ _).map
          ((AlgebraicGeometry.structurePresheafInModuleCat R M).germ U x hxU) :=
      Limits.colimit.isoColimitCocone_ι_hom (C := Ab) ..
    have hα_apply (m : _) : α.hom
          (TopCat.Presheaf.germ
            (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf U x hxU m) =
        (AlgebraicGeometry.structurePresheafInModuleCat R M).germ U x hxU m :=
      congr($hα m)
    change α.hom (r • moduleGermLinear R M U x hxU s) =
      r • (show (AlgebraicGeometry.structurePresheafInModuleCat R M).stalk x from _)
    rw [← map_smul]
    refine (hα_apply _).trans ?_
    dsimp [AlgebraicGeometry.StructureSheaf.toStalk]
    erw [hα_apply]
    exact ((AlgebraicGeometry.structurePresheafInModuleCat R M).germ U x hxU).hom.map_smul _ _

/-- The raw-to-fixed stalk comparison carries each raw germ to the
corresponding fixed-ring module germ. -/
private theorem modulePresheafStalkLinearEquiv_germ
    (R : CommRingCat.{uA}) (M : ModuleCat.{uA} R)
    (U : Opens (PrimeSpectrum.Top R)) (x : PrimeSpectrum.Top R)
    (hxU : x ∈ U) (m : Γₘ(M, U)) :
    modulePresheafStalkLinearEquiv R M x
        (TopCat.Presheaf.germ
          (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf
          U x hxU m) =
      (AlgebraicGeometry.structurePresheafInModuleCat R M).germ
        U x hxU m := by
  let α : TopCat.Presheaf.stalk
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf x ≅
      (forget₂ _ _).obj
        ((AlgebraicGeometry.structurePresheafInModuleCat R M).stalk x) :=
    Limits.colimit.isoColimitCocone ⟨_, Limits.isColimitOfPreserves
      (forget₂ (ModuleCat R) Ab)
      (Limits.colimit.isColimit ((OpenNhds.inclusion x).op ⋙
        AlgebraicGeometry.structurePresheafInModuleCat R M))⟩
  have hα : TopCat.Presheaf.germ
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf U x hxU ≫ α.hom =
      (forget₂ _ _).map
        ((AlgebraicGeometry.structurePresheafInModuleCat R M).germ U x hxU) :=
    Limits.colimit.isoColimitCocone_ι_hom (C := Ab) ..
  change α.hom
      (TopCat.Presheaf.germ
        (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf
        U x hxU m) = _
  exact congr($hα m)

/-- Identify the raw `tilde` stalk with the stalk of its fixed-ring sheaf
presentation. -/
private noncomputable def rawTildeStalkToFixedStalkIso
    (R : CommRingCat.{uA}) (M : ModuleCat.{uA} R)
    (x : PrimeSpectrum.Top R) :
    ModuleCat.of R ((AlgebraicGeometry.tilde M).presheaf.stalk x) ≅
      (AlgebraicGeometry.modulesSpecToSheaf.obj
        (AlgebraicGeometry.tilde M)).presheaf.stalk x :=
  LinearEquiv.toModuleIso (modulePresheafStalkLinearEquiv R M x) ≪≫
    ((TopCat.Presheaf.stalkFunctor
      (X := PrimeSpectrum.Top R) (ModuleCat.{uA} R) x).mapIso
      (AlgebraicGeometry.tilde.modulesSpecToSheafIso M)).symm

/-- Evaluate the canonical `tilde` localization map after the fixed-stalk
comparison. -/
private theorem tilde_toFixedStalk_apply
    (R : CommRingCat.{uA}) (M : ModuleCat.{uA} R)
    (x : PrimeSpectrum.Top R) (m : M) :
    (rawTildeStalkToFixedStalkIso R M x).hom
        ((AlgebraicGeometry.tilde.toStalk M x).hom m) =
      (AlgebraicGeometry.modulesSpecToSheaf.obj
        (AlgebraicGeometry.tilde M)).presheaf.germ ⊤ x (by simp)
          ((AlgebraicGeometry.tilde.toOpen M ⊤).hom m) := by
  change ((TopCat.Presheaf.stalkFunctor
      (X := PrimeSpectrum.Top R) (ModuleCat.{uA} R) x).map
        (AlgebraicGeometry.tilde.modulesSpecToSheafIso M).inv).hom
      (modulePresheafStalkLinearEquiv R M x
        ((AlgebraicGeometry.tilde.toStalk M x).hom m)) = _
  change ((TopCat.Presheaf.stalkFunctor
      (X := PrimeSpectrum.Top R) (ModuleCat.{uA} R) x).map
        (AlgebraicGeometry.tilde.modulesSpecToSheafIso M).inv).hom
      (modulePresheafStalkLinearEquiv R M x
        (TopCat.Presheaf.germ
          (AlgebraicGeometry.moduleStructurePresheaf R M).presheaf
          ⊤ x (by simp) (AlgebraicGeometry.StructureSheaf.toOpenₗ R M ⊤ m))) = _
  rw [modulePresheafStalkLinearEquiv_germ]
  rw [TopCat.Presheaf.stalkFunctor_map_germ_apply]
  rfl

/-- The fixed-stalk localization comparison is natural in the source module
morphism. -/
private theorem tilde_toFixedStalk_naturality
    {R : CommRingCat.{uA}} {M N : ModuleCat.{uA} R} (f : M ⟶ N)
    (x : PrimeSpectrum.Top R) :
    (AlgebraicGeometry.tilde.toStalk M x ≫
        (rawTildeStalkToFixedStalkIso R M x).hom) ≫
      (TopCat.Presheaf.stalkFunctor
        (X := PrimeSpectrum.Top R) (ModuleCat.{uA} R) x).map
          (AlgebraicGeometry.modulesSpecToSheaf.map
            (AlgebraicGeometry.tilde.map f)).val =
      f ≫ AlgebraicGeometry.tilde.toStalk N x ≫
        (rawTildeStalkToFixedStalkIso R N x).hom := by
  ext m
  change ((TopCat.Presheaf.stalkFunctor
      (X := PrimeSpectrum.Top R) (ModuleCat.{uA} R) x).map
        (AlgebraicGeometry.modulesSpecToSheaf.map
          (AlgebraicGeometry.tilde.map f)).val).hom
      ((rawTildeStalkToFixedStalkIso R M x).hom
        ((AlgebraicGeometry.tilde.toStalk M x).hom m)) =
    (rawTildeStalkToFixedStalkIso R N x).hom
      ((AlgebraicGeometry.tilde.toStalk N x).hom (f.hom m))
  rw [tilde_toFixedStalk_apply, tilde_toFixedStalk_apply]
  rw [TopCat.Presheaf.stalkFunctor_map_germ_apply]
  congr 1
  exact congr($(AlgebraicGeometry.tilde.toOpen_map_app f ⊤) m)

/-- The `tilde`--Gamma counit satisfies the adjunction triangle on objects in
the image of `tilde`. -/
private theorem tilde_unit_fromTildeΓ
    {R : CommRingCat.{uA}} (M : ModuleCat.{uA} R) :
    AlgebraicGeometry.tilde.map
        (AlgebraicGeometry.tilde.toTildeΓNatIso.hom.app M) ≫
      AlgebraicGeometry.Scheme.Modules.fromTildeΓNatTrans.app
        (AlgebraicGeometry.tilde M) =
      𝟙 (AlgebraicGeometry.tilde M) := by
  exact (AlgebraicGeometry.tilde.adjunction
    (R := R)).left_triangle_components M

private theorem presentation_mem_tilde_essImage
    {R : CommRingCat.{uA}} {M : (Spec R).Modules}
    (P : M.Presentation) :
    (tilde.functor R).essImage M := by
  apply ObjectProperty.prop_of_isColimit
    (P := (tilde.functor R).essImage) P.isColimit
  rintro (_ | _)
  · exact ⟨ModuleCat.of R (P.relations.I →₀ R), ⟨tildeFinsupp _⟩⟩
  · exact ⟨ModuleCat.of R (P.generators.I →₀ R), ⟨tildeFinsupp _⟩⟩

/-- The ringed-space morphism used to compare the restricted unit module with
the unit module on an open subscheme. -/
private def restrictRingCatSheafHom
    {X Y : Scheme.{uA}} (j : X ⟶ Y) [IsOpenImmersion j] :
    X.ringCatSheaf ⟶
      (j.opensFunctor.sheafPushforwardContinuous RingCat _ _).obj
        Y.ringCatSheaf :=
  let α : X.presheaf ⟶ j.opensFunctor.op ⋙ Y.presheaf :=
    { app U := (j.appIso U.unop).inv }
  ⟨Functor.whiskerRight α (forget₂ CommRingCat RingCat)⟩

/-- For an open immersion, the unit-to-pushforward comparison induced by
`restrictRingCatSheafHom` is an isomorphism. -/
private instance restrictUnitToPushforward_isIso
    {X Y : Scheme.{uA}} (j : X ⟶ Y) [IsOpenImmersion j] :
    IsIso (SheafOfModules.unitToPushforwardObjUnit
      (restrictRingCatSheafHom j)) := by
  apply Scheme.Modules.Hom.isIso_iff_isIso_app.mpr
  intro U
  rw [ConcreteCategory.isIso_iff_bijective]
  change Function.Bijective (j.appIso U).inv.hom
  exact ConcreteCategory.bijective_of_isIso (j.appIso U).inv

/-- The canonical representation of the restricted unit module as the unit
module on the open subscheme. -/
private noncomputable def restrictUnitIso
    {X Y : Scheme.{uA}} (j : X ⟶ Y) [IsOpenImmersion j] :
    (Scheme.Modules.restrictFunctor j).obj
        (SheafOfModules.unit Y.ringCatSheaf) ≅
      SheafOfModules.unit X.ringCatSheaf := by
  exact (asIso (SheafOfModules.unitToPushforwardObjUnit
    (restrictRingCatSheafHom j))).symm

/-- On sections, `restrictUnitIso` is the canonical open-immersion restriction
isomorphism. -/
private theorem restrictUnitIso_hom_app_apply
    {X Y : Scheme.{uA}} (j : X ⟶ Y) [IsOpenImmersion j]
    (U : X.Opens) (x : Γ(Y, j ''ᵁ U)) :
    (restrictUnitIso j).hom.val.app (.op U) x =
      (j.appIso U).hom x := by
  change (inv (SheafOfModules.unitToPushforwardObjUnit
      (restrictRingCatSheafHom j))).val.app (.op U) x = _
  apply (ConcreteCategory.bijective_of_isIso (j.appIso U).inv).injective
  rw [Iso.hom_inv_id_apply]
  dsimp [restrictRingCatSheafHom,
    SheafOfModules.unitToPushforwardObjUnit]
  change (SheafOfModules.unitToPushforwardObjUnit
      (restrictRingCatSheafHom j)).val.app (.op U)
        ((inv (SheafOfModules.unitToPushforwardObjUnit
          (restrictRingCatSheafHom j))).val.app (.op U) x) = x
  change ((inv (SheafOfModules.unitToPushforwardObjUnit
      (restrictRingCatSheafHom j)) ≫
        SheafOfModules.unitToPushforwardObjUnit
          (restrictRingCatSheafHom j)).val.app (.op U)) x = x
  rw [IsIso.inv_hom_id]
  rfl

private noncomputable def restrictPresentation
    {X Y : Scheme.{uA}} (j : X ⟶ Y) [IsOpenImmersion j]
    {M : Y.Modules} (P : M.Presentation) :
    ((Scheme.Modules.restrictFunctor j).obj M).Presentation := by
  let F := Scheme.Modules.restrictFunctor j
  letI : F.IsLeftAdjoint := inferInstance
  letI : PreservesColimitsOfSize.{uA, uA} F := by infer_instance
  exact P.map F (restrictUnitIso j)

private noncomputable def tildeRestrictFreeIso
    {R : CommRingCat.{uA}} {Y : Scheme.{uA}}
    (j : Spec R ⟶ Y) [IsOpenImmersion j] (I : Type uA) :
    tilde (ModuleCat.of R (I →₀ R)) ≅
      (Scheme.Modules.restrictFunctor j).obj
        (SheafOfModules.free (R := Y.ringCatSheaf) I) := by
  letI : (TopologicalSpace.Opens.map j.base).IsRightAdjoint :=
    j.isOpenEmbedding.isOpenMap.adjunction.isRightAdjoint
  letI : (TopologicalSpace.Opens.map j.base).Final := inferInstance
  exact tildeFinsupp I ≪≫
    ((Scheme.Modules.restrictFunctorIsoPullback j).app _ ≪≫
      SheafOfModules.pullbackObjFreeIso j.toRingCatSheafHom I).symm

/-- Every selected lawful-space chart is affine: its image under the lawful
open immersion is the corresponding principal basic open. -/
theorem lawfulChartOpenOnSpace_isAffineOpen
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    AlgebraicGeometry.IsAffineOpen
      (G.lawfulChartOpenOnSpace (E.obstructionIdeal W) i) := by
  apply (Scheme.Hom.isAffineOpen_iff_of_isOpenImmersion
    (G.lawfulOpen (E.obstructionIdeal W)).ι).mp
  rw [G.image_lawfulChartOpenOnSpace]
  exact IsAffineOpen.Spec_basicOpen _

/-- The actual allowed-operation image sheaf restricted along the affine
spectrum presentation of a selected lawful-space chart. -/
noncomputable abbrev chartAllowedOperationOnSpec
    (Pres : ArchitectureOperationPresentation k (E.Observable W) Op
      State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    (AlgebraicGeometry.Spec
      (.of (ChartCircuitLocus.chartRing E W G i))).Modules :=
  let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
  (Pres.allowedOperationSheaf G (E.obstructionIdeal W)).restrict hU.fromSpec

private noncomputable def chartSectionsToRestrictedTop
    (Pres : ArchitectureOperationPresentation k (E.Observable W) Op
      State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    ModuleCat.of (ChartCircuitLocus.chartRing E W G i)
        (ChartCircuitLocus.chartAllowedOperationModule E W Pres G i) ⟶
      moduleSpecΓFunctor.obj (chartAllowedOperationOnSpec E W Pres G i) := by
  let U0 := G.lawfulChartOpenOnSpace (E.obstructionIdeal W) i
  let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
  let j := hU.fromSpec
  let M := Pres.allowedOperationSheaf G (E.obstructionIdeal W)
  let eU : j ''ᵁ (⊤ : (Spec (.of (ChartCircuitLocus.chartRing E W G i))).Opens) = U0 :=
    j.image_top_eq_opensRange.trans hU.opensRange_fromSpec
  let R0 := ChartCircuitLocus.chartRing E W G i
  let T := chartAllowedOperationOnSpec E W Pres G i
  let Q := ((SheafOfModules.forgetToSheafModuleCat
    (Spec (.of R0)).ringCatSheaf (.op ⊤)
    (initialOpOfTerminal isTerminalTop)).obj T).val.obj (.op ⊤)
  letI : Module R0 Q :=
    Module.compHom Q (StructureSheaf.globalSectionsIso R0).hom.hom
  have hscalar :
      (G.lawfulSpace (E.obstructionIdeal W)).presheaf.map
          (eqToHom eU).op =
        (Scheme.ΓSpecIso R0).inv ≫
          (j.appIso (⊤ : (Spec (.of R0)).Opens)).inv := by
    rw [← cancel_mono
      (j.appIso (⊤ : (Spec (.of R0)).Opens)).hom]
    simp only [Category.assoc]
    rw [j.appIso_hom]
    rw [j.naturality_assoc]
    rw [hU.fromSpec_app_self]
    simp only [Category.assoc, ← Functor.map_comp]
    simp only [j.appIso_inv_app_assoc, ← Functor.map_comp]
    congr 1
  change ModuleCat.of R0 _ ⟶ ModuleCat.of R0 Q
  refine ModuleCat.ofHom
    { toFun := fun x ↦ M.presheaf.map (eqToHom eU).op x
      map_add' := by simp
      map_smul' := ?_ }
  intro r x
  calc
    _ = ((G.lawfulSpace (E.obstructionIdeal W)).ringCatSheaf.val.map
          (eqToHom eU).op).hom r •
        (M.val.map (eqToHom eU).op).hom x := by
      exact (M.val.map (eqToHom eU).op).hom.map_smul r x
    _ = _ := by
      change ((G.lawfulSpace (E.obstructionIdeal W)).ringCatSheaf.val.map
            (eqToHom eU).op).hom r •
          (M.val.map (eqToHom eU).op).hom x =
        (j.appIso (⊤ : (Spec (.of R0)).Opens)).inv.hom
            ((Scheme.ΓSpecIso R0).inv.hom r) •
          (M.val.map (eqToHom eU).op).hom x
      congr 1
      exact ConcreteCategory.congr_hom hscalar r

private noncomputable def chartSectionsIso
    (Pres : ArchitectureOperationPresentation k (E.Observable W) Op
      State BeforeWitness AfterWitness)
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    ModuleCat.of (ChartCircuitLocus.chartRing E W G i)
        (ChartCircuitLocus.chartAllowedOperationModule E W Pres G i) ≅
      moduleSpecΓFunctor.obj (chartAllowedOperationOnSpec E W Pres G i) :=
  LinearEquiv.toModuleIso <| LinearEquiv.ofBijective
    (chartSectionsToRestrictedTop E W Pres G i).hom (by
      let U0 := G.lawfulChartOpenOnSpace (E.obstructionIdeal W) i
      let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
      let j := hU.fromSpec
      let M := Pres.allowedOperationSheaf G (E.obstructionIdeal W)
      let eU : j ''ᵁ
          (⊤ : (Spec (.of (ChartCircuitLocus.chartRing E W G i))).Opens) = U0 :=
        j.image_top_eq_opensRange.trans hU.opensRange_fromSpec
      change Function.Bijective
        (M.presheaf.map (eqToHom eU).op).hom
      exact ConcreteCategory.bijective_of_isIso
        (M.presheaf.map (eqToHom eU).op))

private noncomputable def chartDerivationCoefficientPresentation
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
    ((Scheme.Modules.restrictFunctor hU.fromSpec).obj
      (G.derivationCoefficientSheaf (E.obstructionIdeal W))).Presentation := by
  let I0 := E.obstructionIdeal W
  let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
  let P0 := AlgebraicGeometry.presentationTilde
    (R := .of (TypedLocalizationGeometry.ambientLawQuotient I0))
    (M := TypedLocalizationGeometry.ambientDerivationModule
      (k := k) I0)
    Set.univ (by simp) _ (Submodule.span_eq _)
  change ((Scheme.Modules.restrictFunctor hU.fromSpec).obj
    ((Scheme.Modules.restrictFunctor (G.lawfulOpen I0).ι).obj
      (TypedLocalizationGeometry.ambientDerivationSheaf
        (k := k) I0))).Presentation
  exact restrictPresentation hU.fromSpec
    (restrictPresentation (G.lawfulOpen I0).ι P0)

private theorem restrictedOperationFree_mem_essImage
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
    (tilde.functor (ChartCircuitLocus.chartRing E W G i)).essImage
      ((Scheme.Modules.restrictFunctor hU.fromSpec).obj
        (ArchitectureOperationPresentation.operationFreeSheaf Op G
          (E.obstructionIdeal W))) := by
  let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
  exact ⟨ModuleCat.of (ChartCircuitLocus.chartRing E W G i)
      (ArchitectureOperationPresentation.operationIndex
        (E.Observable W) Op →₀ ChartCircuitLocus.chartRing E W G i),
    ⟨tildeRestrictFreeIso hU.fromSpec
      (ArchitectureOperationPresentation.operationIndex
        (E.Observable W) Op)⟩⟩

private theorem restrictedDerivationCoefficient_mem_essImage
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
    (tilde.functor (ChartCircuitLocus.chartRing E W G i)).essImage
      ((Scheme.Modules.restrictFunctor hU.fromSpec).obj
        (G.derivationCoefficientSheaf (E.obstructionIdeal W))) := by
  exact presentation_mem_tilde_essImage
    (chartDerivationCoefficientPresentation E W G i)

private instance restrictedOperationFree_fromTildeΓ_isIso
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
    IsIso (Scheme.Modules.fromTildeΓ
      (R := ChartCircuitLocus.chartRing E W G i)
      ((Scheme.Modules.restrictFunctor hU.fromSpec).obj
        (ArchitectureOperationPresentation.operationFreeSheaf Op G
          (E.obstructionIdeal W)))) := by
  exact isIso_fromTildeΓ_iff.mpr
    (restrictedOperationFree_mem_essImage E W G i)

private instance restrictedDerivationCoefficient_fromTildeΓ_isIso
    (G : TypedLocalizationGeometry k (E.Observable W) Chart)
    (i : Chart) :
    let hU := lawfulChartOpenOnSpace_isAffineOpen E W G i
    IsIso (Scheme.Modules.fromTildeΓ
      (R := ChartCircuitLocus.chartRing E W G i)
      ((Scheme.Modules.restrictFunctor hU.fromSpec).obj
        (G.derivationCoefficientSheaf (E.obstructionIdeal W)))) := by
