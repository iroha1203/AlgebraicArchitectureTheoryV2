import Formal.AG.LawAlgebra.LawEquation
import Formal.Util.AssertStandardAxioms
import Mathlib.RingTheory.Ideal.Cotangent
import Mathlib.RingTheory.Ideal.Quotient.PowTransition
import Mathlib.Tactic

/-!
# Law-generated raw ideal-power sequence

This file constructs the raw first-order coefficient sequence directly from an
`ArchitecturalEquationSystem`.  The obstruction ideal, its square, the
two quotient presheaves, and the conormal presheaf are generated from the law
witness coordinates and their restriction laws.  The projection, conormal
inclusion, and objectwise kernel comparison are proved constructions; no sheaf
condition, exactness certificate, or conclusion-equivalent field is accepted.

Sheafification and the resulting sheaf-level comparison belong to the next
checkpoint.
-/

noncomputable section

namespace ResearchLean.AG.QualitySurface
namespace LawGeneratedIdealPowerSequence

universe u

open CategoryTheory Opposite
open AAT.AG
open AAT.AG.LawAlgebra

variable {U : AtomCarrier.{u}} {A : ArchitectureObject U}
variable {S : Site.AATSite A}

namespace Raw

variable (G : ArchitecturalEquationSystem S.contextPreorder)

/-- The law-generated obstruction ideal. -/
abbrev I (W : S.category) : Ideal (G.Observable W) :=
  G.obstructionIdeal W

/-- The law-generated quotient `O/I`. -/
abbrev Q0 (W : S.category) : Type u :=
  G.ObstructionQuotient W

/-- The law-generated first-order thickening `O/I^2`. -/
abbrev Q1 (W : S.category) : Type u :=
  G.Observable W ⧸ (I G W) ^ 2

/-- The law-generated conormal coefficient `I/I^2`. -/
abbrev Conormal (W : S.category) : Type u :=
  (I G W).Cotangent

/-- Restriction maps the square of the generated ideal into the target square. -/
theorem map_obstructionIdeal_sq_le {source target : S.category}
    (f : source ⟶ target) :
    Ideal.map (G.restrict f) ((I G target) ^ 2) ≤ (I G source) ^ 2 := by
  rw [Ideal.map_pow]
  exact pow_le_pow_left' (G.map_obstructionIdeal_le f) 2

/-- Restriction on the first-order quotient `O/I^2`. -/
def q1Restrict {source target : S.category} (f : source ⟶ target) :
    Q1 G target →+* Q1 G source :=
  Ideal.quotientMap ((I G source) ^ 2) (G.restrict f)
    (Ideal.map_le_iff_le_comap.mp (map_obstructionIdeal_sq_le G f))

/-- Restriction of a quotient representative is represented by the restricted observable. -/
@[simp]
theorem q1Restrict_mk {source target : S.category} (f : source ⟶ target)
    (x : G.Observable target) :
    q1Restrict G f (Ideal.Quotient.mk ((I G target) ^ 2) x) =
      Ideal.Quotient.mk ((I G source) ^ 2) (G.restrict f x) := by
  simp [q1Restrict]

/-- The additive presheaf generated by the first-order quotients `O/I^2`. -/
def q1Coefficient : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u} where
  obj W := AddCommGrpCat.of (Q1 G W.unop)
  map {X Y} φ := AddCommGrpCat.ofHom (q1Restrict G φ.unop).toAddMonoidHom
  map_id X := by
    ext x
    refine Quotient.inductionOn' x ?_
    intro r
    show q1Restrict G (𝟙 X.unop)
        (Ideal.Quotient.mk ((I G X.unop) ^ 2) r) =
      Ideal.Quotient.mk ((I G X.unop) ^ 2) r
    rw [q1Restrict_mk, G.restrict_id]
  map_comp {X Y Z} φ ψ := by
    ext x
    refine Quotient.inductionOn' x ?_
    intro r
    show q1Restrict G (ψ.unop ≫ φ.unop)
        (Ideal.Quotient.mk ((I G X.unop) ^ 2) r) =
      q1Restrict G ψ.unop
        (q1Restrict G φ.unop
          (Ideal.Quotient.mk ((I G X.unop) ^ 2) r))
    rw [q1Restrict_mk, q1Restrict_mk, q1Restrict_mk, G.restrict_comp]

/-- Objectwise projection from `O/I^2` to `O/I`. -/
def projectionAt (W : S.category) : Q1 G W →+* Q0 G W :=
  Ideal.Quotient.factor (Ideal.pow_le_self two_ne_zero)

/-- The projection sends a representative modulo `I^2` to the same representative modulo `I`. -/
@[simp]
theorem projectionAt_mk (W : S.category) (x : G.Observable W) :
    projectionAt G W (Ideal.Quotient.mk ((I G W) ^ 2) x) =
      Ideal.Quotient.mk (I G W) x := by
  exact Ideal.Quotient.factor_mk _ _

/-- The quotient projections form a natural transformation `O/I^2 → O/I`. -/
def projection : q1Coefficient G ⟶ G.obstructionQuotientCoefficient where
  app W := AddCommGrpCat.ofHom (projectionAt G W.unop).toAddMonoidHom
  naturality {X Y} φ := by
    ext x
    refine Quotient.inductionOn' x ?_
    intro r
    change projectionAt G Y.unop
        (q1Restrict G φ.unop
          (Ideal.Quotient.mk ((I G X.unop) ^ 2) r)) =
      G.obstructionQuotientRestrict φ.unop
        (projectionAt G X.unop
          (Ideal.Quotient.mk ((I G X.unop) ^ 2) r))
    rw [q1Restrict_mk, projectionAt_mk, projectionAt_mk,
      G.obstructionQuotientRestrict_mk]

/-- Every `O/I` section has an objectwise representative in `O/I^2`. -/
theorem projectionAt_surjective (W : S.category) :
    Function.Surjective (projectionAt G W) := by
  intro y
  obtain ⟨x, rfl⟩ := Ideal.Quotient.mk_surjective y
  exact ⟨Ideal.Quotient.mk ((I G W) ^ 2) x, by simp⟩

/-- Restriction on the conormal coefficient `I/I^2`. -/
def conormalRestrict {source target : S.category} (f : source ⟶ target) :
    Conormal G target →+ Conormal G source :=
  (Ideal.mapCotangent
    (I G target) (I G source) (G.restrict f).toIntAlgHom
    (Ideal.map_le_iff_le_comap.mp (G.map_obstructionIdeal_le f))).toAddMonoidHom

/-- Conormal restriction on a displayed ideal representative. -/
@[simp]
theorem conormalRestrict_toCotangent {source target : S.category}
    (f : source ⟶ target) (x : I G target) :
    conormalRestrict G f ((I G target).toCotangent x) =
      (I G source).toCotangent
        ⟨G.restrict f x,
          (Ideal.map_le_iff_le_comap.mp (G.map_obstructionIdeal_le f)) x.property⟩ := by
  exact Ideal.mapCotangent_toCotangent _ _ _ _ _

/-- The additive presheaf generated by the conormal coefficients `I/I^2`. -/
def conormalCoefficient : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u} where
  obj W := AddCommGrpCat.of (Conormal G W.unop)
  map {X Y} φ := AddCommGrpCat.ofHom (conormalRestrict G φ.unop)
  map_id X := by
    ext z
    obtain ⟨x, rfl⟩ := (I G X.unop).toCotangent_surjective z
    apply (I G X.unop).toCotangent_eq.mpr
    change G.restrict (𝟙 X.unop) x - x ∈ (I G X.unop) ^ 2
    rw [G.restrict_id, sub_self]
    exact (I G X.unop ^ 2).zero_mem
  map_comp {X Y Z} φ ψ := by
    ext z
    obtain ⟨x, rfl⟩ := (I G X.unop).toCotangent_surjective z
    apply (I G Z.unop).toCotangent_eq.mpr
    change G.restrict (ψ.unop ≫ φ.unop) x -
      G.restrict ψ.unop (G.restrict φ.unop x) ∈ (I G Z.unop) ^ 2
    rw [G.restrict_comp, sub_self]
    exact (I G Z.unop ^ 2).zero_mem

/-- Objectwise inclusion `I/I^2 → O/I^2`. -/
def conormalInclusionAt (W : S.category) : Conormal G W →+ Q1 G W :=
  (I G W).cotangentToQuotientSquare.toAddMonoidHom

/-- The conormal inclusions form a natural transformation into `O/I^2`. -/
def conormalInclusion : conormalCoefficient G ⟶ q1Coefficient G where
  app W := AddCommGrpCat.ofHom (conormalInclusionAt G W.unop)
  naturality {X Y} φ := by
    ext z
    obtain ⟨x, rfl⟩ := (I G X.unop).toCotangent_surjective z
    rfl

/-- The objectwise projection kills the conormal inclusion. -/
theorem projection_inclusion_zero (W : S.category) (x : Conormal G W) :
    projectionAt G W (conormalInclusionAt G W x) = 0 := by
  obtain ⟨y, rfl⟩ := (I G W).toCotangent_surjective x
  change Ideal.Quotient.mk (I G W) y = 0
  exact Ideal.Quotient.eq_zero_iff_mem.mpr y.property

/-- The composite natural transformation `I/I^2 → O/I^2 → O/I` is zero. -/
theorem projection_comp_inclusion :
    conormalInclusion G ≫ projection G = 0 := by
  ext W x
  exact projection_inclusion_zero G W.unop x

/-- The kernel ideal of `O/I^2 → O/I` is the canonical cotangent ideal. -/
theorem projectionAt_ker (W : S.category) :
    RingHom.ker (projectionAt G W) = (I G W).cotangentIdeal := by
  calc
    RingHom.ker (projectionAt G W) =
        (I G W).map (Ideal.Quotient.mk ((I G W) ^ 2)) := by
      simpa [projectionAt] using
        (Ideal.Quotient.factor_ker
          (Ideal.pow_le_self two_ne_zero : (I G W) ^ 2 ≤ I G W))
    _ = (I G W).cotangentIdeal := by
      exact Ideal.map_eq_submodule_map
        (Ideal.Quotient.mk ((I G W) ^ 2)) (I G W)

/-- The conormal inclusion with codomain restricted to the objectwise kernel. -/
def conormalToKernel (W : S.category) :
    Conormal G W →+
      AddMonoidHom.ker (projectionAt G W).toAddMonoidHom where
  toFun x := ⟨conormalInclusionAt G W x, projection_inclusion_zero G W x⟩
  map_zero' := by
    apply Subtype.ext
    exact map_zero (conormalInclusionAt G W)
  map_add' x y := by
    apply Subtype.ext
    exact map_add (conormalInclusionAt G W) x y

/-- The kernel-restricted conormal inclusion is injective. -/
theorem conormalToKernel_injective (W : S.category) :
    Function.Injective (conormalToKernel G W) := by
  intro x y hxy
  have hval := congrArg Subtype.val hxy
  apply (I G W).cotangentEquivIdeal.injective
  apply Subtype.ext
  rw [(I G W).cotangentEquivIdeal_apply,
    (I G W).cotangentEquivIdeal_apply]
  exact hval

/-- Every objectwise kernel element is generated by a conormal class. -/
theorem conormalToKernel_surjective (W : S.category) :
    Function.Surjective (conormalToKernel G W) := by
  intro y
  have hy : y.1 ∈ (I G W).cotangentIdeal := by
    have hy' : y.1 ∈ RingHom.ker (projectionAt G W) := y.2
    rwa [projectionAt_ker G W] at hy'
  let z : Conormal G W := (I G W).cotangentEquivIdeal.symm ⟨y.1, hy⟩
  refine ⟨z, ?_⟩
  apply Subtype.ext
  change conormalInclusionAt G W z = y.1
  have hz := (I G W).cotangentEquivIdeal_apply z
  have heq : (I G W).cotangentEquivIdeal z = ⟨y.1, hy⟩ := by
    exact (I G W).cotangentEquivIdeal.apply_symm_apply ⟨y.1, hy⟩
  rw [heq] at hz
  exact hz.symm

/-- The generated conormal coefficient is objectwise the kernel of the projection. -/
noncomputable def conormalKernelEquiv (W : S.category) :
    Conormal G W ≃+
      AddMonoidHom.ker (projectionAt G W).toAddMonoidHom :=
  AddEquiv.ofBijective (conormalToKernel G W)
    ⟨conormalToKernel_injective G W, conormalToKernel_surjective G W⟩

/-- The kernel equivalence is compatible with the generated conormal inclusion. -/
@[simp]
theorem conormalKernelEquiv_apply (W : S.category) (x : Conormal G W) :
    ((conormalKernelEquiv G W x).1 : Q1 G W) = conormalInclusionAt G W x :=
  rfl

/-- The generated conormal inclusion is objectwise injective. -/
theorem conormalInclusionAt_injective (W : S.category) :
    Function.Injective (conormalInclusionAt G W) := by
  intro x y hxy
  apply conormalToKernel_injective G W
  apply Subtype.ext
  exact hxy

end Raw

end LawGeneratedIdealPowerSequence
end ResearchLean.AG.QualitySurface

#assert_standard_axioms_only ResearchLean.AG.QualitySurface.LawGeneratedIdealPowerSequence
