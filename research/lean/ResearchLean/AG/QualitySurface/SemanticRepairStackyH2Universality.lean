import ResearchLean.AG.QualitySurface.SemanticRepairStackyH2

/-!
Cycle 83 evidence for `G-aat-quality-surface-04`.

This file adds the object-level finite/small stacky `H2` quotient surface over
`FiniteStackyRepairH2Envelope`.

The current stacky envelope intentionally stores only finite 2-coherence data,
boundary witnesses, and the selected 2-cocycle.  It does not store a higher
stack action, quotient relation, neutral cocycle proof, stack effectiveness,
or tower vanishing.  Therefore the same-class relation, neutral cocycle, and
selected/neutral comparison are supplied as visible relation data.  No global
coherence, representation adequacy, arbitrary-site `H2`, or target completion
is hidden in the envelope or in theorem premises.
-/

namespace ResearchLean.AG
namespace QualitySurface
namespace SemanticRepairStackyH2Universality

open SemanticRepairStackyH2

universe z r s

/-! ## Object-level stacky `H2` classes -/

/-- Actual stacky `H2` cocycles in a finite stacky repair envelope. -/
def StackyRepairH2Cocycle
    {Coherence : Type z}
    {Repair : Type r}
    (stack : FiniteStackyRepairH2Envelope Coherence Repair) :
    Type z :=
  { cochain : Coherence // StackyCechZ2 stack cochain }

/--
Visible stacky `H2` class relation data.

The neutral cocycle proof is explicit because `FiniteStackyRepairH2Envelope`
does not require `neutral2` to be a 2-cocycle.  The same-class relation and
selected/neutral comparison are also external theorem data rather than hidden
stack-effectiveness assumptions.
-/
structure StackyRepairH2ClassRelation
    {Coherence : Type z}
    {Repair : Type r}
    (stack : FiniteStackyRepairH2Envelope Coherence Repair) where
  neutral2_cocycle : StackyCechZ2 stack stack.neutral2
  sameClass :
    StackyRepairH2Cocycle stack ->
      StackyRepairH2Cocycle stack ->
        Prop
  sameClass_refl :
    ∀ cocycle : StackyRepairH2Cocycle stack,
      sameClass cocycle cocycle
  sameClass_symm :
    ∀ left right : StackyRepairH2Cocycle stack,
      sameClass left right -> sameClass right left
  sameClass_trans :
    ∀ left middle right : StackyRepairH2Cocycle stack,
      sameClass left middle ->
        sameClass middle right ->
          sameClass left right
  selected_neutral_iff_trivial :
    sameClass
        ⟨stack.selected2Cocycle, stack.selected2_cocycle⟩
        ⟨stack.neutral2, neutral2_cocycle⟩ <->
      StackyRepairTrivial stack

/-- The visible stacky same-class relation on 2-cocycles. -/
def StackyRepairH2SameClass
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    (left right : StackyRepairH2Cocycle stack) : Prop :=
  relation.sameClass left right

/-- The quotient setoid generated by the visible stacky same-class data. -/
def stackyRepairH2CocycleSetoid
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack) :
    Setoid (StackyRepairH2Cocycle stack) where
  r left right := StackyRepairH2SameClass relation left right
  iseqv := by
    constructor
    · intro cocycle
      exact relation.sameClass_refl cocycle
    · intro left right hsame
      exact relation.sameClass_symm left right hsame
    · intro left middle right hleft hright
      exact relation.sameClass_trans left middle right hleft hright

/-- The object-level stacky repair `H2` class quotient. -/
def StackyRepairH2Class
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack) :
    Type z :=
  Quot (stackyRepairH2CocycleSetoid relation)

/-- Build a stacky repair `H2` class from a visible 2-cocycle. -/
def stackyRepairH2Class_mk
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    (cochain : Coherence)
    (hclosed : StackyCechZ2 stack cochain) :
    StackyRepairH2Class relation :=
  Quot.mk (stackyRepairH2CocycleSetoid relation)
    ⟨cochain, hclosed⟩

/-- Same-class 2-cocycles have equal stacky repair `H2` quotient classes. -/
theorem stackyRepairH2Class_eq_of_sameClass
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    {left right : StackyRepairH2Cocycle stack}
    (hsame : StackyRepairH2SameClass relation left right) :
    Quot.mk (stackyRepairH2CocycleSetoid relation) left =
      Quot.mk (stackyRepairH2CocycleSetoid relation) right := by
  exact Quot.sound hsame

/-- The selected 2-cocycle as a stacky repair `H2` class. -/
def stackyRepairH2_selected2Class
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack) :
    StackyRepairH2Class relation :=
  stackyRepairH2Class_mk relation
    stack.selected2Cocycle stack.selected2_cocycle

/-- The neutral 2-cochain as a stacky repair `H2` class. -/
def stackyRepairH2_neutralClass
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack) :
    StackyRepairH2Class relation :=
  stackyRepairH2Class_mk relation
    stack.neutral2 relation.neutral2_cocycle

/-! ## Universal factorization and visible effectivity comparison -/

/--
Lift a 2-cocycle observation to stacky `H2` classes when it visibly respects
the supplied same-class relation.
-/
def stackyRepairH2_lift
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    {Out : Type s}
    (observe : StackyRepairH2Cocycle stack -> Out)
    (respect :
      ∀ left right : StackyRepairH2Cocycle stack,
        StackyRepairH2SameClass relation left right ->
          observe left = observe right) :
    StackyRepairH2Class relation -> Out :=
  Quot.lift observe (by
    intro left right hsame
    exact respect left right hsame)

/-- The lifted observation agrees with the original observation on 2-cocycles. -/
theorem stackyRepairH2_lift_mk
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    {Out : Type s}
    (observe : StackyRepairH2Cocycle stack -> Out)
    (respect :
      ∀ left right : StackyRepairH2Cocycle stack,
        StackyRepairH2SameClass relation left right ->
          observe left = observe right)
    (cochain : Coherence)
    (hclosed : StackyCechZ2 stack cochain) :
    stackyRepairH2_lift relation observe respect
        (stackyRepairH2Class_mk relation cochain hclosed) =
      observe ⟨cochain, hclosed⟩ := by
  rfl

/--
Universal factorization through the stacky repair `H2` quotient class.

Only observations that respect the visible same-class relation factor.
-/
theorem stackyRepairH2_universalFactorization
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    {Out : Type s}
    (observe : StackyRepairH2Cocycle stack -> Out)
    (respect :
      ∀ left right : StackyRepairH2Cocycle stack,
        StackyRepairH2SameClass relation left right ->
          observe left = observe right) :
    (∀ cocycle : StackyRepairH2Cocycle stack,
      stackyRepairH2_lift relation observe respect
          (Quot.mk (stackyRepairH2CocycleSetoid relation) cocycle) =
        observe cocycle) ∧
      (∀ factor : StackyRepairH2Class relation -> Out,
        (∀ cocycle : StackyRepairH2Cocycle stack,
          factor (Quot.mk (stackyRepairH2CocycleSetoid relation) cocycle) =
            observe cocycle) ->
          ∀ cls : StackyRepairH2Class relation,
            factor cls =
              stackyRepairH2_lift relation observe respect cls) := by
  constructor
  · intro cocycle
    rfl
  · intro factor hfactor cls
    refine Quot.inductionOn cls ?_
    intro cocycle
    simpa [stackyRepairH2_lift] using hfactor cocycle

/--
Effective stacky repair descent identifies the selected 2-cocycle class with
the neutral class through the visible same-class relation.
-/
theorem stackyRepairH2_selectedClass_eq_neutral_of_effectiveDescent
    {Coherence : Type z}
    {Repair : Type r}
    {stack : FiniteStackyRepairH2Envelope Coherence Repair}
    (relation : StackyRepairH2ClassRelation stack)
    (heffective : EffectiveStackyRepairDescent stack) :
    stackyRepairH2_selected2Class relation =
      stackyRepairH2_neutralClass relation := by
  rcases heffective with ⟨repair, _heffective, hboundary⟩
  have htrivial : StackyRepairTrivial stack := ⟨repair, hboundary⟩
  have hsame :
      StackyRepairH2SameClass relation
        ⟨stack.selected2Cocycle, stack.selected2_cocycle⟩
        ⟨stack.neutral2, relation.neutral2_cocycle⟩ :=
    relation.selected_neutral_iff_trivial.2 htrivial
  exact Quot.sound hsame

end SemanticRepairStackyH2Universality
end QualitySurface
end ResearchLean.AG
