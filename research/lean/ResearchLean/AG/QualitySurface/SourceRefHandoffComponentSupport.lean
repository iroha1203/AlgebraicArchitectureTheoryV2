import ResearchLean.AG.QualitySurface.SourceRefHandoffObstructionLocus

/-!
Cycle 63 evidence for `G-aat-quality-surface-01`.

This file projects the order-independent source-ref handoff obstruction locus
to a component support invariant and fixes a selected three-law minimality
matrix for support, trace, and repair-frontier handoff laws.  The construction
is relative to bounded source-ref handoffs, selected finite atlases, and the
finite `BridgeComponent` vocabulary.  It does not assert global canonical
minimality, runtime repair synthesis, source extraction completeness, ArchMap
correctness, arbitrary route enumeration, or whole-codebase quality.
-/

namespace ResearchLean.AG
namespace QualitySurface
namespace SourceRefHandoffComponentSupport

open CodebaseTracePacket
open HeterogeneousRouteInteraction
open BridgeComponent
open SourceRefTupleBridge
open SourceRefHandoffBridge
open SourceRefHandoffHolonomyCorrespondence
open SourceRefHandoffObstructionLocus
open ParametrizedSelectedCorrectionSystem
open MultiRouteCorrectionSystem
open TraceLocus
open RepairStage

/-! ## Component support of a handoff obstruction locus -/

/-- Component-level support of the handoff obstruction locus. -/
def HandoffComponentSupport
    (atlas : SourceRefHandoffAtlas)
    (component : BridgeComponent) : Prop :=
  exists loop, loop ∈ atlas.loops /\ HandoffHolonomySupport loop component

/-- The component support has at least one failed component. -/
def HandoffComponentSupportNonempty
    (atlas : SourceRefHandoffAtlas) : Prop :=
  exists component, HandoffComponentSupport atlas component

/-- The component support is empty. -/
def HandoffComponentSupportEmpty
    (atlas : SourceRefHandoffAtlas) : Prop :=
  Not (HandoffComponentSupportNonempty atlas)

/-- Component support nonemptiness is exactly handoff locus nonemptiness. -/
theorem handoffComponentSupport_nonempty_iff_locusNonempty
    (atlas : SourceRefHandoffAtlas) :
    HandoffComponentSupportNonempty atlas <->
      HandoffObstructionLocusNonempty atlas := by
  constructor
  · intro hsupport
    rcases hsupport with ⟨component, loop, hmem, hholonomy⟩
    exact
      ⟨{ loop := loop,
          component := component,
          loop_mem := hmem,
          support := hholonomy }⟩
  · intro hnonempty
    rcases hnonempty with ⟨point⟩
    exact
      ⟨point.component, point.loop, point.loop_mem, point.support⟩

/-- Empty component support is exactly empty handoff obstruction locus. -/
theorem handoffComponentSupport_empty_iff_locusEmpty
    (atlas : SourceRefHandoffAtlas) :
    HandoffComponentSupportEmpty atlas <->
      HandoffObstructionLocusEmpty atlas := by
  constructor
  · intro hempty hnonempty
    exact hempty
      ((handoffComponentSupport_nonempty_iff_locusNonempty atlas).mpr
        hnonempty)
  · intro hempty hsupport
    exact hempty
      ((handoffComponentSupport_nonempty_iff_locusNonempty atlas).mp
        hsupport)

/-- Empty component support is exactly handoff holonomy vanishing. -/
theorem handoffComponentSupport_empty_iff_holonomyVanishes
    (atlas : SourceRefHandoffAtlas) :
    HandoffComponentSupportEmpty atlas <->
      HandoffAtlasHolonomyVanishes atlas := by
  exact
    (handoffComponentSupport_empty_iff_locusEmpty atlas).trans
      (handoffObstructionLocus_empty_iff_holonomyVanishes atlas)

/-- Same obstruction locus preserves component support. -/
theorem sameHandoffObstructionLocus_preserves_componentSupport
    {atlas₁ atlas₂ : SourceRefHandoffAtlas}
    (hsame : SameHandoffObstructionLocus atlas₁ atlas₂)
    (component : BridgeComponent) :
    HandoffComponentSupport atlas₁ component <->
      HandoffComponentSupport atlas₂ component := by
  constructor
  · intro hsupport
    rcases hsupport with ⟨loop, hmem, hholonomy⟩
    have hlocus :=
      (hsame.2 loop component).mp ⟨hmem, hholonomy⟩
    exact ⟨loop, hlocus.1, hlocus.2⟩
  · intro hsupport
    rcases hsupport with ⟨loop, hmem, hholonomy⟩
    have hlocus :=
      (hsame.2 loop component).mpr ⟨hmem, hholonomy⟩
    exact ⟨loop, hlocus.1, hlocus.2⟩

/-! ## Generic singleton atlas wrapper for selected handoff witnesses -/

/-- Route state using a selected source-ref handoff bridge. -/
def componentSupportState
    (handoff : SourceRefHandoff) : HeterogeneousRouteState where
  selectedStage := allBranches
  scanAssignment := allBranchesScanAssignment
  bridge := handoff.toBridgeCertificate

/-- Source-ref handoff loop generated by one handoff witness. -/
def componentSupportLoop
    (handoff : SourceRefHandoff) : SourceRefHandoffLoop where
  name := RouteHolonomyObstructionSupport.RouteLoopName.handoff
  state := componentSupportState handoff
  handoff := handoff
  bridge_eq := rfl

/-- Singleton source-ref handoff atlas generated by one handoff witness. -/
def componentSupportAtlas
    (handoff : SourceRefHandoff) : SourceRefHandoffAtlas where
  loops := [componentSupportLoop handoff]

/-- The singleton atlas wrapper is locally exact on its listed loop. -/
theorem componentSupportAtlas_localExact
    (handoff : SourceRefHandoff) :
    HandoffAtlasLocalExact (componentSupportAtlas handoff) := by
  intro loop hmem
  simp [componentSupportAtlas] at hmem
  subst loop
  constructor
  · simpa [componentSupportLoop, componentSupportState,
      SelectedRouteLocalExact] using stagedCorrection_allBranches_exact
  · simpa [componentSupportLoop, componentSupportState,
      ScanRouteLocalExact] using allBranchesScanAssignment_exact

/-! ## One-component deletion witnesses -/

/-- Endpoint tuple that keeps trace and repair-frontier laws but deletes support. -/
def supportDeletedEndpointTuple : EndpointTuple :=
  { fullPacketEndpointTuple with
    selectedSupport := fun _ => False }

/-- The support-deleted tuple keeps trace compatibility. -/
theorem supportDeletion_traceCompatible :
    HandoffTraceCompatible fullPacket supportDeletedEndpointTuple := by
  intro atom
  cases atom <;> rfl

/-- The support-deleted tuple keeps repair-frontier compatibility. -/
theorem supportDeletion_repairFrontierCompatible :
    HandoffRepairFrontierCompatible fullPacket supportDeletedEndpointTuple := by
  intro atom
  cases atom <;> rfl

/-- The support-deleted tuple breaks support compatibility. -/
theorem supportDeletion_not_supportCompatible :
    Not (HandoffSupportCompatible fullPacket supportDeletedEndpointTuple) := by
  intro hsupport
  exact (hsupport CodeAtom.endpoint).mpr trivial

/-- Handoff witness with only the support law deleted. -/
def supportLawDeletionHandoff : SourceRefHandoff where
  packet := fullPacket
  tuple := supportDeletedEndpointTuple
  supportCertified := false
  traceCertified := true
  repairFrontierCertified := true
  supportCertified_iff := by
    constructor
    · intro h
      cases h
    · intro hsupport
      exact False.elim (supportDeletion_not_supportCompatible hsupport)
  traceCertified_iff := by
    constructor
    · intro _h
      exact supportDeletion_traceCompatible
    · intro _h
      rfl
  repairFrontierCertified_iff := by
    constructor
    · intro _h
      exact supportDeletion_repairFrontierCompatible
    · intro _h
      rfl

/-- Endpoint tuple that keeps support and trace laws but deletes repair frontier. -/
def repairFrontierDeletedEndpointTuple : EndpointTuple :=
  { fullPacketEndpointTuple with
    repairFrontier := fun atom => atom = LocusAtom.api }

/-- The repair-frontier-deleted tuple keeps support compatibility. -/
theorem repairFrontierDeletion_supportCompatible :
    HandoffSupportCompatible fullPacket repairFrontierDeletedEndpointTuple := by
  intro atom
  cases atom <;> rfl

/-- The repair-frontier-deleted tuple keeps trace compatibility. -/
theorem repairFrontierDeletion_traceCompatible :
    HandoffTraceCompatible fullPacket repairFrontierDeletedEndpointTuple := by
  intro atom
  cases atom <;> rfl

/-- The repair-frontier-deleted tuple breaks repair-frontier compatibility. -/
theorem repairFrontierDeletion_not_repairFrontierCompatible :
    Not (HandoffRepairFrontierCompatible
      fullPacket repairFrontierDeletedEndpointTuple) := by
  intro hrepair
  have hendpoint := (hrepair CodeAtom.endpoint).mp rfl
  cases hendpoint

/-- Handoff witness with only the repair-frontier law deleted. -/
def repairFrontierLawDeletionHandoff : SourceRefHandoff where
  packet := fullPacket
  tuple := repairFrontierDeletedEndpointTuple
  supportCertified := true
  traceCertified := true
  repairFrontierCertified := false
  supportCertified_iff := by
    constructor
    · intro _h
      exact repairFrontierDeletion_supportCompatible
    · intro _h
      rfl
  traceCertified_iff := by
    constructor
    · intro _h
      exact repairFrontierDeletion_traceCompatible
    · intro _h
      rfl
  repairFrontierCertified_iff := by
    constructor
    · intro h
      cases h
    · intro hrepair
      exact False.elim
        (repairFrontierDeletion_not_repairFrontierCompatible hrepair)

/-- Handoff witness with only the trace law deleted. -/
abbrev traceLawDeletionHandoff : SourceRefHandoff :=
  traceRenamedHandoff

/-! ## Two-of-three laws and deletion component supports -/

/-- Support deletion keeps the other two handoff laws. -/
theorem supportLawDeletion_twoOfThreeLaws :
    supportLawDeletionHandoff.ComponentLaw BridgeComponent.trace /\
      supportLawDeletionHandoff.ComponentLaw BridgeComponent.repairFrontier /\
      Not (supportLawDeletionHandoff.ComponentLaw BridgeComponent.support) :=
  ⟨supportDeletion_traceCompatible,
    supportDeletion_repairFrontierCompatible,
    supportDeletion_not_supportCompatible⟩

/-- Trace deletion keeps the other two handoff laws. -/
theorem traceLawDeletion_twoOfThreeLaws :
    traceLawDeletionHandoff.ComponentLaw BridgeComponent.support /\
      traceLawDeletionHandoff.ComponentLaw BridgeComponent.repairFrontier /\
      Not (traceLawDeletionHandoff.ComponentLaw BridgeComponent.trace) :=
  ⟨traceRenamedHandoff_supportCompatible,
    traceRenamedHandoff_repairFrontierCompatible,
    traceRenamedHandoff_not_traceCompatible⟩

/-- Repair-frontier deletion keeps the other two handoff laws. -/
theorem repairFrontierLawDeletion_twoOfThreeLaws :
    repairFrontierLawDeletionHandoff.ComponentLaw BridgeComponent.support /\
      repairFrontierLawDeletionHandoff.ComponentLaw BridgeComponent.trace /\
      Not
        (repairFrontierLawDeletionHandoff.ComponentLaw
          BridgeComponent.repairFrontier) :=
  ⟨repairFrontierDeletion_supportCompatible,
    repairFrontierDeletion_traceCompatible,
    repairFrontierDeletion_not_repairFrontierCompatible⟩

/-- Singleton atlas for the support-law deletion witness. -/
abbrev supportLawDeletionAtlas : SourceRefHandoffAtlas :=
  componentSupportAtlas supportLawDeletionHandoff

/-- Singleton atlas for the trace-law deletion witness. -/
abbrev traceLawDeletionAtlas : SourceRefHandoffAtlas :=
  componentSupportAtlas traceLawDeletionHandoff

/-- Singleton atlas for the repair-frontier-law deletion witness. -/
abbrev repairFrontierLawDeletionAtlas : SourceRefHandoffAtlas :=
  componentSupportAtlas repairFrontierLawDeletionHandoff

/-- Support deletion contributes support component support. -/
theorem supportLawDeletion_componentSupport :
    HandoffComponentSupport supportLawDeletionAtlas BridgeComponent.support := by
  refine
    ⟨componentSupportLoop supportLawDeletionHandoff, by
      simp [componentSupportAtlas], ?_⟩
  exact supportDeletion_not_supportCompatible

/-- Trace deletion contributes trace component support. -/
theorem traceLawDeletion_componentSupport :
    HandoffComponentSupport traceLawDeletionAtlas BridgeComponent.trace := by
  refine
    ⟨componentSupportLoop traceLawDeletionHandoff, by
      simp [componentSupportAtlas], ?_⟩
  exact traceRenamedHandoff_not_traceCompatible

/-- Repair-frontier deletion contributes repair-frontier component support. -/
theorem repairFrontierLawDeletion_componentSupport :
    HandoffComponentSupport
      repairFrontierLawDeletionAtlas BridgeComponent.repairFrontier := by
  refine
    ⟨componentSupportLoop repairFrontierLawDeletionHandoff, by
      simp [componentSupportAtlas], ?_⟩
  exact repairFrontierDeletion_not_repairFrontierCompatible

/-- Support deletion has nonempty handoff obstruction locus. -/
theorem supportLawDeletion_handoffLocusNonempty :
    HandoffObstructionLocusNonempty supportLawDeletionAtlas :=
  (handoffComponentSupport_nonempty_iff_locusNonempty
    supportLawDeletionAtlas).mp
    ⟨BridgeComponent.support, supportLawDeletion_componentSupport⟩

/-- Trace deletion has nonempty handoff obstruction locus. -/
theorem traceLawDeletion_handoffLocusNonempty :
    HandoffObstructionLocusNonempty traceLawDeletionAtlas :=
  (handoffComponentSupport_nonempty_iff_locusNonempty
    traceLawDeletionAtlas).mp
    ⟨BridgeComponent.trace, traceLawDeletion_componentSupport⟩

/-- Repair-frontier deletion has nonempty handoff obstruction locus. -/
theorem repairFrontierLawDeletion_handoffLocusNonempty :
    HandoffObstructionLocusNonempty repairFrontierLawDeletionAtlas :=
  (handoffComponentSupport_nonempty_iff_locusNonempty
    repairFrontierLawDeletionAtlas).mp
    ⟨BridgeComponent.repairFrontier,
      repairFrontierLawDeletion_componentSupport⟩

/-- Support deletion remains not interaction exact under local exactness. -/
theorem supportLawDeletion_not_interactionExact :
    Not (HandoffAtlasInteractionExact supportLawDeletionAtlas) :=
  (handoffAtlas_not_interactionExact_iff_locus_nonempty_of_local
    (componentSupportAtlas_localExact supportLawDeletionHandoff)).mpr
    supportLawDeletion_handoffLocusNonempty

/-- Trace deletion remains not interaction exact under local exactness. -/
theorem traceLawDeletion_not_interactionExact :
    Not (HandoffAtlasInteractionExact traceLawDeletionAtlas) :=
  (handoffAtlas_not_interactionExact_iff_locus_nonempty_of_local
    (componentSupportAtlas_localExact traceLawDeletionHandoff)).mpr
    traceLawDeletion_handoffLocusNonempty

/-- Repair-frontier deletion remains not interaction exact under local exactness. -/
theorem repairFrontierLawDeletion_not_interactionExact :
    Not (HandoffAtlasInteractionExact repairFrontierLawDeletionAtlas) :=
  (handoffAtlas_not_interactionExact_iff_locus_nonempty_of_local
    (componentSupportAtlas_localExact
      repairFrontierLawDeletionHandoff)).mpr
    repairFrontierLawDeletion_handoffLocusNonempty

/-! ## Theorem package -/

/--
Cycle-63 theorem package: the order-independent handoff locus has a component
support projection, and each of support, trace, and repair-frontier laws is
independently necessary in selected finite one-component deletion witnesses.
-/
theorem sourceRefHandoffComponentSupport_package :
    (forall atlas,
      HandoffComponentSupportNonempty atlas <->
        HandoffObstructionLocusNonempty atlas) /\
      (forall atlas,
        HandoffComponentSupportEmpty atlas <->
          HandoffObstructionLocusEmpty atlas) /\
      (forall atlas,
        HandoffComponentSupportEmpty atlas <->
          HandoffAtlasHolonomyVanishes atlas) /\
      (forall atlas₁ atlas₂,
        SameHandoffObstructionLocus atlas₁ atlas₂ ->
          forall component,
            HandoffComponentSupport atlas₁ component <->
              HandoffComponentSupport atlas₂ component) /\
      HandoffAtlasLocalExact supportLawDeletionAtlas /\
      HandoffAtlasLocalExact traceLawDeletionAtlas /\
      HandoffAtlasLocalExact repairFrontierLawDeletionAtlas /\
      HandoffComponentSupport
        supportLawDeletionAtlas BridgeComponent.support /\
      HandoffComponentSupport traceLawDeletionAtlas BridgeComponent.trace /\
      HandoffComponentSupport
        repairFrontierLawDeletionAtlas BridgeComponent.repairFrontier /\
      HandoffObstructionLocusNonempty supportLawDeletionAtlas /\
      HandoffObstructionLocusNonempty traceLawDeletionAtlas /\
      HandoffObstructionLocusNonempty repairFrontierLawDeletionAtlas /\
      Not (HandoffAtlasInteractionExact supportLawDeletionAtlas) /\
      Not (HandoffAtlasInteractionExact traceLawDeletionAtlas) /\
      Not (HandoffAtlasInteractionExact repairFrontierLawDeletionAtlas) /\
      supportLawDeletionHandoff.ComponentLaw BridgeComponent.trace /\
      supportLawDeletionHandoff.ComponentLaw BridgeComponent.repairFrontier /\
      Not (supportLawDeletionHandoff.ComponentLaw BridgeComponent.support) /\
      traceLawDeletionHandoff.ComponentLaw BridgeComponent.support /\
      traceLawDeletionHandoff.ComponentLaw BridgeComponent.repairFrontier /\
      Not (traceLawDeletionHandoff.ComponentLaw BridgeComponent.trace) /\
      repairFrontierLawDeletionHandoff.ComponentLaw BridgeComponent.support /\
      repairFrontierLawDeletionHandoff.ComponentLaw BridgeComponent.trace /\
      Not
        (repairFrontierLawDeletionHandoff.ComponentLaw
          BridgeComponent.repairFrontier) := by
  exact
    ⟨handoffComponentSupport_nonempty_iff_locusNonempty,
      handoffComponentSupport_empty_iff_locusEmpty,
      handoffComponentSupport_empty_iff_holonomyVanishes,
      fun _atlas₁ _atlas₂ hsame component =>
        sameHandoffObstructionLocus_preserves_componentSupport
          hsame component,
      componentSupportAtlas_localExact supportLawDeletionHandoff,
      componentSupportAtlas_localExact traceLawDeletionHandoff,
      componentSupportAtlas_localExact repairFrontierLawDeletionHandoff,
      supportLawDeletion_componentSupport,
      traceLawDeletion_componentSupport,
      repairFrontierLawDeletion_componentSupport,
      supportLawDeletion_handoffLocusNonempty,
      traceLawDeletion_handoffLocusNonempty,
      repairFrontierLawDeletion_handoffLocusNonempty,
      supportLawDeletion_not_interactionExact,
      traceLawDeletion_not_interactionExact,
      repairFrontierLawDeletion_not_interactionExact,
      supportLawDeletion_twoOfThreeLaws.1,
      supportLawDeletion_twoOfThreeLaws.2.1,
      supportLawDeletion_twoOfThreeLaws.2.2,
      traceLawDeletion_twoOfThreeLaws.1,
      traceLawDeletion_twoOfThreeLaws.2.1,
      traceLawDeletion_twoOfThreeLaws.2.2,
      repairFrontierLawDeletion_twoOfThreeLaws.1,
      repairFrontierLawDeletion_twoOfThreeLaws.2.1,
      repairFrontierLawDeletion_twoOfThreeLaws.2.2⟩

end SourceRefHandoffComponentSupport
end QualitySurface
end ResearchLean.AG
