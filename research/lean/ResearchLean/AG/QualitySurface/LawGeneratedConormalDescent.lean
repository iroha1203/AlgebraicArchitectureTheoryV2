import Formal.AG.Cohomology.FinitePosetStandardComplex
import Formal.Util.AssertStandardAxioms
import Mathlib.Tactic

/-!
# Law-generated conormal descent: small-cover checkpoint

This checkpoint removes the failed all-sieve presentation.  From a selected
finite-poset cover it generates the canonical tuple nerve, bundles the standard
face-restriction differential as the repository `CoverRelativeCechComplex`,
and exposes the repository `AdditiveCechH1` together with its zero-class
criterion.

The section-specific connecting cocycle and class are generated from explicit
local lifts, and their independence of the local-lift choice is proved through
the repository additive H1 relation.  Zero iff actual global lift and the
lift-fiber torsor remain proof obligations.  No conclusion equivalent to those
claims is accepted as an input field here.
-/

noncomputable section

namespace ResearchLean.AG.QualitySurface
namespace LawGeneratedConormalDescent

universe u

namespace SmallCanonicalTupleCover

variable {U : AAT.AG.AtomCarrier.{u}} {A : AAT.AG.ArchitectureObject U}
variable {S : AAT.AG.Site.AATSite A}
variable {geometry : AAT.AG.Site.FinitePosetCoverGeometry S}

/-- The overlap-generated canonical tuple geometry of a selected finite cover. -/
abbrev TupleGeometry := geometry.canonicalTupleCoverGeometryFromOverlap

/-- The standard finite-poset complex generated from tuple faces and alternating sums. -/
abbrev FiniteComplex (Ob : AAT.AG.Cohomology.ObstructionSheaf S) :=
  AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardFinitePosetCechComplex
    (TupleGeometry (geometry := geometry)) Ob

/-- The small cover-relative cover generated by the canonical tuple nerve. -/
abbrev Cover (Ob : AAT.AG.Cohomology.ObstructionSheaf S) :=
  AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardCoverRelativeCechCover
    (TupleGeometry (geometry := geometry)) Ob

/-- Pointwise additive structure on canonical-tuple cover cochains. -/
instance coverCochainAddCommGroup
    (Ob : AAT.AG.Cohomology.ObstructionSheaf S) (n : Nat) :
    AddCommGroup
      (AAT.AG.Cohomology.CoverRelativeCechCochain
        (Cover (geometry := geometry) Ob) Ob n) := by
  dsimp [Cover, TupleGeometry,
    AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardCoverRelativeCechCover,
    AAT.AG.Cohomology.finitePosetCoverRelativeCover,
    AAT.AG.Site.FinitePosetCechCochain]
  exact Pi.addCommGroup

/--
The standard finite-poset differential, bundled on the repository's additive
cover-relative surface.  No cocycle, class-zero, or lift-effectivity statement
is an input field.
-/
def complex (Ob : AAT.AG.Cohomology.ObstructionSheaf S) :
    AAT.AG.Cohomology.CoverRelativeCechComplex
      (Cover (geometry := geometry) Ob) Ob where
  cochainAddCommGroup := by
    intro n
    infer_instance
  alternatingFaceCombination := by
    intro n terms simplex
    exact
      (AAT.AG.Cohomology.StandardFinitePosetCech.standardAdditiveData
        (TupleGeometry (geometry := geometry)).toCoverGeometry Ob).combineFaces
        n simplex (terms simplex)
  differential := by
    intro n
    let C := FiniteComplex (geometry := geometry) Ob
    exact
      { toFun := C.differential n
        map_zero' := by
          exact AAT.AG.Cohomology.StandardFinitePosetCech.standardDifferential_zero
            C.faces n
        map_add' := by
          intro x y
          funext simplex
          classical
          change C.differential n (x + y) simplex =
            C.differential n x simplex + C.differential n y simplex
          dsimp [C, FiniteComplex,
            AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardFinitePosetCechComplex,
            AAT.AG.Cohomology.StandardFinitePosetCech.standardFinitePosetCechComplex,
            AAT.AG.Cohomology.StandardFinitePosetCech.standardDifferential,
            AAT.AG.Cohomology.StandardFinitePosetCech.standardAdditiveData,
            AAT.AG.Cohomology.StandardFinitePosetCech.obstructionSheafStandardAlternatingCombination]
          rw [← Finset.sum_add_distrib]
          refine Finset.sum_congr rfl ?_
          intro i _hi
          by_cases hi : Even i.val
          · simp only [hi, ↓reduceIte]
            exact Ob.map_add _ _ _
          · simp only [hi, ↓reduceIte]
            dsimp [AAT.AG.Site.FinitePosetCechFaceRestriction]
            dsimp [AAT.AG.Site.FinitePosetCoverGeometry.toObstructionCoefficientRegime,
              AAT.AG.Site.FinitePosetCoverGeometry.toRegime]
            let tau :=
              (((TupleGeometry (geometry := geometry)).toSimplicialFaceAction
                Ob.carrier.toPresheaf).toFaceData).face n simplex i
            rw [show (x + y) tau = x tau + y tau from rfl]
            rw [Ob.map_add]
            abel
          }
  differential_eq_alternatingFaceCombination := by
    intro n c
    funext simplex
    exact
      AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardFinitePosetCechComplex_differential_from_restrictions
        (TupleGeometry (geometry := geometry)) Ob n c simplex
  differential_comp := by
    intro n c
    exact
      AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardFinitePosetCechComplex_differential_comp
        (TupleGeometry (geometry := geometry)) Ob n c

/-- The repository additive `H¹` of the small generated tuple cover. -/
abbrev H1 (Ob : AAT.AG.Cohomology.ObstructionSheaf S) : Type u :=
  (complex (geometry := geometry) Ob).AdditiveCechH1

/-- On the generated small complex, a repository H1 class is zero exactly for a degree-zero coboundary. -/
theorem additiveH1Class_eq_zero_iff
    (Ob : AAT.AG.Cohomology.ObstructionSheaf S)
    (c : (complex (geometry := geometry) Ob).CechCocycle 1) :
    (complex (geometry := geometry) Ob).additiveH1Class c = 0 ↔
      ∃ b : (complex (geometry := geometry) Ob).Cn 0,
        c.1 = (complex (geometry := geometry) Ob).d 0 b :=
  (complex (geometry := geometry) Ob).additiveH1Class_eq_zero_iff c

/-! ## Connecting class generated by local lifts -/

open CategoryTheory Opposite

/-- Generic additive short-exact lift data on the generators of the selected finite cover. -/
structure LiftProblem (geometry : AAT.AG.Site.FinitePosetCoverGeometry S) where
  N : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u}
  E : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u}
  Q : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u}
  kernel : N ⟶ E
  projection : E ⟶ Q
  kernelEquiv : ∀ W, N.obj W ≃+ AddMonoidHom.ker (projection.app W).hom
  kernelEquiv_apply : ∀ W n, ((kernelEquiv W n).1 : E.obj W) = kernel.app W n
  nIsSheaf : AAT.AG.Site.AATSheafCondition S (N ⋙ forget AddCommGrpCat)
  eIsSheaf : AAT.AG.Site.AATSheafCondition S (E ⋙ forget AddCommGrpCat)
  qIsSheaf : AAT.AG.Site.AATSheafCondition S (Q ⋙ forget AddCommGrpCat)
  baseSection : Q.obj (Opposite.op geometry.base)
  localLifts : ∀ i : geometry.cover.Index,
    E.obj (Opposite.op
      (AAT.AG.Site.ContextCategoryObject.of S.contextPreorder (geometry.cover.patch i)))
  localLifts_project : ∀ i : geometry.cover.Index,
    projection.app _ (localLifts i) =
      Q.map (CategoryTheory.homOfLE (geometry.cover.inclusion i)).op baseSection

namespace LiftProblem

open CategoryTheory Opposite

variable (P : LiftProblem geometry)

/-- Kernel, middle, and quotient coefficients as repository obstruction sheaves. -/
abbrev nOb := AAT.AG.Cohomology.ObstructionSheaf.ofAddCommGrpValued P.N P.nIsSheaf
abbrev eOb := AAT.AG.Cohomology.ObstructionSheaf.ofAddCommGrpValued P.E P.eIsSheaf
abbrev qOb := AAT.AG.Cohomology.ObstructionSheaf.ofAddCommGrpValued P.Q P.qIsSheaf

/-- The kernel comparison derives that the composite with the projection is zero. -/
theorem projection_kernel (W) (n : P.N.obj W) :
    P.projection.app W (P.kernel.app W n) = 0 := by
  rw [← P.kernelEquiv_apply]
  exact (P.kernelEquiv W n).property

/-- The selected generator lifts as a degree-zero cochain on the canonical tuple nerve. -/
def localLiftCochain :
    (complex (geometry := geometry) P.eOb).Cn 0 :=
  fun sigma => P.localLifts (sigma 0)

/-- Restriction of the fixed quotient section to every selected generator. -/
def baseSectionCochain :
    (complex (geometry := geometry) P.qOb).Cn 0 :=
  fun sigma => P.Q.map
    (homOfLE (geometry.cover.inclusion (sigma 0))).op P.baseSection

/-- The chosen local lifts project to the degree-zero restriction cochain. -/
theorem projection_localLiftCochain (sigma : (Cover (geometry := geometry) P.eOb).simplex 0) :
    P.projection.app _ (P.localLiftCochain sigma) = P.baseSectionCochain sigma := by
  exact P.localLifts_project (sigma 0)

/-- Naturality transports a cochain map through the generated standard differential. -/
theorem map_differential
    {F G : S.categoryᵒᵖ ⥤ AddCommGrpCat.{u}}
    (hF : AAT.AG.Site.AATSheafCondition S (F ⋙ forget AddCommGrpCat))
    (hG : AAT.AG.Site.AATSheafCondition S (G ⋙ forget AddCommGrpCat))
    (eta : F ⟶ G) (n : Nat)
    (c : (complex (geometry := geometry)
      (AAT.AG.Cohomology.ObstructionSheaf.ofAddCommGrpValued F hF)).Cn n) :
    (fun sigma => eta.app _
      ((complex (geometry := geometry)
        (AAT.AG.Cohomology.ObstructionSheaf.ofAddCommGrpValued F hF)).d n c sigma)) =
    (complex (geometry := geometry)
      (AAT.AG.Cohomology.ObstructionSheaf.ofAddCommGrpValued G hG)).d n
      (fun sigma => eta.app _ (c sigma)) := by
  funext sigma
  classical
  dsimp [complex, FiniteComplex,
    AAT.AG.Cohomology.CoverRelativeCechComplex.d,
    AAT.AG.Cohomology.StandardFinitePosetCech.canonicalTupleStandardFinitePosetCechComplex,
    AAT.AG.Cohomology.StandardFinitePosetCech.standardFinitePosetCechComplex,
    AAT.AG.Cohomology.StandardFinitePosetCech.standardDifferential,
    AAT.AG.Cohomology.StandardFinitePosetCech.standardAdditiveData,
    AAT.AG.Cohomology.StandardFinitePosetCech.obstructionSheafStandardAlternatingCombination]
  rw [map_sum]
  refine Finset.sum_congr rfl ?_
  intro i _hi
  by_cases hi : Even i.val
  · simp only [hi, ↓reduceIte]
    exact eta.naturality_apply _ _
  · simp only [hi, ↓reduceIte, map_neg]
    exact congrArg Neg.neg (eta.naturality_apply _ _)

/-- The restriction cochain of a global quotient section is a degree-zero cocycle. -/
theorem baseSectionCochain_cocycle :
    (complex (geometry := geometry) P.qOb).d 0 P.baseSectionCochain = 0 := by
  funext sigma
  apply (AAT.AG.Cohomology.StandardFinitePosetCech.standardDifferential_degreeZero_eq_zero_iff_faceRestrictions_eq
      (((TupleGeometry (geometry := geometry)).toSimplicialFaceAction
        P.qOb.carrier.toPresheaf).toFaceData) P.baseSectionCochain sigma).2
  dsimp [baseSectionCochain, AAT.AG.Site.FinitePosetCechFaceRestriction,
    AAT.AG.Site.FinitePosetCoverGeometry.toObstructionCoefficientRegime,
    AAT.AG.Site.FinitePosetCoverGeometry.toRegime]
  change (P.Q ⋙ forget AddCommGrpCat).map _
      ((P.Q ⋙ forget AddCommGrpCat).map _ P.baseSection) =
    (P.Q ⋙ forget AddCommGrpCat).map _
      ((P.Q ⋙ forget AddCommGrpCat).map _ P.baseSection)
  rw [← FunctorToTypes.map_comp_apply, ← FunctorToTypes.map_comp_apply]
  congr 1

/-- The literal overlap difference of local lifts lies in the kernel of the quotient map. -/
theorem projection_localLiftDifferential_eq_zero
    (sigma : (Cover (geometry := geometry) P.eOb).simplex 1) :
    P.projection.app _
      ((complex (geometry := geometry) P.eOb).d 0 P.localLiftCochain sigma) = 0 := by
  have hmap := congrFun
    (map_differential (geometry := geometry)
      P.eIsSheaf P.qIsSheaf P.projection 0 P.localLiftCochain) sigma
  calc
    _ = (complex (geometry := geometry) P.qOb).d 0
        (fun tau => P.projection.app _ (P.localLiftCochain tau)) sigma := hmap
    _ = (complex (geometry := geometry) P.qOb).d 0 P.baseSectionCochain sigma := by
      exact congrArg
        (fun z => (complex (geometry := geometry) P.qOb).d 0 z sigma)
        (funext fun tau => P.projection_localLiftCochain tau)
    _ = 0 := congrFun P.baseSectionCochain_cocycle sigma

/-- Kernel-valued overlap difference generated from the chosen local lifts. -/
def localLiftDifference : (complex (geometry := geometry) P.nOb).Cn 1 :=
  fun sigma =>
    (P.kernelEquiv _).symm
      ⟨(complex (geometry := geometry) P.eOb).d 0 P.localLiftCochain sigma,
        P.projection_localLiftDifferential_eq_zero sigma⟩

/-- Applying the kernel inclusion recovers the literal local-lift differential. -/
theorem kernel_localLiftDifference (sigma : (Cover (geometry := geometry) P.nOb).simplex 1) :
    P.kernel.app _ (P.localLiftDifference sigma) =
      (complex (geometry := geometry) P.eOb).d 0 P.localLiftCochain sigma := by
  rw [← P.kernelEquiv_apply]
  change ((P.kernelEquiv _) ((P.kernelEquiv _).symm _)).1 = _
  rw [AddEquiv.apply_symm_apply]

/-- The generated overlap difference is a degree-one cocycle. -/
theorem localLiftDifference_cocycle :
    (complex (geometry := geometry) P.nOb).d 1 P.localLiftDifference = 0 := by
  funext sigma
  apply (P.kernelEquiv _).injective
  apply Subtype.ext
  rw [P.kernelEquiv_apply]
  have hmap := congrFun
    (map_differential (geometry := geometry)
      P.nIsSheaf P.eIsSheaf P.kernel 1 P.localLiftDifference) sigma
  calc
    _ = (complex (geometry := geometry) P.eOb).d 1
        (fun tau => P.kernel.app _ (P.localLiftDifference tau)) sigma := hmap
    _ = (complex (geometry := geometry) P.eOb).d 1
        ((complex (geometry := geometry) P.eOb).d 0 P.localLiftCochain) sigma := by
      exact congrArg
        (fun z => (complex (geometry := geometry) P.eOb).d 1 z sigma)
        (funext fun tau => P.kernel_localLiftDifference tau)
    _ = 0 := congrFun
      ((complex (geometry := geometry) P.eOb).d_comp_d_eq_zero 0 P.localLiftCochain) sigma
    _ = ((P.kernelEquiv _) (0 : P.N.obj _)).1 := by simp

/-- Section-specific connecting cocycle in the repository complex. -/
def connectingCocycle : (complex (geometry := geometry) P.nOb).CechCocycle 1 :=
  ⟨P.localLiftDifference, P.localLiftDifference_cocycle⟩

/-- Section-specific connecting class in repository additive H1. -/
def connectingClass : H1 (geometry := geometry) P.nOb :=
  (complex (geometry := geometry) P.nOb).additiveH1Class P.connectingCocycle

/-! ## Independence of the generator-local lift choice -/

/-- Explicit generator-local lifts of the fixed quotient section. -/
def GeneratorLocalLiftFamily : Type u :=
  { lifts : ∀ i : geometry.cover.Index,
      P.E.obj (op
        (AAT.AG.Site.ContextCategoryObject.of S.contextPreorder (geometry.cover.patch i))) //
    ∀ i, P.projection.app _ (lifts i) =
      P.Q.map (homOfLE (geometry.cover.inclusion i)).op P.baseSection }

/-- The local lifts stored in the problem are one explicit choice. -/
def chosenGeneratorLocalLiftFamily : P.GeneratorLocalLiftFamily :=
  ⟨P.localLifts, P.localLifts_project⟩

/-- Degree-zero middle cochain generated by any explicit local-lift choice. -/
def localLiftCochainFor (L : P.GeneratorLocalLiftFamily) :
    (complex (geometry := geometry) P.eOb).Cn 0 :=
  fun sigma => L.1 (sigma 0)

/-- Every explicit local-lift cochain projects to the fixed base-section cochain. -/
theorem projection_localLiftCochainFor (L : P.GeneratorLocalLiftFamily)
    (sigma : (Cover (geometry := geometry) P.eOb).simplex 0) :
    P.projection.app _ (P.localLiftCochainFor L sigma) = P.baseSectionCochain sigma :=
  L.2 (sigma 0)

/-- The differential of every explicit local-lift cochain is kernel-valued. -/
theorem projection_localLiftDifferentialFor_eq_zero
    (L : P.GeneratorLocalLiftFamily)
    (sigma : (Cover (geometry := geometry) P.eOb).simplex 1) :
    P.projection.app _
      ((complex (geometry := geometry) P.eOb).d 0 (P.localLiftCochainFor L) sigma) = 0 := by
  have hmap := congrFun
    (map_differential (geometry := geometry)
      P.eIsSheaf P.qIsSheaf P.projection 0 (P.localLiftCochainFor L)) sigma
  calc
    _ = (complex (geometry := geometry) P.qOb).d 0
        (fun tau => P.projection.app _ (P.localLiftCochainFor L tau)) sigma := hmap
    _ = (complex (geometry := geometry) P.qOb).d 0 P.baseSectionCochain sigma := by
      exact congrArg
        (fun z => (complex (geometry := geometry) P.qOb).d 0 z sigma)
        (funext fun tau => P.projection_localLiftCochainFor L tau)
    _ = 0 := congrFun P.baseSectionCochain_cocycle sigma

/-- Kernel-valued overlap difference generated from an arbitrary local-lift choice. -/
def localLiftDifferenceFor (L : P.GeneratorLocalLiftFamily) :
    (complex (geometry := geometry) P.nOb).Cn 1 :=
  fun sigma =>
    (P.kernelEquiv _).symm
      ⟨(complex (geometry := geometry) P.eOb).d 0 (P.localLiftCochainFor L) sigma,
        P.projection_localLiftDifferentialFor_eq_zero L sigma⟩

/-- Kernel inclusion recovers the literal differential for every local-lift choice. -/
theorem kernel_localLiftDifferenceFor (L : P.GeneratorLocalLiftFamily)
    (sigma : (Cover (geometry := geometry) P.nOb).simplex 1) :
    P.kernel.app _ (P.localLiftDifferenceFor L sigma) =
      (complex (geometry := geometry) P.eOb).d 0 (P.localLiftCochainFor L) sigma := by
  rw [← P.kernelEquiv_apply]
  change ((P.kernelEquiv _) ((P.kernelEquiv _).symm _)).1 = _
  rw [AddEquiv.apply_symm_apply]

/-- Every generated overlap difference is a degree-one cocycle. -/
theorem localLiftDifferenceFor_cocycle (L : P.GeneratorLocalLiftFamily) :
    (complex (geometry := geometry) P.nOb).d 1 (P.localLiftDifferenceFor L) = 0 := by
  funext sigma
  apply (P.kernelEquiv _).injective
  apply Subtype.ext
  rw [P.kernelEquiv_apply]
  have hmap := congrFun
    (map_differential (geometry := geometry)
      P.nIsSheaf P.eIsSheaf P.kernel 1 (P.localLiftDifferenceFor L)) sigma
  calc
    _ = (complex (geometry := geometry) P.eOb).d 1
        (fun tau => P.kernel.app _ (P.localLiftDifferenceFor L tau)) sigma := hmap
    _ = (complex (geometry := geometry) P.eOb).d 1
        ((complex (geometry := geometry) P.eOb).d 0 (P.localLiftCochainFor L)) sigma := by
      exact congrArg
        (fun z => (complex (geometry := geometry) P.eOb).d 1 z sigma)
        (funext fun tau => P.kernel_localLiftDifferenceFor L tau)
    _ = 0 := congrFun
      ((complex (geometry := geometry) P.eOb).d_comp_d_eq_zero 0
        (P.localLiftCochainFor L)) sigma
    _ = ((P.kernelEquiv _) (0 : P.N.obj _)).1 := by simp

/-- Connecting cocycle generated from an arbitrary explicit local-lift choice. -/
def connectingCocycleFor (L : P.GeneratorLocalLiftFamily) :
    (complex (geometry := geometry) P.nOb).CechCocycle 1 :=
  ⟨P.localLiftDifferenceFor L, P.localLiftDifferenceFor_cocycle L⟩

/-- Connecting class generated from an arbitrary explicit local-lift choice. -/
def connectingClassFor (L : P.GeneratorLocalLiftFamily) :
    H1 (geometry := geometry) P.nOb :=
  (complex (geometry := geometry) P.nOb).additiveH1Class (P.connectingCocycleFor L)

/-- Kernel primitive measuring the pointwise change between two local-lift choices. -/
def changePrimitive (left right : P.GeneratorLocalLiftFamily) :
    (complex (geometry := geometry) P.nOb).Cn 0 :=
  fun sigma =>
    (P.kernelEquiv _).symm
      ⟨P.localLiftCochainFor left sigma - P.localLiftCochainFor right sigma, by
        change P.projection.app _
          (P.localLiftCochainFor left sigma - P.localLiftCochainFor right sigma) = 0
        rw [map_sub, P.projection_localLiftCochainFor,
          P.projection_localLiftCochainFor, sub_self]⟩

/-- Kernel inclusion recovers the literal pointwise change of local lifts. -/
theorem kernel_changePrimitive (left right : P.GeneratorLocalLiftFamily)
    (sigma : (Cover (geometry := geometry) P.nOb).simplex 0) :
    P.kernel.app _ (P.changePrimitive left right sigma) =
      P.localLiftCochainFor left sigma - P.localLiftCochainFor right sigma := by
  rw [← P.kernelEquiv_apply]
  change ((P.kernelEquiv _) ((P.kernelEquiv _).symm _)).1 = _
  rw [AddEquiv.apply_symm_apply]

/-- Changing local lifts changes the generated overlap cocycle by a coboundary. -/
theorem localLiftDifferenceFor_sub (left right : P.GeneratorLocalLiftFamily) :
    P.localLiftDifferenceFor left - P.localLiftDifferenceFor right =
      (complex (geometry := geometry) P.nOb).d 0 (P.changePrimitive left right) := by
  funext sigma
  apply (P.kernelEquiv _).injective
  apply Subtype.ext
  rw [P.kernelEquiv_apply]
  change P.kernel.app _
      (P.localLiftDifferenceFor left sigma - P.localLiftDifferenceFor right sigma) = _
  rw [map_sub, P.kernel_localLiftDifferenceFor, P.kernel_localLiftDifferenceFor]
  rw [P.kernelEquiv_apply]
  have hmap := congrFun
    (map_differential (geometry := geometry)
      P.nIsSheaf P.eIsSheaf P.kernel 0 (P.changePrimitive left right)) sigma
  rw [hmap]
  calc
    _ = (complex (geometry := geometry) P.eOb).d 0
        (P.localLiftCochainFor left - P.localLiftCochainFor right) sigma :=
      (congrFun (map_sub ((complex (geometry := geometry) P.eOb).d 0)
        (P.localLiftCochainFor left) (P.localLiftCochainFor right)) sigma).symm
    _ = _ := congrArg
      (fun z => (complex (geometry := geometry) P.eOb).d 0 z sigma)
      (funext fun tau => (P.kernel_changePrimitive left right tau).symm)

/-- The section-specific connecting class is independent of the local-lift choice. -/
theorem connectingClass_choice_independent (left right : P.GeneratorLocalLiftFamily) :
    P.connectingClassFor left = P.connectingClassFor right := by
  change (complex (geometry := geometry) P.nOb).additiveH1Class
      (P.connectingCocycleFor left) =
    (complex (geometry := geometry) P.nOb).additiveH1Class
      (P.connectingCocycleFor right)
  apply ((complex (geometry := geometry) P.nOb).additiveH1Class_eq_iff_legacy_setoid _ _).2
  exact ⟨P.changePrimitive left right, P.localLiftDifferenceFor_sub left right⟩

end LiftProblem

end SmallCanonicalTupleCover

end LawGeneratedConormalDescent
end ResearchLean.AG.QualitySurface

