                change
                  Presieve.ofArrows
                    (fun i : regime.cover.Index =>
                      (AAT.AG.Cohomology.finitePosetCoverRelativeCover C).chart i)
                    (fun i : regime.cover.Index =>
                      (AAT.AG.Cohomology.finitePosetCoverRelativeCover C).inclusion i)
                    ((AAT.AG.Cohomology.finitePosetCoverRelativeCover C).inclusion i)
                exact Presieve.ofArrows.mk i) = localSection) := by
