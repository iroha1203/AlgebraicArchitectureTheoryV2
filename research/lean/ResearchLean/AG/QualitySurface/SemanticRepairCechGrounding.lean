      Ob.carrier.toPresheaf.map gj.op
        (presieveSource.interpret j (presieveSource.input j)) at hcompat
  rw [hpreserves i, hpreserves j] at hcompat
  exact hcompat

/--
Cycle 297 blocker package: without `arrowCompatibilityLaw`, there is no
