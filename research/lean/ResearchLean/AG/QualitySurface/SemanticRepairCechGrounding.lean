  atom : U.Atom
  atom_traceVisible : semanticSite.sourceTraceToken atom = true
  lawIndex : S.equationSystem.toLegacyLawUniverse.Index
  law_required : S.equationSystem.toLegacyLawUniverse.Required lawIndex
