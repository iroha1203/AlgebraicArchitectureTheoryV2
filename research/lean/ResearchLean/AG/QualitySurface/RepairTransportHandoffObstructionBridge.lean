import ResearchLean.AG.QualitySurface.LawfulRepairTransportCommutator
import ResearchLean.AG.QualitySurface.RouteDefectSupport
import ResearchLean.AG.QualitySurface.SourceRefHandoffObstructionLocus

/-!
Cycle 62 evidence for `G-aat-quality-surface-01`.

This file connects selected source-ref repair/transport route endpoints to the
source-ref handoff obstruction locus.  The bridge is relative to supplied finite
packets, declared repair actions, explicit packet updates, and the existing
packet-to-tuple bridge.  It does not assert canonical repair planning, global
transport functoriality, source extraction completeness, ArchMap correctness,
runtime repair synthesis, arbitrary route enumeration, or whole-codebase
quality.
-/

namespace ResearchLean.AG
namespace QualitySurface
namespace RepairTransportHandoffObstructionBridge

open CodebaseTracePacket
open CodebaseTraceRepairTrajectory
open CodebaseTraceHolonomyPacket
open SourceRefTupleBridge
open SourceRefHandoffBridge
open SourceRefHandoffHolonomyCorrespondence
open SourceRefHandoffObstructionLocus
open LawfulRepairTransportCommutator
open RouteDefectSupportTheory
open HeterogeneousRouteInteraction
open BridgeComponent
open MultiRouteCorrectionSystem
open ParametrizedSelectedCorrectionSystem

/-! ## Endpoint-pair to handoff adapter -/

/-- Endpoint tuple induced by the right repair/transport route endpoint. -/
def endpointPairTuple (right : SourceRefPacket) : EndpointTuple :=
  packetToTuple endpointGridCertificate right

/--
Only packet defects that have a source-ref handoff component are projected to
handoff obstruction points.  Obligation defects are deliberately excluded.
-/
def packetDefectToHandoffComponent :
    SourceRefPacketProtectedComponent -> Option BridgeComponent
  | .obligation => none
  | .repairFrontier _atom => some BridgeComponent.repairFrontier
  | .sourceRefTable _atom => some BridgeComponent.trace

/-- Obligation disagreement has no handoff component projection. -/
theorem obligationDefect_has_no_handoffComponent :
    packetDefectToHandoffComponent
      SourceRefPacketProtectedComponent.obligation = none :=
  rfl

/--
A certified handoff adapter from a left packet endpoint to the tuple induced
by a right packet endpoint.
-/
structure RepairTransportHandoffBridge
    (left right : SourceRefPacket) where
  handoff : SourceRefHandoff
  packet_eq : handoff.packet = left
  tuple_eq : handoff.tuple = endpointPairTuple right

/-- Heterogeneous state that reads the endpoint-pair handoff as its bridge. -/
def RepairTransportHandoffBridge.toState
    {left right : SourceRefPacket}
    (bridge : RepairTransportHandoffBridge left right) :
    HeterogeneousRouteState where
  selectedStage := ParametrizedSelectedCorrectionSystem.RepairStage.allBranches
  scanAssignment := allBranchesScanAssignment
  bridge := bridge.handoff.toBridgeCertificate

/-- The adapter induces a source-ref handoff loop. -/
def RepairTransportHandoffBridge.toLoop
    {left right : SourceRefPacket}
    (bridge : RepairTransportHandoffBridge left right) :
    SourceRefHandoffLoop where
  name := RouteHolonomyObstructionSupport.RouteLoopName.handoff
  state := bridge.toState
  handoff := bridge.handoff
  bridge_eq := rfl

/-- The singleton atlas generated by the adapter. -/
def RepairTransportHandoffBridge.toAtlas
    {left right : SourceRefPacket}
    (bridge : RepairTransportHandoffBridge left right) :
    SourceRefHandoffAtlas where
  loops := [bridge.toLoop]

/-- The singleton adapter atlas is locally exact on its route state. -/
theorem RepairTransportHandoffBridge.toAtlas_localExact
    {left right : SourceRefPacket}
    (bridge : RepairTransportHandoffBridge left right) :
    HandoffAtlasLocalExact bridge.toAtlas := by
  intro loop hmem
  simp [RepairTransportHandoffBridge.toAtlas] at hmem
  subst loop
  constructor
  · simpa [RepairTransportHandoffBridge.toLoop,
      RepairTransportHandoffBridge.toState, SelectedRouteLocalExact]
      using stagedCorrection_allBranches_exact
  · simpa [RepairTransportHandoffBridge.toLoop,
      RepairTransportHandoffBridge.toState, ScanRouteLocalExact]
      using allBranchesScanAssignment_exact

/-! ## Lawful squares have empty handoff obstruction locus -/

/-- Lawful repair/transport endpoints induce an aligned source-ref handoff. -/
def lawfulRepairTransportHandoff
    {τ : SourceRefPacketTransport.PacketUpdate}
    {action transportedAction : SourceRefRepairAction}
    (hlawful : LawfulRepairTransportSquare τ action transportedAction)
    (packet : SourceRefPacket) :
    SourceRefHandoff where
  packet := LawfulRepairTransportCommutator.repairThenTransportPacket
    τ action packet
  tuple := endpointPairTuple
    (LawfulRepairTransportCommutator.transportThenRepairPacket
      τ transportedAction packet)
  supportCertified := true
  traceCertified := true
  repairFrontierCertified := true
  supportCertified_iff := by
    constructor
    · intro _h atom
      have hvisible :=
        repairTransport_visiblePacketSurface_of_lawful hlawful packet
      simpa [HandoffSupportCompatible, endpointPairTuple,
        packetToTuple, projectedSupport, from_to_locusAtom]
        using (hvisible.2 atom).symm
    · intro _h
      rfl
  traceCertified_iff := by
    constructor
    · intro _h atom
      have hzero :=
        repairTransport_noPacketHolonomy_of_lawful hlawful packet
      simpa [HandoffTraceCompatible, endpointPairTuple,
        packetToTuple, projectedTraceField, from_to_locusAtom]
        using congrArg (Option.map sourceRefToTraceToken)
          (hzero.2.2 atom).symm
    · intro _h
      rfl
  repairFrontierCertified_iff := by
    constructor
    · intro _h atom
      have hzero :=
        repairTransport_noPacketHolonomy_of_lawful hlawful packet
      simpa [HandoffRepairFrontierCompatible, endpointPairTuple,
        packetToTuple, projectedRepairFrontier, from_to_locusAtom]
        using (hzero.2.1 atom).symm
    · intro _h
      rfl

/-- Lawful repair/transport endpoints produce the certified handoff adapter. -/
def lawfulRepairTransportHandoffBridge
    {τ : SourceRefPacketTransport.PacketUpdate}
    {action transportedAction : SourceRefRepairAction}
    (hlawful : LawfulRepairTransportSquare τ action transportedAction)
    (packet : SourceRefPacket) :
    RepairTransportHandoffBridge
      (LawfulRepairTransportCommutator.repairThenTransportPacket
        τ action packet)
      (LawfulRepairTransportCommutator.transportThenRepairPacket
        τ transportedAction packet) where
  handoff := lawfulRepairTransportHandoff hlawful packet
  packet_eq := rfl
  tuple_eq := rfl

/-- A lawful repair/transport square has empty handoff obstruction locus. -/
theorem lawfulRepairTransport_handoffLocusEmpty
    {τ : SourceRefPacketTransport.PacketUpdate}
    {action transportedAction : SourceRefRepairAction}
    (hlawful : LawfulRepairTransportSquare τ action transportedAction)
    (packet : SourceRefPacket) :
    HandoffObstructionLocusEmpty
      (lawfulRepairTransportHandoffBridge hlawful packet).toAtlas := by
  refine (handoffObstructionLocus_empty_iff_holonomyVanishes
    (lawfulRepairTransportHandoffBridge hlawful packet).toAtlas).mpr ?_
  intro loop hmem component
  simp [RepairTransportHandoffBridge.toAtlas] at hmem
  subst loop
  change
    (lawfulRepairTransportHandoff hlawful packet).ComponentLaw component
  cases component
  · exact
      (lawfulRepairTransportHandoff hlawful packet).supportCertified_iff.mp
        rfl
  · exact
      (lawfulRepairTransportHandoff hlawful packet).traceCertified_iff.mp
        rfl
  · exact
      (lawfulRepairTransportHandoff hlawful packet).repairFrontierCertified_iff.mp
        rfl

/-! ## Visible-only commutator defects generate handoff obstruction points -/

/--
The visible-only repair/transport endpoints induce a handoff whose support law
is aligned, while trace and repair-frontier laws fail.
-/
def visibleRepairTransportHandoff : SourceRefHandoff where
  packet := RouteDefectSupportTheory.visibleRouteLeft
  tuple := endpointPairTuple RouteDefectSupportTheory.visibleRouteRight
  supportCertified := true
  traceCertified := false
  repairFrontierCertified := false
  supportCertified_iff := by
    constructor
    · intro _h atom
      rw [visibleRouteLeft, visibleRouteRight,
        VisibleRepairTransportCommutator.repairThenTransportPacket_eq_partial,
        VisibleRepairTransportCommutator.transportThenRepairPacket_eq_storageRepair]
      cases atom <;> rfl
    · intro _h
      rfl
  traceCertified_iff := by
    constructor
    · intro h
      cases h
    · intro htrace
      have hstorage := htrace CodeAtom.storage
      change some TraceLocus.LocusTraceToken.refDatabase =
        (none : Option TraceLocus.LocusTraceToken) at hstorage
      cases hstorage
  repairFrontierCertified_iff := by
    constructor
    · intro h
      cases h
    · intro hrepair
      have hstorage := hrepair CodeAtom.storage
      have hleft : visibleRouteLeft.repairFrontier CodeAtom.storage := by
        rw [visibleRouteLeft,
          VisibleRepairTransportCommutator.repairThenTransportPacket_eq_partial]
        exact partialTrace_forces_storage_repair
      have hright : visibleRouteRight.repairFrontier CodeAtom.storage := by
        exact hstorage.mpr hleft
      rw [visibleRouteRight,
        VisibleRepairTransportCommutator.transportThenRepairPacket_eq_storageRepair] at hright
      exact False.elim
        (repairTrajectory_repairFrontier_collapses
          ⟨CodeAtom.storage, hright⟩)

/-- The visible-only repair/transport endpoints produce the handoff adapter. -/
def visibleRepairTransportHandoffBridge :
    RepairTransportHandoffBridge
      RouteDefectSupportTheory.visibleRouteLeft
      RouteDefectSupportTheory.visibleRouteRight where
  handoff := visibleRepairTransportHandoff
  packet_eq := rfl
  tuple_eq := rfl

/-- The selected repair-frontier defect becomes a repair-frontier handoff point. -/
def visibleRepairTransport_repairFrontier_to_handoffObstructionPoint :
    HandoffObstructionPoint visibleRepairTransportHandoffBridge.toAtlas := by
  refine
    { loop := visibleRepairTransportHandoffBridge.toLoop
      component := BridgeComponent.repairFrontier
      loop_mem := by simp [RepairTransportHandoffBridge.toAtlas]
      support := ?_ }
  intro hcomponent
  have hfalse :
      visibleRepairTransportHandoff.repairFrontierCertified = true :=
    visibleRepairTransportHandoff.repairFrontierCertified_iff.mpr
      hcomponent
  cases hfalse

/-- The selected source-ref table defect becomes a trace handoff point. -/
def visibleRepairTransport_tableDefect_to_handoffTraceObstructionPoint :
    HandoffObstructionPoint visibleRepairTransportHandoffBridge.toAtlas := by
  refine
    { loop := visibleRepairTransportHandoffBridge.toLoop
      component := BridgeComponent.trace
      loop_mem := by simp [RepairTransportHandoffBridge.toAtlas]
      support := ?_ }
  intro hcomponent
  have hfalse :
      visibleRepairTransportHandoff.traceCertified = true :=
    visibleRepairTransportHandoff.traceCertified_iff.mpr
      hcomponent
  cases hfalse

/-- The visible-only repair/transport commutator has nonempty handoff locus. -/
theorem visibleRepairTransport_handoffLocusNonempty :
    HandoffObstructionLocusNonempty
      visibleRepairTransportHandoffBridge.toAtlas :=
  ⟨visibleRepairTransport_tableDefect_to_handoffTraceObstructionPoint⟩

/--
The visible-only commutator's handoff locus obstructs interaction exactness
under the adapter's local exactness.
-/
theorem visibleRepairTransport_obstructs_handoffInteractionExact :
    Not (HandoffAtlasInteractionExact
      visibleRepairTransportHandoffBridge.toAtlas) := by
  have hlocal := visibleRepairTransportHandoffBridge.toAtlas_localExact
  exact
    (handoffAtlas_not_interactionExact_iff_locus_nonempty_of_local
      hlocal).mpr
      visibleRepairTransport_handoffLocusNonempty

/-! ## Theorem package -/

/--
Cycle-62 theorem package: lawful repair/transport component laws produce an
empty source-ref handoff obstruction locus, while the selected visible-only
commutator produces trace and repair-frontier handoff obstruction points.  The
obligation defect of the visible-only witness is deliberately not used as a
handoff point, since `ObligationKind` is not a `BridgeComponent`.
-/
theorem repairTransportHandoffObstructionBridge_package :
    (forall {τ : SourceRefPacketTransport.PacketUpdate}
      {action transportedAction : SourceRefRepairAction}
      (hlawful : LawfulRepairTransportSquare τ action transportedAction)
      (packet : SourceRefPacket),
      HandoffObstructionLocusEmpty
        (lawfulRepairTransportHandoffBridge hlawful packet).toAtlas) /\
      HandoffObstructionLocusNonempty
        visibleRepairTransportHandoffBridge.toAtlas /\
      Nonempty
        (HandoffObstructionPoint visibleRepairTransportHandoffBridge.toAtlas) /\
      Nonempty
        (HandoffObstructionPoint visibleRepairTransportHandoffBridge.toAtlas) /\
      supportSurfaceReading.Equivalent
        RouteDefectSupportTheory.visibleRouteLeft
        RouteDefectSupportTheory.visibleRouteRight /\
      RouteDefectSupport
        RouteDefectSupportTheory.visibleRouteLeft
        RouteDefectSupportTheory.visibleRouteRight
        (SourceRefPacketProtectedComponent.repairFrontier CodeAtom.storage) /\
      RouteDefectSupport
        RouteDefectSupportTheory.visibleRouteLeft
        RouteDefectSupportTheory.visibleRouteRight
        (SourceRefPacketProtectedComponent.sourceRefTable CodeAtom.storage) /\
      packetDefectToHandoffComponent
        SourceRefPacketProtectedComponent.obligation = none /\
      Not (HandoffAtlasInteractionExact
        visibleRepairTransportHandoffBridge.toAtlas) := by
  exact
    ⟨lawfulRepairTransport_handoffLocusEmpty,
      visibleRepairTransport_handoffLocusNonempty,
      ⟨visibleRepairTransport_repairFrontier_to_handoffObstructionPoint⟩,
      ⟨visibleRepairTransport_tableDefect_to_handoffTraceObstructionPoint⟩,
      VisibleRepairTransportCommutator.repairTransport_visiblePacketSurface_commutes,
      visibleRepairTransport_defectSupport_storageRepair,
      visibleRepairTransport_defectSupport_storageTable,
      obligationDefect_has_no_handoffComponent,
      visibleRepairTransport_obstructs_handoffInteractionExact⟩

end RepairTransportHandoffObstructionBridge
end QualitySurface
end ResearchLean.AG
